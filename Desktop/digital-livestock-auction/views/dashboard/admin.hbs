      sidebar.classList.add('-translate-x-full');
      overlay.classList.remove('active'); }); overlay.addEventListener('click',
      () => { sidebar.classList.add('-translate-x-full');
      overlay.classList.remove('active'); }); window.addEventListener('resize',
      () => { if (window.innerWidth >= 1024) {
      sidebar.classList.remove('-translate-x-full');
      overlay.classList.remove('active'); } }); // ─── NOTIFICATIONS DROPDOWN
      ─── function toggleNotifications() {
      document.getElementById('notif-dropdown').classList.toggle('open'); }
      document.addEventListener('click', (e) => { if
      (!e.target.closest('[onclick="toggleNotifications()"]') &&
      !e.target.closest('#notif-dropdown'))
      document.getElementById('notif-dropdown').classList.remove('open'); }); //
      ─── TOAST SYSTEM ─── let toastId = 0; function showToast(msg, type =
      'success') { const colors = { success:'bg-green-500', error:'bg-red-500',
      info:'bg-blue-500', warning:'bg-amber-500' }; const icons = {
      success:'bi-check-circle', error:'bi-x-circle', info:'bi-info-circle',
      warning:'bi-exclamation-triangle' }; const id = ++toastId; const el =
      document.createElement('div'); el.id = 'toast-' + id; el.className = `flex
      items-center gap-3 px-4 py-3 rounded-xl glass border border-gray-800/50
      shadow-xl shadow-black/30 animate-toast-in max-w-sm`; el.innerHTML = `<div
      class="w-7 h-7 rounded-lg ${colors[type]}/20 flex items-center
      justify-center flex-shrink-0"><i class="bi ${icons[type]} text-${type ===
      'success' ? 'green' : type === 'error' ? 'red' : type === 'info' ? 'blue'
      : 'amber'}-400"></i></div><p class="text-sm text-white
      flex-1">${msg}</p><button
      onclick="document.getElementById('toast-${id}').remove()"
      class="text-gray-500 hover:text-white"><i class="bi bi-x
      text-sm"></i></button>`; // Force color classes
      el.querySelector('div').style.background = `${type === 'success' ?
      'rgba(34,197,94' : type === 'error' ? 'rgba(239,68,68' : type === 'info' ?
      'rgba(59,130,246' : 'rgba(245,158,11'}, 0.15)`;
      el.querySelector('i').style.color = type === 'success' ? '#4ade80' : type
      === 'error' ? '#f87171' : type === 'info' ? '#60a5fa' : '#fbbf24';
      document.getElementById('toast-container').appendChild(el); setTimeout(()
      => { if (el.parentNode) { el.classList.add('animate-toast-out');
      el.classList.remove('animate-toast-in'); setTimeout(() => el.remove(),
      350); } }, 3500); } // ─── TAB SWITCHING ─── function switchTab(name,
      clickedEl) { document.querySelectorAll('.tab-panel').forEach(p =>
      p.classList.add('hidden')); document.getElementById('tab-' +
      name).classList.remove('hidden');
      document.querySelectorAll('.nav-link').forEach(l =>
      l.classList.remove('active', 'bg-gray-800/40')); if (clickedEl) {
      clickedEl.classList.add('active', 'bg-gray-800/40'); } // Close mobile
      sidebar if (window.innerWidth < 1024) {
      sidebar.classList.add('-translate-x-full');
      overlay.classList.remove('active'); } // Init charts on first view if
      (name === 'analytics') initAnalytics(); if (name === 'system')
      initSystemLogs(); } // ─── REVENUE CHART ─── const revenueData = [320000,
      480000, 390000, 720000, 560000, 810000, 950000]; function
      drawRevenueChart() { const svg = document.getElementById('revenue-chart');
      const container = document.getElementById('revenue-chart-container');
      const w = 800, h = 180, padL = 40, padR = 20, padT = 10; const maxVal =
      Math.max(...revenueData); const xs = revenueData.map((_, i) => padL + (i /
      (revenueData.length - 1)) * (w - padL - padR)); const ys =
      revenueData.map(v => padT + (1 - v / (maxVal * 1.1)) * h); // Line const
      linePts = xs.map((x, i) => `${x},${ys[i]}`).join(' '); // Smooth with
      cubic-bezier approximation let d = `M ${xs[0]} ${ys[0]}`; for (let i = 1;
      i < xs.length; i++) { const cpx1 = xs[i-1] + (xs[i] - xs[i-1]) * 0.4;
      const cpx2 = xs[i] - (xs[i] - xs[i-1]) * 0.4; d += ` C ${cpx1} ${ys[i-1]},
      ${cpx2} ${ys[i]}, ${xs[i]} ${ys[i]}`; }
      document.getElementById('revenue-line').setAttribute('d', d);
      document.getElementById('revenue-fill').setAttribute('d', d + ` L
      ${xs[xs.length-1]} ${h + padT} L ${xs[0]} ${h + padT} Z`); // Dots let
      dotsHtml = ''; xs.forEach((x, i) => { dotsHtml += `<circle cx="${x}"
      cy="${ys[i]}" r="4" fill="#f97316" stroke="#111827" stroke-width="2"
      class="cursor-pointer" data-idx="${i}"
      onmouseenter="showChartTooltip(event,${i})"
      onmouseleave="hideChartTooltip()"/>`; });
      document.getElementById('revenue-dots').innerHTML = dotsHtml; } function
      showChartTooltip(e, idx) { const days =
      ['Mon','Tue','Wed','Thu','Fri','Sat','Sun']; const tip =
      document.getElementById('chart-tooltip'); const container =
      document.getElementById('revenue-chart-container'); const rect =
      container.getBoundingClientRect(); const svgEl = e.target; const svgRect =
      svgEl.closest('svg').getBoundingClientRect(); const cx =
      parseFloat(svgEl.getAttribute('cx')); const cy =
      parseFloat(svgEl.getAttribute('cy')); const scaleX = svgRect.width / 800;
      const scaleY = svgRect.height / 200; tip.innerHTML =
      `<strong>${days[idx]}</strong><br/>UGX
      ${(revenueData[idx]/1000).toFixed(0)}K`; tip.style.left = (cx * scaleX -
      35) + 'px'; tip.style.top = (cy * scaleY - 55) + 'px'; tip.style.opacity =
      '1'; } function hideChartTooltip() {
      document.getElementById('chart-tooltip').style.opacity = '0'; } // Draw on
      load window.addEventListener('load', drawRevenueChart);
      window.addEventListener('resize', drawRevenueChart); // ─── ACTIVITY FEED
      ─── const activityItems = [ { icon:'bi-check-circle', color:'green',
      title:'Sale Completed', desc:'2 cattle sold to John Okello — UGX
      1,450,000', time:'2 min ago' }, { icon:'bi-hand-thumbs-up', color:'blue',
