      logMessages.map(l => { const colors = { info:'text-gray-400',
      warn:'text-amber-400', error:'text-red-400' }; const bg = { info:'',
      warn:'bg-amber-500/5', error:'bg-red-500/5' }; return `<div class="flex
      gap-2 px-2 py-0.5 rounded ${bg[l.level]} hover:bg-gray-800/40
      transition-colors"> <span class="text-gray-600 text-[10px]
      flex-shrink-0">${l.time}</span> <span class="text-[10px] font-semibold
      ${l.level==='info'?'text-blue-400':l.level==='warn'?'text-amber-400':'text-red-400'}
      flex-shrink-0 uppercase w-10 text-right">${l.level}</span> <span
      class="text-[10px] ${colors[l.level]}">${l.msg}</span> </div>`;
      }).join(''); // Simulate new log entries setInterval(() => { const newLog
      = { level:'info', msg:`Heartbeat ping — ${new
      Date().toLocaleTimeString()}`, time:new
      Date().toLocaleTimeString().split(' ')[0] }; logMessages.push(newLog); if
      (logMessages.length > 18) logMessages.shift(); el.innerHTML =
      logMessages.map(l => { const colors = { info:'text-gray-400',
      warn:'text-amber-400', error:'text-red-400' }; const bg = { info:'',
      warn:'bg-amber-500/5', error:'bg-red-500/5' }; return `<div class="flex
      gap-2 px-2 py-0.5 rounded ${bg[l.level]} hover:bg-gray-800/40
      transition-colors"> <span class="text-gray-600 text-[10px]
      flex-shrink-0">${l.time}</span> <span class="text-[10px] font-semibold
      ${l.level==='info'?'text-blue-400':l.level==='warn'?'text-amber-400':'text-red-400'}
      flex-shrink-0 uppercase w-10 text-right">${l.level}</span> <span
      class="text-[10px] ${colors[l.level]}">${l.msg}</span> </div>`;
      }).join(''); el.scrollTop = el.scrollHeight; }, 5000); } // ─── SYSTEM
      PERF SIMULATION ─── setInterval(() => { const fluctuate = (base, range) =>
      Math.max(5, Math.min(95, base + (Math.random()-0.5)*range)); const cpu =
      fluctuate(34, 20); const mem = fluctuate(61, 8); const disk =
      fluctuate(22, 6); const net = fluctuate(48, 15);
      document.getElementById('cpu-val') &&
      (document.getElementById('cpu-val').textContent = cpu.toFixed(0) + '%');
      document.getElementById('cpu-bar') &&
      (document.getElementById('cpu-bar').style.width = cpu + '%');
      document.getElementById('mem-val') &&
      (document.getElementById('mem-val').textContent = mem.toFixed(0) + '%');
      document.getElementById('mem-bar') &&
      (document.getElementById('mem-bar').style.width = mem + '%');
      document.getElementById('disk-val') &&
      (document.getElementById('disk-val').textContent = disk.toFixed(0) + '%');
      document.getElementById('disk-bar') &&
      (document.getElementById('disk-bar').style.width = disk + '%');
      document.getElementById('net-val') &&
      (document.getElementById('net-val').textContent = net.toFixed(0) + '%');
      document.getElementById('net-bar') &&
      (document.getElementById('net-bar').style.width = net + '%'); }, 3000); //
      ─── GLOBAL SEARCH ───
      document.getElementById('global-search').addEventListener('input',
      function() { const q = this.value.toLowerCase(); if (q.length > 2)
      showToast(`Searching for "${this.value}"…`, 'info'); }); // ─── INITIAL
      TOAST ─── setTimeout(() => showToast('Welcome back, Super Admin!',
      'success'), 800);
    </script>
  </body>
</html>