<!-- Ultra-Advanced Buyer Dashboard for ChuuAuction -->
<script src="https://cdn.tailwindcss.com"></script>
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
/>

<div
  class="min-h-screen bg-gray-950 text-white font-body overflow-hidden relative"
>

  <!-- Mobile overlay -->
  <div
    id="sidebar-overlay"
    class="fixed inset-0 bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity z-40"
  ></div>

  <!-- Sidebar -->
  <aside
    id="sidebar"
    class="fixed left-0 top-0 h-full w-72 glass border-r border-gray-800/50 z-50 transition-all duration-500 -translate-x-full lg:translate-x-0 hex-pattern"
  >
    <div class="flex flex-col h-full p-6 relative z-10">

      <!-- Logo -->
      <div class="mb-8 animate-fade-in">
        <div
          class="flex items-center gap-4 p-4 rounded-2xl glass border border-orange-500/20 hover:border-orange-500/40 transition-all duration-300 group cursor-pointer card-3d"
        >
          <img
            src="/img/logo.png"
            alt="ChuuAuction Logo"
            class="w-11 h-11 rounded-full ring-2 ring-orange-500/40 shadow-lg"
          />
          <div class="flex-1">
            <h1 class="text-xl font-black font-display leading-tight">
              <span class="text-gradient neon-glow">Chuu</span><span
                class="text-white"
              >Auction</span>
            </h1>
            <p class="text-xs text-gray-400">Buyer Panel</p>
          </div>
          <button
            id="sidebar-toggle"
            class="w-8 h-8 rounded-lg glass flex items-center justify-center hover:bg-orange-500/20 transition-colors lg:hidden"
          >
            <i class="bi bi-x-lg text-white"></i>
          </button>
        </div>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 overflow-y-auto space-y-2">
        <!-- Dashboard -->
        <a
          href="dashboard/buyer"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer active"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-speedometer2 text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Dashboard</span>
        </a>

        <!-- Place Bid -->
        <a
          href="/buyer/place-bid"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-cash-stack text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Place Bid</span>
        </a>

        <!-- Animal Posts -->
        <a
          href="/buyer/animal-posts"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-card-list text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Animal Posts</span>
        </a>

        <!-- Transactions -->
        <a
          href="/buyer/transactions"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-receipt text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Transactions</span>
        </a>
        <a
          href="/auctions/create"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer active"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-hammer text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Initiate Auction</span>
        </a>

        <!-- Favorites -->
        <a
          href="/buyer/favorites"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-heart text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Favorites</span>
        </a>
        <a
          href="/livestock/notes"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-journal-text text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Notes</span>
        </a>

        <!-- Notifications -->
        <a
          href="/buyer/notifications"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-bell text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Notifications</span>
        </a>

        <!-- Settings -->
        <a
          href="/livestock/settings"
          class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer"
        >
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-gear text-orange-500 text-xl"></i>
          </div>
          <span
            class="font-semibold group-hover:text-orange-500 transition-colors"
          >Settings</span>
        </a>
      </nav>

      <!-- Logout -->
      <div class="mt-4 pt-4 border-t border-gray-800/50">
        <a
          href="/auth/logout"
          class="flex items-center gap-3 px-4 py-3 rounded-xl bg-red-500/10 hover:bg-red-500/20 border border-red-500/30 hover:border-red-500/50 transition-all duration-300 group cursor-pointer"
        >
          <div
            class="w-10 h-10 rounded-xl bg-red-500/20 flex items-center justify-center group-hover:scale-110 transition-transform"
          >
            <i class="bi bi-box-arrow-left text-red-500 text-xl"></i>
          </div>
          <span class="font-semibold text-red-500">Logout</span>
        </a>
      </div>
    </div>
  </aside>

  <!-- Mobile Sidebar Toggle -->
  <button
    id="mobile-sidebar-toggle"
    class="fixed top-6 left-6 z-50 w-12 h-12 rounded-xl glass border border-orange-500/30 flex items-center justify-center lg:hidden hover:bg-orange-500/20 transition-all cursor-pointer"
  >
    <i class="bi bi-list text-2xl text-white"></i>
  </button>

  <!-- Main Content -->
  <main
    class="lg:ml-72 min-h-screen p-6 lg:p-8 relative z-10 ml-0 transition-all duration-500"
  >
    <h1 class="text-4xl md:text-5xl font-black font-display mb-4">Buyer
      <span class="text-gradient neon-glow">Dashboard</span></h1>
    <p class="text-gray-400 mb-6">Welcome back,
      <span class="text-orange-500 font-semibold">{{user.name}}</span>!</p>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div
        class="stat-card p-6 rounded-2xl glass border border-gray-800/50 hover:border-orange-500/50 transition-all duration-300 cursor-pointer card-3d group"
      >
        <div class="flex items-start justify-between mb-4">
          <div
            class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500/20 to-blue-700/20 flex items-center justify-center"
          >
            <i class="bi bi-hourglass-split text-3xl text-blue-500"></i>
          </div>
          <span
            class="text-xs px-2 py-1 rounded-full bg-blue-500/20 text-blue-500 font-semibold"
          >Pending</span>
        </div>
        <h3 class="text-3xl font-black font-display text-white mb-1">8</h3>
        <p class="text-gray-400 text-sm">Pending Bids</p>
      </div>

      <div
        class="stat-card p-6 rounded-2xl glass border border-gray-800/50 hover:border-orange-500/50 transition-all duration-300 cursor-pointer card-3d group"
      >
        <div class="flex items-start justify-between mb-4">
          <div
            class="w-14 h-14 rounded-2xl bg-gradient-to-br from-green-500/20 to-green-700/20 flex items-center justify-center"
          >
            <i class="bi bi-cash-stack text-3xl text-green-500"></i>
          </div>
          <span
            class="text-xs px-2 py-1 rounded-full bg-green-500/20 text-green-500 font-semibold"
          >Completed</span>
        </div>
        <h3 class="text-3xl font-black font-display text-white mb-1">Ugx 1.2M</h3>
        <p class="text-gray-400 text-sm">Total Spent</p>
      </div>

      <div
        class="stat-card p-6 rounded-2xl glass border border-gray-800/50 hover:border-orange-500/50 transition-all duration-300 cursor-pointer card-3d group"
      >
        <div class="flex items-start justify-between mb-4">
          <div
            class="w-14 h-14 rounded-2xl bg-gradient-to-br from-yellow-500/20 to-yellow-700/20 flex items-center justify-center"
          >
            <i class="bi bi-heart text-3xl text-yellow-500"></i>
          </div>
          <span
            class="text-xs px-2 py-1 rounded-full bg-yellow-500/20 text-yellow-500 font-semibold"
          >Saved</span>
        </div>
        <h3 class="text-3xl font-black font-display text-white mb-1">14</h3>
        <p class="text-gray-400 text-sm">Favorites</p>
      </div>

      <div
        class="stat-card p-6 rounded-2xl glass border border-gray-800/50 hover:border-orange-500/50 transition-all duration-300 cursor-pointer card-3d group"
      >
        <div class="flex items-start justify-between mb-4">
          <div
            class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500/20 to-purple-700/20 flex items-center justify-center"
          >
            <i class="bi bi-broadcast text-3xl text-purple-500"></i>
          </div>
          <span
            class="text-xs px-2 py-1 rounded-full bg-purple-500/20 text-purple-500 font-semibold"
          >Live</span>
        </div>
        <h3 class="text-3xl font-black font-display text-white mb-1">5</h3>
        <p class="text-gray-400 text-sm">Active Auctions</p>
      </div>
    </div>
  </main>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => { const sidebar =
  document.getElementById("sidebar"); const overlay =
  document.getElementById("sidebar-overlay"); const openBtn =
  document.getElementById("mobile-sidebar-toggle"); const closeBtn =
  document.getElementById("sidebar-toggle"); const openSidebar = () => {
  sidebar?.classList.remove("-translate-x-full");
  sidebar?.classList.add("translate-x-0"); overlay?.classList.add("active"); };
  const closeSidebar = () => { sidebar?.classList.add("-translate-x-full");
  sidebar?.classList.remove("translate-x-0");
  overlay?.classList.remove("active"); }; openBtn?.addEventListener("click",
  openSidebar); closeBtn?.addEventListener("click", closeSidebar);
  overlay?.addEventListener("click", closeSidebar);
  document.querySelectorAll("#sidebar a").forEach(link => {
  link.addEventListener("click", () => { if (window.innerWidth < 1024)
  closeSidebar(); }); }); const syncSidebar = () => { if (window.innerWidth >=
  1024) { sidebar?.classList.remove("-translate-x-full");
  sidebar?.classList.add("translate-x-0"); overlay?.classList.remove("active");
  } else closeSidebar(); }; window.addEventListener("resize", syncSidebar);
  syncSidebar(); });
</script>