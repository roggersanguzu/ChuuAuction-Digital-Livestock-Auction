<!-- ══════════════════════════════════════════════════════════════════ -->
<!-- PRICING ENGINE JAVASCRIPT -->
<!-- ══════════════════════════════════════════════════════════════════ -->
<script>
// ═══ PRICING DATABASE ═══
const PRICING_DATA = {
  cattle: {
    name: 'Cattle',
    icon: 'bi-circle-fill',
    weights: [
      { label: 'Light (<200kg)', value: 'cattle-light', min: 200000, max: 500000, kg: '<200kg', barWidth: 25 },
      { label: 'Medium (200-350kg)', value: 'cattle-medium', min: 600000, max: 1200000, kg: '200-350kg', barWidth: 60 },
      { label: 'Heavy (350kg+)', value: 'cattle-heavy', min: 1500000, max: 2500000, kg: '350kg+', barWidth: 95 }
    ],
    ages: [
      { label: 'Calf (0-12 months)', value: 'cattle-calf', modifier: -0.15, text: 'Young (-15%)' },
      { label: 'Young Adult (1-3 years)', value: 'cattle-young', modifier: 0, text: 'Prime (Standard)' },
      { label: 'Mature (3-6 years)', value: 'cattle-mature', modifier: 0.05, text: 'Mature (+5%)' },
      { label: 'Old (6+ years)', value: 'cattle-old', modifier: -0.10, text: 'Aging (-10%)' }
    ]
  },
  goat: {
    name: 'Goat',
    icon: 'bi-circle-fill',
    weights: [
      { label: 'Small (30-40kg)', value: 'goat-small', min: 300000, max: 480000, kg: '30-40kg', barWidth: 35 },
      { label: 'Medium (50-70kg)', value: 'goat-medium', min: 500000, max: 840000, kg: '50-70kg', barWidth: 70 },
      { label: 'Large (70kg+)', value: 'goat-large', min: 840000, max: 1000000, kg: '70kg+', barWidth: 95 }
    ],
    ages: [
      { label: 'Kid (0-6 months)', value: 'goat-kid', modifier: -0.20, text: 'Kid (-20%)' },
      { label: 'Young (6-18 months)', value: 'goat-young', modifier: 0, text: 'Prime (Standard)' },
      { label: 'Adult (18+ months)', value: 'goat-adult', modifier: 0.08, text: 'Adult (+8%)' }
    ]
  },
  sheep: {
    name: 'Sheep',
    icon: 'bi-circle-fill',
    weights: [
      { label: 'Lamb (10-20kg)', value: 'sheep-lamb', min: 80000, max: 150000, kg: '10-20kg', barWidth: 20 },
      { label: 'Medium (25-35kg)', value: 'sheep-medium', min: 200000, max: 350000, kg: '25-35kg', barWidth: 55 },
      { label: 'Large (40-55kg+)', value: 'sheep-large', min: 400000, max: 600000, kg: '40-55kg+', barWidth: 90 }
    ],
    ages: [
      { label: 'Lamb (0-12 months)', value: 'sheep-lamb', modifier: -0.10, text: 'Lamb (-10%)' },
      { label: 'Yearling (1-2 years)', value: 'sheep-yearling', modifier: 0, text: 'Prime (Standard)' },
      { label: 'Mature (2+ years)', value: 'sheep-mature', modifier: 0.05, text: 'Mature (+5%)' }
    ]
  },
  pig: {
    name: 'Pig',
    icon: 'bi-circle-fill',
    weights: [
      { label: 'Small (30-50kg)', value: 'pig-small', min: 200000, max: 350000, kg: '30-50kg', barWidth: 30 },
      { label: 'Medium (60-80kg)', value: 'pig-medium', min: 400000, max: 650000, kg: '60-80kg', barWidth: 65 },
      { label: 'Heavy (90-100kg+)', value: 'pig-heavy', min: 700000, max: 900000, kg: '90-100kg+', barWidth: 95 }
    ],
    ages: [
      { label: 'Piglet (0-3 months)', value: 'pig-piglet', modifier: -0.25, text: 'Piglet (-25%)' },
      { label: 'Grower (3-6 months)', value: 'pig-grower', modifier: 0, text: 'Prime (Standard)' },
      { label: 'Finisher (6+ months)', value: 'pig-finisher', modifier: 0.10, text: 'Finisher (+10%)' }
    ]
  }
};

// ═══ STATE ═══
let currentSelection = {
  animalType: null,
  weightRange: null,
  sex: null,
  color: null,
  ageRange: null
};

// ═══ DROPDOWN EVENT LISTENERS ═══
function initializeDropdowns() {
  const animalSelect = document.getElementById('animal-type');
  const weightSelect = document.getElementById('weight-range');
  const ageSelect = document.getElementById('age-range');
  const colorSelect = document.getElementById('color');
  const sexRadios = document.querySelectorAll('input[name="sex"]');
  
  // Animal type change
  animalSelect.addEventListener('change', function() {
    currentSelection.animalType = this.value;
    updateCalculator();
  });
  
  // Weight change listener
  weightSelect.addEventListener('change', function() {
    currentSelection.weightRange = this.value;
    
    // Auto-detect animal type from weight selection
    if (this.value) {
      const animalPrefix = this.value.split('-')[0]; // e.g., "cattle" from "cattle-light"
      if (animalPrefix && PRICING_DATA[animalPrefix]) {
        currentSelection.animalType = animalPrefix;
        animalSelect.value = animalPrefix;
      }
    }
    
    updateCalculator();
  });
  
  // Age change listener
  ageSelect.addEventListener('change', function() {
    currentSelection.ageRange = this.value;
    
    // Auto-detect animal type from age selection
    if (this.value) {
      const animalPrefix = this.value.split('-')[0];
      if (animalPrefix && PRICING_DATA[animalPrefix]) {
        currentSelection.animalType = animalPrefix;
        animalSelect.value = animalPrefix;
      }
    }
    
    updateCalculator();
  });
  
  // Color change listener
  colorSelect.addEventListener('change', function() {
    currentSelection.color = this.value;
    updateCalculator();
  });
  
  // Sex radio listeners
  sexRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      currentSelection.sex = this.value;
      updateCalculator();
    });
  });
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
  initializeDropdowns();
  updateCalculator();
});

// ═══ REAL-TIME PREVIEW UPDATER ═══
function updateCalculator() {
  const animalType = document.getElementById('animal-type')?.value || '';
  const weightRange = document.getElementById('weight-range')?.value || '';
  const sex = document.querySelector('input[name="sex"]:checked')?.value || '';
  const color = document.getElementById('color')?.value || '';
  const ageRange = document.getElementById('age-range')?.value || '';
  
  // Store in state
  currentSelection = { animalType, weightRange, sex, color, ageRange };
  
  // Update preview panels
  updatePreview();
  
  // Update indicators
  updateIndicators();
  
  // Enable/disable calculate button
  const allSelected = animalType && weightRange && sex && color && ageRange;
  const calcBtn = document.getElementById('calculate-btn');
  if (calcBtn) {
    calcBtn.disabled = !allSelected;
  }
}

function updatePreview() {
  const { animalType, weightRange, sex, color, ageRange } = currentSelection;
  
  // Extract animal type from selections if not explicitly set
  let detectedAnimal = animalType;
  if (!detectedAnimal && weightRange) {
    detectedAnimal = weightRange.split('-')[0];
  }
  if (!detectedAnimal && ageRange) {
    detectedAnimal = ageRange.split('-')[0];
  }
  
  // Animal
  if (detectedAnimal && PRICING_DATA[detectedAnimal]) {
    const icons = { 
      cattle: 'bi-circle-fill text-orange-400', 
      goat: 'bi-circle-fill text-blue-400', 
      sheep: 'bi-circle-fill text-purple-400', 
      pig: 'bi-circle-fill text-pink-400' 
    };
    document.getElementById('preview-animal-icon').className = `bi ${icons[detectedAnimal]} text-3xl mb-2`;
    document.getElementById('preview-animal').textContent = PRICING_DATA[detectedAnimal].name;
  } else {
    document.getElementById('preview-animal-icon').className = 'bi bi-question-circle text-3xl text-gray-600 mb-2';
    document.getElementById('preview-animal').textContent = '—';
  }
  
  // Weight
  if (weightRange) {
    const animalKey = weightRange.split('-')[0];
    if (PRICING_DATA[animalKey]) {
      const wData = PRICING_DATA[animalKey].weights.find(w => w.value === weightRange);
      if (wData) document.getElementById('preview-weight').textContent = wData.kg;
    }
  } else {
    document.getElementById('preview-weight').textContent = '—';
  }
  
  // Sex
  if (sex) {
    const sexIcons = { male: 'bi-gender-male text-purple-400', female: 'bi-gender-female text-pink-400' };
    document.getElementById('preview-sex-icon').className = `bi ${sexIcons[sex]} text-3xl mb-2`;
    document.getElementById('preview-sex').textContent = sex.charAt(0).toUpperCase() + sex.slice(1);
  } else {
    document.getElementById('preview-sex-icon').className = 'bi bi-gender-ambiguous text-3xl text-gray-600 mb-2';
    document.getElementById('preview-sex').textContent = '—';
  }
  
  // Color
  if (color) {
    const colorMap = { black: '#1a1a1a', brown: '#8B4513', white: '#f0f0f0', mixed: 'linear-gradient(135deg, #8B4513, #f0f0f0)' };
    const swatch = document.getElementById('preview-color-swatch');
    if (color === 'mixed') {
      swatch.style.background = colorMap[color];
    } else {
      swatch.style.backgroundColor = colorMap[color];
    }
    document.getElementById('preview-color').textContent = color.charAt(0).toUpperCase() + color.slice(1);
  } else {
    document.getElementById('preview-color-swatch').style.backgroundColor = '#374151';
    document.getElementById('preview-color').textContent = '—';
  }
  
  // Age
  if (ageRange) {
    const animalKey = ageRange.split('-')[0];
    if (PRICING_DATA[animalKey]) {
      const ageData = PRICING_DATA[animalKey].ages.find(a => a.value === ageRange);
      if (ageData) {
        const ageLabel = ageData.label.split(' ')[0]; // Extract first word (Calf, Kid, Lamb, etc.)
        document.getElementById('preview-age').textContent = ageLabel;
      }
    }
  } else {
    document.getElementById('preview-age').textContent = '—';
  }
}

function updateIndicators() {
  const { animalType, weightRange, color, ageRange } = currentSelection;
  
  // Weight indicator
  if (weightRange) {
    const animalKey = weightRange.split('-')[0];
    if (PRICING_DATA[animalKey]) {
      const wData = PRICING_DATA[animalKey].weights.find(w => w.value === weightRange);
      if (wData) {
        document.getElementById('weight-indicator').classList.remove('hidden');
        document.getElementById('weight-display').textContent = wData.kg;
        document.getElementById('weight-bar').style.width = wData.barWidth + '%';
      }
    }
  } else {
    document.getElementById('weight-indicator').classList.add('hidden');
  }
  
  // Color premium
  if (color) {
    const premiums = { black: '+15%', brown: '±0%', white: '-5%', mixed: '±0%' };
    document.getElementById('color-premium').classList.remove('hidden');
    document.getElementById('color-premium-text').textContent = premiums[color];
  } else {
    document.getElementById('color-premium').classList.add('hidden');
  }
  
  // Age modifier
  if (ageRange) {
    const animalKey = ageRange.split('-')[0];
    if (PRICING_DATA[animalKey]) {
      const ageData = PRICING_DATA[animalKey].ages.find(a => a.value === ageRange);
      if (ageData) {
        document.getElementById('age-modifier').classList.remove('hidden');
        document.getElementById('age-modifier-text').textContent = ageData.text;
      }
    }
  } else {
    document.getElementById('age-modifier').classList.add('hidden');
  }
}

// ═══ PRICE CALCULATION ENGINE ═══
function calculatePrice() {
  let { animalType, weightRange, sex, color, ageRange } = currentSelection;
  
  // Auto-detect animal type from weight or age if not set
  if (!animalType && weightRange) {
    animalType = weightRange.split('-')[0];
  }
  if (!animalType && ageRange) {
    animalType = ageRange.split('-')[0];
  }
  
  if (!animalType || !weightRange || !sex || !color || !ageRange) {
    return;
  }
  
  const data = PRICING_DATA[animalType];
  if (!data) return;
  
  const wData = data.weights.find(w => w.value === weightRange);
  const ageData = data.ages.find(a => a.value === ageRange);
  
  if (!wData || !ageData) return;
  
  // Base price range
  let baseMin = wData.min;
  let baseMax = wData.max;
  
  // Color modifier
  let colorMod = 1.0;
  let colorText = 'Standard';
  if (color === 'black') { colorMod = 1.15; colorText = '+15% (Black Premium)'; }
  else if (color === 'white') { colorMod = 0.95; colorText = '-5% (White Discount)'; }
  
  // Sex modifier (female premium unless male is heavy)
  let sexMod = 1.0;
  let sexText = 'Standard';
  const weightClass = weightRange.split('-')[1]; // Extract "light", "medium", "heavy" etc.
  if (sex === 'female') {
    sexMod = 1.08;
    sexText = '+8% (Female Premium)';
  } else if (sex === 'male' && (weightClass === 'heavy' || weightClass === 'large')) {
    sexMod = 1.05;
    sexText = '+5% (Heavy Male)';
  }
  
  // Age modifier
  const ageMod = 1 + ageData.modifier;
  
  // Total modifier
  const totalMod = colorMod * sexMod * ageMod;
  
  // Final price
  const finalMin = Math.round(baseMin * totalMod);
  const finalMax = Math.round(baseMax * totalMod);
  
  // Confidence (higher for common combos)
  const confidence = Math.min(95, 75 + (color === 'black' ? 10 : 0) + (sex === 'female' ? 5 : 0) + (weightClass === 'medium' ? 5 : 0));
  
  // Display results
  displayResults(finalMin, finalMax, baseMin, baseMax, colorText, sexText, ageData.text, confidence);
  
  // Generate insights
  generateInsights(animalType, weightClass, sex, color, ageRange, finalMin, finalMax);
}

function displayResults(finalMin, finalMax, baseMin, baseMax, colorText, sexText, ageText, confidence) {
  // Hide empty state, show dashboard
  document.getElementById('empty-state').classList.add('hidden');
  document.getElementById('price-dashboard').classList.remove('hidden');
  
  // Animate price
  animateNumber('final-price-min', finalMin);
  animateNumber('final-price-max', finalMax);
  
  // Base price
  document.getElementById('base-price').textContent = `UGX ${baseMin.toLocaleString()} - ${baseMax.toLocaleString()}`;
  
  // Premium
  const premiumPct = Math.round(((finalMin / baseMin) - 1) * 100);
  document.getElementById('premium-modifier').textContent = (premiumPct >= 0 ? '+' : '') + premiumPct + '%';
  
  // Age factor
  document.getElementById('age-factor').textContent = ageText;
  
  // Breakdown details
  document.getElementById('breakdown-base').textContent = `UGX ${baseMin.toLocaleString()} - ${baseMax.toLocaleString()}`;
  document.getElementById('breakdown-color').textContent = colorText;
  document.getElementById('breakdown-sex').textContent = sexText;
  document.getElementById('breakdown-age').textContent = ageText;
  
  // Confidence
  document.getElementById('confidence-score').textContent = confidence + '% Accurate';
  setTimeout(() => { document.getElementById('confidence-bar').style.width = confidence + '%'; }, 100);
}

function animateNumber(id, target) {
  const el = document.getElementById(id);
  const duration = 1500;
  const start = 0;
  const startTime = performance.now();
  
  function update(currentTime) {
    const elapsed = currentTime - startTime;
    const progress = Math.min(elapsed / duration, 1);
    const easeOut = 1 - Math.pow(1 - progress, 3);
    const current = Math.round(start + (target - start) * easeOut);
    el.textContent = current.toLocaleString();
    if (progress < 1) requestAnimationFrame(update);
  }
  requestAnimationFrame(update);
}

function generateInsights(animalType, weightRange, sex, color, ageRange, finalMin, finalMax) {
  const insights = [];
  
  // Weight insight
  if (weightRange === 'heavy' || weightRange === 'large') {
    insights.push('✓ <strong>Premium weight class</strong> — High market demand for this size category.');
  } else if (weightRange === 'light' || weightRange === 'small' || weightRange === 'lamb') {
    insights.push('⚠ <strong>Lower weight tier</strong>: Consider holding for additional weight gain to maximize value.');
  }
  
  // Color insight
  if (color === 'black') {
    insights.push('✓ <strong>Black coat premium applied</strong>: Traditional preference increases market value by 15%.');
  } else if (color === 'white') {
    insights.push('⚠ <strong>White coat discount</strong>: Slightly lower demand results in 5% price reduction.');
  }
  
  // Sex insight
  if (sex === 'female') {
    insights.push('✓ <strong>Female breeding premium</strong>: Reproductive value adds 8% to market price.');
  } else if (sex === 'male' && (weightRange === 'heavy' || weightRange === 'large')) {
    insights.push('✓ <strong>Heavy male advantage</strong>: Exceptional weight offsets male discount.');
  }
  
  // Age insight
  if (ageRange === 'young' || ageRange === 'yearling' || ageRange === 'grower') {
    insights.push('✓ <strong>Prime age bracket</strong>:Optimal maturity for immediate market sale.');
  }
  
  // Market timing
  const avgPrice = (finalMin + finalMax) / 2;
  if (avgPrice > 1000000) {
    insights.push('💰 <strong>High-value asset</strong>: Consider premium buyer networks for best offers.');
  }
  
  document.getElementById('market-insights').innerHTML = insights.map(i => `<p>${i}</p>`).join('');
}
</script>
