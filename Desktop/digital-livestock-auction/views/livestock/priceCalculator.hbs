<!-- Tailwind Configuration -->
<script>
  tailwind.config = {
    darkMode: 'class',
    theme: {
      extend: {
        fontFamily: {
          'display': ['Bricolage Grotesque', 'system-ui', 'sans-serif'],
          'body': ['Outfit', 'system-ui', 'sans-serif'],
        },
        animation: {
          'float': 'float 6s ease-in-out infinite',
          'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite',
          'fade-in': 'fadeIn 0.6s ease-out',
          'slide-up': 'slideUp 0.5s cubic-bezier(0.23,1,0.32,1)',
          'glow': 'glow 2s ease-in-out infinite',
          'shimmer': 'shimmer 2s infinite',
        },
        keyframes: {
          float: {
            '0%, 100%': { transform: 'translateY(0px)' },
            '50%': { transform: 'translateY(-10px)' },
          },
          fadeIn: {
            '0%': { opacity: '0', transform: 'translateY(10px)' },
            '100%': { opacity: '1', transform: 'translateY(0)' },
          },
          slideUp: {
            '0%': { opacity: '0', transform: 'translateY(20px)' },
            '100%': { opacity: '1', transform: 'translateY(0)' },
          },
          glow: {
            '0%, 100%': { boxShadow: '0 0 20px rgba(249, 115, 22, 0.3)' },
            '50%': { boxShadow: '0 0 40px rgba(249, 115, 22, 0.6), 0 0 60px rgba(249, 115, 22, 0.3)' },
          },
          shimmer: {
            '0%': { backgroundPosition: '-200% 0' },
            '100%': { backgroundPosition: '200% 0' },
          },
        }
      }
    }
  };
</script>

<!-- Advanced Custom Styles -->
<style>
  /* Fonts */
  .font-display { font-family: 'Bricolage Grotesque', system-ui, sans-serif; }
  .font-body { font-family: 'Outfit', system-ui, sans-serif; }

  /* Gradient Text */
  .text-gradient {
    background: linear-gradient(135deg, #f97316, #dc2626, #ea580c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient 3s ease infinite;
    background-size: 200% 200%;
  }

  @keyframes gradient {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Glass Morphism */
  .glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* Neon Glow */
  .neon-glow {
    text-shadow:
      0 0 10px rgba(249, 115, 22, 0.8),
      0 0 20px rgba(249, 115, 22, 0.6),
      0 0 30px rgba(249, 115, 22, 0.4);
  }

  /* 3D Card */
  .card-3d {
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .card-3d:hover {
    transform: perspective(1000px) rotateY(5deg) rotateX(3deg) scale(1.02);
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #1f2937; }
  ::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, #f97316, #dc2626);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, #ea580c, #b91c1c);
  }

  /* Hex Pattern */
  .hex-pattern {
    background-image:
      radial-gradient(circle at 25% 25%, rgba(249, 115, 22, 0.05) 1px, transparent 1px),
      radial-gradient(circle at 75% 75%, rgba(220, 38, 38, 0.05) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  /* Animated Grid */
  .animated-grid {
    background-image:
      linear-gradient(rgba(249, 115, 22, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(249, 115, 22, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
  }

  @keyframes gridMove {
    0% { background-position: 0 0; }
    100% { background-position: 50px 50px; }
  }

  /* Shimmer */
  .shimmer {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.05),
      transparent
    );
    background-size: 200% 100%;
    animation: shimmer 3s infinite;
  }

  /* Price Reveal Animation */
  @keyframes priceReveal {
    0% { opacity: 0; transform: scale(0.9) translateY(20px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }

  .price-reveal {
    animation: priceReveal 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards;
  }

  /* Breakdown Card Animation */
  @keyframes breakdownSlide {
    0% { opacity: 0; transform: translateX(-30px); }
    100% { opacity: 1; transform: translateX(0); }
  }

  .breakdown-card {
    animation: breakdownSlide 0.5s cubic-bezier(0.23, 1, 0.32, 1) forwards;
  }

  /* Select Dropdown Custom Styling */
  select {
    background-image: none;
  }

  select:focus {
    outline: none;
  }

  /* Radio Button Peer Checked Fix */
  input[type="radio"]:checked ~ div {
    border-color: currentColor;
  }

  /* Ambient Background */
  .ambient-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
</style>

