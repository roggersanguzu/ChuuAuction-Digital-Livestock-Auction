            <option>Highest Bid</option>
            <option>Most Bids</option>
            <option>Ending Soonest</option>
            <option>Recently Updated</option>
          </select>
        </div>
      </div>

      <!-- Auctions Grid -->
      <div class="space-y-6">

        <!-- AUCTION 1: Premium Friesian Cattle -->
