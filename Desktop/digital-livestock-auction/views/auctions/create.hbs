    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .price-input-wrapper input:focus ~ .ugx-label,
  .price-input-wrapper input:not(:placeholder-shown) ~ .ugx-label {
    opacity: 0;
  }

  /* Advanced Radio Cards */
  .radio-card-advanced {
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
    overflow: hidden;
  }

  .radio-card-advanced::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(249, 115, 22, 0.1);
    transform: translate(-50%, -50%);
