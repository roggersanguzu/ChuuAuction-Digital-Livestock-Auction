                    class="bi bi-info-circle mr-1"
                  ></i>Minimum 50 characters</p>
                <span class="text-xs font-semibold" id="descCharCountWrapper">
                  <span id="descCharCount" class="text-red-500">0</span><span
                    class="text-gray-500"
                  >/1000</span>
                </span>
              </div>
            </div>

            <!-- Quick Stats Preview Card -->
            <div class="md:col-span-2 mt-4">
