    color: white;
    padding: 12px;
  }

  .custom-select option:hover {
    background: #374151;
  }

  /* Date and Time picker styling */
  input[type="date"]::-webkit-calendar-picker-indicator,
  input[type="time"]::-webkit-calendar-picker-indicator {
    filter: invert(1);
    cursor: pointer;
    font-size: 1.2rem;
    padding: 4px;
  }

  input[type="date"],
  input[type="time"] {
    position: relative;
  }

  /* Price input UGX label handling */
  .price-input-wrapper {
    position: relative;
  }

  .price-input-wrapper .ugx-label {
    position: absolute;
    left: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
