<script>
  // Character counter for description const descTextarea =
  document.querySelector('textarea[name="description"]'); const descCharCount =
  document.getElementById('descCharCount'); const descCharCountWrapper =
  document.getElementById('descCharCountWrapper'); if (descTextarea &&
  descCharCount) { descTextarea.addEventListener('input', (e) => { const count =
  e.target.value.length; descCharCount.textContent = count; if (count >= 50) {
  descCharCount.classList.add('text-green-500');
  descCharCount.classList.remove('text-red-500'); } else {
  descCharCount.classList.add('text-red-500');
  descCharCount.classList.remove('text-green-500'); } }); } // Live Preview
  Updates const animalTypeSelect =
  document.querySelector('select[name="animalType"]'); const breedInput =
  document.querySelector('input[name="breed"]'); const weightInput =
  document.querySelector('input[name="weight"]'); const locationInput =
  document.querySelector('input[name="location"]'); const updatePreview = () =>
  { const categoryMap = { '1': 'Cattle', '2': 'Goat', '3': 'Sheep', '4': 'Pig',
  '5': 'Poultry', '6': 'Rabbit', '7': 'Duck' }; if (animalTypeSelect?.value) {
  document.getElementById('previewCategory').textContent =
  categoryMap[animalTypeSelect.value] || '-'; } if (breedInput?.value) {
  document.getElementById('previewBreed').textContent = breedInput.value || '-';
  } if (weightInput?.value) {
  document.getElementById('previewWeight').textContent = weightInput.value + '
  KG' || '-'; } if (locationInput?.value) {
  document.getElementById('previewLocation').textContent = locationInput.value
  || '-'; } }; animalTypeSelect?.addEventListener('change', updatePreview);
  breedInput?.addEventListener('input', updatePreview);
  weightInput?.addEventListener('input', updatePreview);
  locationInput?.addEventListener('input', updatePreview); // Vaccination toggle
  const vaccinatedToggle = document.getElementById('vaccinatedToggle'); const
  vaccinatedLabel = document.getElementById('vaccinatedLabel'); const
  vaccinationLicenseSection =
  document.getElementById('vaccinationLicenseSection'); const vaccinationLicense
  = document.getElementById('vaccinationLicense');
  vaccinatedToggle?.addEventListener('change', (e) => { if (e.target.checked) {
  vaccinatedLabel.textContent = 'Yes';
  vaccinatedLabel.classList.add('text-green-500');
  vaccinatedLabel.classList.remove('text-gray-400');
  vaccinationLicenseSection.classList.remove('hidden');
  vaccinationLicenseSection.classList.add('animate-slide-up');
  vaccinationLicense.required = true; } else { vaccinatedLabel.textContent =
  'No'; vaccinatedLabel.classList.remove('text-green-500');
  vaccinatedLabel.classList.add('text-gray-400');
  vaccinationLicenseSection.classList.add('hidden'); vaccinationLicense.required
  = false; } }); // Photo upload handler const photoInput =
  document.getElementById('animalPhotosInput'); const photoPreviewGrid =
  document.getElementById('photoPreviewGrid'); const uploadPrompt =
  document.getElementById('uploadPrompt');
  photoInput?.addEventListener('change', (e) => { const files = e.target.files;
  console.log('Files selected:', files.length); if (files.length > 0) {
  photoPreviewGrid.innerHTML = ''; photoPreviewGrid.classList.remove('hidden');
  uploadPrompt.classList.add('hidden'); Array.from(files).forEach((file, index)
  => { if (file.size > 5 * 1024 * 1024) { alert(`${file.name} is too large. Max
  size is 5MB`); return; } const reader = new FileReader(); reader.onload =
  (event) => { const div = document.createElement('div'); div.className =
  'image-preview-card group'; div.innerHTML = ` <img
  src="${event.target.result}" alt="Animal ${index + 1}" /> <div class="absolute
  inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-opacity flex
  flex-col items-center justify-center gap-2"> <button type="button"
  onclick="removeAllPhotos()" class="px-4 py-2 bg-red-500 rounded-lg text-white
  text-sm font-bold hover:bg-red-600 transition-colors"> <i class="bi
  bi-trash"></i> Remove </button> <span class="text-xs text-white">${(file.size
  / 1024).toFixed(0)}KB</span> </div> <div class="absolute top-2 left-2 px-2
  py-1 bg-orange-500 rounded-full text-xs font-bold text-white"> ${index + 1}
  </div> `; photoPreviewGrid.appendChild(div); }; reader.readAsDataURL(file);
  }); // Update step 2 progress
  document.getElementById('step2')?.classList.add('completed');
  if(document.getElementById('step2')) {
  document.getElementById('step2').innerHTML = '<i class="bi bi-check-lg
  text-xl"></i>'; } } }); window.removeAllPhotos = function() { if(photoInput)
  photoInput.value = ''; if(uploadPrompt)
  uploadPrompt.classList.remove('hidden'); if(photoPreviewGrid) {
  photoPreviewGrid.classList.add('hidden'); photoPreviewGrid.innerHTML = ''; }
  document.getElementById('step2')?.classList.remove('completed');
  if(document.getElementById('step2')) {
  document.getElementById('step2').innerHTML = '<i class="bi bi-images
  text-xl"></i>'; } }; // Drag and drop const uploadZone =
  document.querySelector('.photo-upload-zone');
  uploadZone?.addEventListener('dragover', (e) => { e.preventDefault();
  uploadZone.classList.add('active'); });
  uploadZone?.addEventListener('dragleave', () => {
  uploadZone.classList.remove('active'); });
  uploadZone?.addEventListener('drop', (e) => { e.preventDefault();
  uploadZone.classList.remove('active'); photoInput.files =
  e.dataTransfer.files; photoInput.dispatchEvent(new Event('change', { bubbles:
  true })); }); // Price calculator
  document.getElementById('calculatePrice')?.addEventListener('click', () => {
  const animalType = document.querySelector('select[name="animalType"]').value;
  const weight =
  parseFloat(document.querySelector('input[name="weight"]').value) || 0; const
  age = parseFloat(document.querySelector('input[name="ageYears"]').value) || 0;
  if (animalType && weight > 0) { // Simple calculation logic (adjust based on
  your market data) const basePrice = { '1': 1500000, // Cattle '2': 400000, //
  Goat '3': 350000, // Sheep '4': 300000, // Pig '5': 50000, // Poultry }; const
  base = basePrice[animalType] || 100000; const weightFactor = weight * 2000;
  const ageFactor = age * 50000; const estimated = base + weightFactor +
  ageFactor; const recommendedStart = Math.floor(estimated * 0.7); const
  expectedHigh = Math.floor(estimated * 1.3);
  document.getElementById('marketAvg').textContent = `UGX
  ${estimated.toLocaleString()}`;
  document.getElementById('recommendedStart').textContent = `UGX
  ${recommendedStart.toLocaleString()}`;
  document.getElementById('expectedRange').textContent =
  `${recommendedStart.toLocaleString()}-${expectedHigh.toLocaleString()}`; //
  Auto-fill starting price document.getElementById('startingPrice').value =
  recommendedStart; // Update step 3
  document.getElementById('step3').classList.add('completed');
  document.getElementById('step3').innerHTML = '<i class="bi bi-check-lg
  text-xl"></i>'; } else { alert('Please fill in animal type and weight first');
  } }); // Auction duration calculator function updateDurationPreview() { const
  endDate = document.getElementById('endDate').value; const endTime =
  document.getElementById('endTime').value; if (endDate && endTime) { const
  endDateTime = new Date(`${endDate}T${endTime}`); const now = new Date(); const
  diff = endDateTime - now; if (diff > 0) { const days = Math.floor(diff / (1000
  * 60 * 60 * 24)); const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) /
  (1000 * 60 * 60)); const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 *
  60)); document.getElementById('daysLeft').textContent =
  String(days).padStart(2, '0');
  document.getElementById('hoursLeft').textContent = String(hours).padStart(2,
  '0'); document.getElementById('minsLeft').textContent =
  String(mins).padStart(2, '0');
  document.getElementById('durationPreview').textContent = `Auction will run for
  ${days} days, ${hours} hours, and ${mins} minutes`; // Update step 4
  document.getElementById('step4').classList.add('completed');
  document.getElementById('step4').innerHTML = '<i class="bi bi-check-lg
  text-xl"></i>'; } else {
  document.getElementById('durationPreview').textContent = 'End time must be in
  the future'; } } }
  document.getElementById('endDate')?.addEventListener('change',
  updateDurationPreview);
  document.getElementById('endTime')?.addEventListener('change',
  updateDurationPreview); // Set minimum date to tomorrow const tomorrow = new
  Date(); tomorrow.setDate(tomorrow.getDate() + 1);
  document.getElementById('endDate').min = tomorrow.toISOString().split('T')[0];
  // Form submission
  document.getElementById('auctionForm')?.addEventListener('submit', (e) => {
  const terms = document.getElementById('termsCheckbox'); if (!terms.checked) {
  e.preventDefault(); alert('You must agree to the terms and conditions');
  terms.focus(); return; } const submitBtn =
  document.getElementById('submitBtn'); submitBtn.disabled = true;
  submitBtn.innerHTML = ` <i class="bi bi-hourglass-split animate-spin
  text-2xl"></i> <span>Creating Your Auction...</span> `; }); // Save Draft
  functionality
  document.getElementById('saveDraftBtn')?.addEventListener('click', () => {
  const formData = new FormData(document.getElementById('auctionForm')); const
  draftData = {}; for (let [key, value] of formData.entries()) { if (key !==
  'animalPhotos' && key !== 'lc1Document') { draftData[key] = value; } }
  localStorage.setItem('auctionDraft', JSON.stringify(draftData)); // Show
  success message const btn = document.getElementById('saveDraftBtn'); const
  originalHTML = btn.innerHTML; btn.innerHTML = '<i class="bi bi-check-circle
  text-green-500 text-xl"></i><span>Draft Saved!</span>';
  btn.classList.add('border-green-500', 'bg-green-500/10'); setTimeout(() => {
  btn.innerHTML = originalHTML; btn.classList.remove('border-green-500',
  'bg-green-500/10'); }, 2000); }); // Load draft on page load
  window.addEventListener('DOMContentLoaded', () => { const savedDraft =
  localStorage.getItem('auctionDraft'); if (savedDraft) { try { const draftData
  = JSON.parse(savedDraft); Object.keys(draftData).forEach(key => { const input
  = document.querySelector(`[name="${key}"]`); if (input) { if (input.type ===
  'radio') { const radio =
  document.querySelector(`[name="${key}"][value="${draftData[key]}"]`); if
  (radio) radio.checked = true; } else if (input.type === 'checkbox') {
  input.checked = draftData[key] === 'on'; } else { input.value =
  draftData[key]; } } }); } catch (e) { console.error('Error loading draft:',
  e); } } }); // Progress tracking const form =
  document.getElementById('auctionForm'); const sections =
  document.querySelectorAll('.form-section'); // Update steps based on form
  completion form?.addEventListener('input', () => { // Step 1 check const
  animalType = document.querySelector('select[name="animalType"]').value; const
  breed = document.querySelector('input[name="breed"]').value; const weight =
  document.querySelector('input[name="weight"]').value; if (animalType && breed
  && weight) { document.getElementById('step1').classList.add('completed');
  document.getElementById('step1').innerHTML = '<i class="bi bi-check-lg
  text-xl"></i>'; } });
</script>