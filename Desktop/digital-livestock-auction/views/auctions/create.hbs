              >
                <i class="bi bi-check-circle text-green-500 text-xl"></i>
                <span class="text-gray-300">At least 2 clear photos uploaded</span>
              </div>
              <div
                class="flex items-center gap-3 p-4 rounded-xl bg-gray-800/30"
              >
                <i class="bi bi-check-circle text-green-500 text-xl"></i>
