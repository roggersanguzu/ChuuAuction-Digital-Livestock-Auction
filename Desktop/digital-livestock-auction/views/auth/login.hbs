<script>
  // Theme Toggle (unchanged) document.addEventListener('DOMContentLoaded',
  function () { const themeToggle = document.getElementById('theme-toggle');
  const html = document.documentElement; const currentTheme =
  localStorage.getItem('theme') || 'dark'; if (currentTheme === 'dark') {
  html.classList.add('dark'); } themeToggle?.addEventListener('click', function
  () { html.classList.toggle('dark'); localStorage.setItem('theme',
  html.classList.contains('dark') ? 'dark' : 'light'); }); // Password
  visibility toggle const togglePassword =
  document.getElementById('toggle-password'); const passwordInput =
  document.getElementById('password'); const eyeIcon =
  document.getElementById('eye-icon'); togglePassword?.addEventListener('click',
  function () { const type = passwordInput.getAttribute('type') === 'password' ?
  'text' : 'password'; passwordInput.setAttribute('type', type);
  eyeIcon.classList.toggle('bi-eye'); eyeIcon.classList.toggle('bi-eye-slash');
  }); // Real form submission + minimal client validation const form =
  document.getElementById('login-form'); const submitBtn =
  document.getElementById('submit-btn'); form?.addEventListener('submit',
  function (e) { const email =
  form.querySelector('[name="email"]').value.trim(); const password =
  form.querySelector('[name="password"]').value.trim(); if (!email || !password)
  { alert('⚠️ Please fill in email and password'); e.preventDefault(); return; }
  // Show loading state const originalHTML = submitBtn.innerHTML;
  submitBtn.disabled = true; submitBtn.innerHTML = '<i class="bi
  bi-hourglass-split animate-spin"></i> Signing In...'; // Form submits for real
  → no e.preventDefault() at the end }); console.log(' ChuuAuction Login Page
  Loaded – real authentication enabled'); });
</script>