{
  "name": "digital-livestock-auction",
  "version": "1.0.0",
  "description": "Human-centered digital livestock auction platform enabling secure, verified, fair, and accessible trading for Uganda’s smallholder farmers.",
  "license": "ISC",
  "author": "Roggers Anguzu",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build": "npm run build:css",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./src/input.css -o ./public/css/output.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/css/output.css --watch"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cloudinary": "^2.9.0",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-handlebars": "^8.0.4",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.6",
    "multer": "^2.0.2",
    "openai": "^6.17.0",
    "pdf-parse": "^1.1.4",
    "serve-favicon": "^2.5.1",
    "sharp": "^0.33.5",
    "streamifier": "^0.1.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "nodemon": "^3.1.11"
  }
}
