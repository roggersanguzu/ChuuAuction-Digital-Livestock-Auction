      'rgb(249, 115, 22)', pointBorderColor: '#fff', pointHoverBackgroundColor:
      '#fff', pointHoverBorderColor: 'rgb(249, 115, 22)', pointRadius: 5,
      pointHoverRadius: 7 }] }, options: { responsive: true,
      maintainAspectRatio: false, plugins: { legend: { display: false },
      tooltip: { backgroundColor: 'rgba(17, 24, 39, 0.9)', titleColor: '#fff',
      bodyColor: '#fff', borderColor: 'rgba(249, 115, 22, 0.5)', borderWidth: 1,
      padding: 12, displayColors: false } }, scales: { y: { beginAtZero: true,
      grid: { color: 'rgba(249, 115, 22, 0.1)', drawBorder: false }, ticks: {
      color: '#9ca3af' } }, x: { grid: { display: false }, ticks: { color:
      '#9ca3af' } } } } }); } // Spending Overview Chart const spendingCtx =
