      document.getElementById('sidebar-toggle'); const openSidebar = () => {
      sidebar?.classList.remove('-translate-x-full');
      sidebar?.classList.add('translate-x-0'); overlay?.classList.add('active');
      }; const closeSidebar = () => {
      sidebar?.classList.add('-translate-x-full');
      sidebar?.classList.remove('translate-x-0');
