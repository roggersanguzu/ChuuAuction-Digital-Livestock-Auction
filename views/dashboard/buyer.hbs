    <script>
      (function () { document.querySelectorAll(".tab-group").forEach(function
      (group) { group.querySelectorAll(".tab").forEach(function (tab) { if
      (tab.dataset.bound === "1") return; tab.dataset.bound = "1";
      tab.addEventListener("click", function () {
      group.querySelectorAll(".tab").forEach(function (t) {
      t.classList.remove("active"); }); tab.classList.add("active"); }); }); });
      var darkTooltip = { backgroundColor: "rgba(13,15,18,0.95)", titleColor:
      "#f1f2f5", bodyColor: "#8892a4", borderColor: "rgba(249,115,22,0.3)",
      borderWidth: 1, padding: 12, cornerRadius: 10, displayColors: false, };
      var bCtx = document.getElementById("biddingChart"); if (bCtx && typeof
      Chart !== "undefined") { new Chart(bCtx, { type: "line", data: { labels:
      ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"], datasets: [{ label:
      "Bids Placed", data: [3, 5, 2, 8, 4, 7, 6], borderColor: "#f97316",
      backgroundColor: "rgba(249,115,22,0.07)", tension: 0.45, fill: true,
      pointBackgroundColor: "#f97316", pointBorderColor: "#050608",
      pointBorderWidth: 3, pointRadius: 6, pointHoverRadius: 9, }], }, options:
      { responsive: true, maintainAspectRatio: false, plugins: { legend: {
      display: false }, tooltip: darkTooltip }, scales: { y: { beginAtZero:
      true, grid: { color: "rgba(249,115,22,0.05)", drawBorder: false }, ticks:
      { color: "#4d5566", font: { family: "Outfit" } }, }, x: { grid: { display:
      false }, ticks: { color: "#4d5566", font: { family: "Outfit" } }, }, }, },
      }); } var sCtx = document.getElementById("spendingChart"); if (sCtx &&
      typeof Chart !== "undefined") { new Chart(sCtx, { type: "doughnut", data:
      { labels: ["Cattle", "Goats", "Sheep", "Others"], datasets: [{ data: [45,
      30, 15, 10], backgroundColor: [ "rgba(59,130,246,0.75)",
      "rgba(34,197,94,0.75)", "rgba(168,85,247,0.75)", "rgba(234,179,8,0.75)",
      ], borderColor: ["#0d0f12", "#0d0f12", "#0d0f12", "#0d0f12"], borderWidth:
      3, hoverOffset: 8, }], }, options: { responsive: true,
      maintainAspectRatio: false, plugins: { legend: { display: false },
      tooltip: darkTooltip }, cutout: "72%", }, }); } })();
    </script>
