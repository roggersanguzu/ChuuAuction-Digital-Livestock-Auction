<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ChuuAuction , Buyer Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="/vendor/bootstrap-icons/css/bootstrap-icons.css"
    />
    <script>
      tailwind = { config: { corePlugins: { preflight: false } } };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/app-theme.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      :root {
        --orange-core: #f97316;
        --orange-bright: #fb923c;
        --orange-dim: #ea580c;
        --red-core: #dc2626;
        --surface-0: #050608;
        --surface-1: #0d0f12;
        --surface-2: #141720;
        --surface-3: #1c2030;
        --surface-4: #252a3a;
        --border-subtle: rgba(255, 255, 255, 0.04);
        --border-mid: rgba(255, 255, 255, 0.08);
        --border-accent: rgba(249, 115, 22, 0.25);
        --text-primary: #f1f2f5;
        --text-secondary: #8892a4;
        --text-muted: #4d5566;
        --ff-display: "Bricolage Grotesque", system-ui, sans-serif;
        --ff-body: "Outfit", system-ui, sans-serif;
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: var(--ff-body);
        background: var(--surface-0);
        color: var(--text-primary);
        overflow-x: hidden;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: var(--surface-1);
      }
      ::-webkit-scrollbar-thumb {
        background: linear-gradient(
          180deg,
          var(--orange-core),
          var(--red-core)
        );
        border-radius: 99px;
      }
      #bg-canvas {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }
      .noise-overlay {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
        opacity: 0.025;
      }
      .grid-bg {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(249, 115, 22, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(249, 115, 22, 0.025) 1px, transparent 1px);
        background-size: 60px 60px;
        animation: gridDrift 30s linear infinite;
      }
      @keyframes gridDrift {
        from {
          background-position: 0 0;
        }
        to {
          background-position: 60px 60px;
        }
      }
      .layout {
        display: flex;
        min-height: calc(100vh - 1px);
        position: relative;
        z-index: auto;
      }
      .sidebar {
        width: 280px;
        flex-shrink: 0;
        height: 100vh;
        position: sticky;
        top: 0;
        display: flex;
        flex-direction: column;
        background: rgba(13, 15, 18, 0.85);
        backdrop-filter: blur(32px) saturate(1.5);
        border-right: 1px solid var(--border-subtle);
        overflow: hidden;
        transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
      }
      .sidebar-inner {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 28px 20px;
        gap: 8px;
        overflow-y: auto;
        scrollbar-width: none;
      }
      .sidebar-inner::-webkit-scrollbar {
        display: none;
      }
      .sidebar-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
      }
      .logo-block {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-radius: 16px;
        background: linear-gradient(
          135deg,
          rgba(249, 115, 22, 0.08),
          rgba(220, 38, 38, 0.06)
        );
        border: 1px solid var(--border-accent);
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
      }
      .logo-block::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(249, 115, 22, 0.1),
          transparent
        );
        opacity: 0;
        transition: opacity 0.3s;
      }
      .logo-block:hover::after {
        opacity: 1;
      }
      .logo-img {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        object-fit: cover;
        border: 2px solid rgba(249, 115, 22, 0.4);
        background: linear-gradient(
          135deg,
          var(--orange-core),
          var(--red-core)
        );
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: white;
        font-weight: 800;
        font-family: var(--ff-display);
        flex-shrink: 0;
      }
      .logo-text h1 {
        font-family: var(--ff-display);
        font-size: 18px;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.3px;
      }
      .logo-text h1 .accent {
        color: var(--orange-core);
      }
      .logo-text p {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 2px;
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .status-dot {
        width: 7px;
        height: 7px;
        background: #22c55e;
        border-radius: 50%;
        animation: statusPulse 2s ease-in-out infinite;
      }
      @keyframes statusPulse {
        0%,
        100% {
          box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
        }
        50% {
          box-shadow: 0 0 0 4px rgba(34, 197, 94, 0);
        }
      }
      .sidebar-close-btn {
        display: none;
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: var(--surface-2);
        border: 1px solid var(--border-mid);
        color: var(--text-muted);
        align-items: center;
        justify-content: center;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.2s;
      }
      .sidebar-close-btn:hover {
        background: rgba(239, 68, 68, 0.12);
        border-color: rgba(239, 68, 68, 0.3);
        color: #f87171;
      }
      .wallet-card {
        background: linear-gradient(
          135deg,
          rgba(249, 115, 22, 0.1),
          rgba(220, 38, 38, 0.08)
        );
        border: 1px solid rgba(249, 115, 22, 0.15);
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 20px;
      }
      .wallet-label {
        font-size: 11px;
        color: var(--text-muted);
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .wallet-amount {
        font-family: var(--ff-display);
        font-size: 24px;
        font-weight: 800;
      }
      .wallet-amount span {
        color: var(--orange-core);
      }
      .wallet-change {
        font-size: 11px;
        color: #22c55e;
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 4px;
      }
      .nav-section-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-muted);
        padding: 12px 8px 6px;
      }
      .nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 14px;
        border-radius: 12px;
        text-decoration: none;
        color: var(--text-secondary);
        font-weight: 500;
        font-size: 14px;
        transition: all 0.25s ease;
        position: relative;
        overflow: hidden;
        min-width: 0;
      }
      .nav-text {
        min-width: 0;
        overflow-wrap: anywhere;
      }
      .nav-link::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(
          180deg,
          var(--orange-core),
          var(--red-core)
        );
        border-radius: 0 3px 3px 0;
        transform: scaleY(0);
        transition: transform 0.25s ease;
      }
      .nav-link:hover,
      .nav-link.active {
        background: rgba(249, 115, 22, 0.07);
        color: var(--text-primary);
      }
      .nav-link:hover::before,
      .nav-link.active::before {
        transform: scaleY(1);
      }
      .nav-link.active {
        color: var(--orange-bright);
      }
      .nav-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
        transition: transform 0.25s ease;
      }
      .nav-link:hover .nav-icon {
        transform: scale(1.1);
      }
      .nav-icon.orange {
        background: rgba(249, 115, 22, 0.15);
        color: var(--orange-core);
      }
      .nav-icon.blue {
        background: rgba(59, 130, 246, 0.15);
        color: #60a5fa;
      }
      .nav-icon.green {
        background: rgba(34, 197, 94, 0.15);
        color: #4ade80;
      }
      .nav-icon.yellow {
        background: rgba(234, 179, 8, 0.15);
        color: #facc15;
      }
      .nav-icon.purple {
        background: rgba(168, 85, 247, 0.15);
        color: #c084fc;
      }
      .nav-icon.gray {
        background: rgba(148, 163, 184, 0.1);
        color: #94a3b8;
      }
      .nav-icon.red {
        background: rgba(239, 68, 68, 0.15);
        color: #f87171;
      }
      .nav-chevron {
        margin-left: auto;
        font-size: 11px;
        color: var(--text-muted);
        transition: transform 0.25s;
      }
      .nav-link:hover .nav-chevron {
        transform: translateX(3px);
        color: var(--orange-core);
      }
      .nav-badge {
        margin-left: auto;
        background: rgba(249, 115, 22, 0.2);
        border: 1px solid rgba(249, 115, 22, 0.3);
        color: var(--orange-bright);
        font-size: 10px;
        font-weight: 700;
        padding: 1px 7px;
        border-radius: 99px;
      }
      .sidebar-divider {
        height: 1px;
        background: var(--border-subtle);
        margin: 10px 0;
      }
      .logout-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border-radius: 12px;
        background: rgba(239, 68, 68, 0.07);
        border: 1px solid rgba(239, 68, 68, 0.15);
        color: #f87171;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.25s;
        margin-top: auto;
        width: 100%;
        text-align: left;
      }
      .logout-btn:hover {
        background: rgba(239, 68, 68, 0.14);
        border-color: rgba(239, 68, 68, 0.35);
        transform: translateX(3px);
      }
      .logout-btn .nav-icon {
        background: rgba(239, 68, 68, 0.15);
        color: #f87171;
      }
      .main {
        flex: 1;
        min-width: 0;
        padding: 24px 20px;
        overflow: visible;
        padding-bottom: 56px;
      }
      .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 40px;
      }
      .page-title-block {
        max-width: 560px;
      }
      .page-eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--orange-core);
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
      }
      .page-eyebrow::before {
        content: "";
        display: inline-block;
        width: 24px;
        height: 2px;
        background: var(--orange-core);
        border-radius: 2px;
      }
      .page-title {
        font-family: var(--ff-display);
        font-size: clamp(36px, 5vw, 58px);
        font-weight: 800;
        line-height: 1;
        letter-spacing: -2px;
      }
      .page-title .highlight {
        background: linear-gradient(
          130deg,
          var(--orange-core) 0%,
          var(--orange-bright) 40%,
          #fbbf24 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: titleShimmer 4s ease-in-out infinite;
        background-size: 200% 100%;
      }
      @keyframes titleShimmer {
        0%,
        100% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
      }
      .page-subtitle {
        font-size: 15px;
        color: var(--text-secondary);
        margin-top: 12px;
        line-height: 1.5;
      }
      .page-subtitle strong {
        color: var(--orange-bright);
        font-weight: 600;
      }
      .header-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-top: 8px;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        border-radius: 12px;
        font-family: var(--ff-body);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.25s ease;
        border: none;
        text-decoration: none;
      }
      .btn-ghost {
        background: var(--surface-2);
        border: 1px solid var(--border-mid);
        color: var(--text-secondary);
      }
      .btn-ghost:hover {
        border-color: var(--border-accent);
        color: var(--text-primary);
      }
      .btn-primary {
        background: linear-gradient(
          135deg,
          var(--orange-core),
          var(--orange-dim)
        );
        color: white;
        box-shadow: 0 4px 24px rgba(249, 115, 22, 0.3);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(249, 115, 22, 0.45);
      }
      .icon-btn {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        background: var(--surface-2);
        border: 1px solid var(--border-mid);
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.25s;
        position: relative;
      }
      .icon-btn:hover {
        border-color: var(--border-accent);
        color: var(--orange-bright);
      }
      .notif-dot {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 8px;
        height: 8px;
        background: #ef4444;
        border: 2px solid var(--surface-0);
        border-radius: 50%;
        animation: notifPulse 2s ease-in-out infinite;
      }
      @keyframes notifPulse {
        0%,
        100% {
          transform: scale(1);
        }
        50% {
          transform: scale(1.3);
        }
      }
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 36px;
      }
      .stat-card {
        background: var(--surface-1);
        border: 1px solid var(--border-subtle);
        border-radius: 20px;
        padding: 24px;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .stat-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        opacity: 0;
        transition: opacity 0.3s;
      }
      .stat-card:hover {
        transform: translateY(-5px);
        border-color: var(--border-accent);
        background: var(--surface-2);
      }
      .stat-card:hover::before {
        opacity: 1;
      }
      .stat-card.blue::before {
        background: linear-gradient(90deg, transparent, #3b82f6, transparent);
      }
      .stat-card.green::before {
        background: linear-gradient(90deg, transparent, #22c55e, transparent);
      }
      .stat-card.yellow::before {
        background: linear-gradient(90deg, transparent, #eab308, transparent);
      }
      .stat-card.purple::before {
        background: linear-gradient(90deg, transparent, #a855f7, transparent);
      }
      .stat-card:hover.blue {
        box-shadow: 0 20px 60px rgba(59, 130, 246, 0.15);
      }
      .stat-card:hover.green {
        box-shadow: 0 20px 60px rgba(34, 197, 94, 0.12);
      }
      .stat-card:hover.yellow {
        box-shadow: 0 20px 60px rgba(234, 179, 8, 0.12);
      }
      .stat-card:hover.purple {
        box-shadow: 0 20px 60px rgba(168, 85, 247, 0.15);
      }
      .stat-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 20px;
      }
      .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        transition: transform 0.3s;
      }
      .stat-card:hover .stat-icon {
        transform: scale(1.1) rotate(-5deg);
      }
      .stat-icon.blue {
        background: rgba(59, 130, 246, 0.12);
        color: #60a5fa;
      }
      .stat-icon.green {
        background: rgba(34, 197, 94, 0.12);
        color: #4ade80;
      }
      .stat-icon.yellow {
        background: rgba(234, 179, 8, 0.12);
        color: #fde047;
      }
      .stat-icon.purple {
        background: rgba(168, 85, 247, 0.12);
        color: #c084fc;
      }
      .stat-tag {
        font-size: 10px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 99px;
      }
      .stat-tag.blue {
        background: rgba(59, 130, 246, 0.15);
        color: #60a5fa;
        border: 1px solid rgba(59, 130, 246, 0.2);
      }
      .stat-tag.green {
        background: rgba(34, 197, 94, 0.12);
        color: #4ade80;
        border: 1px solid rgba(34, 197, 94, 0.2);
      }
      .stat-tag.yellow {
        background: rgba(234, 179, 8, 0.12);
        color: #fde047;
        border: 1px solid rgba(234, 179, 8, 0.2);
      }
      .stat-tag.live {
        background: rgba(239, 68, 68, 0.15);
        color: #f87171;
        border: 1px solid rgba(239, 68, 68, 0.25);
        display: flex;
        align-items: center;
        gap: 5px;
        animation: liveTagPulse 1.5s ease-in-out infinite;
      }
      @keyframes liveTagPulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.65;
        }
      }
      .live-dot {
        width: 6px;
        height: 6px;
        background: #f87171;
        border-radius: 50%;
      }
      .stat-value {
        font-family: var(--ff-display);
        font-size: 36px;
        font-weight: 800;
        letter-spacing: -1.5px;
        line-height: 1;
        margin-bottom: 6px;
      }
      .stat-label {
        font-size: 13px;
        color: var(--text-secondary);
        margin-bottom: 12px;
      }
      .stat-change {
        font-size: 12px;
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .stat-change.up {
        color: #4ade80;
      }
      .stat-change.down {
        color: #f87171;
      }
      .stat-change span {
        color: var(--text-muted);
      }
      .section-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 24px;
      }
      .section-title {
        font-family: var(--ff-display);
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.5px;
      }
      .section-sub {
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 3px;
      }
      .section-action {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: var(--orange-core);
        text-decoration: none;
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid rgba(249, 115, 22, 0.2);
        background: rgba(249, 115, 22, 0.06);
        transition: all 0.25s;
        cursor: pointer;
      }
      .section-action:hover {
        background: rgba(249, 115, 22, 0.12);
        border-color: rgba(249, 115, 22, 0.4);
      }
      .auctions-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 40px;
      }
      .auction-card {
        background: var(--surface-1);
        border: 1px solid var(--border-subtle);
        border-radius: 22px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
      }
      .auction-card:hover {
        transform: translateY(-8px);
        border-color: rgba(249, 115, 22, 0.3);
        box-shadow:
          0 24px 60px rgba(0, 0, 0, 0.4),
          0 0 0 1px rgba(249, 115, 22, 0.1);
      }
      .auction-img {
        position: relative;
        height: 200px;
        overflow: hidden;
      }
      .auction-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
      }
      .auction-card:hover .auction-img img {
        transform: scale(1.05);
      }
      .auction-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          0deg,
          rgba(5, 6, 8, 0.9) 0%,
