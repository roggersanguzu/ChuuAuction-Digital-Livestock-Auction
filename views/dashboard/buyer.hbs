              <i class="bi bi-x-lg text-white"></i>
            </button>
          </div>
        </div>

        <!-- Quick Stats in Sidebar -->
        <div class="mb-6 p-4 rounded-xl glass border border-gray-800/50">
          <div class="flex items-center justify-between mb-3">
            <span class="text-sm text-gray-400">Wallet Balance</span>
            <i class="bi bi-wallet2 text-orange-500"></i>
          </div>
          <div class="text-2xl font-black text-white mb-1">UGX 2.4M</div>
          <div class="flex items-center gap-2 text-xs">
            <span class="text-green-500 flex items-center gap-1">
              <i class="bi bi-arrow-up"></i>
              +12.5%
            </span>
            <span class="text-gray-500">vs last month</span>
          </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 overflow-y-auto space-y-2 pr-2">
          <!-- Dashboard -->
          <a
            href="dashboard/buyer"
            class="nav-item flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-800/50 transition-all duration-300 group cursor-pointer active"
          >
