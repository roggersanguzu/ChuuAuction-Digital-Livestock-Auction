      openSidebar); closeBtn?.addEventListener('click', closeSidebar);
      overlay?.addEventListener('click', closeSidebar);
      document.querySelectorAll('#sidebar a').forEach(link => {
      link.addEventListener('click', () => { if (window.innerWidth < 1024)
      closeSidebar(); }); }); const syncSidebar = () => { if (window.innerWidth
      >= 1024) { sidebar?.classList.remove('-translate-x-full');
      sidebar?.classList.add('translate-x-0');
      overlay?.classList.remove('active'); } else { closeSidebar(); } };
      window.addEventListener('resize', syncSidebar); syncSidebar(); //
      Initialize Charts initializeCharts(); }); function initializeCharts() { //
