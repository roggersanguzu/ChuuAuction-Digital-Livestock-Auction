                <span class="text-gradient neon-glow">Chuu</span><span
                  class="text-white"
                >Auction</span>
              </h1>
              <p class="text-xs text-gray-400 flex items-center gap-1">
                <i class="bi bi-shield-check text-green-500"></i>
                Buyer Panel
              </p>
            </div>
            <button
              id="sidebar-toggle"
