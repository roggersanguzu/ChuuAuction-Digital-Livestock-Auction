      .bid-progress-label {
        font-size: 10px;
        color: var(--text-muted);
        text-align: right;
      }
      .btn-bid {
        width: 100%;
        padding: 13px;
        border-radius: 14px;
        font-family: var(--ff-body);
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.25s;
      }
      .btn-bid.primary {
        background: linear-gradient(
          135deg,
          var(--orange-core),
          var(--orange-dim)
        );
        color: white;
        box-shadow: 0 4px 20px rgba(249, 115, 22, 0.3);
      }
      .btn-bid.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(249, 115, 22, 0.45);
      }
      .btn-bid.winning {
        background: linear-gradient(
          135deg,
          rgba(34, 197, 94, 0.15),
          rgba(21, 128, 61, 0.15)
        );
        border: 1px solid rgba(34, 197, 94, 0.3);
        color: #4ade80;
      }
      .btn-bid.winning:hover {
        background: linear-gradient(
          135deg,
          rgba(34, 197, 94, 0.22),
          rgba(21, 128, 61, 0.22)
        );
      }
      .analytics-row {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 20px;
        margin-bottom: 36px;
      }
      .card {
        background: var(--surface-1);
        border: 1px solid var(--border-subtle);
        border-radius: 20px;
        padding: 28px;
        transition: border-color 0.25s;
      }
      .card:hover {
        border-color: var(--border-accent);
      }
      .chart-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
      }
      .tab-group {
        display: flex;
        gap: 4px;
        background: var(--surface-2);
        border-radius: 10px;
        padding: 4px;
      }
      .tab {
        padding: 6px 14px;
        border-radius: 7px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        color: var(--text-muted);
        transition: all 0.2s;
        border: none;
        background: none;
      }
      .tab.active {
        background: var(--surface-3);
        color: var(--orange-bright);
      }
      .chart-wrap {
        position: relative;
        height: 260px;
      }
      .activity-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .activity-item {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 14px 0;
        border-bottom: 1px solid var(--border-subtle);
        transition: all 0.2s;
        cursor: pointer;
      }
      .activity-item:last-child {
        border-bottom: none;
      }
      .activity-item:hover {
        padding-left: 6px;
      }
      .activity-icon {
        width: 38px;
        height: 38px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 16px;
      }
      .activity-icon.green {
        background: rgba(34, 197, 94, 0.12);
        color: #4ade80;
      }
      .activity-icon.blue {
        background: rgba(59, 130, 246, 0.12);
        color: #60a5fa;
      }
      .activity-icon.yellow {
        background: rgba(234, 179, 8, 0.12);
        color: #fde047;
      }
      .activity-icon.red {
        background: rgba(239, 68, 68, 0.12);
        color: #f87171;
      }
      .activity-content {
        flex: 1;
        min-width: 0;
      }
      .activity-title {
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 3px;
      }
      .activity-desc {
        font-size: 12px;
        color: var(--text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .activity-right {
        text-align: right;
        flex-shrink: 0;
      }
      .activity-amount {
        font-size: 12px;
        font-weight: 700;
        padding: 3px 8px;
        border-radius: 7px;
        margin-bottom: 4px;
        display: inline-block;
      }
      .activity-amount.green {
        background: rgba(34, 197, 94, 0.12);
        color: #4ade80;
      }
      .activity-amount.blue {
        background: rgba(59, 130, 246, 0.12);
        color: #60a5fa;
      }
      .activity-amount.yellow {
        background: rgba(234, 179, 8, 0.12);
        color: #fde047;
      }
      .activity-amount.red {
        background: rgba(239, 68, 68, 0.12);
        color: #f87171;
      }
      .activity-time {
        font-size: 11px;
        color: var(--text-muted);
      }
      .bottom-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 40px;
      }
      .donut-wrap {
        display: flex;
        align-items: center;
        gap: 28px;
        margin-top: 20px;
      }
      .donut-chart-area {
        position: relative;
        width: 160px;
        height: 160px;
        flex-shrink: 0;
      }
      .donut-center {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        pointer-events: none;
      }
      .donut-center-val {
        font-family: var(--ff-display);
        font-size: 28px;
        font-weight: 800;
        letter-spacing: -1px;
      }
      .donut-center-label {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 2px;
      }
      .legend-items {
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
      }
      .legend-item {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 3px;
        flex-shrink: 0;
      }
      .legend-label {
        flex: 1;
        font-size: 13px;
        color: var(--text-secondary);
      }
      .legend-pct {
        font-size: 13px;
        font-weight: 700;
      }
      .win-ring-area {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 20px 0;
      }
      .ring-svg {
        overflow: visible;
      }
      .ring-bg {
        fill: none;
        stroke: var(--surface-3);
        stroke-width: 10;
      }
      .ring-fill {
        fill: none;
        stroke: url(#ringGrad);
        stroke-width: 10;
        stroke-linecap: round;
        stroke-dasharray: 440;
        stroke-dashoffset: 110;
        transform: rotate(-90deg);
        transform-origin: center;
        transition: stroke-dashoffset 1.2s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      .ring-label {
        font-family: var(--ff-display);
        font-size: 48px;
        font-weight: 800;
        letter-spacing: -2px;
        fill: var(--text-primary);
        text-anchor: middle;
        dominant-baseline: middle;
      }
      .ring-sublabel {
        font-size: 13px;
        fill: var(--text-muted);
        text-anchor: middle;
        dominant-baseline: middle;
      }
      .win-stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }
      .win-stat-item {
        text-align: center;
        padding: 14px;
        background: var(--surface-2);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
      }
      .win-stat-val {
        font-family: var(--ff-display);
        font-size: 26px;
        font-weight: 800;
        margin-bottom: 4px;
      }
      .win-stat-label {
        font-size: 11px;
        color: var(--text-muted);
      }
      .quick-band {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 40px;
      }
      .quick-tile {
        background: var(--surface-1);
        border: 1px solid var(--border-subtle);
        border-radius: 16px;
        padding: 18px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        cursor: pointer;
        transition: all 0.25s;
        text-decoration: none;
        color: inherit;
      }
      .quick-tile:hover {
        border-color: var(--border-accent);
        background: var(--surface-2);
        transform: translateY(-3px);
      }
      .quick-tile-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
      }
      .quick-tile-text {
        min-width: 0;
      }
      .quick-tile-top {
        font-size: 11px;
        color: var(--text-muted);
      }
      .quick-tile-bottom {
        font-size: 14px;
        font-weight: 600;
        white-space: nowrap;
      }
      .mobile-toggle {
        display: none;
        position: fixed;
        top: 20px;
        left: 20px;
        width: 46px;
        height: 46px;
        border-radius: 13px;
        background: var(--surface-2);
        border: 1px solid var(--border-mid);
        color: var(--text-primary);
        align-items: center;
        justify-content: center;
        font-size: 20px;
        cursor: pointer;
        z-index: 100;
        transition: all 0.2s;
      }
      .mobile-toggle:hover {
        border-color: var(--border-accent);
      }
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(4px);
        z-index: 49;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
      }
      @media (max-width: 1200px) {
        .auctions-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 1024px) {
        .sidebar {
          position: fixed;
          z-index: 50;
          transform: translateX(-100%);
        }
        .sidebar.open {
          transform: translateX(0);
        }
        .main {
          margin-left: 0;
          padding: 24px 18px 40px;
        }
        .mobile-toggle {
          display: flex;
        }
        .sidebar-overlay {
          display: block;
        }
        .sidebar-overlay.active {
          opacity: 1;
          pointer-events: all;
        }
        .stats-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .analytics-row {
          grid-template-columns: 1fr;
        }
        .bottom-row {
          grid-template-columns: 1fr;
        }
        .sidebar-close-btn {
          display: flex;
        }
      }
      @media (max-width: 768px) {
        .stats-grid {
          grid-template-columns: repeat(2, 1fr);
        }
        .page-title {
          font-size: 32px !important;
        }
        .page-header {
          flex-direction: column;
        }
        .header-actions {
          flex-wrap: wrap;
          width: 100%;
        }
        .analytics-row {
          grid-template-columns: 1fr;
        }
        .bottom-row {
          grid-template-columns: 1fr;
        }
      }
      @media (max-width: 640px) {
        .main {
          padding: 14px 12px 28px;
        }
        .auctions-grid {
          grid-template-columns: 1fr;
        }
        .stats-grid {
          grid-template-columns: 1fr;
        }
        .page-title {
          font-size: 28px !important;
        }
        .quick-band {
          grid-template-columns: repeat(2, 1fr);
        }
        .page-header {
          flex-direction: column;
          gap: 12px;
        }
        .header-actions {
          width: 100%;
          gap: 8px;
        }
        .header-actions .btn,
        .header-actions .icon-btn {
          flex: 1 1 auto;
          justify-content: center;
        }
        .section-header {
          flex-direction: column;
          align-items: flex-start;
          gap: 10px;
        }
        .section-action {
          width: 100%;
          justify-content: center;
          text-align: center;
        }
        .nav-link {
          gap: 10px;
          padding: 10px 12px;
          font-size: 13px;
          align-items: flex-start;
        }
        .nav-icon {
          width: 32px;
          height: 32px;
          font-size: 14px;
          margin-top: 1px;
        }
        .nav-chevron {
          display: none;
        }
        .nav-text {
          line-height: 1.25;
          white-space: normal;
        }
      }
      @media (max-width: 420px) {
        .quick-band {
          grid-template-columns: 1fr;
        }
        .page-title {
          font-size: 25px !important;
        }
        .wallet-card {
          padding: 12px;
        }
        .stat-card,
        .card {
          padding: 16px;
        }
      }
    </style>
  </head>
  <body>
