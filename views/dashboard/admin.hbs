              </div>
              <div
                id="system-logs"
                class="flex-1 overflow-y-auto max-h-72 space-y-1.5 font-mono"
              ></div>
            </div>
          </div>
        </div>
        <div id="tab-settings" class="tab-panel hidden">
          <div class="grid xl:grid-cols-3 gap-6">
            <div class="xl:col-span-2 glass border border-gray-800/40 rounded-2xl p-6">
              <div class="flex items-center justify-between mb-5">
                <h3 class="font-black font-display text-lg">Platform Settings</h3>
                <span class="text-xs px-2.5 py-1 rounded-full bg-orange-500/15 text-orange-300">Admin Controls</span>
              </div>
              <div class="space-y-5">
                <div class="grid md:grid-cols-2 gap-4">
                  <div>
                    <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Default Auction Duration</label>
                    <select id="setting-auction-duration" class="mt-2 w-full bg-gray-900/60 border border-gray-800 rounded-xl px-3 py-2.5 text-sm text-white focus:outline-none focus:border-orange-500/50">
                      <option value="1">1 Day</option>
                      <option value="3">3 Days</option>
                      <option value="5">5 Days</option>
                      <option value="7" selected>7 Days</option>
                      <option value="14">14 Days</option>
                    </select>
                  </div>
                  <div>
                    <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Min Verification Score</label>
                    <input id="setting-min-score" type="number" min="50" max="100" step="1" value="75" class="mt-2 w-full bg-gray-900/60 border border-gray-800 rounded-xl px-3 py-2.5 text-sm text-white focus:outline-none focus:border-orange-500/50" />
                  </div>
                </div>
                <div class="grid md:grid-cols-2 gap-4">
                  <div class="flex items-center justify-between p-3 rounded-xl bg-gray-900/50 border border-gray-800/50">
                    <div>
                      <p class="text-sm font-semibold">Auto Close Ended Auctions</p>
                      <p class="text-xs text-gray-500">Automatically close and archive ended listings</p>
                    </div>
                    <input id="setting-auto-close" type="checkbox" class="h-5 w-5 accent-orange-500" checked />
                  </div>
                  <div class="flex items-center justify-between p-3 rounded-xl bg-gray-900/50 border border-gray-800/50">
                    <div>
                      <p class="text-sm font-semibold">Require Buyer Verification</p>
                      <p class="text-xs text-gray-500">Only verified buyers can place bids above reserve</p>
                    </div>
                    <input id="setting-buyer-verification" type="checkbox" class="h-5 w-5 accent-orange-500" checked />
                  </div>
                  <div class="flex items-center justify-between p-3 rounded-xl bg-gray-900/50 border border-gray-800/50">
                    <div>
                      <p class="text-sm font-semibold">Enable Real-time Alerts</p>
                      <p class="text-xs text-gray-500">Push moderation and critical system alerts instantly</p>
                    </div>
                    <input id="setting-realtime-alerts" type="checkbox" class="h-5 w-5 accent-orange-500" checked />
                  </div>
                  <div class="flex items-center justify-between p-3 rounded-xl bg-gray-900/50 border border-gray-800/50">
                    <div>
                      <p class="text-sm font-semibold">Maintenance Mode</p>
                      <p class="text-xs text-gray-500">Temporarily disable buyer actions and bidding</p>
                    </div>
                    <input id="setting-maintenance-mode" type="checkbox" class="h-5 w-5 accent-red-500" />
                  </div>
                </div>
                <div>
                  <label class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Admin Note</label>
                  <textarea id="setting-admin-note" rows="4" class="mt-2 w-full bg-gray-900/60 border border-gray-800 rounded-xl px-3 py-2.5 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-orange-500/50" placeholder="Write a short operational note visible to admin team..."></textarea>
                </div>
                <div class="flex flex-wrap items-center gap-3">
                  <button id="settings-save-btn" class="px-4 py-2 rounded-xl bg-gradient-to-r from-orange-500 to-red-600 text-sm font-semibold hover:shadow-lg hover:shadow-orange-500/30 transition-all">
                    <i class="bi bi-save mr-1"></i>Save Settings
                  </button>
                  <button id="settings-reset-btn" class="px-4 py-2 rounded-xl border border-gray-700 text-sm font-semibold text-gray-300 hover:bg-gray-800/40 transition-all">
                    <i class="bi bi-arrow-counterclockwise mr-1"></i>Reset Defaults
                  </button>
                  <span id="settings-last-saved" class="text-xs text-gray-500"></span>
                </div>
              </div>
            </div>
            <div class="glass border border-gray-800/40 rounded-2xl p-6">
              <h3 class="font-black font-display mb-4">Security Quick Actions</h3>
              <div class="space-y-3">
                <button id="security-action-revoke" class="w-full text-left p-3 rounded-xl bg-gray-900/50 border border-gray-800 hover:border-orange-500/40 transition-all">
                  <p class="text-sm font-semibold">Revoke All Active Sessions</p>
                  <p class="text-xs text-gray-500">Force sign-out and require re-login</p>
                </button>
                <button id="security-action-password" class="w-full text-left p-3 rounded-xl bg-gray-900/50 border border-gray-800 hover:border-amber-500/40 transition-all">
                  <p class="text-sm font-semibold">Enforce Strong Password Policy</p>
                  <p class="text-xs text-gray-500">Require uppercase, number and symbols</p>
                </button>
                <button id="security-action-export" class="w-full text-left p-3 rounded-xl bg-gray-900/50 border border-gray-800 hover:border-orange-500/40 transition-all">
                  <p class="text-sm font-semibold">Export Security Audit Logs</p>
                  <p class="text-xs text-gray-500">Generate and download compliance logs</p>
                </button>
                <button id="security-action-emergency" class="w-full text-left p-3 rounded-xl bg-red-500/10 border border-red-500/30 hover:bg-red-500/15 transition-all">
                  <p class="text-sm font-semibold text-red-300">Emergency Platform Lock</p>
                  <p class="text-xs text-red-200/80">Temporarily block bidding and payments</p>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
    <script src="/js/admin-dashboard.js"></script>
    <script src="/js/app-theme.js"></script>
    <script src="/js/dashboard-stats.js"></script>
    <script src="/js/dashboard-notifications.js"></script>
    <script src="/js/admin-user-management.js"></script>
    <script src="/js/admin-operations.js"></script>
  </body>
</html>
