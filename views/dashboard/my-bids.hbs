<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Bids - ChuuAuction</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
      tailwind.config = { darkMode: 'class', theme: { extend: { fontFamily: {
      'display': ['Bricolage Grotesque', 'system-ui', 'sans-serif'], 'body':
      ['Outfit', 'system-ui', 'sans-serif'], } } } }
    </script>

    <style>
      :root {
        --orange-core: #f97316;
        --orange-bright: #fb923c;
        --orange-dim: #ea580c;
        --red-core: #dc2626;
        --green-core: #22c55e;
        --surface-0: #050608;
        --surface-1: #0d0f12;
        --surface-2: #141720;
        --surface-3: #1c2030;
        --border-subtle: rgba(255, 255, 255, 0.04);
        --border-mid: rgba(255, 255, 255, 0.08);
        --border-accent: rgba(249, 115, 22, 0.25);
        --text-primary: #f1f2f5;
        --text-secondary: #8892a4;
        --text-muted: #4d5566;
      }

      body {
        font-family: "Outfit", system-ui, sans-serif;
        background: var(--surface-0);
        color: var(--text-primary);
      }

      .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .glass-strong {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .text-gradient {
        background: linear-gradient(135deg, #f97316, #dc2626);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      .status-pending {
        background: rgba(234, 179, 8, 0.15);
        color: #facc15;
        border-color: rgba(234, 179, 8, 0.3);
      }
      .status-accepted {
        background: rgba(34, 197, 94, 0.15);
        color: #4ade80;
        border-color: rgba(34, 197, 94, 0.3);
      }
      .status-rejected {
        background: rgba(239, 68, 68, 0.15);
        color: #f87171;
        border-color: rgba(239, 68, 68, 0.3);
      }

      .bid-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
      }

      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--surface-1);
      }
      ::-webkit-scrollbar-thumb {
        background: linear-gradient(
          180deg,
          var(--orange-core),
          var(--red-core)
        );
        border-radius: 4px;
      }

      .search-input:focus {
        outline: none;
        border-color: var(--orange-core);
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.2);
      }

      .filter-btn.active {
        background: var(--orange-core);
        color: white;
        border-color: var(--orange-core);
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-950 text-white">

    <!-- Navigation -->
    <nav class="glass border-b border-gray-800 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-4">
            <a href="/" class="flex items-center gap-2">
              <div
                class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center font-bold"
              >C</div>
              <span class="font-display font-bold text-xl">ChuuAuction</span>
            </a>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm text-gray-400">Welcome,
              <span
                class="text-orange-400 font-semibold"
              >{{user.name}}</span></span>
            <a
              href="/auth/logout"
              class="px-4 py-2 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400 hover:bg-red-500/20 transition"
            >
              <i class="bi bi-box-arrow-left mr-2"></i>Logout
            </a>
          </div>
        </div>
      </div>
    </nav>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

      <!-- Header -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-4xl font-black font-display">
            <span class="text-gradient">My Bids</span>
          </h1>
        </div>
        <p class="text-gray-400 ml-14">View all your bids and their status
          across all auctions</p>
      </div>

      <!-- Search and Filters -->
      <div class="glass-strong border border-gray-800 rounded-2xl p-6 mb-8">
        <!-- Search Bar -->
        <div class="relative mb-4">
          <div
            class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
          >
            <i class="bi bi-search text-gray-400"></i>
          </div>
          <input
            type="text"
            id="search-input"
            class="search-input w-full pl-12 pr-4 py-3 bg-gray-900/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:border-orange-500 transition"
            placeholder="Search by animal type, breed, location..."
          />
          <button
            id="clear-search"
            class="absolute inset-y-0 right-0 pr-4 text-gray-500 hover:text-white hidden"
          >
            <i class="bi bi-x-lg"></i>
          </button>
        </div>

        <!-- Filter Row -->
        <div class="flex flex-wrap items-center gap-4">
          <!-- Status Filter -->
          <div class="flex items-center gap-2">
            <span class="text-sm text-gray-400"><i
                class="bi bi-filter mr-1"
              ></i>Status:</span>
            <div class="flex flex-wrap gap-2">
              <button
                class="filter-btn px-4 py-2 rounded-lg border border-gray-700 text-sm hover:border-orange-500 transition active"
                data-filter="status"
                data-value="all"
              >
                All
              </button>
              <button
                class="filter-btn px-4 py-2 rounded-lg border border-gray-700 text-sm hover:border-orange-500 transition"
                data-filter="status"
                data-value="pending"
              >
                <i class="bi bi-hourglass-split mr-1"></i>Pending
              </button>
              <button
                class="filter-btn px-4 py-2 rounded-lg border border-gray-700 text-sm hover:border-orange-500 transition"
                data-filter="status"
                data-value="accepted"
              >
                <i class="bi bi-trophy-fill mr-1"></i>Accepted
              </button>
              <button
                class="filter-btn px-4 py-2 rounded-lg border border-gray-700 text-sm hover:border-orange-500 transition"
                data-filter="status"
                data-value="rejected"
              >
                <i class="bi bi-x-circle-fill mr-1"></i>Rejected
              </button>
            </div>
          </div>

          <!-- Animal Type Filter -->
          <div class="flex items-center gap-2">
            <span class="text-sm text-gray-400"><i
                class="bi bi-grid mr-1"
              ></i>Type:</span>
            <select
              id="animal-type-filter"
              class="px-4 py-2 bg-gray-900/50 border border-gray-700 rounded-lg text-sm text-white focus:border-orange-500 transition"
            >
              <option value="all">All Types</option>
              <option value="cattle">Cattle</option>
              <option value="goat">Goat</option>
              <option value="sheep">Sheep</option>
              <option value="pig">Pig</option>
              <option value="chicken">Chicken</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Sort -->
          <div class="flex items-center gap-2">
            <span class="text-sm text-gray-400"><i
                class="bi bi-sort-down mr-1"
              ></i>Sort:</span>
            <select
              id="sort-filter"
              class="px-4 py-2 bg-gray-900/50 border border-gray-700 rounded-lg text-sm text-white focus:border-orange-500 transition"
            >
              <option value="newest">Newest First</option>
              <option value="oldest">Oldest First</option>
              <option value="highest">Highest Bid</option>
              <option value="lowest">Lowest Bid</option>
            </select>
          </div>

          <!-- Results Count -->
          <div class="ml-auto text-sm text-gray-400">
            <span id="results-count">0</span>
            results found
          </div>
        </div>

        <!-- Advanced Search Tags -->
        <div class="mt-4 pt-4 border-t border-gray-800">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-sm text-gray-400"><i
                class="bi bi-tags mr-1"
              ></i>Quick filters:</span>
            <button
              class="quick-filter px-3 py-1 rounded-full bg-gray-800 border border-gray-700 text-xs hover:border-orange-500 transition"
              data-field="hasNotes"
              data-value="true"
            >
              <i class="bi bi-chat-quote mr-1"></i>Has Notes
            </button>
            <button
              class="quick-filter px-3 py-1 rounded-full bg-gray-800 border border-gray-700 text-xs hover:border-orange-500 transition"
              data-field="hasPhotos"
              data-value="true"
            >
              <i class="bi bi-image mr-1"></i>Has Photos
            </button>
            <button
              class="quick-filter px-3 py-1 rounded-full bg-gray-800 border border-gray-700 text-xs hover:border-orange-500 transition"
              data-field="minAmount"
              data-value="100000"
            >
              <i class="bi bi-cash mr-1"></i>Over 100K
            </button>
            <button
              class="quick-filter px-3 py-1 rounded-full bg-gray-800 border border-gray-700 text-xs hover:border-orange-500 transition"
              data-field="maxAmount"
              data-value="100000"
            >
              <i class="bi bi-cash-stack mr-1"></i>Under 100K
            </button>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-yellow-500/20 flex items-center justify-center"
            >
              <i class="bi bi-hourglass-split text-yellow-500"></i>
            </div>
            <span class="text-gray-400 text-sm">Pending</span>
          </div>
          <p class="text-3xl font-black" id="stat-pending">0</p>
        </div>
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center"
            >
              <i class="bi bi-trophy-fill text-green-500"></i>
            </div>
            <span class="text-gray-400 text-sm">Accepted</span>
          </div>
          <p class="text-3xl font-black text-green-500" id="stat-accepted">0</p>
        </div>
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-red-500/20 flex items-center justify-center"
            >
              <i class="bi bi-x-circle-fill text-red-500"></i>
            </div>
            <span class="text-gray-400 text-sm">Rejected</span>
          </div>
          <p class="text-3xl font-black text-red-500" id="stat-rejected">0</p>
        </div>
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-orange-500/20 flex items-center justify-center"
            >
              <i class="bi bi-cash-stack text-orange-500"></i>
            </div>
            <span class="text-gray-400 text-sm">Total Bids</span>
          </div>
          <p class="text-3xl font-black text-orange-500" id="stat-total">0</p>
        </div>
      </div>

      <!-- Loading State -->
      <div id="loading" class="text-center py-12">
        <div
          class="w-16 h-16 rounded-full border-4 border-orange-500/30 border-t-orange-500 animate-spin mx-auto mb-4"
        ></div>
        <p class="text-gray-400">Loading your bids...</p>
      </div>

      <!-- No Bids State -->
      <div
        id="no-bids"
        class="hidden text-center py-12 glass-strong border border-gray-800 rounded-2xl"
      >
        <div
          class="w-20 h-20 rounded-full bg-gray-800/50 flex items-center justify-center mx-auto mb-4"
        >
          <i class="bi bi-inbox text-4xl text-gray-600"></i>
        </div>
        <h3 class="text-xl font-bold mb-2">No Bids Yet</h3>
        <p class="text-gray-400 mb-6">You haven't placed any bids yet. Start
          bidding on auctions!</p>
        <a
          href="/auctions/animalList"
          class="px-6 py-3 rounded-xl bg-gradient-to-r from-orange-500 to-red-600 font-semibold hover:shadow-lg hover:shadow-orange-500/30 transition"
        >
          <i class="bi bi-search mr-2"></i>Browse Auctions
        </a>
      </div>

      <!-- No Results State -->
      <div
        id="no-results"
        class="hidden text-center py-12 glass-strong border border-gray-800 rounded-2xl"
      >
        <div
          class="w-20 h-20 rounded-full bg-gray-800/50 flex items-center justify-center mx-auto mb-4"
        >
          <i class="bi bi-search text-4xl text-gray-600"></i>
        </div>
        <h3 class="text-xl font-bold mb-2">No Results Found</h3>
        <p class="text-gray-400 mb-6">Try adjusting your search or filters</p>
        <button
          id="clear-filters"
          class="px-6 py-3 rounded-xl bg-gray-800 border border-gray-700 font-semibold hover:border-orange-500 transition"
        >
          <i class="bi bi-x-circle mr-2"></i>Clear All Filters
        </button>
      </div>

      <!-- Bids List - with userId data attribute -->
      <div
        id="bids-container"
        data-user-id="{{userId}}"
        class="space-y-6 hidden"
      >
        <!-- Bids will be dynamically inserted here -->
      </div>

    </div>

    <!-- External JavaScript file -->
    <script src="/js/my-bids.js"></script>
  </body>
</html>