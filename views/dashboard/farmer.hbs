  }
  .stat-card {
    position: relative;
    overflow: hidden;
  }
  .stat-card::after {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    bottom: -50%;
    left: -50%;
    background: linear-gradient(
      45deg,
      transparent,
      rgba(249, 115, 22, 0.1),
      transparent
    );
    transform: rotate(45deg) translateY(-100%);
    transition: transform 0.6s;
  }
  .stat-card:hover::after {
    transform: rotate(45deg) translateY(100%);
  }
