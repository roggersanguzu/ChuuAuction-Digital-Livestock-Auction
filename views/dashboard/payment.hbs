<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Winner Payment - ChuuAuction</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      *,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --bg: #07101c;
        --bg-soft: #0d1726;
        --surface: rgba(255,255,255,0.05);
        --surface-strong: rgba(255,255,255,0.08);
        --border: rgba(255,255,255,0.11);
        --text: #edf3fb;
        --muted: #92a5bc;
        --green: #22c55e;
        --green-deep: #15803d;
        --red: #fb7185;
        --amber: #fbbf24;
      }
      body {
        min-height: 100vh;
        font-family: "DM Sans", system-ui, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(34,197,94,0.14), transparent 30%),
          radial-gradient(circle at top right, rgba(96,165,250,0.12), transparent 28%),
          linear-gradient(180deg, #050912 0%, var(--bg) 55%, #091321 100%);
        padding: 1rem;
      }
      .shell { max-width: 1040px; margin: 0 auto; }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
        padding: 1rem 1.2rem;
        border: 1px solid var(--border);
        border-radius: 18px;
        background: rgba(6, 11, 20, 0.72);
        backdrop-filter: blur(16px);
      }
      .brand {
        font-family: "Syne", sans-serif;
        font-weight: 800;
        letter-spacing: 0.02em;
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }
      .brand-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--green);
        box-shadow: 0 0 16px rgba(34,197,94,0.6);
      }
      .back-link {
        text-decoration: none;
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.7rem 1rem;
        font-size: 0.82rem;
        font-weight: 700;
      }
      .flash-stack { display: grid; gap: 0.75rem; margin-bottom: 1rem; }
      .flash {
        padding: 0.95rem 1rem;
        border-radius: 16px;
        border: 1px solid transparent;
        font-size: 0.92rem;
      }
      .flash.error { background: rgba(251,113,133,0.1); border-color: rgba(251,113,133,0.24); color: #fecdd3; }
      .flash.success { background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.24); color: #bbf7d0; }
      .hero {
        border: 1px solid var(--border);
        border-radius: 28px 28px 0 0;
        padding: 2rem;
        background: linear-gradient(135deg, rgba(34,197,94,0.12), rgba(96,165,250,0.08));
      }
      .eyebrow {
        font-family: "DM Mono", monospace;
        color: #86efac;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-size: 0.68rem;
        margin-bottom: 0.8rem;
      }
      .hero h1 {
        font-family: "Syne", sans-serif;
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        line-height: 1.05;
        margin-bottom: 0.75rem;
      }
      .hero p {
        max-width: 54ch;
        color: var(--muted);
        line-height: 1.7;
      }
      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.15rem;
      }
      .chip, .ref-tag {
        border-radius: 999px;
        padding: 0.45rem 0.85rem;
        border: 1px solid var(--border);
        font-size: 0.76rem;
      }
      .chip.pending { color: var(--amber); background: rgba(251,191,36,0.11); }
      .chip.complete { color: #4ade80; background: rgba(34,197,94,0.11); }
      .chip.failed { color: #fda4af; background: rgba(251,113,133,0.11); }
      .ref-tag {
        font-family: "DM Mono", monospace;
        color: var(--muted);
        overflow-wrap: anywhere;
      }
      .panel {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 1.25rem;
        border: 1px solid var(--border);
        border-top: 0;
        border-radius: 0 0 28px 28px;
        background: var(--bg-soft);
        padding: 1.35rem;
      }
      .card {
        border: 1px solid var(--border);
        border-radius: 20px;
        background: var(--surface);
        padding: 1.15rem;
      }
      .amount-card {
        margin-bottom: 1rem;
        background: linear-gradient(135deg, rgba(34,197,94,0.12), rgba(96,165,250,0.07));
      }
      .label {
        font-family: "DM Mono", monospace;
        color: #86efac;
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-bottom: 0.55rem;
      }
      .amount-line {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.55rem;
      }
      .currency {
        font-family: "Syne", sans-serif;
        color: #86efac;
        font-size: 0.96rem;
        font-weight: 700;
      }
      .amount {
        font-family: "Syne", sans-serif;
        font-size: clamp(2rem, 5vw, 3.2rem);
        line-height: 1;
        overflow-wrap: anywhere;
      }
      .subtle { color: var(--muted); font-size: 0.9rem; margin-top: 0.55rem; }
      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.85rem;
        margin-bottom: 1rem;
      }
      .field-card .field-label {
        font-family: "DM Mono", monospace;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.63rem;
        margin-bottom: 0.4rem;
      }
      .field-card .field-value {
        font-size: 0.96rem;
        font-weight: 700;
        overflow-wrap: anywhere;
      }
      .section-title {
        font-family: "Syne", sans-serif;
        font-size: 1rem;
        margin-bottom: 0.9rem;
      }
      .input-wrap { position: relative; }
      .prefix {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #86efac;
        font-family: "DM Mono", monospace;
        font-size: 0.82rem;
      }
      .amount-input {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: rgba(0,0,0,0.28);
        color: white;
        font-size: 1.08rem;
        font-weight: 700;
        padding: 0.95rem 1rem 0.95rem 4rem;
      }
      .amount-help { margin-top: 0.6rem; font-size: 0.82rem; color: var(--muted); }
      .steps { display: grid; gap: 0.9rem; }
      .step {
        display: grid;
        grid-template-columns: 32px minmax(0, 1fr);
        gap: 0.8rem;
        align-items: start;
      }
      .step-num {
        width: 32px;
        height: 32px;
        border-radius: 999px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--green), var(--green-deep));
        font-family: "DM Mono", monospace;
        font-size: 0.76rem;
      }
      .step-name { font-weight: 800; margin-bottom: 0.15rem; }
      .step-text { color: var(--muted); font-size: 0.86rem; line-height: 1.6; }
      .cta {
        width: 100%;
        margin-top: 1rem;
        border: 0;
        border-radius: 16px;
        padding: 1rem 1.15rem;
        background: linear-gradient(135deg, var(--green), var(--green-deep));
        color: white;
        font-family: "Syne", sans-serif;
        font-size: 0.9rem;
        font-weight: 800;
        letter-spacing: 0.05em;
        cursor: pointer;
        box-shadow: 0 14px 30px rgba(21,128,61,0.3);
      }
      .cta:disabled { opacity: 0.65; cursor: not-allowed; }
      .checkout-msg {
        margin-top: 0.85rem;
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 0.9rem 0.95rem;
        color: var(--muted);
        font-size: 0.85rem;
        line-height: 1.6;
      }
      .status-value {
        font-family: "Syne", sans-serif;
        font-size: 1.5rem;
        margin-bottom: 0.45rem;
        text-transform: capitalize;
      }
      .status-meta {
        font-family: "DM Mono", monospace;
        font-size: 0.7rem;
        color: var(--muted);
        line-height: 1.8;
        overflow-wrap: anywhere;
      }
      .security {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem 1.2rem;
        margin-top: 1rem;
        color: var(--muted);
        font-size: 0.8rem;
      }
      .hidden-field { display: none; }
      .spin { display: inline-block; animation: spin 0.9s linear infinite; }
      @keyframes spin { to { transform: rotate(360deg); } }
      @media (max-width: 860px) {
        .panel { grid-template-columns: 1fr; }
      }
      @media (max-width: 640px) {
        body { padding: 0.7rem; }
        .topbar { flex-wrap: wrap; }
        .back-link { width: 100%; text-align: center; }
        .hero { padding: 1.3rem; }
        .panel { padding: 0.95rem; }
        .grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <div class="topbar">
        <div class="brand"><span class="brand-dot"></span>ChuuAuction</div>
        <a href="/dashboard/my-bids" class="back-link">Back to My Bids</a>
      </div>

      {{#if error_msg}}
        <div class="flash-stack">
          {{#each error_msg}}
            <div class="flash error">{{this}}</div>
          {{/each}}
        </div>
      {{/if}}
      {{#if success_msg}}
        <div class="flash-stack">
          {{#each success_msg}}
            <div class="flash success">{{this}}</div>
          {{/each}}
        </div>
      {{/if}}

      <div class="hero">
        <div class="eyebrow">Winner Checkout</div>
        <h1>Proceed to payment for your winning bid</h1>
        <p>Confirm the amount below, review your livestock details, then launch the IntaSend hosted checkout. This keeps bidding separate from payment while giving you clear status updates.</p>
        <div class="meta">
          <div id="status-badge" class="chip pending">{{transactionStatus}}</div>
          <div class="ref-tag">REF: {{transactionApiRef}}</div>
        </div>
      </div>

      <div class="panel">
        <div>
          <div class="card amount-card">
            <div class="label">Winning Amount</div>
            <div class="amount-line">
              <span class="currency">{{displayCurrency}}</span>
              <span class="amount">{{amount}}</span>
            </div>
            <div class="subtle">Gateway charge currency: {{paymentCurrency}}</div>
          </div>

          <div class="grid">
            <div class="card field-card">
              <div class="field-label">Animal</div>
              <div class="field-value">{{animalType}}{{#if breed}} - {{breed}}{{/if}}</div>
            </div>
            <div class="card field-card">
              <div class="field-label">Seller</div>
              <div class="field-value">{{sellerName}}</div>
            </div>
            <div class="card field-card">
              <div class="field-label">Location</div>
              <div class="field-value">{{auctionLocation}}</div>
            </div>
            <div class="card field-card">
              <div class="field-label">Buyer</div>
              <div class="field-value">{{buyerName}}</div>
            </div>
          </div>

          {{#if providerConfigured}}
            <div class="card">
              <div class="section-title">IntaSend Checkout</div>
              <div class="input-wrap">
                <span class="prefix">{{paymentCurrency}}</span>
                <input
                  id="amount-input"
                  class="amount-input"
                  type="number"
                  min="{{minimumAmount}}"
                  step="1"
                  value="{{amount}}"
                  inputmode="numeric"
                />
              </div>
              <div id="amount-help" class="amount-help">Amount confirmed for IntaSend checkout.</div>

              <div class="grid" style="margin-top: 0.9rem; margin-bottom: 0;">
                <div class="card field-card">
                  <div class="field-label">Buyer Email</div>
                  <div class="field-value">{{buyerEmail}}</div>
                </div>
                <div class="card field-card">
                  <div class="field-label">Buyer Phone</div>
                  <div class="field-value">{{buyerPhone}}</div>
                </div>
              </div>
            </div>
          {{/if}}
        </div>

        <div>
          {{#if providerConfigured}}
            <form id="checkout-form" class="card" action="/dashboard/payment/checkout" method="POST">
              <input type="hidden" name="bidId" value="{{bidId}}" />
              <input id="amount-hidden" type="hidden" name="amount" value="{{amount}}" />

              <div class="section-title">How It Works</div>
              <div class="steps">
                <div class="step">
                  <div class="step-num">1</div>
                  <div>
                    <div class="step-name">Confirm Amount</div>
                    <div class="step-text">Check the amount you want to send through IntaSend checkout.</div>
                  </div>
                </div>
                <div class="step">
                  <div class="step-num">2</div>
                  <div>
                    <div class="step-name">Create Checkout</div>
                    <div class="step-text">The app asks IntaSend for a hosted checkout link and opens it for you.</div>
                  </div>
                </div>
                <div class="step">
                  <div class="step-num">3</div>
                  <div>
                    <div class="step-name">Track Status</div>
                    <div class="step-text">This page keeps syncing the payment result from the server.</div>
                  </div>
                </div>
              </div>

              <button id="proceed-btn" type="submit" class="cta">Proceed to Secure Payment</button>
              <div id="checkout-message" class="checkout-msg">Checkout ready, click <strong style="color:white">Proceed to Secure Payment</strong> to continue.</div>
            </form>
          {{else}}
            <div class="card">
              <div class="section-title">Sandbox keys missing</div>
              <div class="step-text">Add your IntaSend keys to the server environment, restart the app, and reload this page.</div>
            </div>
          {{/if}}

          <div class="card" style="margin-top: 1rem;">
            <div class="section-title">Live Payment Status</div>
            <div id="status-text" class="status-value">{{transactionStatus}}</div>
            <div id="status-meta" class="status-meta">
              API Ref: {{transactionApiRef}}<br />
              {{#if transactionInvoiceId}}Invoice: {{transactionInvoiceId}}{{/if}}
            </div>
          </div>
        </div>
      </div>

      <div class="security">
        <div>SSL Encrypted</div>
        <div>Secure Checkout</div>
        <div>IntaSend Powered</div>
        <div>Sandbox Mode</div>
      </div>
    </div>

    <script>
      (function () {
        var bidId = "{{bidId}}";
        var providerConfigured = {{#if providerConfigured}}true{{else}}false{{/if}};
        var minimumAmount = Number("{{minimumAmount}}") || 0;
        var statusBadge = document.getElementById("status-badge");
        var statusText = document.getElementById("status-text");
        var statusMeta = document.getElementById("status-meta");
        var proceedBtn = document.getElementById("proceed-btn");
        var checkoutForm = document.getElementById("checkout-form");
        var amountHidden = document.getElementById("amount-hidden");
        var amountInput = document.getElementById("amount-input");
        var amountHelp = document.getElementById("amount-help");
        var checkoutMsg = document.getElementById("checkout-message");
        var defaultButtonMarkup = proceedBtn ? proceedBtn.innerHTML : "";

        function setStatus(status, meta) {
          var normalized = String(status || "pending").toLowerCase();
          if (statusText) statusText.textContent = normalized;
          if (statusBadge) {
            statusBadge.textContent = normalized;
            statusBadge.className = "chip " + (normalized === "complete" ? "complete" : normalized === "failed" || normalized === "cancelled" ? "failed" : "pending");
          }
          if (statusMeta && meta) statusMeta.innerHTML = meta.replace(/\|/g, "<br>");
        }

        function setMsg(html, isError) {
          if (!checkoutMsg) return;
          checkoutMsg.innerHTML = html;
          checkoutMsg.style.borderColor = isError ? "rgba(251,113,133,0.24)" : "rgba(255,255,255,0.11)";
          checkoutMsg.style.color = isError ? "#fecdd3" : "#92a5bc";
        }

        function getAmount() {
          return Number(amountInput && amountInput.value ? amountInput.value : minimumAmount);
        }

        function validateAmount() {
          var amount = getAmount();
          if (!amountInput || !amountHelp) return true;
          if (!Number.isFinite(amount) || amount <= 0) {
            amountHelp.textContent = "Enter a valid payment amount.";
            amountHelp.style.color = "#fecdd3";
            return false;
          }
          if (amount < minimumAmount) {
            amountHelp.textContent = "Amount cannot be lower than the winning bid.";
            amountHelp.style.color = "#fecdd3";
            return false;
          }
          amountHelp.textContent = "Amount confirmed for IntaSend checkout.";
          amountHelp.style.color = "#86efac";
          return true;
        }

        async function postJson(url, body) {
          var response = await fetch(url, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-Requested-With": "XMLHttpRequest"
            },
            credentials: "same-origin",
            body: JSON.stringify(body || {})
          });
          var payload = await response.json().catch(function () { return {}; });
          if (!response.ok || payload.success === false) {
            throw new Error(payload.message || "Unable to create checkout session");
          }
          return payload;
        }

        async function refreshStatus() {
          if (!bidId) return;
          try {
            var response = await fetch("/api/payments/" + encodeURIComponent(bidId) + "/status", {
              credentials: "same-origin"
            });
            var payload = await response.json().catch(function () { return {}; });
            if (!response.ok || !payload.success || !payload.data) return;
            var meta = "API Ref: " + (payload.data.apiRef || "-");
            if (payload.data.invoiceId) meta += " | Invoice: " + payload.data.invoiceId;
            if (payload.data.failedReason) meta += " | Reason: " + payload.data.failedReason;
            setStatus(payload.data.status || "pending", meta);
          } catch (error) {
          }
        }

        if (amountInput) {
          amountInput.addEventListener("input", function () {
            validateAmount();
            setMsg('Checkout ready, click <strong style="color:white">Proceed to Secure Payment</strong> to continue.', false);
          });
          validateAmount();
        }

        if (providerConfigured && checkoutForm && proceedBtn) {
          checkoutForm.addEventListener("submit", async function (event) {
            event.preventDefault();

            if (!validateAmount()) {
              setMsg("Enter a valid amount before proceeding.", true);
              return;
            }

            var amount = getAmount();
            if (amountHidden) amountHidden.value = String(amount);

            proceedBtn.disabled = true;
            proceedBtn.innerHTML = '<span class="spin">O</span> Creating checkout...';
            setMsg("Creating IntaSend checkout session...", false);

            try {
              var result = await postJson("/api/payments/checkout-session", {
                bidId: bidId,
                amount: amount
              });
              var checkoutUrl = result && result.data ? result.data.checkoutUrl : "";
              if (!checkoutUrl) {
                throw new Error("IntaSend checkout link was not returned");
              }
              setMsg("Redirecting you to IntaSend sandbox...", false);
              window.location.assign(checkoutUrl);
            } catch (error) {
              setStatus("failed", error.message || "Unable to initialize checkout");
              setMsg(error.message || "Unable to launch payment.", true);
              proceedBtn.disabled = false;
              proceedBtn.innerHTML = defaultButtonMarkup;
            }
          });

          window.setInterval(refreshStatus, 6000);
        }

        refreshStatus();
      })();
    </script>
  </body>
</html>
