<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Auction Bids - ChuuAuction</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="/vendor/bootstrap-icons/css/bootstrap-icons.css"
    />
    <link href="/css/app-theme.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = { darkMode: 'class', theme: { extend: { fontFamily: {
      'display': ['Bricolage Grotesque', 'system-ui', 'sans-serif'], 'body':
      ['Outfit', 'system-ui', 'sans-serif'], } } } }
    </script>
    <style>
      :root {
        --orange-core: #f97316;
        --orange-bright: #fb923c;
        --orange-dim: #ea580c;
        --red-core: #dc2626;
        --green-core: #f59e0b;
        --surface-0: #050608;
        --surface-1: #0d0f12;
        --surface-2: #141720;
        --surface-3: #1c2030;
        --border-subtle: rgba(255, 255, 255, 0.04);
        --border-mid: rgba(255, 255, 255, 0.08);
        --border-accent: rgba(249, 115, 22, 0.25);
        --text-primary: #f1f2f5;
        --text-secondary: #8892a4;
        --text-muted: #4d5566;
      }
      body {
        font-family: "Outfit", system-ui, sans-serif;
        background: var(--surface-0);
        color: var(--text-primary);
      }
      .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }
      .glass-strong {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .text-gradient {
        background: linear-gradient(135deg, #f97316, #dc2626);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .status-pending {
        background: rgba(234, 179, 8, 0.15);
        color: #facc15;
        border-color: rgba(234, 179, 8, 0.3);
      }
      .status-accepted {
        background: rgba(245, 158, 11, 0.15);
        color: #fbbf24;
        border-color: rgba(245, 158, 11, 0.3);
      }
      .status-rejected {
        background: rgba(239, 68, 68, 0.15);
        color: #f87171;
        border-color: rgba(239, 68, 68, 0.3);
      }
      .winner-card {
        animation: winnerGlow 2s ease-in-out infinite;
      }
      @keyframes winnerGlow {
        0%,
        100% {
          box-shadow: 0 0 20px rgba(245, 158, 11, 0.3);
        }
        50% {
          box-shadow:
            0 0 40px rgba(245, 158, 11, 0.6),
            0 0 60px rgba(245, 158, 11, 0.3);
        }
      }
      .bid-card:hover {
        transform: translateY(-2px);
      }
      .auction-group,
      .bid-card {
        overflow: hidden;
      }
      .auction-group,
      .auction-group * {
        word-wrap: break-word;
      }
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--surface-1);
      }
      ::-webkit-scrollbar-thumb {
        background: linear-gradient(
          180deg,
          var(--orange-core),
          var(--red-core)
        );
        border-radius: 4px;
      }
      .filter-btn.active {
        background: var(--orange-core);
        color: white;
        border-color: var(--orange-core);
      }
      @media (max-width: 768px) {
        nav .h-16 {
          height: auto;
          padding: 10px 0;
        }
        nav .h-16 > .flex.items-center.justify-between {
          flex-direction: column;
          align-items: flex-start;
          gap: 8px;
        }
        #auction-bids-page {
          padding-top: 18px;
        }
      }
      @media (max-width: 420px) {
        #auction-bids-page h1 {
          font-size: 1.75rem !important;
          line-height: 1.1;
        }
        #auction-bids-page .ml-14 {
          margin-left: 0 !important;
        }
        #auction-bids-page {
          padding-left: 12px !important;
          padding-right: 12px !important;
        }
        #auction-bids-page .glass-strong,
        #auction-bids-page .glass {
          border-radius: 14px !important;
        }
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-950 text-white">
    <nav class="glass border-b border-gray-800 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-4">
            <a href="/" class="flex items-center gap-2">
              <div
                class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center font-bold"
              >C</div>
              <span class="font-display font-bold text-xl">ChuuAuction</span>
            </a>
          </div>
          <div class="flex items-center gap-4">
            <span class="text-sm text-gray-400">Welcome,
              <span
                class="text-orange-400 font-semibold"
              >{{user.name}}</span></span>
            <form action="/auth/logout" method="POST">
              <button
                type="submit"
                class="px-4 py-2 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400 hover:bg-red-500/20 transition"
              >
                <i class="bi bi-box-arrow-left mr-2"></i>Logout
              </button>
            </form>
          </div>
        </div>
      </div>
    </nav>
    <div
      id="auction-bids-page"
      data-user-id="{{userId}}"
      data-is-admin="{{isAdmin}}"
      data-can-manage-bids="{{canManageBids}}"
      data-auction-id="{{auctionId}}"
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
    >
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
          <a
            href="{{dashboardHome}}"
            class="w-10 h-10 rounded-xl glass border border-gray-800 hover:border-orange-500 flex items-center justify-center transition"
          >
            <i class="bi bi-arrow-left text-orange-500"></i>
          </a>
          <h1 class="text-4xl font-black font-display"><span
              class="text-gradient"
            >Manage Auction Bids</span></h1>
        </div>
        <p class="text-gray-400 ml-14">
          {{#if isAdmin}}View and manage all bids across all auctions in the
            system.{{else}}{{#if canManageBids}}View and manage bids on your
              auctions. Only you can declare winners.{{else}}Track bids you have
              placed across auctions. This view is read-only.{{/if}}{{/if}}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-8">
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-amber-500/20 flex items-center justify-center"
            ><i class="bi bi-collection text-amber-500"></i></div>
            <span class="text-gray-400 text-sm">Total Auctions</span>
          </div>
          <p class="text-3xl font-black" id="stat-auctions">0</p>
        </div>
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-yellow-500/20 flex items-center justify-center"
            ><i class="bi bi-stack text-yellow-500"></i></div>
            <span class="text-gray-400 text-sm">Total Bids</span>
          </div>
          <p class="text-3xl font-black text-yellow-500" id="stat-total">0</p>
        </div>
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center"
            ><i class="bi bi-trophy-fill text-green-500"></i></div>
            <span class="text-gray-400 text-sm">Winners</span>
          </div>
          <p class="text-3xl font-black text-green-500" id="stat-winners">0</p>
        </div>
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center"
            ><i class="bi bi-person-fill text-purple-500"></i></div>
            <span class="text-gray-400 text-sm">Top Bidder</span>
          </div>
          <p
            class="text-lg font-bold text-purple-400 truncate"
            id="stat-top-bidder"
          >-</p>
        </div>
        <div class="glass-strong border border-gray-800 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-2">
            <div
              class="w-10 h-10 rounded-xl bg-orange-500/20 flex items-center justify-center"
            ><i class="bi bi-currency-exchange text-orange-500"></i></div>
            <span class="text-gray-400 text-sm">Highest Bid</span>
          </div>
          <p
            class="text-3xl font-black text-orange-500"
            id="stat-highest-amount"
          >UGX 0</p>
        </div>
      </div>
      <div class="flex gap-2 mb-6 overflow-x-auto pb-2">
        <button
          onclick="filterBids('all')"
          class="filter-btn active px-4 py-2 rounded-xl border border-gray-700 font-semibold transition-all hover:bg-gray-800/50 whitespace-nowrap"
          data-filter="all"
        >
          <i class="bi bi-grid mr-2"></i>All Bids
        </button>
        <button
          onclick="filterBids('pending')"
          class="filter-btn px-4 py-2 rounded-xl border border-gray-700 font-semibold transition-all hover:bg-gray-800/50 whitespace-nowrap"
          data-filter="pending"
        >
          <i class="bi bi-hourglass-split mr-2"></i>Pending
        </button>
        <button
          onclick="filterBids('accepted')"
          class="filter-btn px-4 py-2 rounded-xl border border-gray-700 font-semibold transition-all hover:bg-gray-800/50 whitespace-nowrap"
          data-filter="accepted"
        >
          <i class="bi bi-trophy-fill mr-2"></i>Winners
        </button>
        <button
          onclick="filterBids('rejected')"
          class="filter-btn px-4 py-2 rounded-xl border border-gray-700 font-semibold transition-all hover:bg-gray-800/50 whitespace-nowrap"
          data-filter="rejected"
        >
          <i class="bi bi-x-circle-fill mr-2"></i>Rejected
        </button>
      </div>
      <div id="loading" class="text-center py-12">
        <div
          class="w-16 h-16 rounded-full border-4 border-orange-500/30 border-t-orange-500 animate-spin mx-auto mb-4"
        ></div>
        <p class="text-gray-400">Loading auction bids...</p>
      </div>
      <div
        id="error-state"
        class="hidden text-center py-12 glass-strong border border-red-500/40 rounded-2xl"
      >
        <div
          class="w-20 h-20 rounded-full bg-red-500/20 flex items-center justify-center mx-auto mb-4"
        >
          <i class="bi bi-exclamation-triangle text-4xl text-red-400"></i>
        </div>
        <h3 class="text-xl font-bold mb-2 text-red-300">Could Not Load Bids</h3>
        <p class="text-gray-400 mb-6" id="error-message">Please try again.</p>
        <button
          onclick="reloadBids()"
          class="px-6 py-3 rounded-xl bg-gradient-to-r from-orange-500 to-red-600 font-semibold hover:shadow-lg hover:shadow-orange-500/30 transition"
        >
          <i class="bi bi-arrow-clockwise mr-2"></i>Retry
        </button>
      </div>
      <div
        id="no-bids"
        class="hidden text-center py-12 glass-strong border border-gray-800 rounded-2xl"
      >
        <div
          class="w-20 h-20 rounded-full bg-gray-800/50 flex items-center justify-center mx-auto mb-4"
        >
          <i class="bi bi-inbox text-4xl text-gray-600"></i>
        </div>
        <h3 class="text-xl font-bold mb-2">No Bids Found</h3>
        <p class="text-gray-400 mb-6">{{#if isAdmin}}No bids in the system yet.{{else}}{{#if
              canManageBids}}You haven't received any bids on your auctions
              yet.{{else}}You haven't placed any bids yet.{{/if}}{{/if}}</p>
        {{#if canManageBids}}
          <a
            href="/auctions/create"
            class="px-6 py-3 rounded-xl bg-gradient-to-r from-orange-500 to-red-600 font-semibold hover:shadow-lg hover:shadow-orange-500/30 transition"
          >
            <i class="bi bi-plus-lg mr-2"></i>Create Auction
          </a>
        {{else}}
          <a
            href="/auctions/animalList"
            class="px-6 py-3 rounded-xl bg-gradient-to-r from-orange-500 to-red-600 font-semibold hover:shadow-lg hover:shadow-orange-500/30 transition"
          >
            <i class="bi bi-search mr-2"></i>Browse Auctions
          </a>
        {{/if}}
      </div>
      <div id="bids-container" class="space-y-8 hidden">
      </div>
    </div>
    <div
      id="toast"
      class="fixed bottom-4 right-4 transform translate-y-20 opacity-0 transition-all duration-300 z-50"
    >
      <div
        class="glass-strong border border-green-500/50 rounded-xl p-4 flex items-center gap-3"
      >
        <div
          class="w-10 h-10 rounded-full bg-green-500/20 flex items-center justify-center"
        ><i class="bi bi-check-lg text-green-500"></i></div>
        <div>
          <p class="font-bold" id="toast-title">Success!</p>
          <p class="text-sm text-gray-400" id="toast-message">Bid marked as
            winner</p>
        </div>
      </div>
    </div>
    <script src="/js/auction-bids.js"></script>
      <script src="/js/app-theme.js"></script>
  </body>
</html>
