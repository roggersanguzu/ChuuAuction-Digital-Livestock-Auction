<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Browse Premium Livestock - ChuuAuction</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="/vendor/bootstrap-icons/css/bootstrap-icons.css"
    />
    <link href="/css/app-theme.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Work+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <script>
      tailwind.config = { darkMode: "class", theme: { extend: { fontFamily: {
      display: ["Playfair Display","serif"], body: ["Work Sans","sans-serif"],
      mono: ["DM Mono","monospace"] }, animation: { gradient: "gradient 8s
      linear infinite", float: "float 6s ease-in-out infinite", "slide-up":
      "slideUp 0.5s ease-out", "fade-in": "fadeIn 0.6s ease-out", "scale-in":
      "scaleIn 0.4s cubic-bezier(0.16,1,0.3,1)", shimmer: "shimmer 2s infinite",
      "pulse-soft": "pulseSoft 3s ease-in-out infinite" }, keyframes: {
      gradient: { "0%,100%": { backgroundPosition:"0% 50%" }, "50%": {
      backgroundPosition:"100% 50%" } }, float: { "0%,100%": {
      transform:"translateY(0px)" }, "50%": { transform:"translateY(-20px)" } },
      slideUp: { "0%": { opacity:"0", transform:"translateY(30px)" }, "100%": {
      opacity:"1", transform:"translateY(0)" } }, fadeIn: { "0%": { opacity:"0"
      }, "100%": { opacity:"1" } }, scaleIn: { "0%": { transform:"scale(0.9)",
      opacity:"0" }, "100%": { transform:"scale(1)", opacity:"1" } }, shimmer: {
      "0%": { backgroundPosition:"-1000px 0" }, "100%": {
      backgroundPosition:"1000px 0" } }, pulseSoft: { "0%,100%": { opacity:"1"
      }, "50%": { opacity:"0.7" } } } } } };
    </script>
    <style>
      :root {
        --em: #f97316;
        --em-dim: rgba(249, 115, 22, 0.15);
        --em-glow: rgba(249, 115, 22, 0.25);
        --surface: rgba(255, 255, 255, 0.03);
        --surface-strong: rgba(255, 255, 255, 0.055);
        --border: rgba(255, 255, 255, 0.07);
        --border-hover: rgba(249, 115, 22, 0.4);
      }
      .font-display {
        font-family: "Playfair Display", serif;
      }
      .font-body {
        font-family: "Work Sans", sans-serif;
      }
      .font-mono {
        font-family: "DM Mono", monospace;
      }
      #listings-container > * {
        min-height: 19rem;
      }
      @media (max-width: 640px) {
        #listings-container > * {
          min-height: 17.5rem;
        }
      }
      .glass {
        background: var(--surface);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--border);
      }
      .glass-strong {
        background: var(--surface-strong);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .text-gradient {
        background: linear-gradient(135deg, #f97316, #c2410c, #fb923c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        background-size: 200% 200%;
      }
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #0f172a;
      }
      ::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #f97316, #c2410c);
        border-radius: 3px;
      }
      .card-hover {
        transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .card-hover:hover {
        transform: translateY(-3px) scale(1.005);
        box-shadow: 0 12px 32px var(--em-glow);
        border-color: var(--border-hover) !important;
      }
      .image-container {
        overflow: hidden;
        position: relative;
      }
      .image-container img {
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .image-container:hover img {
        transform: scale(1.12);
      }
      .filter-chip {
        cursor: pointer;
        transition: all 0.25s ease;
        user-select: none;
      }
      .filter-chip:hover {
        transform: translateY(-2px);
      }
      .filter-chip.active {
        background: linear-gradient(135deg, #f97316, #c2410c);
        border-color: #f97316;
        color: #fff;
      }
      .search-glow:focus {
        box-shadow: 0 0 0 2px rgba(249, 115, 22, 0.2);
      }
      @keyframes status-pulse {
        0%,
        100% {
          box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.7);
        }
        50% {
          box-shadow: 0 0 0 6px rgba(249, 115, 22, 0);
        }
      }
      .status-live {
        animation: status-pulse 2s infinite;
      }
      .filter-panel {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .filter-panel.expanded {
        max-height: 800px;
      }
      .shimmer {
        background: linear-gradient(
          90deg,
          #1e293b 0%,
          #334155 50%,
          #1e293b 100%
        );
        background-size: 1000px 100%;
        animation: shimmer 2s infinite;
      }
      .price-shine {
        position: relative;
        overflow: hidden;
      }
      .price-shine::after {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: linear-gradient(
          45deg,
          transparent,
          rgba(255, 255, 255, 0.08),
          transparent
        );
        transform: rotate(45deg);
        animation: shine 4s infinite;
      }
      @keyframes shine {
        0% {
          transform: translateX(-100%) translateY(-100%) rotate(45deg);
        }
        100% {
          transform: translateX(100%) translateY(100%) rotate(45deg);
        }
      }
      @keyframes float-gentle {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-8px);
        }
      }
      .empty-state {
        animation: float-gentle 4s ease-in-out infinite;
      }
      select,
      input[type="text"],
      input[type="number"] {
        color: #f1f5f9 !important;
        background-color: rgba(15, 23, 42, 0.7) !important;
      }
      select option {
        background-color: #0f172a !important;
        color: #f1f5f9 !important;
      }
      input[type="text"]::placeholder,
      input[type="number"]::placeholder {
        color: #64748b !important;
      }
      .stat-item {
        animation: slideUp 0.5s ease-out backwards;
      }
      .tag-pill {
        position: relative;
        overflow: hidden;
      }
      .tag-pill::before {
        content: "";
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.15),
          transparent
        );
        transition: left 0.4s;
      }
      .tag-pill:hover::before {
        left: 100%;
      }
      .page-topline {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        z-index: 100;
        background: linear-gradient(90deg, #f97316, #c2410c, #f97316);
        background-size: 200% 100%;
        animation: gradient 3s ease infinite;
      }
      .section-divider {
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(249, 115, 22, 0.25),
          transparent
        );
      }
      .inp-compact {
        padding: 7px 14px;
        font-size: 12.5px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(15, 23, 42, 0.7);
        color: #f1f5f9;
        outline: none;
        transition:
          border-color 0.2s,
          box-shadow 0.2s;
        width: 100%;
        font-family: "Work Sans", sans-serif;
      }
      .inp-compact:focus {
        border-color: rgba(249, 115, 22, 0.5);
        box-shadow: 0 0 0 2px rgba(249, 115, 22, 0.12);
      }
      .inp-compact::placeholder {
        color: #475569;
      }
      .view-btn {
        transition: all 0.2s;
      }
      .view-btn.active {
        background: rgba(249, 115, 22, 0.15);
        border-color: rgba(249, 115, 22, 0.5) !important;
        color: #f97316;
      }
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.04em;
      }
      .badge-green {
        background: rgba(249, 115, 22, 0.15);
        color: #fb923c;
        border: 1px solid rgba(249, 115, 22, 0.25);
      }
      .badge-blue {
        background: rgba(59, 130, 246, 0.15);
        color: #93c5fd;
        border: 1px solid rgba(59, 130, 246, 0.25);
      }
      .badge-amber {
        background: rgba(245, 158, 11, 0.15);
        color: #fcd34d;
        border: 1px solid rgba(245, 158, 11, 0.25);
      }
      .badge-red {
        background: rgba(239, 68, 68, 0.15);
        color: #fca5a5;
        border: 1px solid rgba(239, 68, 68, 0.25);
      }
      .header-strip {
        background: linear-gradient(
          135deg,
          rgba(249, 115, 22, 0.06) 0%,
          transparent 60%
        );
        border-bottom: 1px solid rgba(249, 115, 22, 0.1);
      }
      @media (max-width: 1024px) {
        .header-strip .flex.items-center.gap-2.animate-fade-in {
          width: 100%;
          justify-content: flex-start;
          flex-wrap: wrap;
        }
      }
      @media (max-width: 640px) {
        .header-strip .pb-4.space-y-2\\.5 {
          padding-bottom: 12px;
        }
        #listings-container {
          grid-template-columns: 1fr !important;
          gap: 14px !important;
        }
        .relative.z-10.max-w-7xl.mx-auto.px-4.sm\\:px-6.lg\\:px-8.py-5.pb-24 {
          padding-left: 12px !important;
          padding-right: 12px !important;
          padding-bottom: 28px !important;
        }
      }
      @media (max-width: 420px) {
        .header-strip h1 {
          font-size: 1.75rem !important;
          line-height: 1.1;
        }
        .header-strip .stat-item {
          min-width: calc(50% - 6px);
        }
        .header-strip .flex.items-center.justify-between.mb-5.animate-slide-up {
          flex-direction: column;
          align-items: flex-start;
          gap: 10px;
        }
      }
    </style>
  </head>
  <body
    class="min-h-screen bg-gray-950 text-white font-body overflow-x-hidden relative"
  >
    <div class="page-topline"></div>
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div
        class="absolute top-0 left-0 w-[500px] h-[500px] bg-amber-500/8 rounded-full blur-[130px] animate-float"
      ></div>
      <div
        class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-amber-600/7 rounded-full blur-[140px] animate-float"
        style="animation-delay:3s;"
      ></div>
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-r from-amber-500/4 to-orange-600/4 rounded-full blur-3xl animate-pulse-soft"
      ></div>
    </div>
    <div class="header-strip relative z-10 pt-5 pb-0">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pb-4 animate-fade-in"
        >
          <div>
            <div class="flex items-center gap-2 mb-1">
              <div
                class="w-1 h-8 rounded-full bg-gradient-to-b from-amber-400 to-orange-600"
              ></div>
              <h1 class="text-3xl font-black font-display">
                <span class="text-gradient">Premium Livestock</span>
              </h1>
            </div>
            <p class="text-gray-500 text-xs font-medium ml-3 tracking-wide">
              Discover exceptional animals from verified farmers across Uganda
            </p>
          </div>
          <div
            class="flex items-center gap-2 animate-fade-in"
            style="animation-delay:0.1s;"
          >
            <div
              class="stat-item flex items-center gap-2.5 px-4 py-2.5 rounded-xl glass border border-gray-800/60 hover:border-amber-500/30 transition-all cursor-default"
              style="animation-delay:0.1s;"
            >
              <div
                class="w-7 h-7 rounded-lg bg-amber-500/15 flex items-center justify-center"
              >
                <i class="bi bi-collection text-amber-500 text-xs"></i>
              </div>
              <div>
                <p
                  class="text-xl font-black text-amber-500 leading-none"
                  id="total-listings"
                >0</p>
                <p
                  class="text-[10px] text-gray-500 font-semibold uppercase tracking-wide"
                >Listings</p>
              </div>
            </div>
            <div
              class="stat-item flex items-center gap-2.5 px-4 py-2.5 rounded-xl glass border border-gray-800/60 hover:border-amber-500/30 transition-all cursor-default"
              style="animation-delay:0.2s;"
            >
              <div
                class="w-7 h-7 rounded-lg bg-amber-500/15 flex items-center justify-center"
              >
                <i class="bi bi-broadcast text-amber-500 text-xs"></i>
              </div>
              <div>
                <p
                  class="text-xl font-black text-amber-500 leading-none"
                  id="live-auctions"
                >0</p>
                <p
                  class="text-[10px] text-gray-500 font-semibold uppercase tracking-wide"
                >Live Now</p>
              </div>
            </div>
            <div
              class="stat-item flex items-center gap-2.5 px-4 py-2.5 rounded-xl glass border border-gray-800/60 hover:border-amber-500/30 transition-all cursor-default"
              style="animation-delay:0.3s;"
            >
              <div
                class="w-7 h-7 rounded-lg bg-amber-500/15 flex items-center justify-center"
              >
                <i class="bi bi-patch-check text-amber-500 text-xs"></i>
              </div>
              <div>
                <p
                  class="text-xl font-black text-amber-500 leading-none"
                  id="verified-sellers"
                >0</p>
                <p
                  class="text-[10px] text-gray-500 font-semibold uppercase tracking-wide"
                >Sellers</p>
              </div>
            </div>
          </div>
        </div>
        <div
          class="pb-4 space-y-2.5 animate-slide-up"
          style="animation-delay:0.15s;"
        >
          <div class="relative">
            <div
              class="absolute left-4 top-1/2 -translate-y-1/2 text-amber-500"
            >
              <i class="bi bi-search text-sm"></i>
            </div>
            <input
              type="text"
              id="main-search"
              placeholder="Search by breed, location, seller or keywords..."
              class="w-full pl-10 pr-10 py-3 text-sm rounded-xl glass-strong border border-gray-800/60 focus:border-amber-500/50 focus:outline-none search-glow transition-all font-medium text-white bg-gray-900/60"
            />
            <button
              onclick="clearSearch()"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-600 hover:text-amber-500 transition-colors"
            >
              <i class="bi bi-x-circle text-sm"></i>
            </button>
          </div>
          <div class="flex flex-wrap gap-2">
            <div class="flex-1 min-w-[150px]">
              <select id="filter-animal-type" class="inp-compact">
                <option value="">All Animals</option>
                <option value="1">Cattle</option>
                <option value="2">Goat</option>
                <option value="3">Sheep</option>
                <option value="4">Pig</option>
                <option value="5">Poultry</option>
                <option value="6">Rabbit</option>
                <option value="7">Duck</option>
              </select>
            </div>
            <div class="flex-1 min-w-[140px]">
              <select id="filter-health" class="inp-compact">
                <option value="">All Conditions</option>
                <option value="Excellent">Excellent</option>
                <option value="Good">Good</option>
                <option value="Fair">Fair</option>
              </select>
            </div>
            <div class="flex-1 min-w-[120px]">
              <select id="filter-sex" class="inp-compact">
                <option value="">All Sexes</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
              </select>
            </div>
            <div class="flex-1 min-w-[150px]">
              <select id="sort-by" class="inp-compact">
                <option value="newest">Newest First</option>
                <option value="oldest">Oldest First</option>
                <option value="weight-high">Highest Weight</option>
                <option value="weight-low">Lowest Weight</option>
                <option value="quantity-high">Most Quantity</option>
                <option value="quantity-low">Least Quantity</option>
              </select>
            </div>
            <button
              onclick="toggleAdvancedFilters()"
