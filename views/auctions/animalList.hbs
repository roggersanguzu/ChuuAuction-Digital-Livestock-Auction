                >Advanced Filters</h3>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                  <label
                    class="block text-xs font-bold text-gray-400 mb-2 uppercase tracking-wide"
                  >Weight Range (KG)</label>
                  <div class="flex gap-2 items-center">
                    <input
                      type="number"
                      id="filter-weight-min"
                      placeholder="Min"
                      class="inp-compact"
                    />
                    <span class="text-gray-600 text-xs">—</span>
                    <input
                      type="number"
                      id="filter-weight-max"
                      placeholder="Max"
                      class="inp-compact"
                    />
                  </div>
                </div>
                <div>
                  <label
                    class="block text-xs font-bold text-gray-400 mb-2 uppercase tracking-wide"
                  >Age Range (yrs)</label>
                  <div class="flex gap-2 items-center">
                    <input
                      type="number"
                      id="filter-age-min"
                      placeholder="Min"
                      class="inp-compact"
                    />
                    <span class="text-gray-600 text-xs">—</span>
                    <input
                      type="number"
                      id="filter-age-max"
                      placeholder="Max"
                      class="inp-compact"
                    />
                  </div>
                </div>
                <div>
                  <label
                    class="block text-xs font-bold text-gray-400 mb-2 uppercase tracking-wide"
                  >Quantity Range</label>
                  <div class="flex gap-2 items-center">
                    <input
                      type="number"
                      id="filter-quantity-min"
                      placeholder="Min"
                      class="inp-compact"
                    />
                    <span class="text-gray-600 text-xs">—</span>
                    <input
                      type="number"
                      id="filter-quantity-max"
                      placeholder="Max"
                      class="inp-compact"
                    />
                  </div>
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label
                    class="block text-xs font-bold text-gray-400 mb-2 uppercase tracking-wide"
                  >Vaccination Status</label>
                  <div class="flex gap-2">
                    <label
                      class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl glass border border-gray-800/60 cursor-pointer hover:border-amber-500/40 transition-all text-xs font-semibold"
                    >
                      <input
                        type="radio"
                        name="vaccination"
                        value=""
                        class="accent-amber-500"
                        checked
                      />
                      All
                    </label>
                    <label
                      class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl glass border border-gray-800/60 cursor-pointer hover:border-amber-500/40 transition-all text-xs font-semibold"
                    >
                      <input
                        type="radio"
                        name="vaccination"
                        value="true"
                        class="accent-amber-500"
                      />
                      ? Yes
                    </label>
                    <label
                      class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl glass border border-gray-800/60 cursor-pointer hover:border-amber-500/40 transition-all text-xs font-semibold"
                    >
                      <input
                        type="radio"
                        name="vaccination"
                        value="false"
                        class="accent-amber-500"
                      />
                      ? No
                    </label>
                  </div>
                </div>
                <div>
                  <label
                    class="block text-xs font-bold text-gray-400 mb-2 uppercase tracking-wide"
                  >Location / District</label>
                  <input
                    type="text"
                    id="filter-location"
                    placeholder="Enter location..."
                    class="inp-compact"
                  />
                </div>
              </div>
              <div class="flex justify-end pt-1">
                <button
                  onclick="applyAdvancedFilters()"
                  class="flex items-center gap-2 px-5 py-2 rounded-xl bg-gradient-to-r from-amber-500 to-orange-600 text-sm font-bold hover:shadow-lg hover:shadow-emerald-500/25 transition-all"
                >
                  <i class="bi bi-check-circle"></i>
                  Apply Filters
                </button>
              </div>
            </div>
          </div>
          <div id="active-filters" class="flex flex-wrap gap-2"></div>
        </div>
        <div class="section-divider"></div>
      </div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 pb-24">
      <div class="flex items-center justify-between mb-5 animate-slide-up">
        <div class="flex items-center gap-3">
          <div>
            <h2 class="text-base font-bold text-white">
              <span
                id="results-count"
                class="text-amber-400 font-black"
              >0</span>
              <span class="text-gray-400 font-medium ml-1">listings found</span>
            </h2>
            <p
              class="text-xs text-gray-600 mt-0.5"
              id="filter-description"
            >Showing all available livestock</p>
          </div>
          <div
            class="flex items-center gap-1.5 px-2.5 py-1 rounded-full glass border border-amber-500/20"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-amber-500 status-live"
            ></span>
            <span
              class="text-[10px] font-bold text-amber-400 uppercase tracking-wider"
            >Live</span>
          </div>
        </div>
        <div class="flex gap-1.5">
          <button
            onclick="setViewMode('grid')"
            id="view-grid"
            class="view-btn active px-3 py-1.5 rounded-lg glass border border-gray-800/60 transition-all text-xs font-semibold"
          >
            <i class="bi bi-grid-3x3-gap mr-1"></i>Grid
          </button>
          <button
            onclick="setViewMode('list')"
            id="view-list"
            class="view-btn px-3 py-1.5 rounded-lg glass border border-gray-800/60 transition-all text-xs font-semibold"
          >
            <i class="bi bi-list-ul mr-1"></i>List
          </button>
        </div>
      </div>
      <div
        id="listings-container"
        class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4"
      ></div>
      <div id="loading-state" class="text-center py-24">
        <div class="inline-flex flex-col items-center gap-4">
          <div class="relative">
            <div
              class="w-12 h-12 border-2 border-amber-500/20 border-t-emerald-500 rounded-full animate-spin"
            ></div>
            <div
              class="absolute inset-2 w-8 h-8 border-2 border-amber-400/10 border-b-emerald-400 rounded-full animate-spin"
              style="animation-direction:reverse;animation-duration:0.7s;"
            ></div>
          </div>
          <div>
            <p class="text-sm font-bold text-gray-400">Loading premium
              livestock...</p>
            <p class="text-xs text-gray-600 mt-1">Fetching the finest animals
              for you</p>
          </div>
        </div>
      </div>
      <div id="empty-state" class="text-center py-24 hidden">
        <div class="empty-state inline-block">
          <div
            class="w-24 h-24 rounded-2xl glass border border-gray-800/60 flex items-center justify-center mx-auto mb-5"
          >
            <i class="bi bi-search text-4xl text-gray-700"></i>
          </div>
          <h3 class="text-xl font-bold text-gray-400 mb-2">No Listings Found</h3>
          <p class="text-sm text-gray-600 mb-5 max-w-xs mx-auto">Try adjusting
            your filters or search criteria to discover more animals</p>
          <button
            onclick="resetFilters()"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-amber-500 to-orange-600 text-sm font-bold hover:shadow-xl hover:shadow-emerald-500/25 transition-all"
          >
            <i class="bi bi-arrow-clockwise"></i>
            Reset All Filters
          </button>
        </div>
      </div>
      <div id="load-more-container" class="text-center mt-10 hidden">
        <button
          onclick="loadMore()"
          class="inline-flex items-center gap-2 px-7 py-3 rounded-xl bg-gradient-to-r from-amber-500 to-orange-600 text-sm font-bold hover:shadow-2xl hover:shadow-emerald-500/25 transition-all hover:-translate-y-0.5"
        >
          <i class="bi bi-arrow-down-circle"></i>
          Load More Listings
        </button>
      </div>
    </div>
    <div
      id="bid-modal"
      class="fixed inset-0 bg-black/80 backdrop-blur-xl z-[60] hidden items-center justify-center p-4"
      onclick="closeBidModal(event)"
    >
      <div
        class="max-w-2xl w-full max-h-[90vh] overflow-y-auto rounded-2xl glass-strong border border-gray-800/60 animate-scale-in"
        onclick="event.stopPropagation()"
      >
        <div id="bid-modal-content"></div>
      </div>
    </div>
    <div
      id="detail-modal"
      class="fixed inset-0 bg-black/80 backdrop-blur-xl z-50 hidden items-center justify-center p-4"
      onclick="closeDetailModal(event)"
    >
      <div
        class="max-w-4xl w-full max-h-[88vh] overflow-y-auto rounded-2xl glass-strong border border-gray-800/60 animate-scale-in"
        onclick="event.stopPropagation()"
      >
        <div id="modal-content"></div>
      </div>
    </div>
    <script src="/js/animalList.js"></script>
      <script src="/js/app-theme.js"></script>
  </body>
</html>

