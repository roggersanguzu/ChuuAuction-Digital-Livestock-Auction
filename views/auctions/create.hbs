<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Auction - AgriVault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="/vendor/fontawesome/css/all.min.css"
    />
    <link href="/css/app-theme.css" rel="stylesheet" />

    <style>
      /* ── RESET & BASE ─────────────────────────────────────────────────────────── */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }

      :root {
        --bg: #04080f;
        --bg2: #080e1a;
        --surface: rgba(255, 255, 255, 0.03);
        --surface2: rgba(255, 255, 255, 0.06);
        --border: rgba(255, 255, 255, 0.08);
        --border2: rgba(255, 255, 255, 0.14);
        --text: #f0f4ff;
        --text2: #94a3b8;
        --text3: #475569;
        --accent: #4ade80;
        --accent2: #22d3ee;
        --accent3: #facc15;
        --accent4: #f87171;
        --accent5: #a78bfa;
        --blue: #60a5fa;
        --orange: #fb923c;
        --r2: 8px;
        --r3: 12px;
        --r4: 16px;
      }

      body {
        font-family: "DM Sans", sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        line-height: 1.6;
        overflow-x: hidden;
      }

      /* ── BACKGROUND MESH ──────────────────────────────────────────────────────── */
      .bg-mesh {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
      }
      .bg-mesh::before {
        content: "";
        position: absolute;
        top: -30%;
        left: -20%;
        width: 70vw;
        height: 70vw;
        background: radial-gradient(
          circle,
          rgba(74, 222, 128, 0.04) 0%,
          transparent 70%
        );
        border-radius: 50%;
      }
      .bg-mesh::after {
        content: "";
        position: absolute;
        bottom: -20%;
        right: -15%;
        width: 60vw;
        height: 60vw;
        background: radial-gradient(
          circle,
          rgba(96, 165, 250, 0.04) 0%,
          transparent 70%
        );
        border-radius: 50%;
      }
      .mesh-dot {
        position: absolute;
        top: 40%;
        left: 60%;
        width: 400px;
        height: 400px;
        background: radial-gradient(
          circle,
          rgba(167, 139, 250, 0.03) 0%,
          transparent 70%
        );
        border-radius: 50%;
      }

      /* ── LAYOUT ───────────────────────────────────────────────────────────────── */
      .wrapper {
        position: relative;
        z-index: 1;
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px 100px;
      }

      /* ── PAGE HEADER ──────────────────────────────────────────────────────────── */
      .page-header {
        margin-bottom: 40px;
      }
      .page-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        background: rgba(74, 222, 128, 0.08);
        border: 1px solid rgba(74, 222, 128, 0.2);
        padding: 5px 14px;
        border-radius: 100px;
        margin-bottom: 14px;
      }
      .page-title {
        font-family: "Syne", sans-serif;
        font-size: clamp(28px, 5vw, 42px);
        font-weight: 800;
        line-height: 1.1;
        color: var(--text);
        margin-bottom: 10px;
      }
      .page-title span {
        color: var(--accent);
      }
      .page-sub {
        font-size: 15px;
        color: var(--text2);
        max-width: 480px;
      }

      /* ── PROGRESS STEPPER ─────────────────────────────────────────────────────── */
      .stepper {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r4);
        padding: 20px 28px;
        margin-bottom: 32px;
        position: relative;
        overflow: hidden;
      }
      .stepper::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          var(--accent) 0%,
          var(--accent2) 50%,
          var(--accent5) 100%
        );
      }

      .step-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        position: relative;
      }
      .step-item:not(:last-child)::after {
        content: "";
        position: absolute;
        top: 18px;
        right: -50%;
        left: 50%;
        height: 1px;
        background: var(--border);
        z-index: 0;
      }

      .step-dot {
        position: relative;
        z-index: 1;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        background: var(--bg2);
        border: 2px solid var(--border2);
        color: var(--text3);
        transition: all 0.35s ease;
      }
      .step-dot.active {
        background: linear-gradient(135deg, #4ade80, #22c55e);
        border-color: transparent;
        color: #04080f;
        box-shadow:
          0 0 0 4px rgba(74, 222, 128, 0.12),
          0 0 20px rgba(74, 222, 128, 0.25);
      }
      .step-dot.completed {
        background: linear-gradient(135deg, #22d3ee, #06b6d4);
        border-color: transparent;
        color: #04080f;
        box-shadow: 0 0 0 4px rgba(34, 211, 238, 0.12);
      }
      .step-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--text3);
        transition: color 0.3s;
        text-align: center;
        letter-spacing: 0.04em;
      }
      .step-item.active .step-label {
        color: var(--accent);
      }
      .step-item.completed .step-label {
        color: var(--accent2);
      }

      /* ── FORM CARDS ───────────────────────────────────────────────────────────── */
      .form-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 32px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s;
      }
      .form-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.08),
          transparent
        );
      }
      .form-card:hover {
        border-color: var(--border2);
      }

      /* ── SECTION HEADER ───────────────────────────────────────────────────────── */
      .section-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 28px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
      }
      .section-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text3);
        background: var(--surface2);
        border: 1px solid var(--border);
        padding: 4px 10px;
        border-radius: 6px;
      }
      .section-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
      }
      .section-icon.blue {
        background: rgba(59, 130, 246, 0.12);
        color: var(--blue);
        border: 1px solid rgba(59, 130, 246, 0.2);
      }
      .section-icon.purple {
        background: rgba(167, 139, 250, 0.12);
        color: var(--accent5);
        border: 1px solid rgba(167, 139, 250, 0.2);
      }
      .section-icon.green {
        background: rgba(74, 222, 128, 0.12);
        color: var(--accent);
        border: 1px solid rgba(74, 222, 128, 0.2);
      }
      .section-icon.orange {
        background: rgba(251, 146, 60, 0.12);
        color: var(--orange);
        border: 1px solid rgba(251, 146, 60, 0.2);
      }

      .section-header-text h2 {
        font-family: "Syne", sans-serif;
        font-size: 18px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 3px;
      }
      .section-header-text p {
        font-size: 13px;
        color: var(--text3);
      }

      /* ── GRID ─────────────────────────────────────────────────────────────────── */
      .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }
      .grid-3 {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
      }
      .col-span-2 {
        grid-column: span 2;
      }
      @media (max-width: 640px) {
        .grid-2 {
          grid-template-columns: 1fr;
        }
        .col-span-2 {
          grid-column: span 1;
        }
      }

      /* ── FORM LABELS & INPUTS ─────────────────────────────────────────────────── */
      .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .form-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--text2);
        letter-spacing: 0.04em;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .form-label i {
        color: var(--accent);
        font-size: 11px;
      }
      .form-label .req {
        color: var(--accent4);
      }

      .clean-input,
      .clean-select,
      .clean-textarea {
        width: 100%;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--border);
        border-radius: var(--r3);
        padding: 12px 16px;
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.2s ease;
        outline: none;
      }
      .clean-input:hover,
      .clean-select:hover,
      .clean-textarea:hover {
        border-color: rgba(74, 222, 128, 0.25);
      }
      .clean-input:focus,
      .clean-select:focus,
      .clean-textarea:focus {
        border-color: rgba(74, 222, 128, 0.45);
        background: rgba(0, 0, 0, 0.4);
        box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.07);
      }
      .clean-input::placeholder,
      .clean-textarea::placeholder {
        color: var(--text3);
      }
      .clean-select option {
        background: #0a0f1e;
        color: var(--text);
      }
      .clean-textarea {
        resize: vertical;
        min-height: 120px;
        line-height: 1.7;
      }

      .input-icon-wrap {
        position: relative;
      }
      .input-icon-wrap .clean-input {
        padding-right: 52px;
      }
      .input-suffix {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 12px;
        font-weight: 700;
        color: var(--text3);
        pointer-events: none;
        font-family: "DM Mono", monospace;
      }

      input[type="date"],
      input[type="time"] {
        color-scheme: dark;
      }
      input[type="date"]::-webkit-calendar-picker-indicator,
      input[type="time"]::-webkit-calendar-picker-indicator {
        filter: invert(0.5) sepia(1) hue-rotate(80deg) saturate(3);
        cursor: pointer;
        opacity: 0.6;
      }
      input[type="number"]::-webkit-inner-spin-button,
      input[type="number"]::-webkit-outer-spin-button {
        opacity: 0;
      }
      input[type="checkbox"] {
        accent-color: var(--accent);
      }

      /* ── INFO TEXT ────────────────────────────────────────────────────────────── */
      .info-text {
        font-size: 11.5px;
        color: var(--text3);
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .info-text i {
        font-size: 10px;
      }
      .info-text.accent {
        color: var(--accent);
      }
      .info-text.warn {
        color: var(--accent3);
      }

      /* ── RADIO SEX CARDS ──────────────────────────────────────────────────────── */
      .sex-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .sex-card {
        position: relative;
      }
      .sex-card input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
      }
      .sex-card label {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 16px;
        border-radius: var(--r3);
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.2s;
        font-size: 13px;
        font-weight: 600;
        color: var(--text2);
      }
      .sex-card label:hover {
        border-color: rgba(74, 222, 128, 0.3);
        background: rgba(74, 222, 128, 0.04);
      }
      .sex-card input:checked + label {
        border-color: var(--accent);
        background: rgba(74, 222, 128, 0.1);
        color: var(--accent);
        box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.07);
      }
      .sex-card label i {
        font-size: 24px;
        margin-bottom: 2px;
      }
      .sex-card:nth-child(1) label i {
        color: #60a5fa;
      }
      .sex-card:nth-child(2) label i {
        color: #f9a8d4;
      }

      /* ── VACCINATED TOGGLE ────────────────────────────────────────────────────── */
      .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 20px;
        border-radius: var(--r3);
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--border);
      }
      .toggle-left {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .toggle-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(74, 222, 128, 0.1);
        border: 1px solid rgba(74, 222, 128, 0.2);
        color: var(--accent);
        font-size: 18px;
      }
      .toggle-right {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .toggle-switch-wrap input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
      }
      .toggle-switch {
        display: block;
        position: relative;
        width: 48px;
        height: 26px;
        background: var(--surface2);
        border-radius: 100px;
        cursor: pointer;
        border: 1px solid var(--border);
        transition: all 0.25s ease;
      }
      .toggle-switch::after {
        content: "";
        position: absolute;
        top: 3px;
        left: 3px;
        width: 18px;
        height: 18px;
        background: var(--text3);
        border-radius: 50%;
        transition: all 0.25s ease;
      }
      .toggle-switch-wrap input:checked + .toggle-switch {
        background: linear-gradient(135deg, #4ade80, #22c55e);
        border-color: var(--accent);
      }
      .toggle-switch-wrap input:checked + .toggle-switch::after {
        left: calc(100% - 21px);
        background: #fff;
      }
      #vaccinatedLabel {
        font-size: 13px;
        font-weight: 600;
        color: var(--text3);
        transition: color 0.2s;
      }

      /* ── PREVIEW BAR ──────────────────────────────────────────────────────────── */
      .preview-bar {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--border);
        border-radius: var(--r3);
        padding: 16px;
      }
      .preview-item {
        text-align: center;
        padding: 10px 8px;
        border-radius: var(--r2);
        background: rgba(0, 0, 0, 0.3);
      }
      .preview-item i {
        font-size: 18px;
        display: block;
        margin-bottom: 6px;
      }
      .preview-label {
        font-size: 10px;
        color: var(--text3);
        margin-bottom: 4px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .preview-value {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        font-family: "DM Mono", monospace;
      }

      /* ── PHOTO UPLOAD ZONE ────────────────────────────────────────────────────── */
      .photo-zone {
        border: 2px dashed rgba(167, 139, 250, 0.3);
        border-radius: 18px;
        padding: 40px 24px;
        text-align: center;
        cursor: pointer;
        background: rgba(0, 0, 0, 0.15);
        transition: all 0.25s ease;
        position: relative;
        min-height: 200px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }
      .photo-zone:hover {
        border-color: rgba(167, 139, 250, 0.6);
        background: rgba(167, 139, 250, 0.04);
      }
      .photo-zone.drag-active {
        border-color: var(--accent5);
        background: rgba(167, 139, 250, 0.08);
        box-shadow: inset 0 0 0 3px rgba(167, 139, 250, 0.1);
      }
      .photo-zone .upload-icon {
        font-size: 44px;
        color: var(--accent5);
        opacity: 0.5;
        display: block;
        margin-bottom: 12px;
        transition: all 0.2s;
      }
      .photo-zone:hover .upload-icon {
        opacity: 0.75;
        transform: translateY(-3px);
      }
      .photo-zone h3 {
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 6px;
      }
      .photo-zone p {
        font-size: 13px;
        color: var(--text3);
        margin-bottom: 20px;
      }
      .upload-badges {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
      }
      .upload-badge {
        font-size: 11px;
        padding: 4px 12px;
        border-radius: 100px;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text2);
        display: flex;
        align-items: center;
        gap: 5px;
      }
      .upload-badge i {
        color: var(--accent);
      }

      /* ── PHOTO PREVIEW GRID ───────────────────────────────────────────────────── */
      #photoPreviewGrid {
        display: none;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 12px;
        margin-top: 20px;
        width: 100%;
      }
      #photoPreviewGrid.show {
        display: grid;
      }
      .photo-thumb {
        position: relative;
        aspect-ratio: 1;
        border-radius: var(--r3);
        overflow: hidden;
        border: 2px solid var(--border2);
        transition: all 0.2s;
      }
      .photo-thumb:hover {
        border-color: var(--accent);
      }
      .photo-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .photo-thumb .thumb-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.8) 0%,
          transparent 60%
        );
        opacity: 0;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: space-between;
        padding: 8px;
        transition: opacity 0.2s;
      }
      .photo-thumb:hover .thumb-overlay {
        opacity: 1;
      }
      .thumb-remove {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: var(--accent4);
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 12px;
        transition: all 0.15s;
      }
      .thumb-remove:hover {
        background: #ef4444;
        transform: scale(1.1);
      }
      .photo-thumb .thumb-num {
        background: rgba(0, 0, 0, 0.7);
        border-radius: 6px;
        padding: 3px 8px;
        font-size: 11px;
        font-weight: 700;
        color: white;
        font-family: "DM Mono", monospace;
        align-self: flex-start;
      }
      .photo-thumb .thumb-name {
        font-size: 10px;
        color: rgba(255, 255, 255, 0.7);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100%;
      }
      .photo-count-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 100px;
        font-size: 12px;
        font-weight: 600;
        background: rgba(74, 222, 128, 0.12);
        border: 1px solid rgba(74, 222, 128, 0.25);
        color: var(--accent);
        margin-top: 12px;
      }

      /* ── PRICING ──────────────────────────────────────────────────────────────── */
      .price-input-wrap {
        position: relative;
      }
      .price-input-wrap .clean-input {
        padding-left: 64px;
        font-family: "DM Mono", monospace;
        font-size: 16px;
        font-weight: 600;
      }
      .price-prefix {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(74, 222, 128, 0.08);
        border-right: 1px solid var(--border);
        border-radius: var(--r3) 0 0 var(--r3);
        font-size: 10px;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: 0.04em;
        font-family: "DM Mono", monospace;
      }
      .price-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }
      @media (max-width: 640px) {
        .price-row {
          grid-template-columns: 1fr;
        }
      }

      /* ── TIPS BOX ─────────────────────────────────────────────────────────────── */
      .tips-box {
        padding: 18px 20px;
        border-radius: var(--r3);
      }
      .tips-box.blue {
        background: rgba(59, 130, 246, 0.06);
        border: 1px solid rgba(59, 130, 246, 0.15);
      }
      .tips-box.orange {
        background: rgba(251, 146, 60, 0.06);
        border: 1px solid rgba(251, 146, 60, 0.15);
      }
      .tips-box h4 {
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .tips-box.blue h4 {
        color: var(--blue);
      }
      .tips-box.orange h4 {
        color: var(--orange);
      }
      .tips-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .tip-item {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        font-size: 12.5px;
        color: var(--text2);
        line-height: 1.5;
      }
      .tip-item i {
        color: var(--accent);
        margin-top: 3px;
        font-size: 11px;
        flex-shrink: 0;
      }

      /* ── TIMER BOX ────────────────────────────────────────────────────────────── */
      .timer-display {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
      }
      .timer-unit {
        text-align: center;
      }
      .timer-box {
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(251, 146, 60, 0.25);
        border-radius: var(--r3);
        padding: 10px 18px;
        font-family: "DM Mono", monospace;
        font-size: 28px;
        font-weight: 700;
        color: var(--orange);
        min-width: 68px;
        text-align: center;
        box-shadow: 0 0 20px rgba(251, 146, 60, 0.08);
      }
      .timer-unit p {
        font-size: 10px;
        color: var(--text3);
        margin-top: 6px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      /* ── CHECKLIST ────────────────────────────────────────────────────────────── */
      .checklist {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 24px;
      }
      .checklist-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 13px 16px;
        border-radius: var(--r2);
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--border);
        font-size: 13px;
        color: var(--text2);
      }
      .checklist-item i {
        color: var(--accent);
        font-size: 14px;
        flex-shrink: 0;
      }
      @media (max-width: 640px) {
        .checklist {
          grid-template-columns: 1fr;
        }
      }

      /* ── TERMS BOX ────────────────────────────────────────────────────────────── */
      .terms-box {
        background: rgba(248, 113, 113, 0.05);
        border: 1px solid rgba(248, 113, 113, 0.15);
        border-radius: var(--r3);
        padding: 18px 20px;
        margin-bottom: 24px;
      }
      .terms-label {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        cursor: pointer;
        font-size: 13px;
        color: var(--text2);
        line-height: 1.6;
      }
      .terms-label input[type="checkbox"] {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
        margin-top: 2px;
        cursor: pointer;
      }

      /* ── CHAR COUNTER ─────────────────────────────────────────────────────────── */
      .desc-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 8px;
      }
      .char-count {
        font-size: 12px;
        font-family: "DM Mono", monospace;
        color: var(--text3);
      }
      .char-count span {
        color: var(--accent4);
        font-weight: 700;
      }
      .char-count span.ok {
        color: var(--accent);
      }

      /* ── BUTTONS ──────────────────────────────────────────────────────────────── */
      .btn-row {
        display: flex;
        gap: 12px;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 13px 26px;
        border-radius: var(--r2);
        font-size: 14px;
        font-weight: 600;
        font-family: "DM Sans", sans-serif;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        text-decoration: none;
      }
      .btn-primary {
        background: var(--accent);
        color: #04080f;
        flex: 2;
        box-shadow: 0 0 24px rgba(74, 222, 128, 0.2);
      }
      .btn-primary:hover {
        background: #86efac;
        box-shadow: 0 0 36px rgba(74, 222, 128, 0.35);
        transform: translateY(-1px);
      }
      .btn-secondary {
        background: var(--surface2);
        color: var(--text2);
        border: 1px solid var(--border);
        flex: 1;
      }
      .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.08);
        color: var(--text);
      }
      .btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
      }

      .btn-select-photo {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 22px;
        border-radius: var(--r2);
        font-size: 13px;
        font-weight: 600;
        background: rgba(167, 139, 250, 0.12);
        border: 1px solid rgba(167, 139, 250, 0.3);
        color: var(--accent5);
        cursor: pointer;
        transition: all 0.2s;
        font-family: "DM Sans", sans-serif;
      }
      .btn-select-photo:hover {
        background: rgba(167, 139, 250, 0.2);
        box-shadow: 0 0 20px rgba(167, 139, 250, 0.15);
      }

      /* ── FOOTER NOTE ──────────────────────────────────────────────────────────── */
      .footer-note {
        text-align: center;
        font-size: 12px;
        color: var(--text3);
        margin-top: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
      }

      /* ── HIDDEN ───────────────────────────────────────────────────────────────── */
      .hidden {
        display: none !important;
      }

      /* ── SUCCESS MODAL ────────────────────────────────────────────────────────── */
      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(16px);
        z-index: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .modal-box {
        background: var(--bg2);
        border: 1px solid var(--border2);
        border-radius: 24px;
        max-width: 480px;
        width: 100%;
        padding: 40px 36px;
        text-align: center;
        position: relative;
        overflow: hidden;
      }
      .modal-box::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), var(--accent2));
      }
      .modal-glow {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        background: rgba(74, 222, 128, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 22px;
        font-size: 38px;
        color: var(--accent);
        box-shadow: 0 0 40px rgba(74, 222, 128, 0.2);
      }
      .modal-title {
        font-family: "Syne", sans-serif;
        font-size: 26px;
        font-weight: 800;
        margin-bottom: 10px;
      }
      .modal-title span {
        color: var(--accent);
      }
      .modal-text {
        font-size: 14px;
        color: var(--text2);
        margin-bottom: 20px;
        line-height: 1.6;
      }
      .modal-id-box {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        padding: 14px;
        margin-bottom: 28px;
      }
      .modal-id-label {
        font-size: 10px;
        color: var(--text3);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 6px;
      }
      .modal-id-value {
        font-family: "DM Mono", monospace;
        font-size: 22px;
        font-weight: 700;
        color: var(--accent);
      }
      .modal-btns {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .modal-btn {
        padding: 13px 20px;
        border-radius: var(--r2);
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: "DM Sans", sans-serif;
      }
      .modal-btn-p {
        background: var(--accent);
        color: #04080f;
        border: none;
      }
      .modal-btn-p:hover {
        background: #86efac;
      }
      .modal-btn-s {
        background: transparent;
        color: var(--text2);
        border: 1px solid var(--border);
      }
      .modal-btn-s:hover {
        background: var(--surface2);
        color: var(--text);
      }

      /* ── ANIMATIONS ───────────────────────────────────────────────────────────── */
      @keyframes fadeUp {
        from {
          opacity: 0;
          transform: translateY(18px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .fade-up-1 {
        animation: fadeUp 0.5s ease-out 0.05s both;
      }
      .fade-up-2 {
        animation: fadeUp 0.5s ease-out 0.12s both;
      }
      .fade-up-3 {
        animation: fadeUp 0.5s ease-out 0.2s both;
      }
      .fade-up-4 {
        animation: fadeUp 0.5s ease-out 0.28s both;
      }
      .fade-up-5 {
        animation: fadeUp 0.5s ease-out 0.36s both;
      }
      .fade-up-6 {
        animation: fadeUp 0.5s ease-out 0.44s both;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      .spin {
        animation: spin 0.9s linear infinite;
      }

      /* ── CONDITIONAL SECTION ──────────────────────────────────────────────────── */
      #vaccinationLicenseSection {
        overflow: hidden;
        max-height: 0;
        transition:
          max-height 0.35s ease,
          opacity 0.3s ease;
        opacity: 0;
      }
      #vaccinationLicenseSection.show {
        max-height: 120px;
        opacity: 1;
      }

      /* ── FIELD VALIDATION HINT ────────────────────────────────────────────────── */
      .clean-input.error {
        border-color: rgba(248, 113, 113, 0.5);
      }
      .clean-input.ok {
        border-color: rgba(74, 222, 128, 0.35);
      }
    </style>
  </head>

  <body>
    <div class="bg-mesh"><div class="mesh-dot"></div></div>

    <div class="wrapper">

      <!-- ── PAGE HEADER ─────────────────────────────────────────────────────── -->
      <div class="page-header fade-up-1">
        <div class="page-eyebrow"><i class="fas fa-gavel"></i>Livestock Auction</div>
        <div class="page-title">Create <span>Auction</span></div>
        <div class="page-sub">List your premium livestock and let verified
          buyers compete in real-time bidding on the AgriVault marketplace.</div>
      </div>

      <!-- ── PROGRESS STEPPER ────────────────────────────────────────────────── -->
      <div class="stepper fade-up-2">
        <div class="step-item active" id="stepItem1">
          <div class="step-dot active" id="step1"><i
              class="fas fa-clipboard-list"
            ></i></div>
          <span class="step-label">Details</span>
        </div>
        <div class="step-item" id="stepItem2">
          <div class="step-dot" id="step2"><i class="fas fa-images"></i></div>
          <span class="step-label">Photos</span>
        </div>
        <div class="step-item" id="stepItem3">
          <div class="step-dot" id="step3"><i class="fas fa-tags"></i></div>
          <span class="step-label">Pricing</span>
        </div>
        <div class="step-item" id="stepItem4">
          <div class="step-dot" id="step4"><i class="fas fa-clock"></i></div>
          <span class="step-label">Timing</span>
        </div>
      </div>

      <!-- ── FORM ────────────────────────────────────────────────────────────── -->
      <form
        action="/auctions"
        method="POST"
        enctype="multipart/form-data"
        id="auctionForm"
      >

        <!-- STEP 1 - Animal Details -->
        <div class="form-card fade-up-3" id="section1">
          <div class="section-header">
            <div class="section-icon blue"><i
                class="fas fa-clipboard-list"
              ></i></div>
            <div class="section-header-text">
              <div
                style="display:flex;align-items:center;gap:10px;margin-bottom:4px;"
              >
                <h2>Step 1: Animal Information</h2>
                <div class="section-badge"><i
                    class="fas fa-circle"
                    style="font-size:6px;color:var(--blue)"
                  ></i>Required</div>
              </div>
              <p>Provide detailed specifications of your livestock for potential
                buyers</p>
            </div>
          </div>

          <div class="grid-2">

            <!-- Animal Type -->
            <div class="form-group">
              <label class="form-label"><i class="fas fa-filter"></i>Animal Type
                <span class="req">*</span></label>
              <select
                name="animalType"
                required
                class="clean-select"
                id="animalTypeSelect"
              >
                <option value="" disabled selected>Select animal category</option>
                <option value="1">🐄 Cattle</option>
                <option value="2">🐐 Goat</option>
                <option value="3">🐑 Sheep</option>
                <option value="4">🐷 Pig</option>
                <option value="5">🐔 Poultry</option>
                <option value="6">🐰 Rabbit</option>
                <option value="7">🦆 Duck</option>
              </select>
            </div>

            <!-- Breed -->
            <div class="form-group">
              <label class="form-label"><i class="fas fa-award"></i>Breed
                <span class="req">*</span></label>
              <input
                type="text"
                name="breed"
                id="breedInput"
                required
                placeholder="e.g., Boer Goat, Ankole Cattle"
                class="clean-input"
              />
            </div>

            <!-- Age -->
            <div class="form-group">
              <label class="form-label"><i class="fas fa-calendar-alt"></i>Age
                <span class="req">*</span></label>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <input
                  type="number"
                  name="ageYears"
                  required
                  min="0"
                  max="20"
                  placeholder="Years"
                  class="clean-input"
                />
                <input
                  type="number"
                  name="ageMonths"
                  required
                  min="0"
                  max="11"
                  placeholder="Months"
                  class="clean-input"
                />
              </div>
              <div class="info-text warn"><i class="fas fa-lightbulb"></i>Age
                affects productivity and resale value</div>
            </div>

            <!-- Sex -->
            <div class="form-group">
              <label class="form-label"><i class="fas fa-venus-mars"></i>Sex
                <span class="req">*</span></label>
              <div class="sex-cards">
                <div class="sex-card">
                  <input
                    type="radio"
                    name="sex"
                    value="Male"
                    id="sexMale"
                    required
                  />
                  <label for="sexMale"><i class="fas fa-mars"></i>Male</label>
                </div>
                <div class="sex-card">
                  <input
                    type="radio"
                    name="sex"
                    value="Female"
                    id="sexFemale"
                  />
                  <label for="sexFemale"><i
                      class="fas fa-venus"
                    ></i>Female</label>
                </div>
              </div>
            </div>

            <!-- Weight -->
            <div class="form-group">
              <label class="form-label"><i
                  class="fas fa-weight-hanging"
                ></i>Estimated Weight
                <span class="req">*</span></label>
              <div class="input-icon-wrap">
                <input
                  type="number"
                  name="weight"
                  id="weightInput"
                  required
                  min="1"
                  step="0.1"
                  placeholder="Enter weight in kilograms"
                  class="clean-input"
                />
                <span class="input-suffix">KG</span>
              </div>
              <div class="info-text"><i
                  class="fas fa-info-circle"
                  style="color:var(--accent2)"
                ></i>Weight determines meat value per unit</div>
            </div>

            <!-- Health Status -->
            <div class="form-group">
              <label class="form-label"><i class="fas fa-heart-pulse"></i>Health
                / Condition
                <span class="req">*</span></label>
              <select name="healthStatus" required class="clean-select">
                <option value="" disabled selected>Select health condition</option>
                <option value="Excellent">Excellent - Perfect condition</option>
                <option value="Good">Good - Minor wear, healthy</option>
                <option value="Fair">Fair - Acceptable condition</option>
              </select>
            </div>

            <!-- Quantity -->
            <div class="form-group">
              <label class="form-label"><i class="fas fa-hashtag"></i>Quantity
                <span class="req">*</span></label>
              <input
                type="number"
                name="quantity"
                required
                min="1"
                max="100"
                value="1"
                placeholder="Number of animals"
                class="clean-input"
              />
            </div>

            <!-- Location -->
            <div class="form-group">
              <label class="form-label"><i
                  class="fas fa-map-marker-alt"
                ></i>Location
                <span class="req">*</span></label>
              <input
                type="text"
                name="location"
                id="locationInput"
                required
                placeholder="e.g., Kampala, Mbarara, Gulu"
                class="clean-input"
              />
            </div>

            <!-- Vaccination Toggle -->
            <div class="form-group col-span-2">
              <div class="toggle-row">
                <div class="toggle-left">
                  <div class="toggle-icon"><i
                      class="fas fa-shield-check"
                    ></i></div>
                  <div>
                    <div
                      style="font-weight:600;color:var(--text);font-size:14px;"
                    >Vaccination Status</div>
                    <div style="font-size:12px;color:var(--text3);">Has this
                      animal received full vaccination?</div>
                  </div>
                </div>
                <div class="toggle-right">
                  <div class="toggle-switch-wrap">
                    <input
                      type="checkbox"
                      name="vaccinated"
                      id="vaccinatedToggle"
                    />
                    <label for="vaccinatedToggle" class="toggle-switch"></label>
                  </div>
                  <span id="vaccinatedLabel">No</span>
                </div>
              </div>
            </div>

            <!-- Vaccination License (Conditional) -->
            <div class="form-group col-span-2" id="vaccinationLicenseSection">
              <label class="form-label"><i
                  class="fas fa-file-medical"
                ></i>Vaccination Certificate Number</label>
              <input
                type="text"
                name="vaccinationLicense"
                id="vaccinationLicense"
                placeholder="Enter vaccination certificate / license number"
                class="clean-input"
                style="font-family:'DM Mono',monospace;text-transform:uppercase;letter-spacing:0.06em;"
              />
              <div class="info-text accent"><i
                  class="fas fa-check-circle"
                ></i>Verified certification is a major trust signal for buyers</div>
            </div>

            <!-- Description -->
            <div class="form-group col-span-2">
              <label class="form-label"><i
                  class="fas fa-pencil-alt"
                ></i>Detailed Description
                <span class="req">*</span></label>
              <textarea
                name="description"
                required
                rows="5"
                minlength="50"
                maxlength="1000"
                placeholder="Provide a comprehensive overview of your livestock, include feeding habits, history, unique characteristics, and anything that adds value..."
                class="clean-textarea"
                id="descTextarea"
              ></textarea>
              <div class="desc-footer">
                <div class="info-text"><i
                    class="fas fa-info-circle"
                    style="color:var(--accent2)"
                  ></i>Minimum 50 characters required</div>
                <div class="char-count"><span
                    id="descCharCount"
                    class=""
                  >0</span>/1000</div>
              </div>
            </div>

            <!-- Live Preview -->
            <div class="col-span-2">
              <div
                style="font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);margin-bottom:10px;display:flex;align-items:center;gap:8px;"
              >
                <i
                  class="fas fa-chart-line"
                  style="color:var(--accent)"
                ></i>Live Listing Preview
              </div>
              <div class="preview-bar">
                <div class="preview-item">
                  <i class="fas fa-filter" style="color:var(--orange)"></i>
                  <div class="preview-label">Category</div>
                  <div class="preview-value" id="previewCategory">-</div>
                </div>
                <div class="preview-item">
                  <i class="fas fa-award" style="color:var(--blue)"></i>
                  <div class="preview-label">Breed</div>
                  <div class="preview-value" id="previewBreed">-</div>
                </div>
                <div class="preview-item">
                  <i
                    class="fas fa-weight-hanging"
                    style="color:var(--accent)"
                  ></i>
                  <div class="preview-label">Weight</div>
                  <div class="preview-value" id="previewWeight">-</div>
                </div>
                <div class="preview-item">
                  <i
                    class="fas fa-map-marker-alt"
                    style="color:var(--accent5)"
                  ></i>
                  <div class="preview-label">Location</div>
                  <div class="preview-value" id="previewLocation">-</div>
                </div>
              </div>
            </div>

          </div>
        </div>

        <!-- STEP 2 - Photo Gallery -->
        <div class="form-card fade-up-4" id="section2">
          <div class="section-header">
            <div class="section-icon purple"><i class="fas fa-images"></i></div>
            <div class="section-header-text">
              <div
                style="display:flex;align-items:center;gap:10px;margin-bottom:4px;"
              >
                <h2>Step 2: Photo Gallery</h2>
                <div class="section-badge"><i
                    class="fas fa-circle"
                    style="font-size:6px;color:var(--accent5)"
                  ></i>2–4 Photos</div>
              </div>
              <p>High-quality images drive 3x more bids, no photo means no
                serious buyer</p>
            </div>
          </div>

          <!-- Drop Zone -->
          <div
            class="photo-zone"
            id="photoZone"
            onclick="if(event.target===this||event.target.closest('#uploadPrompt'))document.getElementById('animalPhotosInput').click()"
          >
            <input
              type="file"
              name="animalPhotos"
              id="animalPhotosInput"
              accept="image/*"
              multiple
              required
              class="hidden"
            />

            <div id="uploadPrompt">
              <i class="fas fa-cloud-upload-alt upload-icon"></i>
              <h3>Drag & Drop Images Here</h3>
              <p>Showcase your livestock with clear, well-lit photos from
                multiple angles</p>
              <button
                type="button"
                class="btn-select-photo"
                onclick="event.stopPropagation();document.getElementById('animalPhotosInput').click()"
              >
                <i class="fas fa-camera"></i>Browse Photos
              </button>
              <div class="upload-badges" style="margin-top:18px;">
                <div class="upload-badge"><i class="fas fa-check"></i>JPG / PNG
                  / WEBP</div>
                <div class="upload-badge"><i class="fas fa-check"></i>Max 5 MB
                  each</div>
                <div class="upload-badge"><i class="fas fa-check"></i>2 to 4
                  photos</div>
              </div>
            </div>

            <!-- Preview Grid (shown after upload) -->
            <div id="photoPreviewGrid"></div>

            <!-- Photo count badge -->
            <div id="photoCountBadge" class="photo-count-badge hidden">
              <i class="fas fa-check-circle"></i>
              <span id="photoCountText">0 photos selected</span>
              <span
                style="margin-left:4px;cursor:pointer;color:var(--accent4);font-weight:700;"
                onclick="event.stopPropagation();removeAllPhotos()"
              >✕ Remove all</span>
            </div>
          </div>
        </div>

        <!-- STEP 3 - Pricing -->
        <div class="form-card fade-up-5" id="section3">
          <div class="section-header">
            <div class="section-icon green"><i class="fas fa-tag"></i></div>
            <div class="section-header-text">
              <h2>Step 3: Pricing &amp; Strategy</h2>
              <p>Set competitive prices to attract serious, high-value bidders</p>
            </div>
          </div>

          <div class="price-row" style="margin-bottom:20px;">
            <div class="form-group">
              <label class="form-label"><i class="fas fa-gavel"></i>Starting Bid
                Price
                <span class="req">*</span></label>
              <div class="price-input-wrap">
                <div class="price-prefix">UGX</div>
                <input
                  type="number"
                  name="startingPrice"
                  id="startingPrice"
                  required
                  min="10000"
                  step="1000"
                  placeholder="0"
                  class="clean-input"
                />
              </div>
              <div class="info-text warn"><i class="fas fa-lightbulb"></i>Lower
                starting price attracts more bidders</div>
            </div>
            <div class="form-group">
              <label class="form-label"><i class="fas fa-lock"></i>Reserve Price
                <span
                  style="color:var(--text3);font-weight:400"
                >(Optional)</span></label>
              <div class="price-input-wrap">
                <div class="price-prefix">UGX</div>
                <input
                  type="number"
                  name="reservePrice"
                  id="reservePrice"
                  min="10000"
                  step="1000"
                  placeholder="0"
                  class="clean-input"
                />
              </div>
              <div class="info-text" style="color:var(--accent3)"><i
                  class="fas fa-eye-slash"
                ></i>Hidden from buyers, protects your minimum value</div>
            </div>
          </div>

          <div class="tips-box blue">
            <h4><i class="fas fa-lightbulb"></i>Pro Pricing Strategy Tips</h4>
            <div class="tips-list">
              <div class="tip-item"><i class="fas fa-check-circle"></i>Research
                similar livestock prices in your local market area</div>
              <div class="tip-item"><i class="fas fa-check-circle"></i>Set your
                reserve 20–30% above starting bid to allow competitive
                escalation</div>
              <div class="tip-item"><i class="fas fa-check-circle"></i>Factor in
                weight, age, breed rarity, and vaccination history for accurate
                valuation</div>
            </div>
          </div>
        </div>

        <!-- STEP 4 - Timing -->
        <div class="form-card fade-up-6" id="section4">
          <div class="section-header">
            <div class="section-icon orange"><i class="fas fa-clock"></i></div>
            <div class="section-header-text">
              <h2>Step 4: Auction Duration</h2>
              <p>Configure when your auction closes, minimum 1 day from now</p>
            </div>
          </div>

          <div class="grid-2" style="margin-bottom:20px;">
            <div class="form-group">
              <label class="form-label"><i class="fas fa-calendar"></i>Auction
                End Date
                <span class="req">*</span></label>
              <input
                type="date"
                name="endDate"
                id="endDate"
                required
                class="clean-input"
              />
            </div>
            <div class="form-group">
              <label class="form-label"><i class="fas fa-clock"></i>Auction End
                Time
                <span class="req">*</span></label>
              <input
                type="time"
                name="endTime"
                id="endTime"
                required
                class="clean-input"
              />
            </div>
            <div class="form-group col-span-2">
              <label class="form-label"><i
                  class="fas fa-globe"
                ></i>Timezone</label>
              <select name="timezone" class="clean-select">
                <option value="EAT" selected>East Africa Time (EAT - UTC+3)</option>
                <option value="UTC">Universal Time (UTC+0)</option>
              </select>
            </div>
          </div>

          <!-- Timer Preview -->
          <div class="tips-box orange">
            <h4><i class="fas fa-stopwatch"></i>Auction Duration Preview</h4>
            <p
              style="font-size:12.5px;color:var(--text2);margin-bottom:18px;"
              id="durationPreview"
            >Select end date and time above to preview the auction countdown</p>
            <div class="timer-display">
              <div class="timer-unit">
                <div class="timer-box" id="daysLeft">00</div>
                <p>Days</p>
              </div>
              <div class="timer-unit">
                <div class="timer-box" id="hoursLeft">00</div>
                <p>Hours</p>
              </div>
              <div class="timer-unit">
                <div class="timer-box" id="minsLeft">00</div>
                <p>Mins</p>
              </div>
            </div>
          </div>
        </div>

        <!-- FINAL - Review and Submit -->
        <div
          class="form-card"
          style="animation:fadeUp 0.5s ease-out 0.52s both;"
        >
          <h3
            style="font-size:15px;font-weight:700;margin-bottom:18px;display:flex;align-items:center;gap:8px;color:var(--text);"
          >
            <i
              class="fas fa-check-square"
              style="color:var(--accent)"
            ></i>Pre-Launch Checklist
          </h3>

          <div class="checklist">
            <div class="checklist-item"><i class="fas fa-check-circle"></i>All
              animal details provided accurately</div>
            <div class="checklist-item"><i class="fas fa-check-circle"></i>At
              least 2 clear, high-quality photos</div>
            <div class="checklist-item"><i
                class="fas fa-check-circle"
              ></i>Competitive and realistic pricing set</div>
            <div class="checklist-item"><i
                class="fas fa-check-circle"
              ></i>Auction timing and timezone confirmed</div>
          </div>

          <div class="terms-box">
            <label class="terms-label">
              <input type="checkbox" name="terms" id="termsCheckbox" required />
              <span>I confirm that all information provided is truthful and
                accurate. I understand the
                <strong style="color:var(--orange)">auction terms &amp;
                  conditions</strong>
                and agree to honor the highest bid if it meets or exceeds my
                reserve price. False information may result in account
                suspension.</span>
            </label>
          </div>

          <div class="btn-row">
            <button type="button" id="saveDraftBtn" class="btn btn-secondary">
              <i class="fas fa-folder-plus"></i>Save Draft
            </button>
            <button type="submit" id="submitBtn" class="btn btn-primary">
              <i class="fas fa-gavel"></i>Launch Auction Now
            </button>
          </div>

          <div class="footer-note">
            <i class="fas fa-shield-check" style="color:var(--accent)"></i>
            Your auction will go live immediately upon submission
          </div>
        </div>

      </form>
    </div>

    <!-- Success Modal -->
    {{#if successMessage}}
      <div class="modal-overlay">
        <div class="modal-box">
          <div class="modal-glow"><i class="fas fa-check"></i></div>
          <div class="modal-title"><span>Auction Live!</span></div>
          <p class="modal-text">{{successMessage}}</p>
          <div class="modal-id-box">
            <div class="modal-id-label">Your Auction ID</div>
            <div class="modal-id-value">{{auctionId}}</div>
          </div>
          <div class="modal-btns">
            <a href="/auctions/animalList" class="modal-btn modal-btn-p"><i
                class="fas fa-eye"
              ></i>View Auction</a>
            <a href="/dashboard/farmer" class="modal-btn modal-btn-s"><i
                class="fas fa-home"
              ></i>Dashboard</a>
          </div>
        </div>
      </div>
    {{/if}}

    <script src="/js/app-theme.js"></script>
    <script src="/js/create-auction-preview.js"></script>
  </body>
</html>


