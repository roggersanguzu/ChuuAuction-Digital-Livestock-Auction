<!-- Ultra-Advanced Ownership Verification System for ChuuAuction -->

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Livestock Ownership Verification | ChuuAuction</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Bricolage+Grotesque:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script>
      tailwind.config = { darkMode: 'class', theme: { extend: { fontFamily: {
      'display': ['Bricolage Grotesque', 'system-ui', 'sans-serif'], 'body':
      ['Outfit', 'system-ui', 'sans-serif'], }, animation: { 'float': 'float 6s
      ease-in-out infinite', 'pulse-slow': 'pulse 4s cubic-bezier(0.4, 0, 0.6,
      1) infinite', 'fade-in': 'fadeIn 0.6s ease-out', 'slide-up': 'slideUp 0.5s
      ease-out', 'scale-in': 'scaleIn 0.4s ease-out', 'glow': 'glow 2s
      ease-in-out infinite', 'shimmer': 'shimmer 2s infinite', 'stamp': 'stamp
      0.6s ease-out', }, keyframes: { float: { '0%, 100%': { transform:
      'translateY(0px)' }, '50%': { transform: 'translateY(-10px)' }, }, fadeIn:
      { '0%': { opacity: '0', transform: 'translateY(10px)' }, '100%': {
      opacity: '1', transform: 'translateY(0)' }, }, slideUp: { '0%': {
      transform: 'translateY(20px)', opacity: '0' }, '100%': { transform:
      'translateY(0)', opacity: '1' }, }, scaleIn: { '0%': { transform:
      'scale(0.9)', opacity: '0' }, '100%': { transform: 'scale(1)', opacity:
      '1' }, }, glow: { '0%, 100%': { boxShadow: '0 0 20px rgba(249, 115, 22,
      0.3)' }, '50%': { boxShadow: '0 0 40px rgba(249, 115, 22, 0.6), 0 0 60px
      rgba(249, 115, 22, 0.3)' }, }, shimmer: { '0%': { backgroundPosition:
      '-200% 0' }, '100%': { backgroundPosition: '200% 0' }, }, stamp: { '0%': {
      transform: 'scale(0) rotate(-180deg)', opacity: '0' }, '50%': { transform:
      'scale(1.1) rotate(5deg)' }, '100%': { transform: 'scale(1) rotate(0deg)',
      opacity: '1' }, } } } } }
    </script>

    <style>
      .font-display {
        font-family: "Bricolage Grotesque", system-ui, sans-serif;
      }
      .font-body {
        font-family: "Outfit", system-ui, sans-serif;
      }

      .text-gradient {
        background: linear-gradient(135deg, #f97316, #dc2626, #ea580c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradient 3s ease infinite;
        background-size: 200% 200%;
      }

      @keyframes gradient {
        0%,
        100% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
      }

      .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .glass-strong {
        background: rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .neon-glow {
        text-shadow:
          0 0 10px rgba(249, 115, 22, 0.8),
          0 0 20px rgba(249, 115, 22, 0.6),
          0 0 30px rgba(249, 115, 22, 0.4);
      }

      .card-3d {
        transform-style: preserve-3d;
        transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
      }

      .card-3d:hover {
        transform: perspective(1000px) rotateY(2deg) rotateX(1deg) scale(1.01);
      }

      .particle {
        position: absolute;
        width: 4px;
        height: 4px;
        background: rgba(249, 115, 22, 0.4);
        border-radius: 50%;
        pointer-events: none;
        animation: particleFloat 5s ease-in-out infinite;
      }

      @keyframes particleFloat {
        0%,
        100% {
          transform: translateY(0) translateX(0);
          opacity: 0;
        }
        10% {
          opacity: 1;
        }
        90% {
          opacity: 1;
        }
        100% {
          transform: translateY(-100px) translateX(30px);
          opacity: 0;
        }
      }

      /* Custom Input Styles */
      .custom-input {
        background: rgba(255, 255, 255, 0.03);
        border: 2px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
      }

      .custom-input:focus {
        background: rgba(255, 255, 255, 0.05);
        border-color: #f97316;
        box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.1);
        outline: none;
      }

      .custom-input:hover {
        border-color: rgba(249, 115, 22, 0.3);
      }

      /* Radio Button Styles */
      .radio-card {
        cursor: pointer;
        transition: all 0.3s ease;
      }

      .radio-card input[type="radio"]:checked + label {
        background: rgba(249, 115, 22, 0.15);
        border-color: #f97316;
      }

      .radio-card:hover label {
        background: rgba(249, 115, 22, 0.08);
        border-color: rgba(249, 115, 22, 0.4);
      }

      /* File Upload Styles */
      .file-upload-zone {
        border: 2px dashed rgba(249, 115, 22, 0.3);
        transition: all 0.3s ease;
        cursor: pointer;
      }

      .file-upload-zone:hover {
        border-color: #f97316;
        background: rgba(249, 115, 22, 0.05);
      }

      .file-upload-zone.active {
        border-color: #f97316;
        background: rgba(249, 115, 22, 0.1);
      }

      /* Contract Watermark */
      .contract-watermark {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-45deg);
        font-size: 8rem;
        font-weight: 900;
        color: rgba(249, 115, 22, 0.03);
        pointer-events: none;
        user-select: none;
        z-index: 0;
      }

      /* Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #1f2937;
      }
      ::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #f97316, #dc2626);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(180deg, #ea580c, #b91c1c);
      }

      /* Preview Image Styles */
      .image-preview {
        position: relative;
        overflow: hidden;
        border-radius: 1rem;
      }

      .image-preview img {
        transition: transform 0.3s ease;
      }

      .image-preview:hover img {
        transform: scale(1.05);
      }

      /* Verification Badge */
      .verification-badge {
        background: linear-gradient(135deg, #f97316, #dc2626);
        animation: stamp 0.6s ease-out;
      }

      /* Progress Steps */
      .step-line {
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 2px;
        background: rgba(255, 255, 255, 0.1);
        z-index: -1;
      }

      .step-line-active {
        background: linear-gradient(90deg, #f97316, #dc2626);
        animation: shimmer 2s infinite;
      }

      /* Signature Area */
      .signature-area {
        border-bottom: 2px solid rgba(249, 115, 22, 0.3);
        min-height: 60px;
        position: relative;
      }

      .signature-area::after {
        content: "Signature";
        position: absolute;
        bottom: -20px;
        left: 0;
        font-size: 0.75rem;
        color: rgba(156, 163, 175, 0.6);
      }
    </style>
  </head>

  <body class="min-h-screen bg-gray-950 text-white font-body overflow-x-hidden">

    <!-- Animated Background -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div
        class="absolute top-20 left-20 w-[600px] h-[600px] bg-orange-500/10 rounded-full blur-[150px] animate-float"
      ></div>
      <div
        class="absolute bottom-20 right-20 w-[500px] h-[500px] bg-red-600/10 rounded-full blur-[150px] animate-float"
        style="animation-delay: 2s;"
      ></div>
      <div
        class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-orange-500/5 to-red-600/5 rounded-full blur-3xl animate-pulse-slow"
      ></div>

      <!-- Particles -->
      <div
        class="particle"
        style="left: 10%; top: 20%; animation-delay: 0s;"
      ></div>
      <div
        class="particle"
        style="left: 80%; top: 30%; animation-delay: 1s;"
      ></div>
      <div
        class="particle"
        style="left: 50%; top: 60%; animation-delay: 2s;"
      ></div>
      <div
        class="particle"
        style="left: 30%; top: 80%; animation-delay: 1.5s;"
      ></div>
      <div
        class="particle"
        style="left: 70%; top: 15%; animation-delay: 0.5s;"
      ></div>
    </div>

    <!-- Main Container -->
    <div class="relative z-10 container mx-auto px-4 py-8 md:py-12 max-w-5xl">

      <!-- Header Section -->
      <div class="mb-12 text-center animate-fade-in">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div
            class="w-16 h-16 rounded-2xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center border border-orange-500/30"
          >
            <i class="bi bi-shield-check text-4xl text-orange-500"></i>
          </div>
        </div>

        <h1 class="text-5xl md:text-6xl font-black font-display mb-4">
          Ownership
          <span class="text-gradient neon-glow">Verification</span>
        </h1>
        <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto">
          Official Livestock Ownership Authentication & Registration System
        </p>

        <!-- Verification ID -->
        <div
          class="mt-6 inline-flex items-center gap-2 px-6 py-3 rounded-full glass border border-orange-500/30"
        >
          <i class="bi bi-fingerprint text-orange-500"></i>
          <span class="text-sm font-semibold">Verification ID:
            <span
              class="text-orange-500"
              id="verificationId"
            >VRF-2026-XXXX</span></span>
        </div>
      </div>

      <!-- Contract Form -->
      <form
        id="verificationForm"
        class="space-y-8 animate-scale-in"
        style="animation-delay: 0.2s;"
      >

        <!-- Contract Document -->
        <div
          class="glass-strong rounded-3xl p-8 md:p-12 relative overflow-hidden card-3d"
        >

          <!-- Watermark -->
          <div class="contract-watermark font-display">VERIFIED</div>

          <!-- Official Header -->
          <div class="relative z-10 mb-10 pb-8 border-b-2 border-gray-800/50">
            <div class="flex items-start justify-between flex-wrap gap-4">
              <div>
                <h2 class="text-3xl font-black font-display mb-2">
                  <span class="text-gradient">OFFICIAL DECLARATION</span>
                </h2>
                <p class="text-sm text-gray-400">Livestock Ownership
                  Verification Contract</p>
              </div>
              <div class="text-right">
                <p class="text-sm text-gray-400">Date of Declaration</p>
                <p class="text-lg font-bold" id="currentDate">05 Feb 2026</p>
              </div>
            </div>
          </div>

          <!-- Section 1: Seller Information -->
          <div class="relative z-10 mb-10">
            <div class="flex items-center gap-3 mb-6">
              <div
                class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-500/20 to-red-600/20 flex items-center justify-center"
              >
                <i class="bi bi-person-badge text-orange-500 text-2xl"></i>
              </div>
              <div>
                <h3 class="text-2xl font-bold font-display">Section I: Declarant
                  Information</h3>
                <p class="text-sm text-gray-400">Personal details of the
                  livestock owner</p>
              </div>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
              <!-- Full Name -->
              <div class="md:col-span-2">
                <label class="block text-sm font-semibold text-gray-300 mb-3">
                  <i class="bi bi-person text-orange-500 mr-2"></i>Full Legal
                  Name
                  <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="sellerName"
                  required
                  placeholder="Enter your full name as per national ID"
                  class="w-full px-6 py-4 rounded-xl custom-input text-white placeholder-gray-500 font-medium"
                />
              </div>

              <!-- Gender -->
              <div>
                <label class="block text-sm font-semibold text-gray-300 mb-3">
                  <i
                    class="bi bi-gender-ambiguous text-orange-500 mr-2"
                  ></i>Gender
                  <span class="text-red-500">*</span>
                </label>
                <div class="grid grid-cols-2 gap-4">
                  <div class="radio-card">
                    <input
                      type="radio"
                      name="sellerGender"
                      value="Male"
                      id="genderMale"
                      class="hidden"
                      required
                    />
                    <label
                      for="genderMale"
                      class="block px-6 py-4 rounded-xl glass border border-gray-800/50 text-center font-semibold cursor-pointer transition-all"
                    >
                      <i class="bi bi-gender-male text-blue-500 mr-2"></i>Male
                    </label>
                  </div>
                  <div class="radio-card">
                    <input
                      type="radio"
                      name="sellerGender"
                      value="Female"
                      id="genderFemale"
                      class="hidden"
                    />
                    <label
                      for="genderFemale"
                      class="block px-6 py-4 rounded-xl glass border border-gray-800/50 text-center font-semibold cursor-pointer transition-all"
                    >
                      <i
                        class="bi bi-gender-female text-pink-500 mr-2"
                      ></i>Female
                    </label>
                  </div>
                </div>
              </div>

              <!-- NIN -->
              <div>
                <label class="block text-sm font-semibold text-gray-300 mb-3">
                  <i
                    class="bi bi-credit-card-2-front text-orange-500 mr-2"
                  ></i>National ID Number (NIN)
                  <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="sellerNIN"
                  required
                  placeholder="CM0000000000000"
                  pattern="[A-Z0-9]{14}"
                  maxlength="14"
                  class="w-full px-6 py-4 rounded-xl custom-input text-white placeholder-gray-500 font-mono font-bold tracking-wider uppercase"
                />
                <p class="text-xs text-gray-500 mt-2"><i
                    class="bi bi-info-circle mr-1"
                  ></i>14-character alphanumeric code</p>
              </div>
            </div>
          </div>

          <!-- Section 2: Animal Details -->
          <div class="relative z-10 mb-10 pt-8 border-t-2 border-gray-800/50">
            <div class="flex items-center gap-3 mb-6">
              <div
                class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500/20 to-emerald-600/20 flex items-center justify-center"
              >
                <i class="bi bi-clipboard-data text-green-500 text-2xl"></i>
              </div>
              <div>
                <h3 class="text-2xl font-bold font-display">Section II:
                  Livestock Specification</h3>
                <p class="text-sm text-gray-400">Detailed description of the
                  animal(s) being verified</p>
              </div>
            </div>

            <div class="space-y-6">
              <!-- Animal Description -->
              <div>
                <label class="block text-sm font-semibold text-gray-300 mb-3">
                  <i
                    class="bi bi-pencil-square text-orange-500 mr-2"
                  ></i>Complete Animal Description
                  <span class="text-red-500">*</span>
                </label>
                <textarea
                  name="animalDetails"
                  required
                  rows="6"
                  placeholder="Provide comprehensive details including:
• Animal Type (Cattle, Goat, Sheep, etc.)
• Gender/Sex of the animal(s)
• Primary and secondary colors
• Breed or cross-breed information
• Approximate age
• Any distinctive markings or features
• Total number of animals (if multiple)"
                  class="w-full px-6 py-4 rounded-xl custom-input text-white placeholder-gray-500 font-medium resize-none"
                ></textarea>
                <div class="flex items-center justify-between mt-2">
                  <p class="text-xs text-gray-500"><i
                      class="bi bi-info-circle mr-1"
                    ></i>Minimum 50 characters required</p>
                  <span class="text-xs text-gray-500"><span
                      id="charCount"
                    >0</span>/500</span>
                </div>
              </div>

              <!-- Quick Animal Tags -->
              <div>
                <label class="block text-sm font-semibold text-gray-300 mb-3">
                  <i class="bi bi-tags text-orange-500 mr-2"></i>Quick
                  Classification Tags
                </label>
                <div class="flex flex-wrap gap-2" id="animalTags">
                  <button
                    type="button"
                    class="tag-btn px-4 py-2 rounded-full glass border border-gray-800/50 text-sm font-semibold hover:border-orange-500/50 hover:bg-orange-500/10 transition-all"
                    data-tag="Cattle"
                  >🐄 Cattle</button>
                  <button
                    type="button"
                    class="tag-btn px-4 py-2 rounded-full glass border border-gray-800/50 text-sm font-semibold hover:border-orange-500/50 hover:bg-orange-500/10 transition-all"
                    data-tag="Goat"
                  >🐐 Goat</button>
                  <button
                    type="button"
                    class="tag-btn px-4 py-2 rounded-full glass border border-gray-800/50 text-sm font-semibold hover:border-orange-500/50 hover:bg-orange-500/10 transition-all"
                    data-tag="Sheep"
                  >🐑 Sheep</button>
                  <button
                    type="button"
                    class="tag-btn px-4 py-2 rounded-full glass border border-gray-800/50 text-sm font-semibold hover:border-orange-500/50 hover:bg-orange-500/10 transition-all"
                    data-tag="Pig"
                  >🐷 Pig</button>
                  <button
                    type="button"
                    class="tag-btn px-4 py-2 rounded-full glass border border-gray-800/50 text-sm font-semibold hover:border-orange-500/50 hover:bg-orange-500/10 transition-all"
                    data-tag="Poultry"
                  >🐔 Poultry</button>
                </div>
              </div>
            </div>
          </div>

          <!-- Section 3: LC1 Documentation -->
          <div class="relative z-10 mb-10 pt-8 border-t-2 border-gray-800/50">
            <div class="flex items-center gap-3 mb-6">
              <div
                class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500/20 to-indigo-600/20 flex items-center justify-center"
              >
                <i class="bi bi-file-earmark-check text-blue-500 text-2xl"></i>
              </div>
              <div>
                <h3 class="text-2xl font-bold font-display">Section III: Legal
                  Documentation</h3>
                <p class="text-sm text-gray-400">LC1 letter or official
                  ownership document</p>
              </div>
            </div>

            <!-- LC1 Possession -->
            <div class="mb-6">
              <label class="block text-sm font-semibold text-gray-300 mb-4">
                <i class="bi bi-question-circle text-orange-500 mr-2"></i>Do you
                possess an LC1 Letter or Official Ownership Document?
                <span class="text-red-500">*</span>
              </label>
              <div class="grid md:grid-cols-2 gap-4">
                <div class="radio-card">
                  <input
                    type="radio"
                    name="hasLC1"
                    value="Yes"
                    id="lc1Yes"
                    class="hidden"
                    required
                  />
                  <label
                    for="lc1Yes"
                    class="block px-6 py-5 rounded-xl glass border border-gray-800/50 text-center font-semibold cursor-pointer transition-all"
                  >
                    <i
                      class="bi bi-check-circle text-green-500 text-3xl mb-2 block"
                    ></i>
                    <span class="block">Yes, I have the document</span>
                  </label>
                </div>
                <div class="radio-card">
                  <input
                    type="radio"
                    name="hasLC1"
                    value="No"
                    id="lc1No"
                    class="hidden"
                  />
                  <label
                    for="lc1No"
                    class="block px-6 py-5 rounded-xl glass border border-gray-800/50 text-center font-semibold cursor-pointer transition-all"
                  >
                    <i
                      class="bi bi-x-circle text-red-500 text-3xl mb-2 block"
                    ></i>
                    <span class="block">No, I don't have it</span>
                  </label>
                </div>
              </div>
            </div>

            <!-- LC1 Document Upload -->
            <div id="lc1UploadSection" class="hidden">
              <label class="block text-sm font-semibold text-gray-300 mb-4">
                <i class="bi bi-cloud-upload text-orange-500 mr-2"></i>Upload
                LC1 Letter / Official Document
                <span class="text-red-500">*</span>
              </label>
              <div
                class="file-upload-zone rounded-xl p-8 text-center relative overflow-hidden"
              >
                <input
                  type="file"
                  name="lc1Document"
                  id="lc1FileInput"
                  accept=".pdf,.jpg,.jpeg,.png"
                  class="hidden"
                />
                <div id="lc1UploadPrompt">
                  <i
                    class="bi bi-file-earmark-arrow-up text-6xl text-orange-500/50 mb-4 block"
                  ></i>
                  <p class="text-lg font-semibold mb-2">Click to upload or drag
                    and drop</p>
                  <p class="text-sm text-gray-400 mb-4">PDF, JPG, or PNG (Max
                    5MB)</p>
                  <button
                    type="button"
                    onclick="document.getElementById('lc1FileInput').click()"
                    class="px-6 py-3 rounded-xl bg-gradient-to-r from-orange-500 to-red-600 text-white font-semibold hover:shadow-lg hover:shadow-orange-500/30 transition-all"
                  >
                    <i class="bi bi-folder2-open mr-2"></i>Browse Files
                  </button>
                </div>
                <div id="lc1FilePreview" class="hidden">
                  <i
                    class="bi bi-file-earmark-check text-6xl text-green-500 mb-4 block"
                  ></i>
                  <p class="text-lg font-semibold mb-2" id="lc1FileName"></p>
                  <p class="text-sm text-gray-400 mb-4" id="lc1FileSize"></p>
                  <button
                    type="button"
                    onclick="clearLC1File()"
                    class="px-6 py-3 rounded-xl glass border border-red-500/30 text-red-500 font-semibold hover:bg-red-500/10 transition-all"
                  >
                    <i class="bi bi-trash mr-2"></i>Remove File
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Section 4: Animal Photography -->
          <div class="relative z-10 pt-8 border-t-2 border-gray-800/50">
            <div class="flex items-center gap-3 mb-6">
              <div
                class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500/20 to-pink-600/20 flex items-center justify-center"
              >
                <i class="bi bi-camera text-purple-500 text-2xl"></i>
              </div>
              <div>
                <h3 class="text-2xl font-bold font-display">Section IV: Visual
                  Documentation</h3>
                <p class="text-sm text-gray-400">Photographic evidence of
                  livestock ownership</p>
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-300 mb-4">
                <i class="bi bi-images text-orange-500 mr-2"></i>Upload Animal
                Photo(s)
                <span class="text-red-500">*</span>
              </label>
              <p class="text-sm text-gray-400 mb-4">
                <i class="bi bi-info-circle text-blue-500 mr-2"></i>
                <strong>For multiple animals:</strong>
                Please take a group photo showing all animals together
              </p>

              <div
                class="file-upload-zone rounded-xl p-8 text-center relative overflow-hidden"
              >
                <input
                  type="file"
                  name="animalPhotos"
                  id="animalPhotoInput"
                  accept="image/*"
                  multiple
                  class="hidden"
                  required
                />
                <div id="photoUploadPrompt">
                  <i
                    class="bi bi-camera-fill text-6xl text-purple-500/50 mb-4 block"
                  ></i>
                  <p class="text-lg font-semibold mb-2">Upload clear photos of
                    your animal(s)</p>
                  <p class="text-sm text-gray-400 mb-4">JPG or PNG • Max 5MB per
                    image • Multiple photos allowed</p>
                  <button
                    type="button"
                    onclick="document.getElementById('animalPhotoInput').click()"
                    class="px-6 py-3 rounded-xl bg-gradient-to-r from-purple-500 to-pink-600 text-white font-semibold hover:shadow-lg hover:shadow-purple-500/30 transition-all"
                  >
                    <i class="bi bi-camera mr-2"></i>Take or Upload Photos
                  </button>
                </div>
                <div
                  id="photoPreviewGrid"
                  class="hidden grid grid-cols-2 md:grid-cols-4 gap-4"
                ></div>
              </div>
            </div>
          </div>

        </div>

        <!-- Declaration & Consent -->
        <div
          class="glass-strong rounded-3xl p-8 md:p-10 card-3d animate-slide-up"
          style="animation-delay: 0.4s;"
        >
          <div class="flex items-start gap-4 mb-6">
            <div
              class="w-12 h-12 rounded-xl bg-gradient-to-br from-yellow-500/20 to-amber-600/20 flex items-center justify-center flex-shrink-0"
            >
              <i
                class="bi bi-exclamation-triangle text-yellow-500 text-2xl"
              ></i>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold font-display mb-2">Legal Declaration
                & Consent</h3>
              <p class="text-sm text-gray-400">Please read carefully before
                proceeding</p>
            </div>
          </div>

          <div
            class="bg-yellow-500/5 border border-yellow-500/20 rounded-xl p-6 mb-6"
          >
            <h4 class="font-bold text-yellow-500 mb-3 flex items-center gap-2">
              <i class="bi bi-shield-exclamation"></i>
              Important Notice
            </h4>
            <ul class="space-y-2 text-sm text-gray-300">
              <li class="flex items-start gap-2">
                <i class="bi bi-check-circle text-yellow-500 mt-1"></i>
                <span>I hereby declare that all information provided above is
                  true and accurate to the best of my knowledge.</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="bi bi-check-circle text-yellow-500 mt-1"></i>
                <span>I confirm that I am the lawful owner of the livestock
                  described in this document.</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="bi bi-check-circle text-yellow-500 mt-1"></i>
                <span>I understand that providing false information may result
                  in legal consequences.</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="bi bi-check-circle text-yellow-500 mt-1"></i>
                <span><strong class="text-red-400">Once submitted, this
                    verification cannot be edited or updated.</strong></span>
              </li>
            </ul>
          </div>

          <!-- Consent Checkbox -->
          <div class="mb-6">
            <label class="flex items-start gap-4 cursor-pointer group">
              <input
                type="checkbox"
                name="consent"
                id="consentCheckbox"
                required
                class="mt-1 w-6 h-6 rounded border-2 border-gray-600 bg-transparent checked:bg-orange-500 checked:border-orange-500 transition-all cursor-pointer"
              />
              <span
                class="text-sm font-medium text-gray-300 group-hover:text-white transition-colors"
              >
                I have read and agree to the terms stated above. I consent to
                the processing of my personal data for verification purposes and
                understand that this submission is
                <strong class="text-orange-500">final and irrevocable</strong>.
              </span>
            </label>
          </div>

          <!-- Signature Section -->
          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <div>
              <label
                class="block text-sm font-semibold text-gray-300 mb-3"
              >Digital Signature</label>
              <div class="signature-area"></div>
            </div>
            <div>
              <label
                class="block text-sm font-semibold text-gray-300 mb-3"
              >Date</label>
              <input
                type="text"
                readonly
                value="05 February 2026"
                class="w-full px-6 py-4 rounded-xl glass border border-gray-800/50 text-gray-400 font-medium"
              />
            </div>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="submitBtn"
            class="w-full py-6 rounded-xl bg-gradient-to-r from-orange-500 via-red-600 to-orange-500 bg-size-200 hover:bg-pos-100 text-white font-bold text-lg shadow-xl shadow-orange-500/30 hover:shadow-orange-500/50 transition-all duration-500 flex items-center justify-center gap-3 group disabled:opacity-50 disabled:cursor-not-allowed"
            style="background-size: 200% auto;"
          >
            <i
              class="bi bi-shield-check text-2xl group-hover:scale-110 transition-transform"
            ></i>
            <span>Submit Verification Application</span>
            <i
              class="bi bi-arrow-right text-xl group-hover:translate-x-2 transition-transform"
            ></i>
          </button>

          <p class="text-center text-xs text-gray-500 mt-4">
            <i class="bi bi-lock-fill text-green-500 mr-1"></i>
            Your data is encrypted and securely stored in compliance with data
            protection regulations
          </p>
        </div>

        <!-- Support Contact -->
        <div
          class="text-center glass rounded-2xl p-6 animate-fade-in"
          style="animation-delay: 0.6s;"
        >
          <p class="text-sm text-gray-400 mb-2">Need assistance with the
            verification process?</p>
          <div class="flex items-center justify-center gap-6 flex-wrap">
            <a
              href="tel:+256700000000"
              class="text-orange-500 font-semibold hover:text-orange-400 transition-colors"
            >
              <i class="bi bi-telephone-fill mr-2"></i>+256 700 000 000
            </a>
            <a
              href="mailto:support@chuuauction.com"
              class="text-orange-500 font-semibold hover:text-orange-400 transition-colors"
            >
              <i class="bi bi-envelope-fill mr-2"></i>support@chuuauction.com
            </a>
          </div>
        </div>

      </form>

    </div>

    <!-- Success Modal -->
    <div
      id="successModal"
      class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden items-center justify-center p-4"
    >
      <div
        class="glass-strong rounded-3xl p-8 md:p-12 max-w-2xl w-full text-center animate-scale-in border-2 border-orange-500/30"
      >
        <div
          class="w-24 h-24 mx-auto mb-6 rounded-full bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center verification-badge"
        >
          <i class="bi bi-check-lg text-5xl text-white"></i>
        </div>

        <h2 class="text-4xl font-black font-display mb-4">
          <span class="text-gradient">Verification Submitted!</span>
        </h2>

        <p class="text-gray-300 text-lg mb-6">
          Your ownership verification application has been successfully
          submitted and is now under review.
        </p>

        <div class="bg-gray-800/50 rounded-2xl p-6 mb-6">
          <p class="text-sm text-gray-400 mb-2">Your Verification Reference
            Number</p>
          <p
            class="text-3xl font-bold text-orange-500 font-mono"
            id="referenceNumber"
          >VRF-2026-XXXX</p>
        </div>

        <div
          class="text-left bg-blue-500/10 border border-blue-500/20 rounded-xl p-4 mb-6"
        >
          <h4 class="font-bold text-blue-400 mb-2 flex items-center gap-2">
            <i class="bi bi-info-circle"></i>Next Steps
          </h4>
          <ul class="text-sm text-gray-300 space-y-1">
            <li>• Review typically takes 2-3 business days</li>
            <li>• You will receive updates via SMS and email</li>
            <li>• Keep your reference number for tracking</li>
          </ul>
        </div>

        <button
          onclick="window.location.href='/dashboard/farmer'"
          class="px-8 py-4 rounded-xl bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold hover:shadow-xl hover:shadow-orange-500/30 transition-all"
        >
          <i class="bi bi-house-door mr-2"></i>Return to Dashboard
        </button>
      </div>
    </div>

    <script>
      // Generate unique verification ID function generateVerificationId() {
      const timestamp = Date.now().toString(36).toUpperCase(); const random =
      Math.random().toString(36).substring(2, 6).toUpperCase(); return
      `VRF-2026-${timestamp}${random}`; } // Set current date
      document.getElementById('currentDate').textContent = new
      Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year:
      'numeric' }); // Set verification ID const verId =
      generateVerificationId();
      document.getElementById('verificationId').textContent = verId; //
      Character counter for animal details const animalDetailsTextarea =
      document.querySelector('textarea[name="animalDetails"]'); const charCount
      = document.getElementById('charCount');
      animalDetailsTextarea?.addEventListener('input', (e) => { const count =
      e.target.value.length; charCount.textContent = count; if (count >= 50) {
      charCount.classList.add('text-green-500');
      charCount.classList.remove('text-red-500'); } else {
      charCount.classList.add('text-red-500');
      charCount.classList.remove('text-green-500'); } }); // Animal tag buttons
      document.querySelectorAll('.tag-btn').forEach(btn => {
      btn.addEventListener('click', () => { const tag = btn.dataset.tag; const
      textarea = document.querySelector('textarea[name="animalDetails"]'); const
      currentText = textarea.value; // Toggle active state
      btn.classList.toggle('border-orange-500');
      btn.classList.toggle('bg-orange-500/20'); // Add tag to textarea if not
      present if (!currentText.includes(tag)) { textarea.value = currentText ?
      `${currentText}\n${tag}: ` : `${tag}: `; textarea.dispatchEvent(new
      Event('input')); textarea.focus(); } }); }); // LC1 Document visibility
      toggle const lc1Radio = document.querySelectorAll('input[name="hasLC1"]');
      const lc1UploadSection = document.getElementById('lc1UploadSection');
      const lc1FileInput = document.getElementById('lc1FileInput');
      lc1Radio.forEach(radio => { radio.addEventListener('change', (e) => { if
      (e.target.value === 'Yes') { lc1UploadSection.classList.remove('hidden');
      lc1UploadSection.classList.add('animate-slide-up'); lc1FileInput.required
      = true; } else { lc1UploadSection.classList.add('hidden');
      lc1FileInput.required = false; clearLC1File(); } }); }); // LC1 File
      Upload Handler
      document.getElementById('lc1FileInput')?.addEventListener('change', (e) =>
      { const file = e.target.files[0]; if (file) { const fileName = file.name;
      const fileSize = (file.size / 1024 / 1024).toFixed(2) + ' MB';
      document.getElementById('lc1FileName').textContent = fileName;
      document.getElementById('lc1FileSize').textContent = fileSize;
      document.getElementById('lc1UploadPrompt').classList.add('hidden');
      document.getElementById('lc1FilePreview').classList.remove('hidden'); //
      Add success animation
      document.querySelector('.file-upload-zone').classList.add('active'); } });
      function clearLC1File() { document.getElementById('lc1FileInput').value =
      ''; document.getElementById('lc1UploadPrompt').classList.remove('hidden');
      document.getElementById('lc1FilePreview').classList.add('hidden');
      document.querySelector('.file-upload-zone').classList.remove('active'); }
      // Animal Photo Upload Handler
      document.getElementById('animalPhotoInput')?.addEventListener('change',
      (e) => { const files = e.target.files; if (files.length > 0) { const grid
      = document.getElementById('photoPreviewGrid'); grid.innerHTML = '';
      Array.from(files).forEach((file, index) => { const reader = new
      FileReader(); reader.onload = (e) => { const div =
      document.createElement('div'); div.className = 'image-preview relative
      group'; div.innerHTML = ` <img src="${e.target.result}" alt="Animal
      ${index + 1}" class="w-full h-32 object-cover rounded-lg border-2
      border-gray-800/50" /> <div class="absolute inset-0 bg-black/60 opacity-0
      group-hover:opacity-100 transition-opacity rounded-lg flex items-center
      justify-center"> <button type="button" onclick="removePhoto(${index})"
      class="px-3 py-2 bg-red-500 rounded-lg text-white text-sm font-semibold">
      <i class="bi bi-trash"></i> Remove </button> </div> `;
      grid.appendChild(div); }; reader.readAsDataURL(file); });
      document.getElementById('photoUploadPrompt').classList.add('hidden');
      grid.classList.remove('hidden'); } }); function removePhoto(index) { // In
      a real implementation, you'd manage file removal properly // For now, just
      clear and prompt re-upload
      document.getElementById('animalPhotoInput').value = '';
      document.getElementById('photoUploadPrompt').classList.remove('hidden');
      document.getElementById('photoPreviewGrid').classList.add('hidden'); } //
      Drag and drop for file uploads
      document.querySelectorAll('.file-upload-zone').forEach(zone => {
      zone.addEventListener('dragover', (e) => { e.preventDefault();
      zone.classList.add('active'); }); zone.addEventListener('dragleave', () =>
      { zone.classList.remove('active'); }); zone.addEventListener('drop', (e)
      => { e.preventDefault(); zone.classList.remove('active'); const input =
      zone.querySelector('input[type="file"]'); input.files =
      e.dataTransfer.files; input.dispatchEvent(new Event('change', { bubbles:
      true })); }); }); // Form submission
      document.getElementById('verificationForm')?.addEventListener('submit',
      async (e) => { e.preventDefault(); const submitBtn =
      document.getElementById('submitBtn'); const originalText =
      submitBtn.innerHTML; // Disable button and show loading submitBtn.disabled
      = true; submitBtn.innerHTML = ` <i class="bi bi-hourglass-split
      animate-spin text-2xl"></i> <span>Processing Verification...</span> `; //
      Simulate API call setTimeout(() => { // Generate reference number
      document.getElementById('referenceNumber').textContent = verId; // Show
      success modal
      document.getElementById('successModal').classList.remove('hidden');
      document.getElementById('successModal').classList.add('flex'); // Reset
      button submitBtn.disabled = false; submitBtn.innerHTML = originalText; },
      2000); }); // NIN auto-formatting const ninInput =
      document.querySelector('input[name="sellerNIN"]');
      ninInput?.addEventListener('input', (e) => { e.target.value =
      e.target.value.toUpperCase(); }); // Form validation enhancement const
      form = document.getElementById('verificationForm');
      form?.addEventListener('invalid', (e) => { e.preventDefault(); const
      firstInvalid = form.querySelector(':invalid');
      firstInvalid?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      firstInvalid?.focus(); }, true);
    </script>

  </body>
</html>