<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Smart Price Calculator — AgriVault</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>

<style>
/* ── RESET ─────────────────────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}

/* ── TOKENS ────────────────────────────────────────────────────────────── */
:root{
  --bg:       #050a12;
  --bg2:      #080f1c;
  --surface:  rgba(255,255,255,0.028);
  --surface2: rgba(255,255,255,0.055);
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.13);

  --fire:     #f97316;
  --fire2:    #ef4444;
  --fire3:    #fb923c;
  --ember:    rgba(249,115,22,0.12);

  --cyan:     #22d3ee;
  --violet:   #a78bfa;
  --emerald:  #34d399;
  --amber:    #fbbf24;
  --rose:     #fb7185;
  --blue:     #60a5fa;

  --text:     #f1f5ff;
  --text2:    #8493a8;
  --text3:    #3d4f63;

  --r2: 8px;
  --r3: 12px;
  --r4: 16px;
  --r5: 20px;
  --r6: 24px;
}

body{
  font-family:'DM Sans',sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  overflow-x:hidden;
  line-height:1.6;
}

/* ── BACKGROUND ────────────────────────────────────────────────────────── */
.bg-canvas{
  position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;
}
.bg-orb{
  position:absolute;border-radius:50%;filter:blur(120px);
  animation:orbFloat 8s ease-in-out infinite;
}
.orb-1{ top:-10%;left:-5%;  width:600px;height:600px;background:radial-gradient(circle,rgba(249,115,22,0.09),transparent 70%); animation-delay:0s;}
.orb-2{ bottom:-10%;right:-5%;width:700px;height:700px;background:radial-gradient(circle,rgba(239,68,68,0.07),transparent 70%); animation-delay:3s;}
.orb-3{ top:40%;left:40%;  width:500px;height:500px;background:radial-gradient(circle,rgba(34,211,238,0.04),transparent 70%); animation-delay:5s;}

.bg-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(249,115,22,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(249,115,22,0.025) 1px,transparent 1px);
  background-size:60px 60px;
  animation:gridDrift 25s linear infinite;
}

@keyframes orbFloat{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-20px) scale(1.04);}}
@keyframes gridDrift{0%{background-position:0 0;}100%{background-position:60px 60px;}}

/* ── WRAPPER ───────────────────────────────────────────────────────────── */
.wrapper{
  position:relative;z-index:1;
  max-width:1280px;margin:0 auto;
  padding:36px 24px 80px;
}

/* ── PAGE HEADER ───────────────────────────────────────────────────────── */
.page-header{
  display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;
  gap:20px;margin-bottom:40px;
}
.eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
  color:var(--fire);background:rgba(249,115,22,0.1);
  border:1px solid rgba(249,115,22,0.25);
  padding:5px 14px;border-radius:100px;margin-bottom:12px;
}
.page-title{
  font-family:'Syne',sans-serif;
  font-size:clamp(28px,4.5vw,46px);font-weight:800;line-height:1.1;
  margin-bottom:8px;
}
.page-title .fire{
  background:linear-gradient(135deg,#f97316,#ef4444,#fb923c);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;background-size:200%;
  animation:fireShift 3s ease infinite;
}
@keyframes fireShift{0%,100%{background-position:0% 50%;}50%{background-position:100% 50%;}}
.page-sub{font-size:14px;color:var(--text2);}

.live-badge{
  display:flex;align-items:center;gap:8px;
  padding:8px 16px;border-radius:100px;
  background:rgba(52,211,153,0.08);
  border:1px solid rgba(52,211,153,0.2);
  font-size:12px;font-weight:700;color:var(--emerald);
}
.pulse-dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--emerald);
  animation:pulseGlow 2s ease-in-out infinite;
}
@keyframes pulseGlow{0%,100%{box-shadow:0 0 0 0 rgba(52,211,153,0.4);}50%{box-shadow:0 0 0 6px rgba(52,211,153,0);}}

/* ── MAIN GRID ─────────────────────────────────────────────────────────── */
.main-grid{
  display:grid;
  grid-template-columns:380px 1fr;
  gap:24px;
  align-items:start;
}
@media(max-width:1024px){.main-grid{grid-template-columns:1fr;}}

/* ── GLASS CARD ────────────────────────────────────────────────────────── */
.glass-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--r6);
  position:relative;overflow:hidden;
  transition:border-color 0.3s,box-shadow 0.3s;
}
.glass-card::before{
  content:'';position:absolute;
  top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.07),transparent);
}
.glass-card:hover{border-color:var(--border2);}
.card-pad{padding:24px;}
.card-pad-lg{padding:28px;}

/* ── SECTION ICON ──────────────────────────────────────────────────────── */
.sec-icon{
  width:44px;height:44px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  font-size:19px;flex-shrink:0;
  transition:transform 0.2s;
}
.glass-card:hover .sec-icon{transform:scale(1.08);}
.ic-fire   {background:rgba(249,115,22,0.12);color:var(--fire);  border:1px solid rgba(249,115,22,0.2);}
.ic-blue   {background:rgba(96,165,250,0.12); color:var(--blue);  border:1px solid rgba(96,165,250,0.2);}
.ic-violet {background:rgba(167,139,250,0.12);color:var(--violet);border:1px solid rgba(167,139,250,0.2);}
.ic-amber  {background:rgba(251,191,36,0.12); color:var(--amber); border:1px solid rgba(251,191,36,0.2);}
.ic-emerald{background:rgba(52,211,153,0.12); color:var(--emerald);border:1px solid rgba(52,211,153,0.2);}
.ic-cyan   {background:rgba(34,211,238,0.12); color:var(--cyan);  border:1px solid rgba(34,211,238,0.2);}
.ic-rose   {background:rgba(251,113,133,0.12);color:var(--rose);  border:1px solid rgba(251,113,133,0.2);}

/* ── FORM INPUTS ───────────────────────────────────────────────────────── */
.form-group{display:flex;flex-direction:column;gap:8px;}
.form-label{
  font-size:11.5px;font-weight:600;
  color:var(--text2);letter-spacing:0.05em;text-transform:uppercase;
  display:flex;align-items:center;gap:6px;
}
.form-label i{font-size:12px;color:var(--fire);}

.clean-select{
  width:100%;
  background:rgba(0,0,0,0.35);
  border:1px solid var(--border);
  border-radius:var(--r3);
  padding:12px 44px 12px 14px;
  color:var(--text);
  font-family:'DM Sans',sans-serif;
  font-size:13.5px;font-weight:500;
  appearance:none;cursor:pointer;
  outline:none;
  transition:all 0.2s;
}
.clean-select:hover{border-color:rgba(249,115,22,0.3);}
.clean-select:focus{border-color:rgba(249,115,22,0.5);box-shadow:0 0 0 3px rgba(249,115,22,0.07);}
.clean-select option{background:#0a1020;color:var(--text);}
.clean-select optgroup{color:var(--text2);}

.select-wrap{position:relative;}
.select-arrow{
  position:absolute;right:14px;top:50%;transform:translateY(-50%);
  pointer-events:none;font-size:12px;color:var(--fire);
  transition:transform 0.2s;
}
.select-wrap:focus-within .select-arrow{transform:translateY(-50%) rotate(180deg);}

/* ── SEX RADIO ─────────────────────────────────────────────────────────── */
.sex-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.sex-option{position:relative;}
.sex-option input{position:absolute;opacity:0;width:0;height:0;}
.sex-label{
  display:flex;flex-direction:column;align-items:center;gap:8px;
  padding:16px 10px;border-radius:var(--r4);
  background:rgba(0,0,0,0.25);
  border:1.5px solid var(--border);
  cursor:pointer;transition:all 0.2s;
  font-size:13px;font-weight:600;color:var(--text2);
}
.sex-label:hover{border-color:rgba(167,139,250,0.4);background:rgba(167,139,250,0.04);}
.sex-label i{font-size:22px;}
.sex-option input:checked + .sex-label{
  border-color:var(--violet);
  background:rgba(167,139,250,0.1);
  color:var(--text);
  box-shadow:0 0 0 3px rgba(167,139,250,0.08);
}
.sex-option:nth-child(1) input:checked + .sex-label i{color:var(--blue);}
.sex-option:nth-child(2) input:checked + .sex-label i{color:var(--rose);}

/* ── MINI INDICATOR ────────────────────────────────────────────────────── */
.mini-indicator{
  display:flex;flex-direction:column;gap:8px;
  padding:12px 14px;border-radius:var(--r3);
  background:rgba(0,0,0,0.2);border:1px solid var(--border);
  margin-top:10px;
  animation:fadeDown 0.3s ease-out;
}
@keyframes fadeDown{from{opacity:0;transform:translateY(-6px);}to{opacity:1;transform:translateY(0);}}
.mi-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.mi-label{font-size:11px;color:var(--text3);}
.mi-val{font-size:13px;font-weight:700;font-family:'DM Mono',monospace;}
.mi-bar-track{height:4px;background:rgba(255,255,255,0.07);border-radius:4px;overflow:hidden;}
.mi-bar{height:100%;border-radius:4px;transition:width 0.7s cubic-bezier(0.23,1,0.32,1);}

/* ── CALCULATE BUTTON ──────────────────────────────────────────────────── */
.calc-btn{
  width:100%;padding:16px 24px;
  border-radius:var(--r4);border:none;cursor:pointer;
  background:linear-gradient(135deg,#f97316,#ef4444,#dc2626);
  background-size:200%;
  color:white;
  font-family:'Syne',sans-serif;font-size:15px;font-weight:700;
  display:flex;align-items:center;justify-content:center;gap:10px;
  transition:all 0.25s;
  box-shadow:0 0 0 rgba(249,115,22,0);
  position:relative;overflow:hidden;
}
.calc-btn::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.1),transparent);
  opacity:0;transition:opacity 0.2s;
}
.calc-btn:not(:disabled):hover{
  transform:translateY(-2px);
  box-shadow:0 8px 32px rgba(249,115,22,0.35);
  background-position:right center;
}
.calc-btn:not(:disabled):hover::before{opacity:1;}
.calc-btn:not(:disabled):active{transform:translateY(0);}
.calc-btn:disabled{opacity:0.35;cursor:not-allowed;}
.calc-btn i{font-size:20px;transition:transform 0.2s;}
.calc-btn:not(:disabled):hover i{transform:rotate(15deg) scale(1.1);}

/* ── RIGHT PANEL STACK ─────────────────────────────────────────────────── */
.right-stack{display:flex;flex-direction:column;gap:20px;}

/* ── LIVE MONITOR ──────────────────────────────────────────────────────── */
.monitor-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:18px;
}
.monitor-grid{
  display:grid;grid-template-columns:repeat(5,1fr);gap:10px;
}
@media(max-width:640px){.monitor-grid{grid-template-columns:repeat(3,1fr);}}

.monitor-cell{
  display:flex;flex-direction:column;align-items:center;text-align:center;
  padding:14px 8px;border-radius:var(--r3);
  background:rgba(0,0,0,0.3);
  border:1px solid var(--border);
  transition:all 0.25s;
}
.monitor-cell.active{
  border-color:rgba(249,115,22,0.3);
  background:rgba(249,115,22,0.04);
}
.monitor-cell i{font-size:22px;color:var(--text3);margin-bottom:6px;transition:color 0.2s;}
.monitor-cell.active i{color:var(--fire);}
.mc-label{font-size:10px;color:var(--text3);margin-bottom:4px;letter-spacing:0.06em;text-transform:uppercase;}
.mc-val{font-size:12px;font-weight:700;color:var(--text2);transition:color 0.2s;}
.monitor-cell.active .mc-val{color:var(--text);}

/* ── EMPTY STATE ───────────────────────────────────────────────────────── */
.empty-state{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:64px 32px;text-align:center;
}
.empty-icon{
  width:88px;height:88px;border-radius:24px;
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);
  font-size:42px;color:var(--text3);
  margin-bottom:20px;
  box-shadow:inset 0 0 40px rgba(0,0,0,0.3);
}
.empty-title{font-family:'Syne',sans-serif;font-size:22px;font-weight:700;color:var(--text2);margin-bottom:10px;}
.empty-text{font-size:13.5px;color:var(--text3);max-width:340px;line-height:1.7;}

.empty-steps{
  display:flex;gap:10px;margin-top:24px;flex-wrap:wrap;justify-content:center;
}
.empty-step{
  display:flex;align-items:center;gap:6px;
  font-size:12px;color:var(--text3);
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);
  border-radius:100px;padding:6px 14px;
}
.empty-step i{color:var(--fire);font-size:11px;}

/* ── PRICE DISPLAY ─────────────────────────────────────────────────────── */
#price-dashboard{display:none;}
#price-dashboard.show{display:block;animation:fadeUp 0.5s ease-out;}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}

.price-hero{
  border-radius:var(--r6);padding:32px;
  background:linear-gradient(135deg,rgba(249,115,22,0.06),rgba(239,68,68,0.04),rgba(0,0,0,0));
  border:1px solid rgba(249,115,22,0.2);
  position:relative;overflow:hidden;
  margin-bottom:20px;
}
.price-hero::before{
  content:'';position:absolute;
  top:-60%;right:-20%;
  width:400px;height:400px;
  background:radial-gradient(circle,rgba(249,115,22,0.08),transparent 70%);
  border-radius:50%;pointer-events:none;
}
.price-hero-top{
  display:flex;align-items:flex-start;justify-content:space-between;
  margin-bottom:24px;gap:16px;
}
.price-eyebrow{font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);margin-bottom:8px;}
.price-amount{
  font-family:'Syne',sans-serif;
  font-size:clamp(24px,4vw,38px);font-weight:800;
  display:flex;align-items:baseline;flex-wrap:wrap;gap:8px;
}
.price-currency{font-size:0.6em;color:var(--text3);font-weight:600;}
.price-sep{font-size:0.7em;color:var(--text3);}
.price-min,.price-max{
  background:linear-gradient(135deg,#f97316,#ef4444);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.price-float-icon{
  width:68px;height:68px;border-radius:20px;
  display:flex;align-items:center;justify-content:center;
  background:rgba(249,115,22,0.1);
  border:1px solid rgba(249,115,22,0.2);
  font-size:32px;color:var(--fire);
  flex-shrink:0;
  animation:floatIcon 4s ease-in-out infinite;
}
@keyframes floatIcon{0%,100%{transform:translateY(0);}50%{transform:translateY(-6px);}}

.confidence-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.confidence-label{font-size:11px;color:var(--text3);}
.confidence-val{font-size:12px;font-weight:700;color:var(--emerald);font-family:'DM Mono',monospace;}
.conf-track{height:5px;background:rgba(255,255,255,0.06);border-radius:4px;overflow:hidden;}
.conf-fill{height:100%;background:linear-gradient(90deg,var(--emerald),var(--cyan));border-radius:4px;transition:width 1s cubic-bezier(0.23,1,0.32,1);}

/* ── BREAKDOWN GRID ────────────────────────────────────────────────────── */
.breakdown-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:12px;
  margin-bottom:20px;
}
@media(max-width:640px){.breakdown-grid{grid-template-columns:1fr;}}

.breakdown-cell{
  padding:18px;border-radius:var(--r4);
  background:rgba(0,0,0,0.25);
  border:1px solid var(--border);
  transition:border-color 0.2s;
}
.breakdown-cell:hover{border-color:var(--border2);}
.bc-header{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.bc-icon{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:14px;}
.bc-icon.blue   {background:rgba(96,165,250,0.12);color:var(--blue);}
.bc-icon.amber  {background:rgba(251,191,36,0.12); color:var(--amber);}
.bc-icon.emerald{background:rgba(52,211,153,0.12); color:var(--emerald);}
.bc-sub{font-size:10px;color:var(--text3);}
.bc-name{font-size:11.5px;font-weight:600;color:var(--text2);}
.bc-val{font-size:20px;font-weight:800;font-family:'Syne',sans-serif;}
.bc-val.fire{color:var(--fire);}
.bc-val.amber{color:var(--amber);}
.bc-val.emerald{color:var(--emerald);}

/* ── COMPOSITION TABLE ─────────────────────────────────────────────────── */
.comp-table{display:flex;flex-direction:column;gap:8px;margin-bottom:20px;}
.comp-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:12px 16px;border-radius:var(--r3);
  background:rgba(0,0,0,0.2);border:1px solid var(--border);
  transition:border-color 0.2s,background 0.2s;
}
.comp-row:hover{border-color:var(--border2);background:rgba(0,0,0,0.3);}
.comp-left{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text2);}
.comp-left i{font-size:14px;width:16px;text-align:center;}
.comp-right{font-size:13px;font-weight:700;font-family:'DM Mono',monospace;}

/* ── INSIGHTS ──────────────────────────────────────────────────────────── */
.insight-item{
  display:flex;align-items:flex-start;gap:10px;
  font-size:13px;color:var(--text2);line-height:1.6;
  padding:12px 14px;border-radius:var(--r3);
  background:rgba(0,0,0,0.2);border:1px solid var(--border);
}
.insight-item i{font-size:14px;flex-shrink:0;margin-top:2px;}

/* ── PRICE HISTORY MINI CHART ──────────────────────────────────────────── */
.spark-chart{
  display:flex;align-items:flex-end;gap:4px;height:40px;
  padding:4px 0;
}
.spark-bar{
  flex:1;border-radius:3px 3px 0 0;
  background:linear-gradient(180deg,rgba(249,115,22,0.5),rgba(249,115,22,0.15));
  transition:height 0.6s cubic-bezier(0.23,1,0.32,1);
  min-height:4px;
}
.spark-bar.active{background:linear-gradient(180deg,var(--fire),rgba(249,115,22,0.3));}

/* ── MARKET SCORE ──────────────────────────────────────────────────────── */
.score-ring{
  width:80px;height:80px;flex-shrink:0;
  position:relative;
}
.score-svg{transform:rotate(-90deg);}
.score-track{fill:none;stroke:rgba(255,255,255,0.06);stroke-width:6;}
.score-fill{fill:none;stroke:url(#scoreGrad);stroke-width:6;stroke-linecap:round;
  transition:stroke-dashoffset 1.2s cubic-bezier(0.23,1,0.32,1);}
.score-text{
  position:absolute;inset:0;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
}
.score-num{font-family:'DM Mono',monospace;font-size:18px;font-weight:700;color:var(--fire);}
.score-sub{font-size:8px;font-weight:600;letter-spacing:0.06em;color:var(--text3);text-transform:uppercase;}

/* ── ANIMATIONS ────────────────────────────────────────────────────────── */
@keyframes slideInLeft{from{opacity:0;transform:translateX(-20px);}to{opacity:1;transform:translateX(0);}}
@keyframes revealCard{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

.anim-1{animation:revealCard 0.4s ease-out 0.05s both;}
.anim-2{animation:revealCard 0.4s ease-out 0.10s both;}
.anim-3{animation:revealCard 0.4s ease-out 0.16s both;}
.anim-4{animation:revealCard 0.4s ease-out 0.22s both;}
.anim-5{animation:revealCard 0.4s ease-out 0.28s both;}
.anim-6{animation:revealCard 0.4s ease-out 0.34s both;}

/* ── SCROLLBAR ─────────────────────────────────────────────────────────── */
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:rgba(0,0,0,0.2);}
::-webkit-scrollbar-thumb{background:linear-gradient(180deg,var(--fire),var(--fire2));border-radius:4px;}

/* ── MISC UTILS ────────────────────────────────────────────────────────── */
.flex{display:flex;}.items-center{align-items:center;}.gap-3{gap:12px;}.mb-2{margin-bottom:8px;}.mb-4{margin-bottom:16px;}.hidden{display:none!important;}
.sec-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--text);}
.sec-sub{font-size:12px;color:var(--text3);}
.text-mono{font-family:'DM Mono',monospace;}
.tracking-badge{
  font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--emerald);
  display:flex;align-items:center;gap:5px;
}
.left-stack{display:flex;flex-direction:column;gap:16px;}
</style>
</head>
<body>

<!-- Background -->
<div class="bg-canvas">
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>
  <div class="bg-orb orb-3"></div>
  <div class="bg-grid"></div>
</div>

<div class="wrapper">

  <!-- ── PAGE HEADER ──────────────────────────────────────────────────── -->
  <div class="page-header anim-1">
    <div>
      <div class="eyebrow"><i class="bi bi-calculator"></i>AgriVault Valuation Engine</div>
      <h1 class="page-title">Smart Price <span class="fire">Calculator</span></h1>
      <p class="page-sub">AI-powered livestock valuation · Uganda market pricing · Real-time analysis</p>
    </div>
    <div class="live-badge">
      <div class="pulse-dot"></div>
      Live Pricing Active
    </div>
  </div>

  <!-- ── MAIN GRID ─────────────────────────────────────────────────────── -->
  <div class="main-grid">

    <!-- ════ LEFT: INPUT PANEL ══════════════════════════════════════════ -->
    <div class="left-stack">

      <!-- Animal Type -->
      <div class="glass-card card-pad anim-2">
        <div class="flex items-center gap-3 mb-4">
          <div class="sec-icon ic-fire"><i class="bi bi-tag-fill"></i></div>
          <div>
            <div class="sec-title">Animal Type</div>
            <div class="sec-sub">Select livestock category</div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label"><i class="bi bi-list-ul"></i>Category</label>
          <div class="select-wrap">
            <select id="animal-type" class="clean-select">
              <option value="">Select Animal</option>
              <option value="cattle">🐄 Cattle (Cows & Bulls)</option>
              <option value="goat">🐐 Goats</option>
              <option value="sheep">🐑 Sheep</option>
              <option value="pig">🐷 Pigs</option>
            </select>
            <i class="bi bi-chevron-down select-arrow"></i>
          </div>
        </div>
      </div>

      <!-- Weight Range -->
      <div class="glass-card card-pad anim-3">
        <div class="flex items-center gap-3 mb-4">
          <div class="sec-icon ic-blue"><i class="bi bi-speedometer"></i></div>
          <div>
            <div class="sec-title">Weight Class</div>
            <div class="sec-sub">Current animal weight</div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label"><i class="bi bi-bar-chart-fill"></i>Weight Range</label>
          <div class="select-wrap">
            <select id="weight-range" class="clean-select">
              <option value="">Select Weight Range</option>
              <optgroup label="🐄 Cattle">
                <option value="cattle-light">Light (<200kg) — UGX 200K–500K</option>
                <option value="cattle-medium">Medium (200–350kg) — UGX 600K–1.2M</option>
                <option value="cattle-heavy">Heavy (350kg+) — UGX 1.5M–2.5M</option>
              </optgroup>
              <optgroup label="🐐 Goats">
                <option value="goat-small">Small (30–40kg) — UGX 300K–480K</option>
                <option value="goat-medium">Medium (50–70kg) — UGX 500K–840K</option>
                <option value="goat-large">Large (70kg+) — UGX 840K–1M</option>
              </optgroup>
              <optgroup label="🐑 Sheep">
                <option value="sheep-lamb">Lamb (10–20kg) — UGX 80K–150K</option>
                <option value="sheep-medium">Medium (25–35kg) — UGX 200K–350K</option>
                <option value="sheep-large">Large (40–55kg+) — UGX 400K–600K</option>
              </optgroup>
              <optgroup label="🐷 Pigs">
                <option value="pig-small">Small (30–50kg) — UGX 200K–350K</option>
                <option value="pig-medium">Medium (60–80kg) — UGX 400K–650K</option>
                <option value="pig-heavy">Heavy (90–100kg+) — UGX 700K–900K</option>
              </optgroup>
            </select>
            <i class="bi bi-chevron-down select-arrow"></i>
          </div>
          <div id="weight-indicator" class="mini-indicator hidden">
            <div class="mi-top">
              <span class="mi-label">Selected Class</span>
              <span class="mi-val" id="weight-display" style="color:var(--blue)">—</span>
            </div>
            <div class="mi-bar-track">
              <div class="mi-bar" id="weight-bar" style="width:0%;background:linear-gradient(90deg,var(--blue),var(--cyan))"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Sex -->
      <div class="glass-card card-pad anim-4">
        <div class="flex items-center gap-3 mb-4">
          <div class="sec-icon ic-violet"><i class="bi bi-gender-ambiguous"></i></div>
          <div>
            <div class="sec-title">Sex</div>
            <div class="sec-sub">Gender classification</div>
          </div>
        </div>
        <div class="sex-grid">
          <div class="sex-option">
            <input type="radio" name="sex" value="male" id="sexMale"/>
            <label for="sexMale" class="sex-label">
              <i class="bi bi-gender-male" style="color:var(--blue)"></i>
              Male
            </label>
          </div>
          <div class="sex-option">
            <input type="radio" name="sex" value="female" id="sexFemale"/>
            <label for="sexFemale" class="sex-label">
              <i class="bi bi-gender-female" style="color:var(--rose)"></i>
              Female
            </label>
          </div>
        </div>
      </div>

      <!-- Coat Color -->
      <div class="glass-card card-pad anim-5">
        <div class="flex items-center gap-3 mb-4">
          <div class="sec-icon ic-amber"><i class="bi bi-palette-fill"></i></div>
          <div>
            <div class="sec-title">Coat Color</div>
            <div class="sec-sub">Premium color modifier</div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label"><i class="bi bi-circle-half"></i>Select Color</label>
          <div class="select-wrap">
            <select id="color" class="clean-select">
              <option value="">Select Color</option>
              <option value="black">⬛ Black — Premium +15%</option>
              <option value="brown">🟫 Brown — Standard ±0%</option>
              <option value="white">⬜ White — Standard −5%</option>
              <option value="mixed">🎨 Mixed / Spotted — Standard ±0%</option>
            </select>
            <i class="bi bi-chevron-down select-arrow"></i>
          </div>
          <div id="color-premium" class="mini-indicator hidden">
            <div class="mi-top">
              <span class="mi-label">Color Premium</span>
              <span class="mi-val" id="color-premium-text" style="color:var(--amber)">+0%</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Age -->
      <div class="glass-card card-pad anim-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="sec-icon ic-emerald"><i class="bi bi-calendar-event-fill"></i></div>
          <div>
            <div class="sec-title">Age Category</div>
            <div class="sec-sub">Maturity classification</div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label"><i class="bi bi-clock-fill"></i>Select Age Range</label>
          <div class="select-wrap">
            <select id="age-range" class="clean-select">
              <option value="">Select Age Range</option>
              <optgroup label="🐄 Cattle">
                <option value="cattle-calf">Calf (0–12 months) — Young −15%</option>
                <option value="cattle-young">Young Adult (1–3 years) — Prime</option>
                <option value="cattle-mature">Mature (3–6 years) — Mature +5%</option>
                <option value="cattle-old">Old (6+ years) — Aging −10%</option>
              </optgroup>
              <optgroup label="🐐 Goats">
                <option value="goat-kid">Kid (0–6 months) — Kid −20%</option>
                <option value="goat-young">Young (6–18 months) — Prime</option>
                <option value="goat-adult">Adult (18+ months) — Adult +8%</option>
              </optgroup>
              <optgroup label="🐑 Sheep">
                <option value="sheep-lamb-age">Lamb (0–12 months) — Lamb −10%</option>
                <option value="sheep-yearling">Yearling (1–2 years) — Prime</option>
                <option value="sheep-mature">Mature (2+ years) — Mature +5%</option>
              </optgroup>
              <optgroup label="🐷 Pigs">
                <option value="pig-piglet">Piglet (0–3 months) — Piglet −25%</option>
                <option value="pig-grower">Grower (3–6 months) — Prime</option>
                <option value="pig-finisher">Finisher (6+ months) — Finisher +10%</option>
              </optgroup>
            </select>
            <i class="bi bi-chevron-down select-arrow"></i>
          </div>
          <div id="age-modifier" class="mini-indicator hidden">
            <div class="mi-top">
              <span class="mi-label">Age Factor</span>
              <span class="mi-val" id="age-modifier-text" style="color:var(--emerald)">Standard</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Calculate Button -->
      <button id="calculate-btn" class="calc-btn" onclick="calculatePrice()" disabled>
        <i class="bi bi-calculator-fill"></i>
        Calculate Market Price
      </button>

    </div><!-- /left -->

    <!-- ════ RIGHT: RESULTS PANEL ════════════════════════════════════════ -->
    <div class="right-stack">

      <!-- Live Selection Monitor -->
      <div class="glass-card card-pad-lg">
        <div class="monitor-header">
          <div class="flex items-center gap-3">
            <div class="sec-icon ic-cyan"><i class="bi bi-activity"></i></div>
            <div>
              <div class="sec-title">Live Selection Monitor</div>
              <div class="sec-sub">Real-time tracking of your inputs</div>
            </div>
          </div>
          <div class="tracking-badge">
            <div class="pulse-dot" style="background:var(--emerald);width:6px;height:6px;"></div>
            Tracking
          </div>
        </div>

        <div class="monitor-grid">
          <div class="monitor-cell" id="mc-animal">
            <i class="bi bi-circle" id="mc-animal-icon"></i>
            <div class="mc-label">Animal</div>
            <div class="mc-val" id="preview-animal">—</div>
          </div>
          <div class="monitor-cell" id="mc-weight">
            <i class="bi bi-speedometer"></i>
            <div class="mc-label">Weight</div>
            <div class="mc-val" id="preview-weight">—</div>
          </div>
          <div class="monitor-cell" id="mc-sex">
            <i class="bi bi-gender-ambiguous" id="mc-sex-icon"></i>
            <div class="mc-label">Sex</div>
            <div class="mc-val" id="preview-sex">—</div>
          </div>
          <div class="monitor-cell" id="mc-color">
            <div id="color-swatch" style="width:22px;height:22px;border-radius:50%;background:#2a3548;margin-bottom:6px;border:2px solid rgba(255,255,255,0.08);"></div>
            <div class="mc-label">Color</div>
            <div class="mc-val" id="preview-color">—</div>
          </div>
          <div class="monitor-cell" id="mc-age">
            <i class="bi bi-calendar-event"></i>
            <div class="mc-label">Age</div>
            <div class="mc-val" id="preview-age">—</div>
          </div>
        </div>
      </div>

      <!-- Empty State / Price Dashboard -->
      <div class="glass-card">
        <!-- Empty State -->
        <div class="empty-state" id="empty-state">
          <div class="empty-icon"><i class="bi bi-calculator"></i></div>
          <div class="empty-title">Ready to Calculate</div>
          <div class="empty-text">Fill in all five fields on the left to unlock an instant AI-powered price prediction based on Uganda's live livestock market data.</div>
          <div class="empty-steps">
            <div class="empty-step"><i class="bi bi-1-circle-fill"></i>Select Animal</div>
            <div class="empty-step"><i class="bi bi-2-circle-fill"></i>Choose Weight</div>
            <div class="empty-step"><i class="bi bi-3-circle-fill"></i>Pick Sex</div>
            <div class="empty-step"><i class="bi bi-4-circle-fill"></i>Set Color</div>
            <div class="empty-step"><i class="bi bi-5-circle-fill"></i>Enter Age</div>
          </div>
        </div>

        <!-- Price Dashboard -->
        <div id="price-dashboard" style="padding:24px;">

          <!-- Price Hero -->
          <div class="price-hero">
            <div class="price-hero-top">
              <div>
                <div class="price-eyebrow">Estimated Market Value</div>
                <div class="price-amount">
                  <span class="price-currency">UGX</span>
                  <span class="price-min" id="final-price-min">0</span>
                  <span class="price-sep">—</span>
                  <span class="price-max" id="final-price-max">0</span>
                </div>
              </div>
              <div class="price-float-icon"><i class="bi bi-cash-stack"></i></div>
            </div>
            <!-- Market Score Ring -->
            <div style="display:flex;align-items:center;gap:20px;margin-top:8px;">
              <div style="flex:1;">
                <div class="confidence-row">
                  <span class="confidence-label">Valuation Confidence</span>
                  <span class="confidence-val" id="confidence-score">—</span>
                </div>
                <div class="conf-track">
                  <div class="conf-fill" id="confidence-bar" style="width:0%"></div>
                </div>
              </div>
              <div class="score-ring">
                <svg class="score-svg" width="80" height="80" viewBox="0 0 80 80">
                  <defs>
                    <linearGradient id="scoreGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" style="stop-color:#f97316"/>
                      <stop offset="100%" style="stop-color:#ef4444"/>
                    </linearGradient>
                  </defs>
                  <circle class="score-track" cx="40" cy="40" r="34"/>
                  <circle class="score-fill" id="score-arc" cx="40" cy="40" r="34"
                    stroke-dasharray="213.6" stroke-dashoffset="213.6"/>
                </svg>
                <div class="score-text">
                  <div class="score-num" id="score-num">0</div>
                  <div class="score-sub">Score</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Breakdown Cells -->
          <div class="breakdown-grid">
            <div class="breakdown-cell">
              <div class="bc-header">
                <div class="bc-icon blue"><i class="bi bi-tag-fill"></i></div>
                <div>
                  <div class="bc-name">Base Price</div>
                  <div class="bc-sub">Weight Class</div>
                </div>
              </div>
              <div class="bc-val fire" id="base-price" style="font-size:14px;">UGX 0</div>
            </div>
            <div class="breakdown-cell">
              <div class="bc-header">
                <div class="bc-icon amber"><i class="bi bi-stars"></i></div>
                <div>
                  <div class="bc-name">Premium</div>
                  <div class="bc-sub">Color + Sex</div>
                </div>
              </div>
              <div class="bc-val amber" id="premium-modifier">+0%</div>
            </div>
            <div class="breakdown-cell">
              <div class="bc-header">
                <div class="bc-icon emerald"><i class="bi bi-calendar-check-fill"></i></div>
                <div>
                  <div class="bc-name">Age Factor</div>
                  <div class="bc-sub">Maturity</div>
                </div>
              </div>
              <div class="bc-val emerald" id="age-factor" style="font-size:14px;">—</div>
            </div>
          </div>

          <!-- Composition Analysis -->
          <div class="glass-card" style="margin-bottom:16px;background:rgba(0,0,0,0.15);">
            <div class="card-pad">
              <div class="flex items-center gap-3 mb-4">
                <div class="sec-icon ic-fire"><i class="bi bi-pie-chart-fill"></i></div>
                <div class="sec-title">Price Composition Analysis</div>
              </div>
              <div class="comp-table">
                <div class="comp-row">
                  <div class="comp-left"><i class="bi bi-check-circle-fill" style="color:var(--blue)"></i>Base Weight Category</div>
                  <span class="comp-right" style="color:var(--blue)" id="breakdown-base">—</span>
                </div>
                <div class="comp-row">
                  <div class="comp-left"><i class="bi bi-palette-fill" style="color:var(--amber)"></i>Color Premium</div>
                  <span class="comp-right" style="color:var(--amber)" id="breakdown-color">—</span>
                </div>
                <div class="comp-row">
                  <div class="comp-left"><i class="bi bi-gender-ambiguous" style="color:var(--violet)"></i>Sex Modifier</div>
                  <span class="comp-right" style="color:var(--violet)" id="breakdown-sex">—</span>
                </div>
                <div class="comp-row">
                  <div class="comp-left"><i class="bi bi-calendar-event-fill" style="color:var(--emerald)"></i>Age Adjustment</div>
                  <span class="comp-right" style="color:var(--emerald)" id="breakdown-age">—</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Market Insights -->
          <div class="glass-card" style="background:rgba(0,0,0,0.15);">
            <div class="card-pad">
              <div class="flex items-center gap-3 mb-4">
                <div class="sec-icon ic-cyan"><i class="bi bi-lightbulb-fill"></i></div>
                <div class="sec-title">Market Intelligence</div>
              </div>
              <div id="market-insights" style="display:flex;flex-direction:column;gap:8px;"></div>
            </div>
          </div>

        </div>
      </div>

    </div><!-- /right -->
  </div><!-- /main-grid -->
</div><!-- /wrapper -->

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- PRICING ENGINE ─────────────────────────────────────────────────────── -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<script>
// ── PRICING DATABASE ────────────────────────────────────────────────────
const PRICING_DATA = {
  cattle:{
    name:'Cattle',emoji:'🐄',
    weights:[
      {value:'cattle-light', label:'Light',  kg:'<200kg',   min:200000, max:500000,  barWidth:25},
      {value:'cattle-medium',label:'Medium', kg:'200–350kg',min:600000, max:1200000, barWidth:62},
      {value:'cattle-heavy', label:'Heavy',  kg:'350kg+',   min:1500000,max:2500000, barWidth:96}
    ],
    ages:[
      {value:'cattle-calf',  label:'Calf',        modifier:-0.15,text:'Young (−15%)'},
      {value:'cattle-young', label:'Young Adult',  modifier:0,    text:'Prime (Standard)'},
      {value:'cattle-mature',label:'Mature',       modifier:0.05, text:'Mature (+5%)'},
      {value:'cattle-old',   label:'Old',          modifier:-0.10,text:'Aging (−10%)'}
    ]
  },
  goat:{
    name:'Goat',emoji:'🐐',
    weights:[
      {value:'goat-small', label:'Small', kg:'30–40kg',min:300000,max:480000, barWidth:35},
      {value:'goat-medium',label:'Medium',kg:'50–70kg',min:500000,max:840000, barWidth:70},
      {value:'goat-large', label:'Large', kg:'70kg+',  min:840000,max:1000000,barWidth:96}
    ],
    ages:[
      {value:'goat-kid',  label:'Kid',  modifier:-0.20,text:'Kid (−20%)'},
      {value:'goat-young',label:'Young',modifier:0,    text:'Prime (Standard)'},
      {value:'goat-adult',label:'Adult',modifier:0.08, text:'Adult (+8%)'}
    ]
  },
  sheep:{
    name:'Sheep',emoji:'🐑',
    weights:[
      {value:'sheep-lamb',  label:'Lamb',  kg:'10–20kg',  min:80000, max:150000,barWidth:18},
      {value:'sheep-medium',label:'Medium',kg:'25–35kg',  min:200000,max:350000,barWidth:55},
      {value:'sheep-large', label:'Large', kg:'40–55kg+', min:400000,max:600000,barWidth:92}
    ],
    ages:[
      {value:'sheep-lamb-age', label:'Lamb',     modifier:-0.10,text:'Lamb (−10%)'},
      {value:'sheep-yearling', label:'Yearling', modifier:0,    text:'Prime (Standard)'},
      {value:'sheep-mature',   label:'Mature',   modifier:0.05, text:'Mature (+5%)'}
    ]
  },
  pig:{
    name:'Pig',emoji:'🐷',
    weights:[
      {value:'pig-small', label:'Small',  kg:'30–50kg',   min:200000,max:350000,barWidth:30},
      {value:'pig-medium',label:'Medium', kg:'60–80kg',   min:400000,max:650000,barWidth:65},
      {value:'pig-heavy', label:'Heavy',  kg:'90–100kg+', min:700000,max:900000,barWidth:96}
    ],
    ages:[
      {value:'pig-piglet',   label:'Piglet',   modifier:-0.25,text:'Piglet (−25%)'},
      {value:'pig-grower',   label:'Grower',   modifier:0,    text:'Prime (Standard)'},
      {value:'pig-finisher', label:'Finisher', modifier:0.10, text:'Finisher (+10%)'}
    ]
  }
};

// ── STATE ───────────────────────────────────────────────────────────────
let sel={animalType:'',weightRange:'',sex:'',color:'',ageRange:''};

// ── INIT ────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('animal-type').addEventListener('change',function(){sel.animalType=this.value;sync();});
  document.getElementById('weight-range').addEventListener('change',function(){
    sel.weightRange=this.value;
    if(this.value){const p=this.value.split('-')[0];if(PRICING_DATA[p]){sel.animalType=p;document.getElementById('animal-type').value=p;}}
    sync();
  });
  document.getElementById('age-range').addEventListener('change',function(){
    sel.ageRange=this.value;
    if(this.value){const p=this.value.split('-')[0];if(PRICING_DATA[p]){sel.animalType=p;document.getElementById('animal-type').value=p;}}
    sync();
  });
  document.getElementById('color').addEventListener('change',function(){sel.color=this.value;sync();});
  document.querySelectorAll('input[name="sex"]').forEach(r=>r.addEventListener('change',function(){sel.sex=this.value;sync();}));
});

// ── SYNC ─────────────────────────────────────────────────────────────────
function sync(){
  sel.animalType = document.getElementById('animal-type').value||sel.animalType;
  updateMonitor();
  updateIndicators();
  const all = sel.animalType && sel.weightRange && sel.sex && sel.color && sel.ageRange;
  document.getElementById('calculate-btn').disabled = !all;
}

// ── MONITOR UPDATE ────────────────────────────────────────────────────────
function updateMonitor(){
  const {animalType,weightRange,sex,color,ageRange}=sel;

  // Detect animal from any prefix
  let animal = animalType || (weightRange && weightRange.split('-')[0]) || (ageRange && ageRange.split('-')[0]) || '';

  // Animal cell
  const mc=document.getElementById('mc-animal');
  if(animal && PRICING_DATA[animal]){
    const d=PRICING_DATA[animal];
    document.getElementById('mc-animal-icon').className='bi bi-circle-fill';
    document.getElementById('preview-animal').textContent=d.name;
    mc.classList.add('active');
  } else {
    document.getElementById('mc-animal-icon').className='bi bi-circle';
    document.getElementById('preview-animal').textContent='—';
    mc.classList.remove('active');
  }

  // Weight cell
  const mcw=document.getElementById('mc-weight');
  if(weightRange){
    const ak=weightRange.split('-')[0];
    const wd=PRICING_DATA[ak]?.weights.find(w=>w.value===weightRange);
    if(wd){document.getElementById('preview-weight').textContent=wd.kg;mcw.classList.add('active');}
  } else {document.getElementById('preview-weight').textContent='—';mcw.classList.remove('active');}

  // Sex cell
  const mcs=document.getElementById('mc-sex');
  if(sex){
    const icons={male:'bi-gender-male',female:'bi-gender-female'};
    document.getElementById('mc-sex-icon').className='bi '+icons[sex];
    document.getElementById('preview-sex').textContent=sex.charAt(0).toUpperCase()+sex.slice(1);
    mcs.classList.add('active');
  } else {
    document.getElementById('mc-sex-icon').className='bi bi-gender-ambiguous';
    document.getElementById('preview-sex').textContent='—';
    mcs.classList.remove('active');
  }

  // Color cell
  const mcc=document.getElementById('mc-color');
  const swatchColors={black:'#1c1c1c',brown:'#7c4a1e',white:'#e5e5e5',mixed:'linear-gradient(135deg,#7c4a1e,#e5e5e5)'};
  if(color){
    const sw=document.getElementById('color-swatch');
    if(color==='mixed') sw.style.background=swatchColors.mixed;
    else sw.style.background=swatchColors[color]||'#2a3548';
    document.getElementById('preview-color').textContent=color.charAt(0).toUpperCase()+color.slice(1);
    mcc.classList.add('active');
  } else {
    document.getElementById('color-swatch').style.background='#2a3548';
    document.getElementById('preview-color').textContent='—';
    mcc.classList.remove('active');
  }

  // Age cell
  const mca=document.getElementById('mc-age');
  if(ageRange){
    const ak=ageRange.split('-')[0];
    const ad=PRICING_DATA[ak]?.ages.find(a=>a.value===ageRange);
    if(ad){document.getElementById('preview-age').textContent=ad.label;mca.classList.add('active');}
  } else {document.getElementById('preview-age').textContent='—';mca.classList.remove('active');}
}

// ── INDICATORS ────────────────────────────────────────────────────────────
function updateIndicators(){
  const {weightRange,color,ageRange}=sel;

  // Weight bar
  if(weightRange){
    const ak=weightRange.split('-')[0];
    const wd=PRICING_DATA[ak]?.weights.find(w=>w.value===weightRange);
    if(wd){
      const wi=document.getElementById('weight-indicator');
      wi.classList.remove('hidden');
      document.getElementById('weight-display').textContent=wd.kg;
      document.getElementById('weight-bar').style.width=wd.barWidth+'%';
    }
  } else {
    const wi = document.getElementById('weight-indicator');
    if(wi) wi.classList.add('hidden');
  }

  // Color premium
  if(color){
    const pMap={black:'+15%',brown:'±0%',white:'−5%',mixed:'±0%'};
    const cp=document.getElementById('color-premium');
    if(cp) {
      cp.classList.remove('hidden');
      const cpt=document.getElementById('color-premium-text');
      if(cpt) {
        cpt.textContent=pMap[color];
        cpt.style.color=color==='black'?'var(--amber)':color==='white'?'var(--rose)':'var(--text2)';
      }
    }
  } else {
    const cp = document.getElementById('color-premium');
    if(cp) cp.classList.add('hidden');
  }

  // Age modifier
  if(ageRange){
    const ak=ageRange.split('-')[0];
    const ad=PRICING_DATA[ak]?.ages.find(a=>a.value===ageRange);
    if(ad){
      const am=document.getElementById('age-modifier');
      if(am) {
        am.classList.remove('hidden');
        const amt=document.getElementById('age-modifier-text');
        if(amt) {
          amt.textContent=ad.text;
          amt.style.color=ad.modifier<0?'var(--rose)':ad.modifier>0?'var(--emerald)':'var(--text2)';
        }
      }
    }
  } else {
    const am = document.getElementById('age-modifier');
    if(am) am.classList.add('hidden');
  }
}

// ── CALCULATE ─────────────────────────────────────────────────────────────
function calculatePrice(){
  let {animalType,weightRange,sex,color,ageRange}=sel;
  if(!animalType) animalType=weightRange?.split('-')[0]||ageRange?.split('-')[0]||'';
  if(!animalType||!weightRange||!sex||!color||!ageRange) return;

  const data=PRICING_DATA[animalType];
  if(!data) return;

  const wd=data.weights.find(w=>w.value===weightRange);
  const ad=data.ages.find(a=>a.value===ageRange);
  if(!wd||!ad) return;

  // Modifiers
  const colorMods={black:1.15,brown:1.0,white:0.95,mixed:1.0};
  const colorMod=colorMods[color]||1;
  let colorText={black:'+15% — Black Coat Premium',brown:'±0% — Standard',white:'−5% — White Discount',mixed:'±0% — Standard'}[color];

  let sexMod=1.0,sexText='±0% — Standard';
  const wClass=weightRange.split('-').slice(1).join('-');
  if(sex==='female'){sexMod=1.08;sexText='+8% — Female Breeding Premium';}
  else if(sex==='male'&&(wClass==='heavy'||wClass==='large')){sexMod=1.05;sexText='+5% — Heavy Male Premium';}

  const ageMod=1+ad.modifier;
  const totalMod=colorMod*sexMod*ageMod;

  const finalMin=Math.round(wd.min*totalMod);
  const finalMax=Math.round(wd.max*totalMod);

  const confidence=Math.min(97,72+(color==='black'?10:0)+(sex==='female'?5:0)+(wClass==='medium'?6:0)+(ad.modifier===0?4:0));
  const premiumPct=Math.round(((colorMod*sexMod)-1)*100);

  // Show dashboard
  const emptyState = document.getElementById('empty-state');
  if(emptyState) emptyState.classList.add('hidden');
  
  const dash=document.getElementById('price-dashboard');
  if(dash) {
    dash.classList.add('show');
    dash.style.display = 'block';
  }

  // Animate numbers
  animNum('final-price-min',finalMin);
  animNum('final-price-max',finalMax);
  animNum('score-num',confidence);

  // Base price
  const basePriceEl = document.getElementById('base-price');
  if(basePriceEl) basePriceEl.textContent=`UGX ${wd.min.toLocaleString()} – ${wd.max.toLocaleString()}`;

  // Premium
  const premEl = document.getElementById('premium-modifier');
  if(premEl) premEl.textContent=(premiumPct>=0?'+':'')+premiumPct+'%';

  // Age factor
  const ageEl = document.getElementById('age-factor');
  if(ageEl) ageEl.textContent=ad.text;

  // Breakdown
  const bdBase = document.getElementById('breakdown-base');
  if(bdBase) bdBase.textContent=`UGX ${wd.min.toLocaleString()} – ${wd.max.toLocaleString()}`;
  
  const bdColor = document.getElementById('breakdown-color');
  if(bdColor) bdColor.textContent=colorText;
  
  const bdSex = document.getElementById('breakdown-sex');
  if(bdSex) bdSex.textContent=sexText;
  
  const bdAge = document.getElementById('breakdown-age');
  if(bdAge) bdAge.textContent=ad.text;

  // Confidence bar
  const confScore = document.getElementById('confidence-score');
  if(confScore) confScore.textContent=confidence+'% Accurate';
  
  setTimeout(()=>{
    const confBar = document.getElementById('confidence-bar');
    if(confBar) confBar.style.width=confidence+'%';
  },80);

  // Score arc
  const circumference=213.6;
  const offset=circumference-(confidence/100)*circumference;
  setTimeout(()=>{
    const scoreArc = document.getElementById('score-arc');
    if(scoreArc) scoreArc.style.strokeDashoffset=offset;
  },80);

  // Insights
  buildInsights(animalType,wClass,sex,color,ageRange,finalMin,finalMax,ad.modifier);
}

// ── NUMBER ANIMATION ───────────────────────────────────────────────────────
function animNum(id,target){
  const el=document.getElementById(id);
  if(!el) return;
  const dur=1400,start=0,t0=performance.now();
  const fmt=target>9999?n=>n.toLocaleString():n=>n;
  function step(now){
    const p=Math.min((now-t0)/dur,1);
    const ease=1-Math.pow(1-p,3);
    el.textContent=fmt(Math.round(start+(target-start)*ease));
    if(p<1)requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}

// ── INSIGHTS ───────────────────────────────────────────────────────────────
function buildInsights(animal,wClass,sex,color,ageRange,fMin,fMax,ageMod){
  const items=[];
  const avg=(fMin+fMax)/2;

  if(wClass==='heavy'||wClass==='large')
    items.push({icon:'bi-graph-up-arrow',col:'var(--emerald)',text:'<strong>Premium weight class detected.</strong> Heavy/Large animals command top-tier bids in all Uganda markets.'});
  else if(wClass==='light'||wClass==='small')
    items.push({icon:'bi-exclamation-triangle-fill',col:'var(--amber)',text:'<strong>Consider holding for additional gain.</strong> Lighter animals typically yield 30–50% more revenue at heavier weight classes.'});

  if(color==='black')
    items.push({icon:'bi-star-fill',col:'var(--amber)',text:'<strong>Black coat premium applied (+15%).</strong> Culturally preferred in most Ugandan markets — highest demand for cultural ceremonies.'});
  else if(color==='white')
    items.push({icon:'bi-info-circle-fill',col:'var(--blue)',text:'<strong>White coat discount (−5%).</strong> Lower local preference; consider eastern market outlets where white animals are preferred.'});

  if(sex==='female')
    items.push({icon:'bi-heart-fill',col:'var(--rose)',text:'<strong>Female breeding premium (+8%).</strong> Reproductive potential significantly elevates market value across all weight classes.'});

  if(ageMod===0)
    items.push({icon:'bi-check-circle-fill',col:'var(--emerald)',text:'<strong>Prime age bracket.</strong> This animal is at optimal maturity for immediate sale — peak value window is now.'});
  else if(ageMod<0)
    items.push({icon:'bi-hourglass-split',col:'var(--cyan)',text:'<strong>Age discount applied.</strong> Younger or older animals receive value adjustments. Consider timing your listing strategically.'});

  if(avg>=1000000)
    items.push({icon:'bi-gem',col:'var(--fire)',text:'<strong>High-value asset (1M+ UGX).</strong> List on AgriVault premium tier for access to verified corporate buyers and export networks.'});

  items.push({icon:'bi-clock-history',col:'var(--text2)',text:'<strong>Best auction windows:</strong> Monday & Friday 8AM–12PM EAT achieve 22% higher final prices based on platform data.'});

  const insightsEl = document.getElementById('market-insights');
  if(insightsEl) {
    insightsEl.innerHTML=items.map(i=>
      `<div class="insight-item"><i class="bi ${i.icon}" style="color:${i.col}"></i><span>${i.text}</span></div>`
    ).join('');
  }
}
</script>
