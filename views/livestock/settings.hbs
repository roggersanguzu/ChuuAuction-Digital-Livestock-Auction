    <script>
      // Theme Toggle const themeToggle =
      document.getElementById('theme-toggle'); const body = document.body;
      themeToggle.addEventListener('click', () => {
      themeToggle.classList.toggle('active'); body.classList.toggle('light');
      localStorage.setItem('theme', body.classList.contains('light') ? 'light' :
      'dark'); }); // Load saved theme if (localStorage.getItem('theme') ===
      'light') { body.classList.add('light');
      themeToggle.classList.add('active'); } // Settings Tab Navigation const
      tabButtons = document.querySelectorAll('.settings-tab-btn'); const
      contentSections = document.querySelectorAll('.settings-content');
      tabButtons.forEach(button => { button.addEventListener('click', () => {
      const targetTab = button.dataset.tab; // Remove active class from all
      buttons and sections tabButtons.forEach(btn =>
      btn.classList.remove('active', 'bg-gray-800/50'));
      contentSections.forEach(section => { section.classList.add('hidden');
      section.classList.remove('active'); }); // Add active class to clicked
      button and corresponding section button.classList.add('active',
      'bg-gray-800/50'); const targetSection =
      document.getElementById(`${targetTab}-section`);
      targetSection.classList.remove('hidden');
      targetSection.classList.add('active'); // Scroll to top of content
      window.scrollTo({ top: 0, behavior: 'smooth' }); }); }); // Accordion
      Functionality
      document.querySelectorAll('.accordion-trigger').forEach(trigger => {
      trigger.addEventListener('click', (e) => { e.preventDefault(); const
      content = trigger.nextElementSibling; const icon =
      trigger.querySelector('.accordion-icon'); const isActive =
      content.classList.contains('active'); // Close all other accordions in the
      same section const parentSection = trigger.closest('.settings-content');
      if (parentSection) {
      parentSection.querySelectorAll('.accordion-content').forEach(acc => { if
      (acc !== content) { acc.classList.remove('active');
      acc.previousElementSibling.querySelector('.accordion-icon')?.classList.remove('rotate-180');
      } }); } // Toggle current accordion content.classList.toggle('active');
      icon?.classList.toggle('rotate-180'); }); }); // Toggle Switches
      document.querySelectorAll('.toggle-switch').forEach(toggle => {
      toggle.addEventListener('click', () => {
      toggle.classList.toggle('active'); }); }); // Modal Functions function
      openContactModal() {
      document.getElementById('contact-modal').classList.add('active'); }
      function closeContactModal() {
      document.getElementById('contact-modal').classList.remove('active'); }
      function confirmDelete() {
      document.getElementById('delete-modal').classList.add('active'); }
      function closeDeleteModal() {
      document.getElementById('delete-modal').classList.remove('active');
      document.getElementById('delete-confirm-input').value = ''; } function
      confirmDeactivate() {
      document.getElementById('deactivate-modal').classList.add('active'); }
      function closeDeactivateModal() {
      document.getElementById('deactivate-modal').classList.remove('active'); }
      function executeDelete() { const input =
      document.getElementById('delete-confirm-input').value; if (input ===
      'DELETE') { alert('Account deletion initiated. You will receive a
      confirmation email.'); closeDeleteModal(); } else { alert('Please type
      DELETE exactly to confirm'); } } function executeDeactivate() {
      alert('Account deactivated successfully. You can reactivate anytime by
      logging back in.'); closeDeactivateModal(); } function sendAdminMessage(e)
      { e.preventDefault(); alert('Message sent successfully! Our team will
      respond within 24 hours.'); closeContactModal(); } function
      submitFraudReport(e) { e.preventDefault(); const checkbox =
      document.getElementById('fraud-acknowledgment'); if (!checkbox.checked) {
      alert('Please acknowledge the terms before submitting'); return; }
      alert('Fraud report submitted successfully. Case ID: #FR-2026-0205-' +
      Math.floor(Math.random() * 1000)); e.target.reset(); } // Close modals on
      outside click document.querySelectorAll('.modal').forEach(modal => {
      modal.addEventListener('click', (e) => { if (e.target === modal) {
      modal.classList.remove('active'); } }); }); // Initialize first tab
      document.querySelector('.settings-tab-btn').click();
    </script>

