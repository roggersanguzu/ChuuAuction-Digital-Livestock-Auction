<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LiveStock Verify — Verification Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
    />
    <style>
      :root {
        --bg: #050810;
        --bg2: #080c18;
        --surface: rgba(255, 255, 255, 0.035);
        --surface2: rgba(255, 255, 255, 0.06);
        --border: rgba(255, 255, 255, 0.07);
        --border2: rgba(255, 255, 255, 0.12);
        --accent: #4ade80;
        --accent2: #22d3ee;
        --accent3: #f59e0b;
        --accent4: #f87171;
        --accent5: #a78bfa;
        --text: #f0f4ff;
        --text2: #8892aa;
        --text3: #404862;
        --blue: #3b82f6;
        --glow-green: rgba(74, 222, 128, 0.15);
        --glow-cyan: rgba(34, 211, 238, 0.12);
        --r: 6px;
        --r2: 10px;
        --r3: 14px;
        --r4: 20px;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: "DM Sans", sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
      }

      /* ─── NOISE OVERLAY ─── */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 0;
        opacity: 0.6;
      }
      /* ─── AMBIENT GLOW ─── */
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        background:
          radial-gradient(
            ellipse 70% 55% at 15% 60%,
            rgba(74, 222, 128, 0.07) 0%,
            transparent 65%
          ),
          radial-gradient(
            ellipse 60% 50% at 85% 20%,
            rgba(34, 211, 238, 0.06) 0%,
            transparent 65%
          ),
          radial-gradient(
            ellipse 40% 40% at 50% 90%,
            rgba(167, 139, 250, 0.05) 0%,
            transparent 65%
          );
        pointer-events: none;
        z-index: 0;
      }

      /* ─── SCROLLBAR ─── */
      ::-webkit-scrollbar {
        width: 4px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 99px;
      }

      /* ════════════════════════════════
       HEADER
    ════════════════════════════════ */
      .header {
        position: sticky;
        top: 0;
        z-index: 300;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 32px;
        height: 62px;
        background: rgba(5, 8, 16, 0.85);
        backdrop-filter: blur(24px);
        border-bottom: 1px solid var(--border);
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
      }
      .logo-icon {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #16a34a, #0891b2);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 17px;
        box-shadow: 0 0 20px rgba(74, 222, 128, 0.3);
      }
      .logo-name {
        font-family: "Syne", sans-serif;
        font-size: 17px;
        font-weight: 800;
        letter-spacing: -0.3px;
      }
      .logo-name em {
        color: var(--accent);
        font-style: normal;
      }
      .logo-version {
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--text3);
        background: var(--surface2);
        border: 1px solid var(--border);
        padding: 2px 7px;
        border-radius: 4px;
        margin-left: 4px;
      }

      .header-center {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: "DM Mono", monospace;
        font-size: 11px;
        color: var(--text3);
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 6px 14px;
        border-radius: 99px;
      }
      .header-center .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 8px var(--accent);
        animation: pulse-dot 2s ease-in-out infinite;
      }
      @keyframes pulse-dot {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.5;
          transform: scale(0.8);
        }
      }

      .header-right {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .hdr-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 8px 16px;
        border-radius: var(--r2);
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid var(--border2);
        background: var(--surface2);
        color: var(--text2);
        transition: all 0.2s;
        font-family: "DM Sans", sans-serif;
      }
      .hdr-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: var(--text);
        transform: translateY(-1px);
      }
      .hdr-btn-primary {
        background: var(--accent);
        color: #000;
        border-color: var(--accent);
        font-weight: 600;
        box-shadow: 0 0 20px rgba(74, 222, 128, 0.25);
      }
      .hdr-btn-primary:hover {
        background: #86efac;
        box-shadow: 0 0 28px rgba(74, 222, 128, 0.4);
      }

      .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4ade80, #22d3ee);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: #000;
        cursor: pointer;
        border: 2px solid rgba(74, 222, 128, 0.4);
      }

      /* ════════════════════════════════
       LAYOUT
    ════════════════════════════════ */
      .layout {
        display: flex;
        flex: 1;
        position: relative;
        z-index: 1;
      }

      /* ─── SIDEBAR ─── */
      .sidebar {
        width: 220px;
        min-width: 220px;
        background: rgba(5, 8, 16, 0.6);
        backdrop-filter: blur(20px);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        padding: 20px 10px;
        position: sticky;
        top: 62px;
        height: calc(100vh - 62px);
        overflow-y: auto;
      }
      .sb-section {
        margin-bottom: 8px;
      }
      .sb-label {
        font-family: "DM Mono", monospace;
        font-size: 9px;
        font-weight: 500;
        color: var(--text3);
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 12px 14px 6px;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 14px;
        border-radius: var(--r2);
        cursor: pointer;
        border: 1px solid transparent;
        font-size: 13px;
        font-weight: 500;
        color: var(--text2);
        transition: all 0.15s;
        position: relative;
      }
      .nav-item i {
        width: 14px;
        font-size: 12px;
        opacity: 0.7;
      }
      .nav-item:hover {
        background: var(--surface2);
        color: var(--text);
      }
      .nav-item.active {
        background: rgba(74, 222, 128, 0.08);
        border-color: rgba(74, 222, 128, 0.2);
        color: var(--accent);
      }
      .nav-item.active i {
        opacity: 1;
      }
      .nav-item.active::before {
        content: "";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 2px;
        height: 60%;
        background: var(--accent);
        border-radius: 0 2px 2px 0;
        box-shadow: 0 0 8px var(--accent);
      }
      .nav-badge {
        margin-left: auto;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        font-weight: 500;
        padding: 1px 7px;
        border-radius: 99px;
        background: var(--surface2);
        color: var(--text3);
        border: 1px solid var(--border);
      }
      .nav-item.active .nav-badge {
        background: rgba(74, 222, 128, 0.15);
        color: var(--accent);
        border-color: rgba(74, 222, 128, 0.3);
      }

      .sb-divider {
        height: 1px;
        background: var(--border);
        margin: 10px 10px;
      }

      .sb-info {
        margin-top: auto;
        padding: 14px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r3);
        margin: auto 4px 0;
      }
      .sb-info-label {
        font-size: 10px;
        color: var(--text3);
        margin-bottom: 4px;
      }
      .sb-info-val {
        font-family: "DM Mono", monospace;
        font-size: 11px;
        color: var(--accent);
      }

      /* ─── MAIN ─── */
      .main {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
      }
      .main-inner {
        flex: 1;
        padding: 28px 32px;
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      /* ═══ HEADER AREA ═══ */
      .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
      }
      .page-title-block {
      }
      .page-eyebrow {
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--accent2);
        letter-spacing: 2.5px;
        text-transform: uppercase;
        margin-bottom: 6px;
      }
      .page-title {
        font-family: "Syne", sans-serif;
        font-size: 26px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.5px;
        line-height: 1.1;
      }
      .page-title span {
        color: var(--accent);
      }
      .page-sub {
        font-size: 13px;
        color: var(--text3);
        margin-top: 6px;
      }

      .page-actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      /* ═══ STATS GRID ═══ */
      .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
      }
      .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r4);
        padding: 22px 24px;
        position: relative;
        overflow: hidden;
        transition: all 0.25s;
        cursor: default;
      }
      .stat-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--card-bg, transparent);
        opacity: 0;
        transition: opacity 0.25s;
      }
      .stat-card:hover::before {
        opacity: 1;
      }
      .stat-card:hover {
        border-color: var(--card-border, var(--border2));
        transform: translateY(-3px);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
      }

      .stat-card-total {
        --card-bg: linear-gradient(
          135deg,
          rgba(34, 211, 238, 0.06),
          transparent
        );
        --card-border: rgba(34, 211, 238, 0.3);
      }
      .stat-card-pending {
        --card-bg: linear-gradient(
          135deg,
          rgba(245, 158, 11, 0.06),
          transparent
        );
        --card-border: rgba(245, 158, 11, 0.3);
      }
      .stat-card-verified {
        --card-bg: linear-gradient(
          135deg,
          rgba(74, 222, 128, 0.06),
          transparent
        );
        --card-border: rgba(74, 222, 128, 0.3);
      }
      .stat-card-rejected {
        --card-bg: linear-gradient(
          135deg,
          rgba(248, 113, 113, 0.06),
          transparent
        );
        --card-border: rgba(248, 113, 113, 0.3);
      }

      .stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        margin-bottom: 14px;
        position: relative;
        z-index: 1;
      }
      .stat-icon-cyan {
        background: rgba(34, 211, 238, 0.1);
        color: var(--accent2);
        border: 1px solid rgba(34, 211, 238, 0.2);
      }
      .stat-icon-yellow {
        background: rgba(245, 158, 11, 0.1);
        color: var(--accent3);
        border: 1px solid rgba(245, 158, 11, 0.2);
      }
      .stat-icon-green {
        background: rgba(74, 222, 128, 0.1);
        color: var(--accent);
        border: 1px solid rgba(74, 222, 128, 0.2);
      }
      .stat-icon-red {
        background: rgba(248, 113, 113, 0.1);
        color: var(--accent4);
        border: 1px solid rgba(248, 113, 113, 0.2);
      }

      .stat-value {
        font-family: "Syne", sans-serif;
        font-size: 34px;
        font-weight: 800;
        line-height: 1;
        position: relative;
        z-index: 1;
      }
      .stat-label {
        font-size: 12px;
        color: var(--text3);
        margin-top: 6px;
        font-weight: 500;
        position: relative;
        z-index: 1;
      }
      .stat-trend {
        position: absolute;
        bottom: 20px;
        right: 20px;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        padding: 3px 8px;
        border-radius: 4px;
      }
      .trend-up {
        color: var(--accent);
        background: rgba(74, 222, 128, 0.1);
        border: 1px solid rgba(74, 222, 128, 0.2);
      }
      .trend-down {
        color: var(--accent4);
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.2);
      }
      .trend-neutral {
        color: var(--text3);
        background: var(--surface2);
        border: 1px solid var(--border);
      }

      /* ═══ BANNER ═══ */
      .role-banner {
        display: none;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        border-radius: var(--r3);
        font-size: 13px;
      }
      .role-banner.admin {
        background: rgba(34, 211, 238, 0.06);
        border: 1px solid rgba(34, 211, 238, 0.2);
        color: var(--accent2);
      }
      .role-banner.user {
        background: rgba(74, 222, 128, 0.06);
        border: 1px solid rgba(74, 222, 128, 0.2);
        color: var(--accent);
      }

      /* ═══ TOOLBAR ═══ */
      .toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding: 14px 18px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r3);
      }
      .search-wrap {
        position: relative;
        flex: 1;
        min-width: 220px;
      }
      .search-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text3);
        font-size: 12px;
      }
      .search-input {
        width: 100%;
        padding: 9px 13px 9px 36px;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 13px;
        outline: none;
        transition: all 0.2s;
      }
      .search-input:focus {
        border-color: rgba(74, 222, 128, 0.4);
        background: rgba(0, 0, 0, 0.4);
        box-shadow: 0 0 0 3px rgba(74, 222, 128, 0.06);
      }
      .search-input::placeholder {
        color: var(--text3);
      }
      .filter-select {
        padding: 9px 13px;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 13px;
        outline: none;
        cursor: pointer;
        min-width: 138px;
        transition: border-color 0.2s;
      }
      .filter-select:focus {
        border-color: rgba(74, 222, 128, 0.4);
      }
      .filter-select option {
        background: #080c18;
      }

      .tb-sep {
        width: 1px;
        height: 28px;
        background: var(--border);
        flex-shrink: 0;
      }
      .tb-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 9px 14px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: var(--r2);
        color: var(--text2);
        font-size: 12px;
        font-family: "DM Sans", sans-serif;
        cursor: pointer;
        transition: all 0.2s;
      }
      .tb-btn:hover {
        background: var(--surface2);
        color: var(--text);
      }
      .tb-count {
        font-family: "DM Mono", monospace;
        font-size: 11px;
        color: var(--text3);
        margin-left: auto;
        padding: 4px 10px;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 99px;
      }

      /* ═══ CARDS GRID ═══ */
      .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
        gap: 18px;
      }

      /* ─── VERIFICATION CARD ─── */
      .v-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r4);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
      }
      .v-card::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: var(--r4);
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
      }
      .v-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.45);
        border-color: var(--border2);
      }
      .v-card:hover::after {
        opacity: 1;
      }

      /* accent stripe */
      .v-card .stripe {
        height: 3px;
        width: 100%;
      }
      .v-card.s-pending .stripe {
        background: linear-gradient(90deg, var(--accent3), #d97706);
      }
      .v-card.s-processing .stripe {
        background: linear-gradient(90deg, #3b82f6, #2563eb);
      }
      .v-card.s-verified .stripe {
        background: linear-gradient(90deg, var(--accent), #16a34a);
      }
      .v-card.s-rejected .stripe {
        background: linear-gradient(90deg, var(--accent4), #dc2626);
      }
      .v-card.s-needs_review .stripe {
        background: linear-gradient(90deg, var(--accent5), #7c3aed);
      }
      .v-card.s-incomplete .stripe {
        background: var(--border);
      }

      .v-card-head {
        padding: 18px 20px 14px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
      }
      .v-card-id {
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--text3);
        letter-spacing: 0.5px;
        margin-bottom: 5px;
      }
      .v-card-name {
        font-family: "Syne", sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
      }

      /* Badges */
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 99px;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        font-weight: 500;
        border: 1px solid;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .badge::before {
        content: "●";
        font-size: 7px;
      }
      .badge-pending {
        color: #fbbf24;
        background: rgba(245, 158, 11, 0.08);
        border-color: rgba(245, 158, 11, 0.25);
      }
      .badge-processing {
        color: #60a5fa;
        background: rgba(59, 130, 246, 0.08);
        border-color: rgba(59, 130, 246, 0.25);
      }
      .badge-verified {
        color: #4ade80;
        background: rgba(74, 222, 128, 0.08);
        border-color: rgba(74, 222, 128, 0.25);
      }
      .badge-rejected {
        color: #f87171;
        background: rgba(248, 113, 113, 0.08);
        border-color: rgba(248, 113, 113, 0.25);
      }
      .badge-needs_review {
        color: #c4b5fd;
        background: rgba(167, 139, 250, 0.08);
        border-color: rgba(167, 139, 250, 0.25);
      }
      .badge-incomplete {
        color: #64748b;
        background: rgba(100, 116, 139, 0.08);
        border-color: rgba(100, 116, 139, 0.25);
      }

      .v-card-body {
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        flex: 1;
      }
      .info-row {
        display: flex;
        align-items: center;
        gap: 0;
        font-size: 12.5px;
      }
      .info-label {
        color: var(--text3);
        min-width: 110px;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.2px;
      }
      .info-value {
        color: var(--text2);
        font-size: 12.5px;
      }
      .info-value strong {
        color: var(--text);
        font-weight: 600;
      }

      .type-tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 4px;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text2);
        font-weight: 500;
      }

      /* Doc tags */
      .doc-tag {
        font-family: "DM Mono", monospace;
        font-size: 10px;
        padding: 2px 8px;
        border-radius: 4px;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text3);
        margin-right: 6px;
      }

      /* Card footer */
      .v-card-foot {
        padding: 12px 18px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(0, 0, 0, 0.2);
      }
      .foot-select {
        flex: 1;
        padding: 7px 12px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: var(--r);
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 12px;
        outline: none;
        cursor: pointer;
      }
      .foot-select option {
        background: #080c18;
      }
      .foot-select:focus {
        border-color: rgba(74, 222, 128, 0.4);
      }

      .foot-btn {
        padding: 7px 14px;
        border-radius: var(--r);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        font-family: "DM Sans", sans-serif;
      }
      .foot-btn-save {
        background: var(--accent);
        color: #000;
        border: none;
        box-shadow: 0 0 16px rgba(74, 222, 128, 0.2);
      }
      .foot-btn-save:hover {
        background: #86efac;
        box-shadow: 0 0 24px rgba(74, 222, 128, 0.4);
      }
      .foot-btn-save:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        box-shadow: none;
      }
      .foot-btn-view {
        background: transparent;
        color: var(--text2);
        border: 1px solid var(--border);
      }
      .foot-btn-view:hover {
        background: var(--surface2);
        color: var(--text);
      }

      .status-readonly {
        flex: 1;
        padding: 7px 12px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: var(--r);
        color: var(--text3);
        font-size: 12px;
      }

      /* ═══ EMPTY / LOADING ═══ */
      .state-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        padding: 80px 32px;
        color: var(--text3);
        text-align: center;
        background: var(--surface);
        border: 1px dashed var(--border);
        border-radius: var(--r4);
      }
      .state-icon {
        font-size: 48px;
        opacity: 0.3;
      }
      .state-title {
        font-family: "Syne", sans-serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--text2);
      }
      .state-sub {
        font-size: 13px;
        line-height: 1.7;
        max-width: 300px;
      }

      .spinner-ring {
        width: 42px;
        height: 42px;
        border: 2px solid rgba(255, 255, 255, 0.06);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      /* ═══ MODAL ═══ */
      .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(12px);
        z-index: 600;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .overlay.open {
        display: flex;
      }
      .modal {
        background: #080c18;
        border: 1px solid var(--border2);
        border-radius: 24px;
        width: 100%;
        max-width: 740px;
        max-height: 90vh;
        overflow-y: auto;
        animation: modal-in 0.25s cubic-bezier(0.23, 1, 0.32, 1);
      }
      @keyframes modal-in {
        from {
          transform: scale(0.93) translateY(8px);
          opacity: 0;
        }
        to {
          transform: scale(1);
          opacity: 1;
        }
      }
      .modal-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 22px 28px;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        background: #080c18;
        z-index: 1;
      }
      .modal-title {
        font-family: "Syne", sans-serif;
        font-size: 17px;
        font-weight: 800;
      }
      .modal-id {
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--text3);
        margin-top: 4px;
      }
      .modal-x {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        background: var(--surface2);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text2);
        font-size: 14px;
        transition: all 0.15s;
      }
      .modal-x:hover {
        background: rgba(248, 113, 113, 0.1);
        border-color: rgba(248, 113, 113, 0.3);
        color: var(--accent4);
      }
      .modal-body {
        padding: 24px 28px;
        display: flex;
        flex-direction: column;
        gap: 22px;
      }
      .modal-sec-label {
        font-family: "DM Mono", monospace;
        font-size: 9px;
        font-weight: 500;
        color: var(--text3);
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .modal-sec-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .field {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        padding: 12px 16px;
      }
      .field-label {
        font-family: "DM Mono", monospace;
        font-size: 9px;
        color: var(--text3);
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 6px;
      }
      .field-value {
        font-size: 14px;
        color: var(--text);
        word-break: break-all;
      }

      /* ═══ TOAST ═══ */
      .toast-wrap {
        position: fixed;
        bottom: 28px;
        right: 28px;
        z-index: 900;
        display: flex;
        flex-direction: column;
        gap: 8px;
        pointer-events: none;
      }
      .toast {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 18px;
        border-radius: var(--r2);
        background: #0f1729;
        border: 1px solid var(--border2);
        font-size: 13px;
        color: var(--text);
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
        animation: toast-in 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        pointer-events: all;
      }
      .toast.success {
        border-left: 3px solid var(--accent);
      }
      .toast.error {
        border-left: 3px solid var(--accent4);
      }
      @keyframes toast-in {
        from {
          opacity: 0;
          transform: translateX(12px) scale(0.95);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      @keyframes toast-out {
        from {
          opacity: 1;
        }
        to {
          opacity: 0;
          transform: translateX(16px) scale(0.95);
        }
      }
      .toast.hiding {
        animation: toast-out 0.25s ease forwards;
      }

      /* ─── RESPONSIVE ─── */
      @media (max-width: 900px) {
        .sidebar {
          display: none;
        }
        .stats-row {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 600px) {
        .main-inner {
          padding: 16px;
        }
        .stats-row {
          grid-template-columns: 1fr 1fr;
        }
        .field-grid {
          grid-template-columns: 1fr;
        }
        .toolbar {
          flex-direction: column;
          align-items: stretch;
        }
        .search-wrap {
          min-width: 100%;
        }
      }

      /* ─── ENTRY ANIMATIONS ─── */
      .v-card {
        animation: card-in 0.35s cubic-bezier(0.23, 1, 0.32, 1) both;
      }
      @keyframes card-in {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
    </style>
  </head>
  <body>

    <!-- HEADER -->
    <header class="header">
      <a class="logo" href="/">
        <div class="logo-icon">🐄</div>
        <span class="logo-name">Live<em>Stock</em> Verify</span>
        <span class="logo-version">v2.4.1</span>
      </a>
      <div class="header-center">
        <span class="dot"></span>
        SYSTEM ONLINE ·
        <span id="hdr-clock">--:--:--</span>
      </div>
      <div class="header-right">
        <button class="hdr-btn" onclick="refreshData()"><i
            class="fas fa-sync-alt"
          ></i>
          Refresh</button>
        <div class="avatar" id="user-avatar" title="User">U</div>
      </div>
    </header>

    <div class="layout">

      <!-- SIDEBAR -->
      <aside class="sidebar">
        <div class="sb-section">
          <div class="sb-label">Views</div>
          <div
            class="nav-item active"
            data-nav="all"
            onclick="setNav('all',this)"
          >
            <i class="fas fa-th-large"></i>
            All
            <span class="nav-badge" id="nb-all">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="pending"
            onclick="setNav('pending',this)"
          >
            <i class="fas fa-clock"></i>
            Pending
            <span class="nav-badge" id="nb-pending">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="processing"
            onclick="setNav('processing',this)"
          >
            <i class="fas fa-cog fa-spin" style="animation-duration:3s"></i>
            Processing
            <span class="nav-badge" id="nb-processing">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="verified"
            onclick="setNav('verified',this)"
          >
            <i class="fas fa-check-circle"></i>
            Approved
            <span class="nav-badge" id="nb-verified">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="rejected"
            onclick="setNav('rejected',this)"
          >
            <i class="fas fa-times-circle"></i>
            Rejected
            <span class="nav-badge" id="nb-rejected">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="needs_review"
            onclick="setNav('needs_review',this)"
          >
            <i class="fas fa-search"></i>
            Review
            <span class="nav-badge" id="nb-needs_review">0</span>
          </div>
        </div>

        <div class="sb-divider"></div>

        <div class="sb-info">
          <div class="sb-info-label">Last sync</div>
          <div class="sb-info-val" id="last-sync">Never</div>
        </div>
      </aside>

      <!-- MAIN -->
      <main class="main">
        <div class="main-inner">

          <!-- Page Header -->
          <div class="page-header">
            <div class="page-title-block">
              <div class="page-eyebrow">Dashboard · Real-time</div>
              <div class="page-title">Verification <span>Oversight</span></div>
              <div class="page-sub">Monitor, review, and action all livestock
                verification submissions</div>
            </div>
          </div>

          <!-- Stats -->
          <div class="stats-row">
            <div class="stat-card stat-card-total">
              <div class="stat-icon stat-icon-cyan"><i
                  class="fas fa-layer-group"
                ></i></div>
              <div class="stat-value" id="st-total">0</div>
              <div class="stat-label">Total Submissions</div>
            </div>
            <div class="stat-card stat-card-pending">
              <div class="stat-icon stat-icon-yellow"><i
                  class="fas fa-hourglass-half"
                ></i></div>
              <div
                class="stat-value"
                style="color:var(--accent3)"
                id="st-pending"
              >0</div>
              <div class="stat-label">Awaiting Review</div>
            </div>
            <div class="stat-card stat-card-verified">
              <div class="stat-icon stat-icon-green"><i
                  class="fas fa-check-double"
                ></i></div>
              <div
                class="stat-value"
                style="color:var(--accent)"
                id="st-verified"
              >0</div>
              <div class="stat-label">Verified & Approved</div>
            </div>
            <div class="stat-card stat-card-rejected">
              <div class="stat-icon stat-icon-red"><i
                  class="fas fa-ban"
                ></i></div>
              <div
                class="stat-value"
                style="color:var(--accent4)"
                id="st-rejected"
              >0</div>
              <div class="stat-label">Rejected Cases</div>
            </div>
          </div>

          <!-- Banners -->
          <div id="admin-banner" class="role-banner admin">
            <i class="fas fa-shield-alt"></i>
            <strong>Admin View</strong>
            — You have full access to review and update verification statuses.
          </div>
          <div id="user-banner" class="role-banner user">
            <i class="fas fa-user-check"></i>
            <strong>My Verifications</strong>
            — Viewing your own submissions. Only admins can modify status.
          </div>

          <!-- Toolbar -->
          <div class="toolbar">
            <div class="search-wrap">
              <i class="fas fa-search search-icon"></i>
              <input
                type="text"
                class="search-input"
                id="search-input"
                placeholder="Search by ID, farmer name, or verification type…"
                oninput="applyFilters()"
              />
            </div>
            <div class="tb-sep"></div>
            <select
              class="filter-select"
              id="filter-status"
              onchange="applyFilters()"
            >
              <option value="all">All Status</option>
              <option value="pending">Pending</option>
              <option value="processing">Processing</option>
              <option value="verified">Approved</option>
              <option value="rejected">Rejected</option>
              <option value="needs_review">Needs Review</option>
              <option value="incomplete">Incomplete</option>
            </select>
            <select
              class="filter-select"
              id="filter-type"
              onchange="applyFilters()"
            >
              <option value="all">All Types</option>
              <option value="ownership">Ownership</option>
              <option value="health">Health</option>
              <option value="both">Both</option>
            </select>
            <div class="tb-sep"></div>
            <button class="tb-btn" onclick="clearFilters()"><i
                class="fas fa-times"
              ></i>
              Clear</button>
            <span class="tb-count" id="result-count">0 results</span>
          </div>

          <!-- Cards -->
          <div id="cards-container">
            <div class="state-box">
              <div class="spinner-ring"></div>
              <div class="state-title">Initialising…</div>
              <div class="state-sub">Fetching verification records from the
                system</div>
            </div>
          </div>

        </div>
      </main>
    </div>

    <!-- DETAIL MODAL -->
    <div class="overlay" id="detail-overlay" onclick="closeModal(event)">
      <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-head">
          <div>
            <div class="modal-title"><i
                class="fas fa-file-search"
                style="color:var(--accent)"
              ></i>
              Verification Details</div>
            <div class="modal-id" id="modal-sub-id">—</div>
          </div>
          <button class="modal-x" onclick="closeModal()"><i
              class="fas fa-times"
            ></i></button>
        </div>
        <div class="modal-body" id="modal-body"></div>
      </div>
    </div>

    <!-- TOAST CONTAINER -->
    <div class="toast-wrap" id="toast-wrap"></div>

    <!-- VERIFICATION SCRIPT -->
    <script src="/js/verificationStatus.js"></script>

    <script>
      /* ── CLOCK ─────────────────────────── */ setInterval(()=>{ const n=new
      Date();
      document.getElementById('hdr-clock').textContent=n.toLocaleTimeString();
      },1000); /* ── UPDATE USER AVATAR ─────────────────────────── */ function
      updateUserAvatar() { if (window.currentUser && window.currentUser.name) {
      const avatar = document.getElementById('user-avatar'); if (avatar) {
      avatar.textContent = window.currentUser.name.charAt(0).toUpperCase();
      avatar.title = window.currentUser.name; } } } /* ── OVERRIDE
      loadCurrentUser to update avatar ─────────────────────────── */ const
      originalLoadCurrentUser = window.loadCurrentUser; window.loadCurrentUser =
      async function() { await originalLoadCurrentUser(); updateUserAvatar(); };
      /* ── LAST SYNC ─────────────────────────── */ function updateLastSync(){
      document.getElementById('last-sync').textContent = new
      Date().toLocaleTimeString(); } /* ── TOAST HELPER
      ─────────────────────────── */ function showToast(msg, type) { const wrap
      = document.getElementById('toast-wrap'); const t =
      document.createElement('div'); t.className = 'toast ' + (type ||
      'success'); t.innerHTML = '<i class="fas ' + (type === 'success' ?
      'fa-check-circle' : 'fa-exclamation-circle') + '" style="color:' + (type
      === 'success' ? 'var(--accent)' : 'var(--accent4)') + '"></i> ' + msg;
      wrap.appendChild(t); setTimeout(() => { t.classList.add('hiding');
      setTimeout(() => t.remove(), 300); }, 3000); } /* ── OVERRIDE updateStatus
      for toast ─────────────────────────── */ const originalUpdateStatus =
      window.updateStatus; window.updateStatus = async function(id) { try {
      await originalUpdateStatus(id); updateLastSync(); } catch(e) {
      showToast(e.message, 'error'); } }; /* ── INIT ON PAGE LOAD
      ─────────────────────────── */
      document.addEventListener('DOMContentLoaded', function() { // Just ensure
      the page starts fresh updateLastSync(); });
    </script>

  </body>
</html>