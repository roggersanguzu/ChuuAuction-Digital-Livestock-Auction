        border: 1px solid var(--border);
        border-radius: 99px;
      }
      .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 16px;
      }
      .v-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r4);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: all 0.32s cubic-bezier(0.23, 1, 0.32, 1);
        position: relative;
        animation: cardIn 0.4s cubic-bezier(0.23, 1, 0.32, 1) both;
      }
      @keyframes cardIn {
        from {
          opacity: 0;
          transform: translateY(14px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .v-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
        border-color: var(--border2);
      }
      .v-card::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: var(--r4);
        pointer-events: none;
        opacity: 0;
        transition: opacity var(--trans);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
      }
      .v-card:hover::after {
        opacity: 1;
      }
      .v-stripe {
        height: 3px;
        width: 100%;
      }
      .s-pending .v-stripe {
        background: linear-gradient(90deg, var(--amber), #d97706);
      }
      .s-processing .v-stripe {
        background: linear-gradient(90deg, var(--blue), #d97706);
      }
      .s-verified .v-stripe {
        background: linear-gradient(90deg, var(--green), #d97706);
      }
      .s-rejected .v-stripe {
        background: linear-gradient(90deg, var(--red), #dc2626);
      }
      .s-needs_review .v-stripe {
        background: linear-gradient(90deg, var(--violet), #dc2626);
      }
      .s-incomplete .v-stripe {
        background: var(--border);
      }
      .s-verified:hover {
        box-shadow:
          0 20px 50px rgba(251, 191, 36, 0.12),
          0 0 0 1px rgba(251, 191, 36, 0.08);
      }
      .s-pending:hover {
        box-shadow:
          0 20px 50px rgba(245, 158, 11, 0.1),
          0 0 0 1px rgba(245, 158, 11, 0.06);
      }
      .s-rejected:hover {
        box-shadow:
          0 20px 50px rgba(248, 113, 113, 0.1),
          0 0 0 1px rgba(248, 113, 113, 0.06);
      }
      .s-processing:hover {
        box-shadow:
          0 20px 50px rgba(251, 191, 36, 0.1),
          0 0 0 1px rgba(96, 165, 250, 0.06);
      }
      .v-card-head {
        padding: 16px 20px 14px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
      }
      .v-card-meta {
      }
      .v-card-id {
        font-family: "DM Mono", monospace;
        font-size: 9.5px;
        color: var(--text3);
        letter-spacing: 0.6px;
        margin-bottom: 5px;
        overflow-wrap: anywhere;
      }
      .v-card-name {
        font-family: "Syne", sans-serif;
        font-size: 14.5px;
        font-weight: 700;
        color: var(--text);
      }
      .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 99px;
        font-family: "DM Mono", monospace;
        font-size: 9.5px;
        font-weight: 500;
        border: 1px solid;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .status-badge::before {
        content: "?";
        font-size: 6px;
      }
      .badge-pending {
        color: #fbbf24;
        background: rgba(245, 158, 11, 0.07);
        border-color: rgba(245, 158, 11, 0.22);
      }
      .badge-processing {
        color: #93c5fd;
        background: rgba(59, 130, 246, 0.07);
        border-color: rgba(59, 130, 246, 0.22);
      }
      .badge-verified {
        color: #fbbf24;
        background: rgba(251, 191, 36, 0.07);
        border-color: rgba(251, 191, 36, 0.22);
      }
      .badge-rejected {
        color: #f87171;
        background: rgba(248, 113, 113, 0.07);
        border-color: rgba(248, 113, 113, 0.22);
      }
      .badge-needs_review {
        color: #c4b5fd;
        background: rgba(251, 146, 60, 0.07);
        border-color: rgba(251, 146, 60, 0.22);
      }
      .badge-incomplete {
        color: #64748b;
        background: rgba(100, 116, 139, 0.07);
        border-color: rgba(100, 116, 139, 0.22);
      }
      .v-card-body {
        padding: 14px 20px 12px;
        display: flex;
        flex-direction: column;
        gap: 7px;
        flex: 1;
      }
      .info-row {
        display: flex;
        align-items: flex-start;
        gap: 0;
        font-size: 12px;
      }
      .info-label {
        min-width: 108px;
        font-size: 10.5px;
        font-weight: 500;
        color: var(--text3);
        letter-spacing: 0.1px;
        flex-shrink: 0;
      }
      .info-value {
        color: var(--text2);
        font-size: 12px;
        line-height: 1.45;
        overflow-wrap: anywhere;
      }
      .info-value strong {
        color: var(--text);
        font-weight: 600;
      }
      .type-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 10.5px;
        padding: 2px 9px;
        border-radius: 4px;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text2);
        font-weight: 500;
      }
      .doc-chip {
        font-family: "DM Mono", monospace;
        font-size: 9.5px;
        padding: 2px 7px;
        border-radius: 3px;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text3);
        margin-right: 4px;
      }
      .card-progress {
        margin-top: 6px;
      }
      .card-progress-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 10px;
        color: var(--text3);
        margin-bottom: 4px;
      }
      .card-progress-bar {
        height: 3px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 3px;
        overflow: hidden;
      }
      .card-progress-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.8s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .v-card-foot {
        padding: 11px 16px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(0, 0, 0, 0.18);
      }
      .foot-select {
        flex: 1;
        padding: 7px 10px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: var(--r);
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 12px;
        outline: none;
        cursor: pointer;
        transition: border-color 0.2s;
      }
      .foot-select:focus {
        border-color: rgba(251, 191, 36, 0.35);
      }
      .foot-select option {
        background: #070d1a;
      }
      .foot-readonly {
        flex: 1;
        padding: 7px 10px;
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid var(--border);
        border-radius: var(--r);
        color: var(--text3);
        font-size: 12px;
        pointer-events: none;
      }
      .foot-btn {
        padding: 7px 13px;
        border-radius: var(--r);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--trans);
        font-family: "DM Sans", sans-serif;
      }
      .fb-save {
        background: var(--green);
        color: #000;
        border: none;
        box-shadow: 0 0 14px rgba(251, 191, 36, 0.18);
      }
      .fb-save:hover {
        background: #86efac;
        box-shadow: 0 0 22px rgba(251, 191, 36, 0.35);
      }
      .fb-save:disabled {
        opacity: 0.35;
        cursor: not-allowed;
        box-shadow: none;
      }
      .fb-view {
        background: transparent;
        color: var(--text2);
        border: 1px solid var(--border);
      }
      .fb-view:hover {
        background: var(--surface2);
        color: var(--text);
      }
      .state-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 16px;
        padding: 80px 32px;
        text-align: center;
        background: var(--surface);
        border: 1px dashed var(--border);
        border-radius: var(--r5);
      }
      .state-icon {
        font-size: 46px;
        opacity: 0.22;
      }
      .state-title {
        font-family: "Syne", sans-serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--text2);
      }
      .state-sub {
        font-size: 13px;
        color: var(--text3);
        line-height: 1.7;
        max-width: 280px;
      }
      .spinner {
        width: 40px;
        height: 40px;
        border: 2px solid rgba(255, 255, 255, 0.05);
        border-top-color: var(--green);
        border-radius: 50%;
        animation: spin 0.65s linear infinite;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.82);
        backdrop-filter: blur(14px);
        z-index: 700;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .overlay.open {
        display: flex;
      }
      .modal {
        background: var(--bg2);
        border: 1px solid var(--border2);
        border-radius: 22px;
        width: 100%;
        max-width: 720px;
        max-height: 88vh;
        overflow-y: auto;
        animation: modalIn 0.28s cubic-bezier(0.23, 1, 0.32, 1);
      }
      @keyframes modalIn {
        from {
          transform: scale(0.94) translateY(10px);
          opacity: 0;
        }
        to {
          transform: scale(1);
          opacity: 1;
        }
      }
      .modal-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 26px;
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        background: var(--bg2);
        z-index: 1;
      }
      .modal-head-left {
      }
      .modal-title {
        font-family: "Syne", sans-serif;
        font-size: 16px;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .modal-title i {
        color: var(--green);
      }
      .modal-id {
        font-family: "DM Mono", monospace;
        font-size: 9.5px;
        color: var(--text3);
        margin-top: 4px;
      }
      .modal-close {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: var(--surface2);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: var(--text2);
        font-size: 13px;
        transition: all var(--trans);
      }
      .modal-close:hover {
        background: rgba(248, 113, 113, 0.1);
        border-color: rgba(248, 113, 113, 0.3);
        color: var(--red);
      }
      .modal-body {
        padding: 22px 26px;
        display: flex;
        flex-direction: column;
        gap: 20px;
      }
      .modal-sec-hdr {
        font-family: "DM Mono", monospace;
        font-size: 9px;
        color: var(--text3);
        letter-spacing: 2.5px;
        text-transform: uppercase;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .modal-sec-hdr::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .field {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        padding: 12px 15px;
        transition: border-color var(--trans);
      }
      .field:hover {
        border-color: var(--border2);
      }
      .field-label {
        font-family: "DM Mono", monospace;
        font-size: 9px;
        color: var(--text3);
        letter-spacing: 1.8px;
        text-transform: uppercase;
        margin-bottom: 5px;
      }
      .field-value {
        font-size: 13.5px;
        color: var(--text);
        word-break: break-all;
      }
      .modal-hero {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 12px;
      }
      .modal-hero-card {
        background: linear-gradient(
          145deg,
          rgba(255, 255, 255, 0.04),
          rgba(255, 255, 255, 0.015)
        );
        border: 1px solid var(--border2);
        border-radius: 14px;
        padding: 14px 16px;
      }
      .modal-hero-title {
        font-family: "Syne", sans-serif;
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 6px;
      }
      .modal-hero-sub {
        font-size: 12px;
        color: var(--text2);
      }
      .modal-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        border-radius: 999px;
        padding: 6px 12px;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        letter-spacing: 0.2px;
        border: 1px solid;
      }
      .modal-kpi-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
      }
      .modal-kpi {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 10px 12px;
      }
      .modal-kpi-label {
        font-family: "DM Mono", monospace;
        font-size: 9px;
        color: var(--text3);
        letter-spacing: 1.7px;
        text-transform: uppercase;
        margin-bottom: 6px;
      }
      .modal-kpi-value {
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
      }
      .modal-intel-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .modal-intel-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 12px 14px;
      }
      .modal-intel-card.warning {
        border-color: rgba(248, 113, 113, 0.28);
        background: rgba(248, 113, 113, 0.08);
      }
      .modal-intel-card.success {
        border-color: rgba(251, 191, 36, 0.28);
        background: rgba(251, 191, 36, 0.08);
      }
      .modal-intel-label {
        font-family: "DM Mono", monospace;
        font-size: 9px;
        color: var(--text3);
        letter-spacing: 1.6px;
        text-transform: uppercase;
        margin-bottom: 7px;
      }
      .modal-intel-value {
        font-size: 13px;
        line-height: 1.55;
        color: var(--text);
      }
      .toast-zone {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 900;
        display: flex;
        flex-direction: column;
        gap: 8px;
        pointer-events: none;
      }
      .toast {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 18px;
        background: #0c1525;
        border: 1px solid var(--border2);
        border-radius: var(--r2);
        font-size: 13px;
        color: var(--text);
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.65);
        animation: toastIn 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        pointer-events: all;
      }
      .toast.success {
        border-left: 3px solid var(--green);
      }
      .toast.error {
        border-left: 3px solid var(--red);
      }
      .toast.hiding {
        animation: toastOut 0.25s ease forwards;
      }
      @keyframes toastIn {
        from {
          opacity: 0;
          transform: translateX(14px) scale(0.96);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      @keyframes toastOut {
        from {
          opacity: 1;
        }
        to {
          opacity: 0;
          transform: translateX(16px) scale(0.95);
        }
      }
      @media (max-width: 960px) {
        .header {
          height: auto;
          min-height: var(--header-h);
          padding: 10px 14px;
          gap: 10px;
          align-items: flex-start;
          flex-wrap: wrap;
        }
        .logo {
          min-width: 0;
        }
        .hdr-status {
          order: 3;
          width: 100%;
          border-radius: var(--r2);
          padding: 8px 10px;
          font-size: 10px;
          letter-spacing: 0.2px;
        }
        .hdr-right {
          margin-left: auto;
          flex-wrap: wrap;
          justify-content: flex-end;
        }
        .sidebar {
          display: none;
        }
        .stats-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 600px) {
        .main-inner {
          padding: 16px;
        }
        .stats-grid {
          grid-template-columns: 1fr;
        }
        .field-grid {
          grid-template-columns: 1fr;
        }
        .toolbar {
          flex-direction: column;
          align-items: stretch;
        }
        .search-wrap {
          min-width: 100%;
        }
        .filter-select,
        .tb-btn {
          width: 100%;
        }
        .tb-sep {
          width: 100%;
          height: 1px;
        }
        .result-count {
          margin-left: 0;
          width: 100%;
          text-align: center;
        }
        .cards-grid {
          grid-template-columns: 1fr;
          gap: 12px;
        }
        .v-card {
          min-width: 0;
        }
        .v-card-head {
          flex-direction: column;
          align-items: flex-start;
          gap: 8px;
        }
        .modal-hero,
        .modal-kpi-grid,
        .modal-intel-grid {
          grid-template-columns: 1fr;
        }
      }
      @media (max-width: 420px) {
        .main-inner {
          padding: 12px;
        }
        .v-card-head,
        .v-card-body,
        .v-card-foot {
          padding-left: 14px;
          padding-right: 14px;
        }
        .info-row {
          flex-direction: column;
          gap: 3px;
        }
        .info-label {
          min-width: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-mesh">
      <div class="bg-mesh-mid"></div>
    </div>
    <header class="header">
      <a class="logo" href="/">
        <div class="logo-mark">🛡️</div>
        <span class="logo-wordmark">Live<em>Stock</em> Verify</span>
        <span class="logo-chip">v2.4.1</span>
      </a>
      <div class="hdr-status">
        <div class="status-dot"></div>
        <span id="hdr-system-state">SYSTEM ONLINE</span>
        &nbsp;•&nbsp;
        <span id="hdr-clock">--:--:--</span>
        &nbsp;•&nbsp;
        <span id="hdr-uptime">UP 00:00:00</span>
      </div>
      <div class="hdr-right">
        <button class="hdr-action" onclick="refreshData()">
          <i class="fas fa-sync-alt"></i>Refresh
        </button>
        <div class="avatar" id="user-avatar" title="User">U</div>
      </div>
    </header>
    <div class="layout">
      <aside class="sidebar">
        <div class="sb-section">
          <div class="sb-label">Views</div>
          <div
            class="nav-item active"
            data-nav="all"
            onclick="setNav('all',this)"
          >
            <i class="fas fa-th-large"></i>All Submissions
            <span class="nav-badge" id="nb-all">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="pending"
            onclick="setNav('pending',this)"
          >
            <i class="fas fa-hourglass-half"></i>Pending
            <span class="nav-badge" id="nb-pending">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="processing"
            onclick="setNav('processing',this)"
          >
            <i class="fas fa-cog"></i>Processing
            <span class="nav-badge" id="nb-processing">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="verified"
            onclick="setNav('verified',this)"
          >
            <i class="fas fa-check-circle"></i>Approved
            <span class="nav-badge" id="nb-verified">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="rejected"
            onclick="setNav('rejected',this)"
          >
            <i class="fas fa-times-circle"></i>Rejected
            <span class="nav-badge" id="nb-rejected">0</span>
          </div>
          <div
            class="nav-item"
            data-nav="needs_review"
            onclick="setNav('needs_review',this)"
          >
            <i class="fas fa-search"></i>Needs Review
            <span class="nav-badge" id="nb-needs_review">0</span>
          </div>
        </div>
        <div class="sb-divider"></div>
        <div class="sb-section">
          <div class="sb-label">Quick Filters</div>
          <div class="nav-item" onclick="setTypeFilter('ownership')">
            <i class="fas fa-file-contract"></i>Ownership Only
          </div>
          <div class="nav-item" onclick="setTypeFilter('health')">
            <i class="fas fa-heartbeat"></i>Health Only
          </div>
          <div class="nav-item" onclick="setTypeFilter('both')">
            <i class="fas fa-layer-group"></i>Both Docs
          </div>
        </div>
        <div class="sb-divider"></div>
        <div class="sb-footer">
          <div class="sb-widget">
            <div class="sb-widget-row">
              <span class="sb-widget-label">Approval Rate</span>
              $10%</span>
            </div>
            <div class="mini-bar-track">
              <div class="mini-bar" id="sb-rate-bar" style="width:0%"></div>
            </div>
            <div class="sb-widget-row" style="margin-bottom:0">
              <span class="sb-widget-label">Total Processed</span>
              <span class="sb-widget-val" id="sb-processed">0</span>
            </div>
            <div class="sb-divider" style="margin:10px 0;"></div>
            <div class="sb-sync-row">
              <i class="fas fa-circle"></i>
              Last sync:
              <span id="last-sync">—</span>
            </div>
          </div>
        </div>
      </aside>
      <main class="main">
        <div class="main-inner">
          <div class="page-header">
            <div>
              <div class="page-eyebrow">Dashboard • Real-time</div>
              <div class="page-title">Verification <span>Oversight</span></div>
              <div class="page-sub">Monitor, review and action all livestock
                verification submissions in real time</div>
            </div>
            <div class="page-actions">
              <button class="action-chip ghost" onclick="clearFilters()">
                <i class="fas fa-sliders-h"></i>Reset Filters
              </button>
              <button class="action-chip primary" onclick="refreshData()">
                <i class="fas fa-bolt"></i>Refresh Data
              </button>
            </div>
          </div>
          <div class="stats-grid">
            <div
              class="stat-card sc-total"
              data-stat-filter="all"
              tabindex="0"
              role="button"
              aria-label="Show all submissions"
            >
              <div
                class="v-stripe st-stripe"
                style="background:linear-gradient(90deg,var(--cyan),transparent)"
              ></div>
              <div class="stat-icon si-cyan"><i
                  class="fas fa-layer-group"
                ></i></div>
              <div
                class="stat-number"
                id="st-total"
                style="color:var(--cyan)"
              >0</div>
              <div class="stat-label">Total Submissions</div>
              <div class="stat-sparkline sparkline-cyan" id="spark-total"></div>
              <div class="stat-trend trend-up" id="tr-total">—</div>
            </div>
            <div
              class="stat-card sc-pending"
              data-stat-filter="pending"
              tabindex="0"
              role="button"
              aria-label="Show pending submissions"
            >
              <div
                class="v-stripe st-stripe"
                style="background:linear-gradient(90deg,var(--amber),transparent)"
              ></div>
              <div class="stat-icon si-amber"><i
                  class="fas fa-hourglass-half"
                ></i></div>
              <div
                class="stat-number"
                id="st-pending"
                style="color:var(--amber)"
              >0</div>
              <div class="stat-label">Awaiting Review</div>
              <div
                class="stat-sparkline sparkline-amber"
                id="spark-pending"
              ></div>
              <div class="stat-trend trend-flat" id="tr-pending">—</div>
            </div>
            <div
              class="stat-card sc-verified"
              data-stat-filter="verified"
              tabindex="0"
              role="button"
              aria-label="Show verified submissions"
            >
              <div
                class="v-stripe st-stripe"
                style="background:linear-gradient(90deg,var(--green),transparent)"
              ></div>
              <div class="stat-icon si-green"><i
                  class="fas fa-check-double"
                ></i></div>
              <div
                class="stat-number"
                id="st-verified"
                style="color:var(--green)"
              >0</div>
              <div class="stat-label">Verified &amp; Approved</div>
              <div
                class="stat-sparkline sparkline-green"
                id="spark-verified"
              ></div>
              <div class="stat-trend trend-up" id="tr-verified">—</div>
            </div>
            <div
              class="stat-card sc-rejected"
              data-stat-filter="rejected"
              tabindex="0"
              role="button"
              aria-label="Show rejected submissions"
            >
              <div
                class="v-stripe st-stripe"
                style="background:linear-gradient(90deg,var(--red),transparent)"
              ></div>
              <div class="stat-icon si-red"><i class="fas fa-ban"></i></div>
              <div
                class="stat-number"
                id="st-rejected"
                style="color:var(--red)"
              >0</div>
              <div class="stat-label">Rejected Cases</div>
              <div
                class="stat-sparkline sparkline-red"
                id="spark-rejected"
              ></div>
              <div class="stat-trend trend-down" id="tr-rejected">—</div>
            </div>
          </div>
          <div id="admin-banner" class="role-banner admin">
            <i class="fas fa-shield-alt"></i>
            <strong>Admin View</strong>
            • Full access to review and update all verification statuses.
          </div>
          <div id="user-banner" class="role-banner user">
            <i class="fas fa-user-check"></i>
            <strong>My Verifications</strong>
            ,Viewing your own submissions. Only admins can modify status.
          </div>
          <div class="toolbar">
            <div class="search-wrap">
              <i class="fas fa-search search-icon"></i>
              <input
                type="text"
                class="search-input"
                id="search-input"
                placeholder="Roggers Anguzu"
                oninput="applyFilters()"
              />
            </div>
            <div class="tb-sep"></div>
            <select
              class="filter-select"
              id="filter-status"
              onchange="applyFilters()"
            >
              <option value="all">All Status</option>
              <option value="pending">Pending</option>
              <option value="processing">Processing</option>
              <option value="verified">Approved</option>
              <option value="rejected">Rejected</option>
              <option value="needs_review">Needs Review</option>
              <option value="incomplete">Incomplete</option>
            </select>
            <select
              class="filter-select"
              id="filter-type"
              onchange="applyFilters()"
            >
              <option value="all">All Types</option>
              <option value="ownership">Ownership</option>
              <option value="health">Health</option>
              <option value="both">Both</option>
            </select>
            <div class="tb-sep"></div>
            <button class="tb-btn" onclick="clearFilters()">
              <i class="fas fa-times"></i>Clear
            </button>
            <span class="result-count" id="result-count">0 results</span>
          </div>
          <div id="cards-container">
            <div class="state-box">
              <div class="spinner"></div>
              <div class="state-title">Initialising System...</div>
              <div class="state-sub">Fetching verification records from the
                server</div>
            </div>
          </div>
        </div>
      </main>
    </div>
    <div class="overlay" id="detail-overlay" onclick="closeModal(event)">
      <div class="modal" onclick="event.stopPropagation()">
        <div class="modal-head">
          <div class="modal-head-left">
            <div class="modal-title">
              <i class="fas fa-file-search"></i>Verification Details
            </div>
            <div class="modal-id" id="modal-sub-id">—</div>
          </div>
          <button class="modal-close" onclick="closeModal()">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <div class="modal-body" id="modal-body"></div>
      </div>
    </div>
    <div class="toast-zone" id="toast-zone"></div>
    <script src="/js/verificationStatus.js"></script>
    <script>
      setInterval(()=>{ document.getElementById('hdr-clock').textContent = new
      Date().toLocaleTimeString(); },1000);  function
      updateUserAvatar(){ if(window.currentUser?.name){ const
      av=document.getElementById('user-avatar'); if(av){
      av.textContent=window.currentUser.name.charAt(0).toUpperCase();
      av.title=window.currentUser.name; } } } const
      _origLoadUser=window.loadCurrentUser; window.loadCurrentUser=async
      function(){ await _origLoadUser?.(); updateUserAvatar(); };  function
      updateLastSync(){ document.getElementById('last-sync').textContent=new
      Date().toLocaleTimeString(); }  function
      renderSparkline(containerId, values){ const
      el=document.getElementById(containerId); if(!el) return; const
      max=Math.max(...values,1); el.innerHTML=values.map(v=>{ const
      h=Math.max(4,Math.round((v/max)*100)); return `<div class="spark-b"
      style="height:${h}%"></div>`; }).join(''); }  const
      _origUpdateStats=window.updateStats; window.updateStats=function(data){
      _origUpdateStats?.(data); const total = data?.total ?? 0; const pending =
      data?.pending ?? 0; const verified = data?.verified ?? 0; const rejected =
      data?.rejected ?? 0; const proc = data?.processing ?? 0; // Approval rate
      widget const rate = total > 0 ? Math.round((verified/total)*100) : 0;
      const rateEl=document.getElementById('sb-rate'); const
      rateBar=document.getElementById('sb-rate-bar'); const
      procEl=document.getElementById('sb-processed'); if(rateEl)
      rateEl.textContent=rate+'%'; if(rateBar){ setTimeout(()=>{
      rateBar.style.width=rate+'%'; },200); } if(procEl)
      procEl.textContent=verified+rejected; // Trend chips (fake delta for demo)
      const setTrend=(id,val)=>{ const el=document.getElementById(id);
      if(!el||val==null) return; el.textContent= val>=0 ? '? '+val+' today' : '?
      '+Math.abs(val)+' today'; el.className='stat-trend
      '+(val>0?'trend-up':val<0?'trend-down':'trend-flat'); };
      setTrend('tr-total', 3); setTrend('tr-pending', 0);
      setTrend('tr-verified', 2); setTrend('tr-rejected', -1); // Sparklines
      renderSparkline('spark-total', [3,5,2,8,6,9,total]);
      renderSparkline('spark-pending', [2,4,6,3,5,2,pending]);
      renderSparkline('spark-verified',[1,3,5,4,7,8,verified]);
      renderSparkline('spark-rejected',[2,1,3,2,4,1,rejected]);
      updateLastSync(); };  function setTypeFilter(type){
      const sel=document.getElementById('filter-type'); if(sel){ sel.value=type;
      applyFilters(); } }  function
      showToast(msg,type='success'){ const
      zone=document.getElementById('toast-zone'); const
      t=document.createElement('div'); t.className='toast '+type; const
      icon=type==='success'?'fa-check-circle':'fa-exclamation-circle'; const
      col=type==='success'?'var(--green)':'var(--red)'; t.innerHTML=`<i
      class="fas ${icon}" style="color:${col};font-size:14px;"></i> ${msg}`;
      zone.appendChild(t); setTimeout(()=>{ t.classList.add('hiding');
      setTimeout(()=>t.remove(),300); },3200); }  const
      _origUpdateStatus=window.updateStatus; window.updateStatus=async
      function(id){ try{ await _origUpdateStatus?.(id); showToast('Status
      updated successfully','success'); updateLastSync(); }catch(e){
      showToast(e?.message||'Update failed','error'); } };  const
      _origRenderCards=window.renderCards; window.renderCards=function(list){
      _origRenderCards?.(list); injectCardProgress(); }; function
      injectCardProgress(){ document.querySelectorAll('.v-card').forEach(card=>{
      const statusClass=[...card.classList].find(c=>c.startsWith('s-')); const
      status=statusClass?.replace('s-',''); const progressMap={ pending:25,
      processing:55, verified:100, rejected:100, needs_review:70, incomplete:10
      }; const pct=progressMap[status]||0; const colMap={
      pending:'var(--amber)', processing:'var(--blue)', verified:'var(--green)',
      rejected:'var(--red)', needs_review:'var(--violet)',
      incomplete:'var(--text3)' }; const
      body=card.querySelector('.v-card-body'); if(body &&
      !body.querySelector('.card-progress')){ const
      div=document.createElement('div'); div.className='card-progress';
      div.innerHTML=` <div class="card-progress-label"> <span>Verification
      Progress</span> <span style="color:${colMap[status]||'var(--text3)'};
      font-family:'DM Mono',monospace; font-size:10px;">${pct}%</span> </div>
      <div class="card-progress-bar"> <div class="card-progress-fill"
      style="width:0%; background:${colMap[status]||'var(--text3)'}"></div>
      </div>`; body.appendChild(div); setTimeout(()=>{ const
      fill=div.querySelector('.card-progress-fill'); if(fill)
      fill.style.width=pct+'%'; },300); } }); }
      document.addEventListener('DOMContentLoaded',()=>{ updateLastSync(); });
    </script>
    <script src="/js/app-theme.js"></script>
  </body>
</html>

