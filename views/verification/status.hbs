<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LiveStock Verify • Verification Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500;600&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css" />
    <link href="/css/app-theme.css" rel="stylesheet" />
    <style>
      :root {
        --bg: #04080f;
        --bg2: #070d1a;
        --bg3: #0a1120;
        --surface: rgba(255, 255, 255, 0.028);
        --surface2: rgba(255, 255, 255, 0.055);
        --surface3: rgba(255, 255, 255, 0.085);
        --border: rgba(255, 255, 255, 0.065);
        --border2: rgba(255, 255, 255, 0.12);
        --border3: rgba(255, 255, 255, 0.18);
        --green: #fbbf24;
        --green-dim: rgba(251, 191, 36, 0.12);
        --green-glow: rgba(251, 191, 36, 0.25);
        --cyan: #f97316;
        --cyan-dim: rgba(249, 115, 22, 0.1);
        --amber: #f59e0b;
        --amber-dim: rgba(245, 158, 11, 0.1);
        --red: #f87171;
        --red-dim: rgba(248, 113, 113, 0.1);
        --violet: #a78bfa;
        --violet-dim: rgba(251, 146, 60, 0.1);
        --blue: #fbbf24;
        --blue-dim: rgba(251, 191, 36, 0.1);
        --text: #eef2ff;
        --text2: #7d8fa8;
        --text3: #394558;
        --r: 6px;
        --r2: 10px;
        --r3: 14px;
        --r4: 18px;
        --r5: 24px;
        --sidebar-w: 230px;
        --header-h: 60px;
        --trans: 0.22s cubic-bezier(0.23, 1, 0.32, 1);
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: "DM Sans", sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
        line-height: 1.55;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.45;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      }
      .bg-mesh {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }
      .bg-mesh::before {
        content: "";
        position: absolute;
        top: -20%;
        left: -15%;
        width: 700px;
        height: 700px;
        background: radial-gradient(
          ellipse,
          rgba(251, 191, 36, 0.055) 0%,
          transparent 68%
        );
        border-radius: 50%;
        animation: meshFloat1 12s ease-in-out infinite;
      }
      .bg-mesh::after {
        content: "";
        position: absolute;
        bottom: -15%;
        right: -10%;
        width: 600px;
        height: 600px;
        background: radial-gradient(
          ellipse,
          rgba(34, 211, 238, 0.045) 0%,
          transparent 65%
        );
        border-radius: 50%;
        animation: meshFloat2 14s ease-in-out infinite;
      }
      .bg-mesh-mid {
        position: absolute;
        top: 40%;
        left: 45%;
        width: 500px;
        height: 500px;
        background: radial-gradient(
          ellipse,
          rgba(251, 146, 60, 0.03) 0%,
          transparent 65%
        );
        border-radius: 50%;
        animation: meshFloat1 18s ease-in-out infinite reverse;
      }
      @keyframes meshFloat1 {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(30px, -25px) scale(1.05);
        }
      }
      @keyframes meshFloat2 {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(-25px, 20px) scale(1.04);
        }
      }
      ::-webkit-scrollbar {
        width: 4px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 99px;
      }
      .header {
        position: sticky;
        top: 0;
        z-index: 400;
        height: var(--header-h);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 28px;
        background: rgba(4, 8, 15, 0.88);
        backdrop-filter: blur(28px) saturate(1.4);
        border-bottom: 1px solid var(--border);
      }
      .header::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(251, 191, 36, 0.12),
          rgba(249, 115, 22, 0.1),
          transparent
        );
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 11px;
        text-decoration: none;
      }
      .logo-mark {
        position: relative;
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #d97706 0%, #0e7490 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        box-shadow:
          0 0 0 1px rgba(251, 191, 36, 0.3),
          0 0 20px rgba(251, 191, 36, 0.2);
      }
      .logo-mark::after {
        content: "";
        position: absolute;
        inset: -1px;
        border-radius: 11px;
        background: linear-gradient(
          135deg,
          rgba(251, 191, 36, 0.3),
          rgba(34, 211, 238, 0.2)
        );
        z-index: -1;
        opacity: 0;
        transition: opacity 0.3s;
      }
      .logo:hover .logo-mark::after {
        opacity: 1;
      }
      .logo-wordmark {
        font-family: "Syne", sans-serif;
        font-size: 16px;
        font-weight: 800;
        letter-spacing: -0.3px;
      }
      .logo-wordmark em {
        color: var(--green);
        font-style: normal;
      }
      .logo-chip {
        font-family: "DM Mono", monospace;
        font-size: 9.5px;
        color: var(--text3);
        background: var(--surface2);
        border: 1px solid var(--border);
        padding: 2px 7px;
        border-radius: 4px;
      }
      .hdr-status {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 8px;
        padding: 6px 16px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 99px;
        font-family: "DM Mono", monospace;
        font-size: 10.5px;
        color: var(--text3);
        letter-spacing: 0.5px;
      }
      .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 8px var(--green);
        animation: dotPulse 2.2s ease-in-out infinite;
      }
      @keyframes dotPulse {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.5;
          transform: scale(0.75);
        }
      }
      .hdr-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .hdr-action {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        background: var(--surface2);
        border: 1px solid var(--border2);
        border-radius: var(--r2);
        font-size: 12px;
        font-weight: 500;
        color: var(--text2);
        cursor: pointer;
        transition: all var(--trans);
        font-family: "DM Sans", sans-serif;
      }
      .hdr-action:hover {
        background: var(--surface3);
        color: var(--text);
        transform: translateY(-1px);
      }
      .hdr-action.primary {
        background: var(--green);
        color: #000;
        border-color: var(--green);
        font-weight: 600;
        box-shadow: 0 0 20px var(--green-glow);
      }
      .hdr-action.primary:hover {
        background: #86efac;
        box-shadow: 0 0 28px rgba(251, 191, 36, 0.4);
      }
      .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--green), var(--cyan));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 800;
        color: #000;
        border: 2px solid rgba(251, 191, 36, 0.35);
        cursor: pointer;
        transition: all var(--trans);
      }
      .avatar:hover {
        box-shadow: 0 0 20px var(--green-glow);
        transform: scale(1.06);
      }
      .layout {
        display: flex;
        flex: 1;
        position: relative;
        z-index: 1;
      }
      .sidebar {
        width: var(--sidebar-w);
        min-width: var(--sidebar-w);
        background: rgba(4, 8, 15, 0.65);
        backdrop-filter: blur(24px);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        padding: 16px 8px;
        position: sticky;
        top: var(--header-h);
        height: calc(100vh - var(--header-h));
        overflow-y: auto;
      }
      .sb-section {
        margin-bottom: 4px;
      }
      .sb-label {
        font-family: "DM Mono", monospace;
        font-size: 8.5px;
        font-weight: 500;
        color: var(--text3);
        letter-spacing: 2.5px;
        text-transform: uppercase;
        padding: 12px 14px 6px;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 9px 12px;
        border-radius: var(--r2);
        cursor: pointer;
        font-size: 12.5px;
        font-weight: 500;
        color: var(--text2);
        border: 1px solid transparent;
        transition: all var(--trans);
        position: relative;
        margin-bottom: 2px;
      }
      .nav-item i {
        width: 14px;
        font-size: 11px;
        opacity: 0.65;
        transition: opacity 0.2s;
      }
      .nav-item:hover {
        background: var(--surface2);
        color: var(--text);
      }
      .nav-item:hover i {
        opacity: 0.9;
      }
      .nav-item.active {
        background: rgba(251, 191, 36, 0.07);
        border-color: rgba(251, 191, 36, 0.18);
        color: var(--green);
      }
      .nav-item.active i {
        opacity: 1;
        color: var(--green);
      }
      .nav-item.active::before {
        content: "";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 2.5px;
        height: 55%;
        background: var(--green);
        border-radius: 0 3px 3px 0;
        box-shadow: 0 0 10px var(--green);
      }
      .nav-badge {
        margin-left: auto;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        font-weight: 500;
        padding: 2px 7px;
        border-radius: 99px;
        background: var(--surface2);
        border: 1px solid var(--border);
        color: var(--text3);
        transition: all var(--trans);
      }
      .nav-item.active .nav-badge {
        background: rgba(251, 191, 36, 0.14);
        border-color: rgba(251, 191, 36, 0.3);
        color: var(--green);
      }
      .sb-divider {
        height: 1px;
        background: var(--border);
        margin: 10px 10px;
      }
      .sb-footer {
        margin-top: auto;
        padding: 0 4px;
      }
      .sb-widget {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r3);
        padding: 14px;
      }
      .sb-widget-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
      }
      .sb-widget-label {
        font-size: 10.5px;
        color: var(--text3);
        font-weight: 500;
      }
      .sb-widget-val {
        font-family: "DM Mono", monospace;
        font-size: 11px;
        color: var(--green);
      }
      .mini-bar-track {
        height: 3px;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 8px;
      }
      .mini-bar {
        height: 100%;
        background: linear-gradient(90deg, var(--green), var(--cyan));
        border-radius: 3px;
        transition: width 1s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .sb-sync-row {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        color: var(--text3);
      }
      .sb-sync-row i {
        color: var(--green);
        font-size: 9px;
      }
      .main {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
      }
      .main-inner {
        flex: 1;
        padding: 28px 32px;
        display: flex;
        flex-direction: column;
        gap: 22px;
      }
      .page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
      }
      .page-eyebrow {
        font-family: "DM Mono", monospace;
        font-size: 10px;
        color: var(--cyan);
        letter-spacing: 2.5px;
        text-transform: uppercase;
        margin-bottom: 7px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .page-eyebrow::before {
        content: "";
        width: 16px;
        height: 1.5px;
        background: linear-gradient(90deg, var(--cyan), transparent);
        border-radius: 1px;
      }
      .page-title {
        font-family: "Syne", sans-serif;
        font-size: clamp(22px, 3vw, 30px);
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.5px;
        line-height: 1.1;
        margin-bottom: 5px;
      }
      .page-title span {
        color: var(--green);
      }
      .page-sub {
        font-size: 12.5px;
        color: var(--text3);
      }
      .page-actions {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .action-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: var(--r2);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--trans);
        font-family: "DM Sans", sans-serif;
        border: 1px solid;
      }
      .action-chip.primary {
        background: var(--green);
        color: #000;
        border-color: var(--green);
        box-shadow: 0 0 20px var(--green-glow);
      }
      .action-chip.primary:hover {
        background: #86efac;
        box-shadow: 0 0 28px rgba(251, 191, 36, 0.4);
        transform: translateY(-1px);
      }
      .action-chip.ghost {
        background: transparent;
        color: var(--text2);
        border-color: var(--border2);
      }
      .action-chip.ghost:hover {
        background: var(--surface2);
        color: var(--text);
      }
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
      }
      .stat-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r5);
        padding: 22px 22px 18px;
        position: relative;
        overflow: hidden;
        transition: all var(--trans);
        cursor: default;
      }
      .stat-card[data-stat-filter] {
        cursor: pointer;
      }
      .stat-card[data-stat-filter]:focus-visible {
        outline: 2px solid var(--cyan);
        outline-offset: 2px;
      }
      .stat-card.is-active {
        border-color: color-mix(in srgb, var(--cyan) 55%, var(--border2));
        box-shadow:
          0 0 0 1px color-mix(in srgb, var(--cyan) 45%, transparent),
          0 18px 40px rgba(0, 0, 0, 0.42);
      }
      .stat-card::before {
        content: "";
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity var(--trans);
        border-radius: var(--r5);
      }
      .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
      }
      .stat-card:hover::before {
        opacity: 1;
      }
      .stat-card .st-stripe {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
      }
      .sc-total {
        --card-glow: rgba(34, 211, 238, 0.06);
        --border-h: rgba(34, 211, 238, 0.3);
      }
      .sc-pending {
        --card-glow: rgba(245, 158, 11, 0.06);
        --border-h: rgba(245, 158, 11, 0.3);
      }
      .sc-verified {
        --card-glow: rgba(251, 191, 36, 0.06);
        --border-h: rgba(251, 191, 36, 0.3);
      }
      .sc-rejected {
        --card-glow: rgba(248, 113, 113, 0.06);
        --border-h: rgba(248, 113, 113, 0.3);
      }
      .stat-card::before {
        background: radial-gradient(
          ellipse at 30% 40%,
          var(--card-glow, transparent),
          transparent 70%
        );
      }
      .stat-card:hover {
        border-color: var(--border-h, var(--border2));
      }
      .stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        margin-bottom: 16px;
        position: relative;
        z-index: 1;
      }
      .si-cyan {
        background: var(--cyan-dim);
        color: var(--cyan);
        border: 1px solid rgba(34, 211, 238, 0.2);
      }
      .si-amber {
        background: var(--amber-dim);
        color: var(--amber);
        border: 1px solid rgba(245, 158, 11, 0.2);
      }
      .si-green {
        background: var(--green-dim);
        color: var(--green);
        border: 1px solid rgba(251, 191, 36, 0.2);
      }
      .si-red {
        background: var(--red-dim);
        color: var(--red);
        border: 1px solid rgba(248, 113, 113, 0.2);
      }
      .stat-number {
        font-family: "Syne", sans-serif;
        font-size: 36px;
        font-weight: 800;
        line-height: 1;
        position: relative;
        z-index: 1;
      }
      .stat-label {
        font-size: 11.5px;
        color: var(--text3);
        font-weight: 500;
        margin-top: 6px;
        position: relative;
        z-index: 1;
      }
      .stat-trend {
        position: absolute;
        bottom: 18px;
        right: 18px;
        font-family: "DM Mono", monospace;
        font-size: 10px;
        padding: 3px 8px;
        border-radius: 5px;
      }
      .trend-up {
        color: var(--green);
        background: rgba(251, 191, 36, 0.1);
        border: 1px solid rgba(251, 191, 36, 0.2);
      }
      .trend-down {
        color: var(--red);
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.2);
      }
      .trend-flat {
        color: var(--text3);
        background: var(--surface2);
        border: 1px solid var(--border);
      }
      .stat-sparkline {
        display: flex;
        align-items: flex-end;
        gap: 2px;
        height: 24px;
        margin-top: 10px;
        position: relative;
        z-index: 1;
      }
      .spark-b {
        flex: 1;
        border-radius: 2px 2px 0 0;
        min-height: 2px;
        opacity: 0.35;
        transition:
          opacity 0.2s,
          height 0.6s;
      }
      .spark-b:last-child {
        opacity: 0.8;
      }
      .stat-card:hover .spark-b {
        opacity: 0.55;
      }
      .stat-card:hover .spark-b:last-child {
        opacity: 1;
      }
      .sparkline-cyan .spark-b {
        background: var(--cyan);
      }
      .sparkline-amber .spark-b {
        background: var(--amber);
      }
      .sparkline-green .spark-b {
        background: var(--green);
      }
      .sparkline-red .spark-b {
        background: var(--red);
      }
      .role-banner {
        display: none;
        align-items: center;
        gap: 12px;
        padding: 13px 18px;
        border-radius: var(--r3);
        font-size: 12.5px;
        animation: fadeDown 0.4s ease-out;
      }
      @keyframes fadeDown {
        from {
          opacity: 0;
          transform: translateY(-8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .role-banner.admin {
        background: rgba(34, 211, 238, 0.05);
        border: 1px solid rgba(34, 211, 238, 0.18);
        color: var(--cyan);
      }
      .role-banner.user {
        background: rgba(251, 191, 36, 0.05);
        border: 1px solid rgba(251, 191, 36, 0.18);
        color: var(--green);
      }
      .toolbar {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        padding: 14px 16px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r4);
      }
      .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
      }
      .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text3);
        font-size: 12px;
        pointer-events: none;
      }
      .search-input {
        width: 100%;
        padding: 9px 12px 9px 34px;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 13px;
        outline: none;
        transition: all 0.2s;
      }
      .search-input::placeholder {
        color: var(--text3);
      }
      .search-input:focus {
        border-color: rgba(251, 191, 36, 0.4);
        background: rgba(0, 0, 0, 0.4);
        box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.06);
      }
      .filter-select {
        padding: 9px 12px;
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid var(--border);
        border-radius: var(--r2);
        color: var(--text);
        font-family: "DM Sans", sans-serif;
        font-size: 12.5px;
        outline: none;
        cursor: pointer;
        min-width: 130px;
        transition: border-color 0.2s;
      }
      .filter-select:focus {
        border-color: rgba(251, 191, 36, 0.4);
      }
      .filter-select option {
        background: #070d1a;
      }
      .tb-sep {
        width: 1px;
        height: 26px;
        background: var(--border);
        flex-shrink: 0;
      }
      .tb-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 13px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: var(--r2);
        color: var(--text2);
        font-size: 12px;
        font-family: "DM Sans", sans-serif;
        cursor: pointer;
        transition: all var(--trans);
      }
      .tb-btn:hover {
        background: var(--surface2);
        color: var(--text);
      }
      .result-count {
        margin-left: auto;
        font-family: "DM Mono", monospace;
        font-size: 10.5px;
        color: var(--text3);
        padding: 5px 12px;
