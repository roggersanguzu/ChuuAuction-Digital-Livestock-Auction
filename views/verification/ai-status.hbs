<!DOCTYPE html>
<html lang="en" data-theme="dark" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{title}} | ChuuAuction</title>
    <link rel="stylesheet" href="/css/output.css" />
    <link
      rel="stylesheet"
      href="/vendor/bootstrap-icons/css/bootstrap-icons.css"
    />
    <link href="/css/app-theme.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800;900&family=Geist+Mono:wght@300;400;500;600&family=Cabinet+Grotesk:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --hud-amber: #f59e0b;
        --hud-ember: #f97316;
        --hud-crimson: #dc2626;
        --hud-success: #f59e0b;
        --hud-cyan: #f97316;
        --hud-blue: #fbbf24;
        --hud-amber-glow: rgba(245, 158, 11, 0.22);
        --hud-ember-glow: rgba(249, 115, 22, 0.18);
        --hud-success-glow: rgba(245, 158, 11, 0.18);
        --hud-crimson-glow: rgba(220, 38, 38, 0.18);
        --void: #020305;
        --void-2: #07080d;
        --surface: rgba(255, 255, 255, 0.032);
        --surface-2: rgba(255, 255, 255, 0.055);
        --border: rgba(255, 255, 255, 0.07);
        --border-amber: rgba(245, 158, 11, 0.25);
        --border-hi: rgba(245, 158, 11, 0.55);
        --text-primary: #f4f6fb;
        --text-muted: #8c94a8;
        --text-dim: #3d4455;
        --f-display: "Syne", sans-serif;
        --f-body: "Cabinet Grotesk", sans-serif;
        --f-mono: "Geist Mono", monospace;
        --r: 10px;
        --r-lg: 16px;
        --r-xl: 22px;
        --ease: cubic-bezier(0.4, 0, 0.2, 1);
        --t: 0.3s var(--ease);
      }
      [data-theme="light"] {
        --void: #f2f4f8;
        --void-2: #ffffff;
        --surface: rgba(15, 23, 42, 0.04);
        --surface-2: rgba(15, 23, 42, 0.07);
        --border: rgba(15, 23, 42, 0.1);
        --border-amber: rgba(217, 119, 6, 0.3);
        --border-hi: rgba(217, 119, 6, 0.6);
        --text-primary: #0b1020;
        --text-muted: #475569;
        --text-dim: #94a3b8;
        --hud-amber: #d97706;
        --hud-ember: #ea580c;
        --hud-success: #d97706;
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: var(--f-body);
        background: var(--void);
        color: var(--text-primary);
        min-height: 100vh;
        overflow-x: hidden;
        line-height: 1.6;
        background-image: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(245, 158, 11, 0.008) 2px,
          rgba(245, 158, 11, 0.008) 3px
        );
      }
      [data-theme="light"] body {
        background-image: none;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(
            ellipse 55% 45% at 5% 0%,
            rgba(245, 158, 11, 0.07) 0%,
            transparent 55%
          ),
          radial-gradient(
            ellipse 45% 40% at 95% 5%,
            rgba(249, 115, 22, 0.06) 0%,
            transparent 50%
          ),
          radial-gradient(
            ellipse 35% 50% at 50% 100%,
            rgba(220, 38, 38, 0.04) 0%,
            transparent 55%
          );
      }
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.022;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.88' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 160px 160px;
      }
      ::-webkit-scrollbar {
        width: 4px;
      }
      ::-webkit-scrollbar-track {
        background: var(--void-2);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--hud-amber);
        border-radius: 99px;
      }
      #page-root {
        position: relative;
        z-index: 1;
        max-width: 1480px;
        margin: 0 auto;
        padding: 18px 18px 72px;
      }
      .cmd-hero {
        position: relative;
        overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--border-amber);
        border-radius: var(--r-xl);
        padding: 0;
        margin-bottom: 18px;
        backdrop-filter: blur(24px) saturate(140%);
        animation: heroEntrance 0.7s var(--ease) both;
      }
      .cmd-hero::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent 0%,
          var(--hud-amber) 20%,
          var(--hud-ember) 50%,
          var(--hud-crimson) 80%,
          transparent 100%
        );
        animation: lineShimmer 4s linear infinite;
      }
      .cmd-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(
            ellipse 60% 70% at 75% 50%,
            rgba(245, 158, 11, 0.05),
            transparent
          ),
          radial-gradient(
            ellipse 40% 60% at 5% 50%,
            rgba(249, 115, 22, 0.04),
            transparent
          );
      }
      .hud-grid {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(245, 158, 11, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(245, 158, 11, 0.04) 1px, transparent 1px);
        background-size: 40px 40px;
        mask-image: radial-gradient(
          ellipse 80% 90% at 80% 50%,
          black 0%,
          transparent 80%
        );
      }
      .cmd-hero-inner {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 28px;
        padding: 28px 32px;
        flex-wrap: wrap;
      }
      .orbit-stage {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        gap: 10px;
        perspective: 800px;
      }
      .animal-pod {
        position: relative;
        width: 82px;
        height: 82px;
        border-radius: 20px;
        background: linear-gradient(
          145deg,
          rgba(245, 158, 11, 0.18),
          rgba(249, 115, 22, 0.12)
        );
        border: 1px solid rgba(245, 158, 11, 0.3);
        box-shadow:
          0 0 0 1px rgba(245, 158, 11, 0.08),
          0 24px 48px rgba(0, 0, 0, 0.55),
          inset 0 1px 0 rgba(255, 255, 255, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 38px;
        transform-style: preserve-3d;
        overflow: hidden;
      }
      .animal-pod::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.1) 0%,
          transparent 55%
        );
      }
      .pod-scan {
        position: absolute;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(245, 158, 11, 0.8),
          transparent
        );
        animation: podScan 2.8s linear infinite;
      }
      @keyframes podScan {
        0% {
          top: 0%;
          opacity: 0;
        }
        8% {
          opacity: 1;
        }
        92% {
          opacity: 1;
        }
        100% {
          top: 100%;
          opacity: 0;
        }
      }
      .animal-pod.p-cow {
        animation: podFloat 5.5s ease-in-out infinite;
      }
      .animal-pod.p-goat {
        animation: podFloat 5.5s ease-in-out infinite;
        animation-delay: -0.9s;
        width: 72px;
        height: 72px;
        font-size: 32px;
      }
      .animal-pod.p-sheep {
        animation: podFloat 5.5s ease-in-out infinite;
        animation-delay: -1.8s;
        width: 62px;
        height: 62px;
        font-size: 26px;
      }
      @keyframes podFloat {
        0%,
        100% {
          transform: perspective(700px) rotateY(-14deg) rotateX(8deg)
            translateY(0px);
        }
        50% {
          transform: perspective(700px) rotateY(14deg) rotateX(-5deg)
            translateY(-9px);
        }
      }
      .pod-ring {
        position: absolute;
        inset: -6px;
        border-radius: 26px;
        border: 1px dashed rgba(245, 158, 11, 0.25);
        animation: ringRotate 8s linear infinite;
      }
      @keyframes ringRotate {
        to {
          transform: rotate(360deg);
        }
      }
      .hero-text {
        flex: 1;
        min-width: 260px;
      }
      .hero-kicker {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--f-mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--hud-amber);
        background: rgba(245, 158, 11, 0.08);
        border: 1px solid rgba(245, 158, 11, 0.22);
        padding: 4px 14px;
        border-radius: 99px;
        margin-bottom: 14px;
      }
      .hero-title {
        font-family: var(--f-display);
        font-size: clamp(22px, 2.8vw, 36px);
        font-weight: 900;
        line-height: 1.08;
        letter-spacing: -0.025em;
        margin-bottom: 12px;
      }
      .hero-title span {
        background: linear-gradient(
          135deg,
          var(--hud-amber) 0%,
          var(--hud-ember) 55%,
          var(--hud-crimson) 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .hero-desc {
        font-size: 14px;
        color: var(--text-muted);
        max-width: 540px;
        line-height: 1.7;
        margin-bottom: 14px;
      }
      .signal-badge {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        font-family: var(--f-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        color: rgba(245, 158, 11, 0.9);
        background: rgba(245, 158, 11, 0.06);
        border: 1px solid rgba(245, 158, 11, 0.22);
        border-radius: 99px;
        padding: 5px 14px;
      }
      .sig-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--hud-success);
        box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.6);
        animation: sigPulse 2s ease-in-out infinite;
      }
      @keyframes sigPulse {
        0% {
          box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.7);
        }
        70% {
          box-shadow: 0 0 0 9px rgba(245, 158, 11, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(245, 158, 11, 0);
        }
      }
      .hero-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
        flex-wrap: wrap;
      }
      .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: var(--r);
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-family: var(--f-body);
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: var(--t);
      }
      .btn-ghost:hover {
        border-color: var(--border-amber);
        color: var(--text-primary);
        background: var(--surface-2);
      }
      .btn-prime {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 22px;
        border-radius: var(--r);
        background: linear-gradient(135deg, var(--hud-amber), var(--hud-ember));
        border: none;
        color: #08090e;
        font-family: var(--f-body);
        font-size: 13px;
        font-weight: 800;
        cursor: pointer;
        transition: var(--t);
        position: relative;
        overflow: hidden;
      }
      .btn-prime::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.25),
          transparent
        );
        opacity: 0;
        transition: opacity 0.3s;
      }
      .btn-prime:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 36px rgba(245, 158, 11, 0.4);
      }
      .btn-prime:hover::after {
        opacity: 1;
      }
      .btn-prime.is-spinning i {
        animation: spinIcon 0.6s linear infinite;
      }
      @keyframes spinIcon {
        to {
          transform: rotate(360deg);
        }
      }
      .metrics-strip {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        margin-bottom: 18px;
      }
      .m-card {
        position: relative;
        overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 20px 18px;
        backdrop-filter: blur(14px);
        transition: var(--t);
        cursor: default;
      }
      .m-card:nth-child(1) {
        animation: cardUp 0.5s var(--ease) 0.08s both;
      }
      .m-card:nth-child(2) {
        animation: cardUp 0.5s var(--ease) 0.14s both;
      }
      .m-card:nth-child(3) {
        animation: cardUp 0.5s var(--ease) 0.2s both;
      }
      .m-card:nth-child(4) {
        animation: cardUp 0.5s var(--ease) 0.26s both;
      }
      .m-card::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          110deg,
          transparent 25%,
          rgba(255, 255, 255, 0.055) 50%,
          transparent 75%
        );
        transform: translateX(-120%);
        transition: transform 0.55s var(--ease);
      }
      .m-card:hover::after {
        transform: translateX(120%);
      }
      .m-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        opacity: 0;
        transition: opacity 0.35s;
      }
      .m-card.ma::before {
        background: linear-gradient(
          90deg,
          transparent,
          var(--hud-cyan),
          transparent
        );
      }
      .m-card.mb::before {
        background: linear-gradient(
          90deg,
          transparent,
          var(--hud-amber),
          transparent
        );
      }
      .m-card.mc::before {
        background: linear-gradient(
          90deg,
          transparent,
          var(--hud-success),
          transparent
        );
      }
      .m-card.md::before {
        background: linear-gradient(
          90deg,
          transparent,
          var(--hud-blue),
          transparent
        );
      }
      .m-card:hover::before {
        opacity: 1;
      }
      .m-card:hover {
        border-color: var(--border-amber);
        transform: translateY(-4px);
        box-shadow: 0 22px 56px rgba(0, 0, 0, 0.3);
      }
      .m-label {
        font-family: var(--f-mono);
        font-size: 9px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 10px;
      }
      .m-val {
        font-family: var(--f-display);
        font-size: 46px;
        font-weight: 900;
        line-height: 1;
        margin-bottom: 6px;
      }
      .m-val.vc {
        color: var(--hud-cyan);
        text-shadow: 0 0 22px rgba(34, 211, 238, 0.35);
      }
      .m-val.va {
        color: var(--hud-amber);
        text-shadow: 0 0 22px rgba(245, 158, 11, 0.35);
      }
      .m-val.vs {
        color: var(--hud-success);
        text-shadow: 0 0 22px rgba(245, 158, 11, 0.35);
      }
      .m-val.vb {
        color: var(--hud-blue);
        text-shadow: 0 0 22px rgba(96, 165, 250, 0.35);
      }
      .m-sub {
        font-size: 11px;
        color: var(--text-dim);
      }
      .m-bars {
        display: flex;
        align-items: flex-end;
        gap: 3px;
        height: 24px;
        margin-top: 12px;
      }
      .m-bar {
        flex: 1;
        border-radius: 2px 2px 0 0;
        background: var(--text-dim);
        opacity: 0.4;
        transition: opacity 0.3s;
      }
      .m-bar.hi {
        opacity: 1;
      }
      .ma .m-bar.hi {
        background: var(--hud-cyan);
      }
      .mb .m-bar.hi {
        background: var(--hud-amber);
      }
      .mc .m-bar.hi {
        background: var(--hud-success);
      }
      .md .m-bar.hi {
        background: var(--hud-blue);
      }
      .m-ghost {
        position: absolute;
        bottom: -4px;
        right: 8px;
        font-family: var(--f-display);
        font-size: 78px;
        font-weight: 900;
        color: var(--border);
        line-height: 1;
        pointer-events: none;
        transition: color 0.35s;
      }
      .m-card:hover .m-ghost {
        color: rgba(245, 158, 11, 0.06);
      }
      .filter-cmd {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 16px 20px;
        margin-bottom: 18px;
        backdrop-filter: blur(14px);
        animation: cardUp 0.5s var(--ease) 0.32s both;
      }
      .filter-label {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: var(--f-mono);
        font-size: 9px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--hud-amber);
        margin-bottom: 12px;
      }
      .filter-label::after {
        content: "";
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, var(--border-amber), transparent);
      }
      .filter-grid {
        display: grid;
        grid-template-columns: 2.2fr 1fr 1fr 1fr 1fr;
        gap: 10px;
      }
      .f-ctrl {
        background: rgba(7, 8, 13, 0.7);
        border: 1px solid var(--border);
        border-radius: var(--r);
        color: var(--text-primary);
        font-family: var(--f-mono);
        font-size: 12px;
        padding: 9px 13px;
        outline: none;
        transition:
          border-color 0.25s,
          box-shadow 0.25s;
        width: 100%;
      }
      [data-theme="light"] .f-ctrl {
        background: rgba(255, 255, 255, 0.88);
      }
      .f-ctrl::placeholder {
        color: var(--text-dim);
      }
      .f-ctrl:focus {
        border-color: var(--hud-amber);
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.12);
      }
      .f-ctrl option {
        background: #07080d;
      }
      .main-split {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 16px;
        animation: cardUp 0.5s var(--ease) 0.38s both;
      }
      .list-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-xl);
        overflow: hidden;
        backdrop-filter: blur(14px);
        display: flex;
        flex-direction: column;
      }
      .list-hd {
        padding: 16px 20px 14px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(245, 158, 11, 0.02);
      }
      .list-hd-title {
        font-family: var(--f-display);
        font-size: 15px;
        font-weight: 800;
      }
      .list-hd-hint {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--text-dim);
      }
      .list-body {
        padding: 12px;
        flex: 1;
        overflow-y: auto;
        min-height: 350px;
      }
      .sub-btn {
        width: 100%;
        display: block;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 13px 15px;
        margin-bottom: 8px;
        text-align: left;
        color: var(--text-primary);
        cursor: pointer;
        transition: var(--t);
        position: relative;
        overflow: hidden;
      }
      .sub-btn::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 2px;
        background: var(--hud-amber);
        opacity: 0;
        transition: opacity 0.25s;
        border-radius: 0 2px 2px 0;
      }
      .sub-btn:hover {
        border-color: rgba(245, 158, 11, 0.3);
        background: rgba(245, 158, 11, 0.03);
        transform: translateX(3px);
      }
      .sub-btn:hover::before {
        opacity: 1;
      }
      .sub-btn.is-active {
        background: linear-gradient(
          135deg,
          rgba(245, 158, 11, 0.1),
          rgba(249, 115, 22, 0.06)
        );
        border-color: rgba(245, 158, 11, 0.42);
      }
      .sub-btn.is-active::before {
        opacity: 1;
      }
      .sub-btn.is-active::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(245, 158, 11, 0.04),
          transparent
        );
        animation: rowGlow 3s ease-in-out infinite;
      }
      @keyframes rowGlow {
        0%,
        100% {
          transform: translateX(-100%);
        }
        50% {
          transform: translateX(100%);
        }
      }
      .sub-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 8px;
      }
      .sub-name {
        font-family: var(--f-display);
        font-size: 14px;
        font-weight: 700;
      }
      .sub-auction {
        font-family: var(--f-mono);
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 2px;
      }
      .sub-id {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--text-dim);
        margin-top: 2px;
      }
      .sub-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin-bottom: 7px;
      }
      .chip {
        font-family: var(--f-mono);
        font-size: 10px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 3px 8px;
        color: var(--text-muted);
      }
      .chip.chip-ai-on {
        background: rgba(245, 158, 11, 0.08);
        border-color: rgba(245, 158, 11, 0.22);
        color: var(--hud-success);
      }
      .chip.chip-ai-off {
        background: rgba(255, 255, 255, 0.04);
        border-color: var(--border);
        color: var(--text-dim);
      }
      .sub-date {
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--text-dim);
      }
      .spill {
        font-family: var(--f-mono);
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.06em;
        padding: 3px 10px;
        border-radius: 99px;
        text-transform: uppercase;
        flex-shrink: 0;
      }
      .sp-pending {
        background: rgba(245, 158, 11, 0.12);
        color: var(--hud-amber);
        border: 1px solid rgba(245, 158, 11, 0.28);
      }
      .sp-processing {
        background: rgba(96, 165, 250, 0.12);
        color: var(--hud-blue);
        border: 1px solid rgba(96, 165, 250, 0.28);
      }
      .sp-verified {
        background: rgba(245, 158, 11, 0.12);
        color: var(--hud-success);
        border: 1px solid rgba(245, 158, 11, 0.28);
      }
      .sp-rejected {
        background: rgba(220, 38, 38, 0.12);
        color: #f87171;
        border: 1px solid rgba(220, 38, 38, 0.28);
      }
      .sp-needs_review {
        background: rgba(249, 115, 22, 0.12);
        color: #fb923c;
        border: 1px solid rgba(249, 115, 22, 0.28);
      }
      .sp-incomplete {
        background: rgba(100, 116, 139, 0.12);
        color: #94a3b8;
        border: 1px solid rgba(100, 116, 139, 0.28);
      }
      .state-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 52px 24px;
        text-align: center;
        gap: 12px;
      }
      .state-ico {
        font-size: 30px;
        opacity: 0.35;
      }
      .state-txt {
        font-size: 13px;
        color: var(--text-muted);
      }
      .list-pg {
        padding: 12px 20px 16px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .pg-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 16px;
        border-radius: var(--r);
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-family: var(--f-mono);
        font-size: 11px;
        cursor: pointer;
        transition: var(--t);
      }
      .pg-btn:hover:not(:disabled) {
        border-color: var(--border-amber);
        color: var(--hud-amber);
      }
      .pg-btn:disabled {
        opacity: 0.35;
        cursor: default;
      }
      .pg-info {
        font-family: var(--f-mono);
        font-size: 11px;
        color: var(--text-muted);
      }
      .detail-panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-xl);
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(14px);
        display: flex;
        flex-direction: column;
      }
      .detail-panel::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--hud-cyan) 30%,
          var(--hud-amber) 60%,
          transparent
        );
      }
      .detail-panel::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 3px,
          rgba(245, 158, 11, 0.005) 3px,
          rgba(245, 158, 11, 0.005) 4px
        );
      }
      .dp-deco {
        position: absolute;
        bottom: -8px;
        right: -10px;
        font-size: 90px;
        opacity: 0.04;
        pointer-events: none;
        z-index: 1;
        transform: scaleX(-1);
      }
      .dp-scroll {
        position: relative;
        z-index: 2;
        flex: 1;
        overflow-y: auto;
        padding: 20px;
      }
      .dp-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        text-align: center;
        gap: 18px;
        padding: 32px;
      }
      .dp-placeholder-ico {
        width: 72px;
        height: 72px;
        border-radius: 20px;
        background: var(--surface-2);
        border: 1px solid var(--border-amber);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        position: relative;
      }
      .dp-placeholder-ico::after {
        content: "";
        position: absolute;
        inset: -5px;
        border-radius: 25px;
        border: 1px dashed rgba(245, 158, 11, 0.22);
        animation: orbitSpin 7s linear infinite;
      }
      @keyframes orbitSpin {
        to {
          transform: rotate(360deg);
        }
      }
      .d-sec {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
        padding: 14px 16px;
        margin-bottom: 10px;
      }
      .d-sec-title {
        font-family: var(--f-mono);
        font-size: 9px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--hud-amber);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .d-sec-title::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border-amber);
      }
      .d-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 7px;
        gap: 12px;
      }
      .d-row:last-child {
        margin-bottom: 0;
      }
      .d-key {
        font-family: var(--f-mono);
        font-size: 11px;
        color: var(--text-muted);
        flex-shrink: 0;
      }
      .d-val {
        font-size: 12px;
        color: var(--text-primary);
        text-align: right;
        word-break: break-word;
      }
      .conf-wrap {
        margin-bottom: 10px;
      }
      .conf-row {
        display: flex;
        justify-content: space-between;
        font-family: var(--f-mono);
        font-size: 10px;
        color: var(--text-muted);
        margin-bottom: 5px;
      }
      .conf-track {
        height: 5px;
        background: var(--border);
        border-radius: 99px;
        overflow: hidden;
        position: relative;
      }
      .conf-fill {
        height: 100%;
        border-radius: 99px;
        width: 0;
        transition: width 1.1s cubic-bezier(0.4, 0, 0.2, 1);
      }
      .conf-fill.f-own {
        background: linear-gradient(90deg, var(--hud-amber), var(--hud-cyan));
      }
      .conf-fill.f-hlt {
        background: linear-gradient(90deg, var(--hud-blue), var(--hud-success));
      }
      .ai-bubble {
        background: rgba(34, 211, 238, 0.04);
        border: 1px solid rgba(34, 211, 238, 0.14);
        border-radius: var(--r);
        padding: 10px 13px;
        font-size: 12px;
        color: var(--text-muted);
        line-height: 1.65;
        margin-top: 6px;
      }
      .doc-lnk {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-family: var(--f-mono);
        font-size: 11px;
        color: var(--hud-cyan);
        text-decoration: none;
        background: rgba(34, 211, 238, 0.05);
        border: 1px solid rgba(34, 211, 238, 0.16);
        border-radius: 5px;
        padding: 3px 9px;
        margin: 2px;
        transition: var(--t);
      }
      .doc-lnk:hover {
        background: rgba(34, 211, 238, 0.1);
        border-color: rgba(34, 211, 238, 0.35);
      }
      .btn-analyze {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, var(--hud-blue), var(--hud-cyan));
        border: none;
        border-radius: var(--r-lg);
        color: #070a12;
        font-family: var(--f-display);
        font-size: 14px;
        font-weight: 800;
        cursor: pointer;
        transition: var(--t);
        position: relative;
        overflow: hidden;
        letter-spacing: 0.01em;
      }
      .btn-analyze::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.2),
          transparent
        );
        opacity: 0;
        transition: opacity 0.3s;
      }
      .btn-analyze:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 44px rgba(96, 165, 250, 0.4);
      }
      .btn-analyze:hover::before {
        opacity: 1;
      }
      .btn-analyze:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
      }
      .spin-ring {
        display: inline-block;
        width: 13px;
        height: 13px;
        border: 2px solid rgba(0, 0, 0, 0.3);
        border-top-color: #070a12;
        border-radius: 50%;
        animation: spinIcon 0.65s linear infinite;
      }
      @keyframes heroEntrance {
        from {
          opacity: 0;
          transform: translateY(-18px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes cardUp {
        from {
          opacity: 0;
          transform: translateY(22px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes lineShimmer {
        0% {
          background-position: -200% center;
        }
        100% {
          background-position: 200% center;
        }
      }
      @media (max-width: 1240px) {
        .main-split {
          grid-template-columns: 1fr 360px;
        }
      }
      @media (max-width: 1024px) {
        .metrics-strip {
          grid-template-columns: repeat(2, 1fr);
        }
        .filter-grid {
          grid-template-columns: 1fr 1fr;
        }
        .main-split {
          grid-template-columns: 1fr;
        }
        .detail-panel {
          min-height: 480px;
        }
        .orbit-stage {
          display: none;
        }
      }
      @media (max-width: 640px) {
        #page-root {
          padding: 10px 10px 56px;
        }
        .metrics-strip {
          gap: 10px;
        }
        .filter-grid {
          grid-template-columns: 1fr;
        }
        .cmd-hero-inner {
          padding: 20px;
        }
        .hero-actions {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div id="page-root">
      <header class="cmd-hero">
        <div class="hud-grid"></div>
        <div class="cmd-hero-inner">
          <div class="orbit-stage">
            <div class="animal-pod p-cow">
              <div class="pod-ring"></div>
              <div class="pod-scan"></div>
              <img src="/img/cow.png" alt="Cow" style="width:40px;height:40px;object-fit:contain;" />
            </div>
            <div class="animal-pod p-goat">
              <div class="pod-scan" style="animation-delay:-.9s"></div>
              <img src="/img/goat.png" alt="Goat" style="width:34px;height:34px;object-fit:contain;" />
            </div>
            <div class="animal-pod p-sheep">
              <div class="pod-scan" style="animation-delay:-1.8s"></div>
              <img src="/img/sheep.png" alt="Sheep" style="width:28px;height:28px;object-fit:contain;" />
            </div>
          </div>
          <div class="hero-text">
            <div class="hero-kicker">
              <i class="bi bi-shield-fill-check"></i>
              Admin Control Center
            </div>
            <h1 class="hero-title">
              AI Verification<br />
              <span>Intelligence Hub</span>
            </h1>
            <p class="hero-desc">
              Assess submitted livestock ownership and health records with
              Gemini analysis, confidence metrics, and audit-ready review
              actions. Full document chain of custody.
            </p>
            <div class="signal-badge">
              <span class="sig-dot"></span>
              REAL-TIME VERIFICATION WORKFLOW ACTIVE
            </div>
          </div>
          <div class="hero-actions">
            <a href="/dashboard/admin" class="btn-ghost">
              <i class="bi bi-arrow-left-short"></i>
              Back to Admin
            </a>
            <button id="refresh-btn" type="button" class="btn-prime">
              <i class="bi bi-arrow-clockwise"></i>
              Refresh
            </button>
          </div>
        </div>
      </header>
      <div class="metrics-strip">
        <div class="m-card ma">
          <div class="m-label">Total Submissions</div>
          <div id="stat-total" class="m-val vc">0</div>
          <div class="m-sub">All uploaded verification records</div>
          <div class="m-bars">
            <div class="m-bar" style="height:35%"></div>
            <div class="m-bar" style="height:52%"></div>
            <div class="m-bar" style="height:44%"></div>
            <div class="m-bar" style="height:68%"></div>
            <div class="m-bar" style="height:59%"></div>
            <div class="m-bar hi" style="height:88%"></div>
          </div>
          <div class="m-ghost"><i class="bi bi-bar-chart-line"></i></div>
        </div>
        <div class="m-card mb">
          <div class="m-label">Pending Review</div>
          <div id="stat-pending" class="m-val va">0</div>
          <div class="m-sub">Awaiting analysis or decision</div>
          <div class="m-bars">
            <div class="m-bar" style="height:60%"></div>
            <div class="m-bar" style="height:40%"></div>
            <div class="m-bar" style="height:74%"></div>
            <div class="m-bar" style="height:50%"></div>
            <div class="m-bar" style="height:88%"></div>
            <div class="m-bar hi" style="height:65%"></div>
          </div>
          <div class="m-ghost"><i class="bi bi-hourglass-split"></i></div>
        </div>
        <div class="m-card mc">
          <div class="m-label">Verified</div>
          <div id="stat-verified" class="m-val vs">0</div>
          <div class="m-sub">Approved records on platform</div>
          <div class="m-bars">
            <div class="m-bar" style="height:22%"></div>
            <div class="m-bar" style="height:38%"></div>
            <div class="m-bar" style="height:56%"></div>
            <div class="m-bar" style="height:72%"></div>
            <div class="m-bar" style="height:82%"></div>
            <div class="m-bar hi" style="height:94%"></div>
          </div>
          <div class="m-ghost"><i class="bi bi-check2-circle"></i></div>
        </div>
        <div class="m-card md">
          <div class="m-label">Gemini Analyzed</div>
          <div id="stat-analyzed" class="m-val vb">0</div>
          <div class="m-sub">Completed AI analysis passes</div>
          <div class="m-bars">
            <div class="m-bar" style="height:28%"></div>
            <div class="m-bar" style="height:48%"></div>
            <div class="m-bar" style="height:40%"></div>
            <div class="m-bar" style="height:62%"></div>
            <div class="m-bar" style="height:76%"></div>
            <div class="m-bar hi" style="height:86%"></div>
          </div>
          <div class="m-ghost"><i class="bi bi-cpu"></i></div>
        </div>
      </div>
      <div class="filter-cmd">
        <div class="filter-label">
          <i class="bi bi-funnel-fill"></i>
          Search and Filter Controls
        </div>
        <div class="filter-grid">
          <input
            id="search-input"
            type="text"
            class="f-ctrl"
            placeholder="Search submitter, phone, auction ID, verification ID..."
          />
          <select id="status-filter" class="f-ctrl">
            <option value="all">All Statuses</option>
            <option value="pending">Pending</option>
            <option value="processing">Processing</option>
            <option value="verified">Verified</option>
            <option value="rejected">Rejected</option>
            <option value="needs_review">Needs Review</option>
            <option value="incomplete">Incomplete</option>
          </select>
          <select id="type-filter" class="f-ctrl">
            <option value="all">All Types</option>
            <option value="ownership">Ownership</option>
            <option value="health">Health</option>
            <option value="both">Both</option>
          </select>
          <select id="ai-filter" class="f-ctrl">
            <option value="all">All AI States</option>
            <option value="pending_ai">Not Analyzed</option>
            <option value="analyzed">Analyzed</option>
          </select>
          <select id="limit-filter" class="f-ctrl">
            <option value="8">8 per page</option>
            <option value="12" selected>12 per page</option>
            <option value="20">20 per page</option>
            <option value="40">40 per page</option>
          </select>
        </div>
      </div>
      <div class="main-split">
        <div class="list-panel">
          <div class="list-hd">
            <span class="list-hd-title">Submitted Verifications</span>
            <span class="list-hd-hint">Select a record to inspect</span>
          </div>
          <div class="list-body">
            <div id="rows">
              <div class="state-box">
                <div
                  class="animal-pod p-cow"
                  style="width:54px;height:54px;font-size:24px;animation:podFloat 5.5s ease-in-out infinite;"
                >
                  <div class="pod-scan"></div><i class="bi bi-broadcast-pin"></i>
                </div>
                <div class="state-txt">Loading submissions...</div>
              </div>
            </div>
          </div>
          <div class="list-pg">
            <button id="prev-page" class="pg-btn" disabled>
              <i class="bi bi-chevron-left"></i>
              Prev
            </button>
            <span id="page-label" class="pg-info">Page 1 of 1</span>
            <button id="next-page" class="pg-btn" disabled>
              Next
              <i class="bi bi-chevron-right"></i>
            </button>
          </div>
        </div>
        <div class="detail-panel">
          <div class="dp-deco"><i class="bi bi-shield-check"></i></div>
          <div class="dp-scroll">
            <div id="detail-panel">
              <div class="dp-placeholder">
                <div class="dp-placeholder-ico"><i class="bi bi-search"></i></div>
                <div
                  style="font-family:var(--f-display);font-size:17px;font-weight:800;"
                >Select a Submission</div>
                <div
                  style="font-size:13px;color:var(--text-muted);max-width:210px;line-height:1.65;"
                >
                  Choose a verification record to inspect details and run Gemini
                  analysis.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script src="/js/app-theme.js"></script>
    <script src="/js/admin-ai-verification.js"></script>
  </body>
</html>
