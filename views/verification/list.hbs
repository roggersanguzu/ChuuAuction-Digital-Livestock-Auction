<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Verifications - AI Insights | ChuuAuction</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="/vendor/bootstrap-icons/css/bootstrap-icons.css"
    />
    <link href="/css/app-theme.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      .font-display {
        font-family: "Crimson Pro", serif;
      }
      .font-mono {
        font-family: "Space Mono", monospace;
      }
      .font-body {
        font-family: "Inter", sans-serif;
      }
      .glass {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }
      .glass-strong {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #1f2937;
      }
      ::-webkit-scrollbar-thumb {
        background: linear-gradient(180deg, #3b82f6, #2563eb);
        border-radius: 4px;
      }
      @keyframes ai-pulse {
        0%,
        100% {
          box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.7);
        }
        50% {
          box-shadow: 0 0 0 10px rgba(139, 92, 246, 0);
        }
      }
      .ai-badge {
        animation: ai-pulse 2s infinite;
      }
      .insight-card {
        transition: all 0.3s ease;
      }
      .insight-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 40px rgba(139, 92, 246, 0.2);
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-950 text-white font-body overflow-x-hidden">
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div
        class="absolute top-20 left-20 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[150px]"
      ></div>
      <div
        class="absolute bottom-20 right-20 w-[500px] h-[500px] bg-purple-600/10 rounded-full blur-[150px]"
      ></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="text-center mb-12 animate-fade-in">
        <div class="flex items-center justify-center gap-4 mb-6">
          <div
            class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-600 to-purple-600 flex items-center justify-center shadow-2xl ai-badge"
          >
            <i class="bi bi-shield-check-fill text-4xl text-white"></i>
          </div>
          <h1
            class="text-5xl md:text-7xl font-black font-display tracking-tight"
          >
            <span
              class="bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent"
            >
              My Verifications
            </span>
          </h1>
        </div>
        <p class="text-xl text-gray-300 max-w-3xl mx-auto mb-4">
          AI-powered analysis with actionable insights
        </p>
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass border border-purple-500/30"
        >
          <i class="bi bi-stars text-purple-400"></i>
          <span class="text-sm font-mono text-purple-300">Enhanced with Gemini
            AI</span>
        </div>
      </div>
      <div id="batch-insights" class="mb-8 hidden">
        <div class="p-6 rounded-2xl glass-strong border border-purple-500/30">
          <h2 class="text-2xl font-bold mb-4 flex items-center gap-2">
            <i class="bi bi-graph-up text-purple-400"></i>
            Overall Analytics
          </h2>
          <div class="grid md:grid-cols-4 gap-4" id="batch-stats"></div>
        </div>
      </div>
      <div id="loading" class="flex flex-col items-center justify-center py-20">
        <div
          class="w-20 h-20 border-8 border-blue-500 border-t-transparent rounded-full animate-spin mb-6"
        ></div>
        <p class="text-xl text-gray-400">Loading your verifications...</p>
      </div>
      <div id="empty-state" class="hidden text-center py-20">
        <i class="bi bi-clipboard-x text-8xl text-gray-600 mb-8 block"></i>
        <h2 class="text-3xl font-bold mb-4">No Verifications Yet</h2>
        <p class="text-lg text-gray-400 mb-8 max-w-xl mx-auto">
          You haven't submitted any livestock verifications yet. Get started
          now!
        </p>
        <a
          href="/verification/submit"
          class="inline-flex items-center px-8 py-4 rounded-2xl bg-gradient-to-r from-blue-600 to-purple-600 font-bold text-lg hover:shadow-2xl hover:shadow-purple-500/30 transition-all"
        >
          <i class="bi bi-plus-lg mr-3 text-xl"></i>
          Submit New Verification
        </a>
      </div>
      <div id="verifications-grid" class="grid gap-8 lg:grid-cols-1 hidden">
      </div>
    </div>
    <script>
      async function loadVerifications() { const loading =
      document.getElementById("loading"); const empty =
      document.getElementById("empty-state"); const grid =
      document.getElementById("verifications-grid"); const batchInsightsSection
      = document.getElementById("batch-insights"); const batchStats =
      document.getElementById("batch-stats"); try { const response = await
      fetch("/verification/api/my-verifications"); const result = await
      response.json(); loading.classList.add("hidden"); if (!result.success ||
      !result.data || result.data.length === 0) {
      empty.classList.remove("hidden"); return; }
      grid.classList.remove("hidden"); // Display batch insights if available if
      (result.batchInsights) { batchInsightsSection.classList.remove("hidden");
      displayBatchInsights(result.batchInsights, batchStats); } // Render each
      verification card result.data.forEach(verification => { const card =
      createVerificationCard(verification); grid.appendChild(card); }); } catch
      (err) { console.error(err); loading.classList.add("hidden");
      showError(empty); } } function displayBatchInsights(insights, container) {
      const stats = [ { icon: "bi-check-circle", label: "Verification Rate",
      value: `${Math.round(insights.summary?.verificationRate || 0)}%`, color:
      "green" }, { icon: "bi-star", label: "Average Score", value:
      `${Math.round(insights.summary?.averageScore || 0)}%`, color: "blue" }, {
      icon: "bi-shield-check", label: "Compliance", value:
      `${Math.round(insights.qualityMetrics?.healthCompliance || 0)}%`, color:
      "purple" }, { icon: "bi-graph-up", label: "Market Readiness", value:
      "Good", color: "orange" } ]; stats.forEach(stat => { const statCard =
      document.createElement("div"); statCard.className = `p-4 rounded-xl glass
      border border-${stat.color}-500/30`; statCard.innerHTML = ` <i class="bi
      ${stat.icon} text-2xl text-${stat.color}-400 mb-2 block"></i> <div
      class="text-2xl font-bold">${stat.value}</div> <div class="text-xs
      text-gray-400">${stat.label}</div> `; container.appendChild(statCard); });
      } function createVerificationCard(verification) { const card =
      document.createElement("div"); card.className = "rounded-3xl
      overflow-hidden glass-strong border border-gray-700/50
      hover:border-purple-500/50 transition-all duration-300 shadow-xl
      hover:shadow-2xl hover:shadow-purple-500/20"; const insights =
      verification.aiVerification?.insights || {}; const analytics =
      verification.aiVerification?.analytics || {}; card.innerHTML = ` <div
      class="p-8">  <div class="flex justify-between items-start
      mb-6"> <div> <h3 class="text-3xl font-black font-display capitalize
      bg-gradient-to-r from-blue-400 to-purple-500 bg-clip-text
      text-transparent"> ${verification.verificationType} Verification </h3> <p
      class="text-sm text-gray-400 mt-1"> Submitted ${new
      Date(verification.createdAt).toLocaleDateString()} </p> </div> <div
      class="flex items-center gap-3"> <span class="px-4 py-2 rounded-full
      text-sm font-bold ${getStatusClass(verification.status)}">
      ${verification.status.toUpperCase()} </span>
      ${verification.overallApproved ? '<i class="bi bi-check-circle-fill
      text-3xl text-green-400"></i>' : '<i class="bi bi-x-circle-fill text-3xl
      text-red-400"></i>' } </div> </div>  <div class="mb-8">
      <div class="flex justify-between text-sm mb-2"> <span>Verification
      Score</span> <span
      class="font-bold">${Math.round(verification.verificationScore ||
      0)}%</span> </div> <div class="w-full bg-gray-800 rounded-full h-3
      overflow-hidden"> <div class="h-full rounded-full transition-all
      duration-1000 ${getScoreColor(verification.verificationScore)}"
      style="width: ${Math.round(verification.verificationScore || 0)}%"></div>
      </div> </div>  ${insights.recommendations ? `
      <div class="mb-8 p-6 rounded-2xl glass border border-purple-500/20"> <h4
      class="text-xl font-bold mb-4 flex items-center gap-2"> <i class="bi
      bi-lightbulb text-yellow-400"></i> AI-Powered Insights </h4>  <div class="grid grid-cols-2 gap-4 mb-4"> <div
      class="p-4 rounded-xl bg-blue-500/10 border border-blue-500/30"> <div
      class="text-sm text-gray-400 mb-1">Trust Score</div> <div class="text-2xl
      font-bold text-blue-400">${Math.round(insights.trustScore || 0)}%</div>
      </div> <div class="p-4 rounded-xl bg-green-500/10 border
      border-green-500/30"> <div class="text-sm text-gray-400
      mb-1">Compliance</div> <div class="text-2xl font-bold
      text-green-400">${Math.round(insights.complianceScore || 0)}%</div> </div>
      </div>  ${insights.riskAssessment ? ` <div
      class="mb-4 p-4 rounded-xl
      ${getRiskColor(insights.riskAssessment.level)}"> <div class="flex
      items-center gap-2 mb-2"> <i class="bi bi-exclamation-triangle"></i> <span
      class="font-bold">Risk Level:
      ${insights.riskAssessment.level?.toUpperCase()}</span> </div>
      ${insights.riskAssessment.factors?.length ? ` <div class="text-sm
      space-y-1"> ${insights.riskAssessment.factors.slice(0, 3).map(f => `<div>•
      ${f}</div>`).join('')} </div> ` : ''} </div> ` : ''}  ${insights.recommendations.immediate?.length ? ` <div
      class="mb-4"> <div class="text-sm font-bold text-orange-400 mb-2"> <i
      class="bi bi-lightning mr-1"></i>Immediate Actions: </div> <div
      class="space-y-2"> ${insights.recommendations.immediate.slice(0,
      3).map(rec => ` <div class="flex items-start gap-2 text-sm"> <i class="bi
      bi-check-circle text-orange-400 mt-0.5"></i> <span>${rec}</span> </div>
      `).join('')} </div> </div> ` : ''}
      ${insights.marketValue ? ` <div class="p-4 rounded-xl bg-purple-500/10
      border border-purple-500/30"> <div class="text-sm text-gray-400
      mb-1">Estimated Market Value</div> <div class="text-lg font-bold
      text-purple-400">${insights.marketValue.estimated || 'Under
      Analysis'}</div> ${insights.marketValue.factors?.length ? ` <div
      class="text-xs text-gray-400 mt-2"> Based on:
      ${insights.marketValue.factors.slice(0, 2).join(', ')} </div> ` : ''}
      </div> ` : ''} </div> ` : ''}  <div
      class="space-y-6"> ${renderOwnershipSection(verification)}
      ${renderHealthSection(verification)} ${renderPhotoSection(verification)}
      </div>  ${analytics.actionItems?.length ? ` <div
      class="mt-6 p-4 rounded-xl bg-blue-500/10 border border-blue-500/30"> <h4
      class="font-bold text-blue-400 mb-3"> <i class="bi bi-list-check
      mr-2"></i>Action Items </h4> <div class="space-y-2">
      ${analytics.actionItems.slice(0, 5).map(item => ` <label class="flex
      items-start gap-3 cursor-pointer"> <input type="checkbox" class="mt-1
      rounded border-gray-600"> <span class="text-sm">${item}</span> </label>
      `).join('')} </div> </div> ` : ''}  <div class="mt-8 pt-6
      border-t border-gray-700/50 text-sm text-gray-400 flex justify-between
      items-center"> <span>ID: ${verification._id}</span>
      ${verification.expiresAt ? `<span>Expires: ${new
      Date(verification.expiresAt).toLocaleDateString()}</span>` : ''} </div>
      </div> `; return card; } function renderOwnershipSection(verification) {
      return ` <div class="p-6 rounded-2xl glass border border-blue-500/20
      insight-card"> <div class="flex items-center gap-3 mb-4"> <i class="bi
      bi-person-badge-fill text-3xl text-blue-400"></i> <h4 class="text-xl
      font-bold">Ownership Verification</h4> </div> <div class="grid grid-cols-2
      gap-4 mb-4 text-sm"> <div> <span class="text-gray-400">Status:</span><br>
      <span class="font-bold ${verification.aiVerification.ownershipVerified ?
      'text-green-400' : 'text-red-400'}">
      ${verification.aiVerification.ownershipVerified ? "Verified" : "Not
      Verified"} </span> </div> <div> <span
      class="text-gray-400">Confidence:</span><br> <span
      class="font-bold">${Math.round(verification.aiVerification.ownershipConfidence
      || 0)}%</span> </div> </div> <p class="text-gray-300 text-sm
      leading-relaxed"> ${verification.aiVerification.ownershipAnalysis || "No
      detailed analysis available yet."} </p>
      ${verification.aiVerification.ownershipFlags?.length ? ` <div class="mt-4
      flex flex-wrap gap-2">
      ${verification.aiVerification.ownershipFlags.map(flag => ` <span
      class="px-3 py-1 rounded-full text-xs bg-red-500/20 text-red-300 border
      border-red-500/30">${flag}</span> `).join('')} </div> ` : ''} </div> `; }
      function renderHealthSection(verification) { return ` <div class="p-6
      rounded-2xl glass border border-green-500/20 insight-card"> <div
      class="flex items-center gap-3 mb-4"> <i class="bi bi-heart-pulse-fill
      text-3xl text-green-400"></i> <h4 class="text-xl font-bold">Health
      Assessment</h4> </div> <div class="grid grid-cols-2 gap-4 mb-4 text-sm">
      <div> <span class="text-gray-400">Assessment:</span><br> <span
      class="font-bold
      capitalize">${verification.aiVerification.healthAssessment ||
      "Pending"}</span> </div> <div> <span
      class="text-gray-400">Confidence:</span><br> <span
      class="font-bold">${Math.round(verification.aiVerification.healthConfidence
      || 0)}%</span> </div> </div> <p class="text-gray-300 text-sm
      leading-relaxed"> ${verification.aiVerification.healthAnalysis || "No
      health analysis available yet."} </p>
      ${verification.aiVerification.healthFlags?.length ? ` <div class="mt-4
      flex flex-wrap gap-2"> ${verification.aiVerification.healthFlags.map(flag
      => ` <span class="px-3 py-1 rounded-full text-xs bg-red-500/20
      text-red-300 border border-red-500/30">${flag}</span> `).join('')} </div>
      ` : ''} </div> `; } function renderPhotoSection(verification) { return `
      <div class="p-6 rounded-2xl glass border border-purple-500/20
      insight-card"> <div class="flex items-center gap-3 mb-4"> <i class="bi
      bi-images text-3xl text-purple-400"></i> <h4 class="text-xl
      font-bold">Photo & Breed Analysis</h4> </div> <div class="grid grid-cols-2
      gap-4 mb-4 text-sm"> <div> <span class="text-gray-400">Breed:</span><br>
      <span class="font-bold">${verification.aiVerification.detectedBreed ||
      "Not detected"}</span> </div> <div> <span
      class="text-gray-400">Quality:</span><br> <span class="font-bold
      capitalize">${verification.aiVerification.photoQuality ||
      "Unknown"}</span> </div> </div> <p class="text-gray-300 text-sm
      leading-relaxed"> ${verification.aiVerification.photoAnalysis || "No photo
      analysis available yet."} </p> </div> `; } function getStatusClass(status)
      { const classes = { verified: "bg-green-500/20 text-green-300 border
      border-green-500/30", rejected: "bg-red-500/20 text-red-300 border
      border-red-500/30", processing: "bg-blue-500/20 text-blue-300 border
      border-blue-500/30 animate-pulse", pending: "bg-yellow-500/20
      text-yellow-300 border border-yellow-500/30" }; return classes[status] ||
      classes.pending; } function getScoreColor(score) { if (score >= 90) return
      "bg-green-500"; if (score >= 70) return "bg-blue-500"; if (score >= 50)
      return "bg-yellow-500"; return "bg-red-500"; } function
      getRiskColor(level) { const colors = { low: "bg-green-500/10 border
      border-green-500/30 text-green-300", medium: "bg-yellow-500/10 border
      border-yellow-500/30 text-yellow-300", high: "bg-red-500/10 border
      border-red-500/30 text-red-300" }; return colors[level] || colors.medium;
      } function showError(container) { container.innerHTML = ` <i class="bi
      bi-exclamation-triangle text-8xl text-red-500 mb-8 block"></i> <h2
      class="text-3xl font-bold mb-4">Failed to Load Verifications</h2> <p
      class="text-lg text-gray-400 mb-8">Please try again later or contact
      support.</p> <button onclick="location.reload()" class="inline-flex
      items-center px-8 py-4 rounded-2xl bg-red-600/80 hover:bg-red-600
      font-bold text-lg transition-all"> <i class="bi bi-arrow-repeat mr-3"></i>
      Retry </button> `; container.classList.remove("hidden"); } // Load
      immediately loadVerifications();
    </script>
      <script src="/js/app-theme.js"></script>
  </body>
</html>


