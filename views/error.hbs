{{#> main title=title}}
<div class="min-h-screen flex items-center justify-center bg-gray-950 text-gray-100 relative overflow-hidden">
  <div class="absolute top-10 left-1/4 w-72 h-72 bg-gradient-to-tr from-orange-500/30 to-red-600/30 rounded-full blur-3xl animate-float"></div>
  <div class="absolute bottom-16 right-1/3 w-96 h-96 bg-gradient-to-br from-red-600/20 via-orange-500/20 to-red-700/20 rounded-full blur-3xl animate-float" style="animation-delay:1s;"></div>
  <div class="text-center px-6 py-12 max-w-lg relative z-10">
    <h1 class="text-[10rem] sm:text-[12rem] font-black bg-gradient-to-r from-orange-500 via-red-600 to-orange-600 bg-clip-text text-transparent animate-gradient mb-4">
      404
    </h1>
    <h2 class="text-4xl sm:text-5xl font-semibold mb-6 text-gray-200">Page Not Found</h2>
    <p class="text-lg sm:text-xl text-gray-400 mb-8">
      Oops! The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/"
      class="inline-block relative px-8 py-4 font-bold text-white rounded-2xl bg-gradient-to-r from-orange-500 to-red-600 text-lg sm:text-xl overflow-hidden group hover:scale-105 transition-all duration-300"
    >
      <span class="relative z-10">Go Back Home</span>
      <span class="absolute inset-0 bg-white/10 group-hover:bg-white/20 transition-all duration-500 rounded-2xl"></span>
    </a>
    <div class="absolute top-0 left-0 w-1 h-1 bg-white rounded-full animate-pulse opacity-50"></div>
    <div class="absolute bottom-0 right-0 w-1.5 h-1.5 bg-white rounded-full animate-pulse opacity-40"></div>
  </div>
</div>
{{/main}}

