    <script src="/js/app-theme.js"></script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        var html = document.documentElement;
        var themeButton = document.getElementById("theme-toggle");
        var themeIcon = document.getElementById("theme-icon");
        var navbar = document.getElementById("navbar");
        var ham = document.getElementById("ham");
        var drawer = document.getElementById("drw");
        var overlay = document.getElementById("drw-overlay");
        var closeBtn = document.getElementById("drw-close");
        var savedTheme =
          localStorage.getItem("chuu-theme") ||
          localStorage.getItem("theme") ||
          "dark";
        html.setAttribute("data-theme", savedTheme);
        function syncThemeIcon(theme) {
          if (!themeIcon) return;
          themeIcon.className =
            theme === "dark" ? "bi bi-moon-stars" : "bi bi-sun-fill";
        }
        syncThemeIcon(savedTheme);
        if (themeButton && themeButton.dataset.themeBound !== "1") {
          themeButton.dataset.themeBound = "1";
          themeButton.addEventListener("click", function () {
            var current = html.getAttribute("data-theme");
            var next = current === "dark" ? "light" : "dark";
            html.setAttribute("data-theme", next);
            localStorage.setItem("chuu-theme", next);
            localStorage.setItem("theme", next);
            syncThemeIcon(next);
          });
        }
        function navOffset() {
          return (navbar ? navbar.offsetHeight : 74) + 16;
        }
        function closeDrawer() {
          if (!drawer || !overlay || !ham) return;
          drawer.classList.remove("open");
          overlay.classList.remove("open");
          ham.classList.remove("open");
          document.body.style.overflow = "";
        }
        function openDrawer() {
          if (!drawer || !overlay || !ham) return;
          drawer.classList.add("open");
          overlay.classList.add("open");
          ham.classList.add("open");
          document.body.style.overflow = "hidden";
        }
        function forceCloseDrawer(event) {
          if (event) {
            event.preventDefault();
            event.stopPropagation();
          }
          closeDrawer();
        }
        function scrollToHash(hash) {
          if (!hash || hash === "#") return;
          var target = document.querySelector(hash);
          if (!target) return;
          window.scrollTo({
            top:
              target.getBoundingClientRect().top +
              window.scrollY -
              navOffset(),
            behavior: "smooth",
          });
        }
        if (navbar) {
          window.addEventListener(
            "scroll",
            function () {
              navbar.classList.toggle("scrolled", window.scrollY > 40);
            },
            { passive: true },
          );
        }
        if (ham && drawer && overlay) {
          ham.addEventListener("click", function (event) {
            event.preventDefault();
            event.stopPropagation();
            if (drawer.classList.contains("open")) closeDrawer();
            else openDrawer();
          });
          if (closeBtn) {
            closeBtn.addEventListener("click", forceCloseDrawer);
            closeBtn.addEventListener("touchend", forceCloseDrawer);
            closeBtn.addEventListener("pointerdown", forceCloseDrawer);
          }
          overlay.addEventListener("click", closeDrawer);
          drawer.querySelectorAll(".drw-link, .drw-ft a").forEach(function (item) {
            item.addEventListener("click", function () {
              closeDrawer();
            });
          });
          document.addEventListener("keydown", function (event) {
            if (event.key === "Escape") closeDrawer();
          });
        }
        document.addEventListener("click", function (event) {
          var trigger = event.target.closest("#drw-close");
          if (!trigger) return;
          forceCloseDrawer(event);
        });
        document.querySelectorAll('a[href^="#"]').forEach(function (link) {
          link.addEventListener("click", function (event) {
            var href = link.getAttribute("href");
            if (!href || href === "#") return;
            if (!document.querySelector(href)) return;
            event.preventDefault();
            closeDrawer();
            requestAnimationFrame(function () {
              scrollToHash(href);
            });
          });
        });
        document.body.classList.add("js-go");
        var revealObserver = new IntersectionObserver(
          function (entries, observer) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("show");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.07, rootMargin: "0px 0px -28px 0px" },
        );
        document.querySelectorAll(".reveal").forEach(function (element, index) {
          element.style.transitionDelay = (index % 5) * 70 + "ms";
          revealObserver.observe(element);
        });
        var countObserver = new IntersectionObserver(
          function (entries, observer) {
            entries.forEach(function (entry) {
              if (!entry.isIntersecting) return;
              var element = entry.target;
              var raw = element.textContent;
              var numeric = parseFloat(raw.replace(/[^0-9.]/g, ""));
              if (Number.isNaN(numeric)) return;
              var suffix = raw.replace(/[0-9.]/g, "");
              var elapsed = 0;
              var duration = 1800;
              var interval = 16;
              var timer = setInterval(function () {
                elapsed += interval;
                var progress = Math.min(elapsed / duration, 1);
                var eased = 1 - Math.pow(1 - progress, 4);
                element.textContent =
                  (numeric > 100
                    ? Math.round(numeric * eased)
                    : (numeric * eased).toFixed(1)) + suffix;
                if (progress >= 1) {
                  element.textContent = raw;
                  clearInterval(timer);
                }
              }, interval);
              observer.unobserve(element);
            });
          },
          { threshold: 0.5 },
        );
        document.querySelectorAll(".stat-num, .i-num").forEach(function (element) {
          countObserver.observe(element);
        });
      });
    </script>
