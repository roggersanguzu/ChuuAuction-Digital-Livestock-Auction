<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ChuuAuction | Digital Livestock Market Uganda</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Instrument+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="/vendor/bootstrap-icons/css/bootstrap-icons.css"
    />
    <link href="/css/output.css" rel="stylesheet" />
    <link href="/css/app-theme.css" rel="stylesheet" />
    <style>
      :root {
        --amber: #f59e0b;
        --amber-d: #b45309;
        --ember: #dc2626;
        --ochre: #d97706;
        --clay: #92400e;
        --earth: #78350f;
        --cream: #fef3c7;
        --bg: #09090b;
        --bg2: #0f0e0c;
        --bg3: #161410;
        --surf: rgba(245, 158, 11, 0.05);
        --surf2: rgba(245, 158, 11, 0.1);
        --border: rgba(245, 158, 11, 0.12);
        --border2: rgba(245, 158, 11, 0.3);
        --text: #faf5e9;
        --muted: #a8956e;
        --dim: #5c4d37;
        --glow: rgba(245, 158, 11, 0.25);
        --rad: 14px;
        --rad-lg: 22px;
        --rad-xl: 32px;
        --nav-h: 74px;
        --ease: cubic-bezier(0.4, 0, 0.2, 1);
        --t: 0.38s var(--ease);
      }
      [data-theme="light"] {
        --bg: #fdf8ef;
        --bg2: #f5edd8;
        --bg3: #ede0c4;
        --surf: rgba(180, 83, 9, 0.05);
        --surf2: rgba(180, 83, 9, 0.09);
        --border: rgba(180, 83, 9, 0.14);
        --border2: rgba(180, 83, 9, 0.38);
        --text: #1c1209;
        --muted: #7c5e38;
        --dim: #c4a97a;
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
        font-size: 16px;
      }
      section[id] {
        scroll-margin-top: calc(var(--nav-h) + 18px);
      }
      body {
        font-family: "Instrument Sans", sans-serif;
        background: var(--bg);
        color: var(--text);
        overflow-x: hidden;
        transition:
          background 0.4s,
          color 0.4s;
      }
      a {
        text-decoration: none;
        color: inherit;
      }
      img {
        max-width: 100%;
        display: block;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 1000;
        pointer-events: none;
        opacity: 0.025;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 200px 200px;
      }
      ::-webkit-scrollbar {
        width: 5px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--amber);
        border-radius: 99px;
      }
      .display {
        font-family: "Playfair Display", serif;
      }
      .mono {
        font-family: "JetBrains Mono", monospace;
      }
      .grad-text {
        background: linear-gradient(
          135deg,
          var(--amber) 0%,
          #fbbf24 45%,
          var(--ochre) 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 5px 16px;
        border-radius: 99px;
        background: var(--surf2);
        border: 1px solid var(--border2);
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--amber);
      }
      .btn-fire {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 15px 34px;
        background: linear-gradient(135deg, var(--amber), var(--ember));
        color: #fff;
        border: none;
        border-radius: var(--rad);
        font-family: "Instrument Sans", sans-serif;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: var(--t);
        position: relative;
        overflow: hidden;
        white-space: nowrap;
        text-align: center;
        line-height: 1.12;
      }
      .btn-fire::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.18),
          transparent
        );
        opacity: 0;
        transition: opacity 0.3s;
      }
      .btn-fire:hover {
        transform: translateY(-3px);
        box-shadow:
          0 16px 48px var(--glow),
          0 0 0 1px rgba(245, 158, 11, 0.4);
      }
      .btn-fire:hover::after {
        opacity: 1;
      }
      .btn-fire:active {
        transform: translateY(0);
      }
      .btn-outline {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 14px 30px;
        background: transparent;
        color: var(--text);
        border: 1px solid var(--border2);
        border-radius: var(--rad);
        font-family: "Instrument Sans", sans-serif;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: var(--t);
        white-space: nowrap;
        backdrop-filter: blur(12px);
        text-align: center;
        line-height: 1.12;
      }
      .btn-outline:hover {
        border-color: var(--amber);
        color: var(--amber);
        background: var(--surf);
        transform: translateY(-2px);
      }
      .card {
        background: var(--surf);
        border: 1px solid var(--border);
        border-radius: var(--rad-lg);
        backdrop-filter: blur(16px);
        transition: var(--t);
      }
      .card:hover {
        border-color: var(--border2);
        background: var(--surf2);
        transform: translateY(-5px);
        box-shadow:
          0 24px 64px rgba(0, 0, 0, 0.35),
          0 0 0 1px var(--border2);
      }
      #navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 800;
        height: var(--nav-h);
        background: rgba(9, 9, 11, 0.8);
        backdrop-filter: blur(24px) saturate(160%);
        border-bottom: 1px solid var(--border);
        transition: all 0.4s;
      }
      [data-theme="light"] #navbar {
        background: rgba(253, 248, 239, 0.88);
      }
      #navbar.scrolled {
        height: 62px;
        border-bottom-color: var(--border2);
        box-shadow: 0 8px 48px rgba(0, 0, 0, 0.25);
      }
      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 100%;
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 28px;
      }
      .nav-logo {
        display: flex;
        align-items: center;
        gap: 14px;
        cursor: pointer;
      }
      .nav-logo-mark {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, var(--amber), var(--ember));
        border-radius: 13px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        box-shadow: 0 4px 20px var(--glow);
        transition: transform 0.35s;
      }
      .nav-logo:hover .nav-logo-mark {
        transform: rotate(12deg) scale(1.1);
      }
      .nav-logo-name {
        font-family: "Playfair Display", serif;
        font-size: 22px;
        font-weight: 900;
        line-height: 1;
      }
      .nav-logo-sub {
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        color: var(--muted);
        letter-spacing: 0.06em;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 2px;
      }
      .nav-link {
        padding: 8px 18px;
        font-size: 14px;
        font-weight: 500;
        color: var(--muted);
        border-radius: 10px;
        cursor: pointer;
        transition: var(--t);
        position: relative;
      }
      .nav-link::after {
        content: "";
        position: absolute;
        bottom: 3px;
        left: 50%;
        right: 50%;
        height: 2px;
        background: var(--amber);
        border-radius: 99px;
        transition: all 0.3s;
      }
      .nav-link:hover {
        color: var(--text);
        background: var(--surf);
      }
      .nav-link:hover::after {
        left: 18px;
        right: 18px;
      }
      .nav-sep {
        width: 1px;
        height: 22px;
        background: var(--border);
        margin: 0 8px;
      }
      .nav-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .icon-btn {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        background: var(--surf);
        border: 1px solid var(--border);
        cursor: pointer;
        transition: var(--t);
        color: var(--muted);
        font-size: 16px;
      }
      .icon-btn:hover {
        border-color: var(--border2);
        color: var(--amber);
        background: var(--surf2);
      }
      .ham {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        width: 42px;
        height: 42px;
        gap: 6px;
        background: var(--surf);
        border: 1px solid var(--border);
        border-radius: var(--rad);
        cursor: pointer;
        transition: var(--t);
      }
      .ham:hover {
        border-color: var(--border2);
      }
      .ham-l {
        width: 20px;
        height: 2px;
        background: var(--text);
        border-radius: 99px;
        transition: all 0.35s var(--ease);
        transform-origin: center;
      }
      .ham.open .ham-l:nth-child(1) {
        transform: translateY(8px) rotate(45deg);
      }
      .ham.open .ham-l:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
      }
      .ham.open .ham-l:nth-child(3) {
        transform: translateY(-8px) rotate(-45deg);
      }
      .drw-overlay {
        position: fixed;
        inset: 0;
        z-index: 900;
        background: rgba(0, 0, 0, 0.65);
        backdrop-filter: blur(4px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s;
      }
      .drw-overlay.open {
        opacity: 1;
        pointer-events: all;
      }
      .drw {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        z-index: 950;
        width: min(340px, 88vw);
        background: var(--bg2);
        border-left: 1px solid var(--border);
        transform: translateX(100%);
        transition: transform 0.42s var(--ease);
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .drw.open {
        transform: translateX(0);
      }
      .drw-hd {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 22px 24px;
        border-bottom: 1px solid var(--border);
      }
      .drw-title {
        font-family: "Playfair Display", serif;
        font-size: 18px;
        font-weight: 700;
      }
      .drw-close {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--surf);
        border: 1px solid var(--border);
        border-radius: 9px;
        cursor: pointer;
        color: var(--muted);
        transition: var(--t);
      }
      .drw-close:hover {
        color: var(--amber);
        border-color: var(--border2);
      }
      .drw-body {
        flex: 1;
        overflow-y: auto;
        padding: 18px 14px;
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .drw-link {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        border-radius: var(--rad);
        background: var(--surf);
        border: 1px solid var(--border);
        color: var(--text);
        font-weight: 500;
        cursor: pointer;
        transition: var(--t);
        font-size: 15px;
      }
      .drw-link:hover {
        background: var(--surf2);
        border-color: var(--border2);
        transform: translateX(4px);
      }
      .drw-link-ico {
        width: 36px;
        height: 36px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--surf2);
        border-radius: 9px;
        color: var(--amber);
        font-size: 15px;
      }
      .drw-ft {
        padding: 16px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      #hero {
        min-height: 100svh;
        display: flex;
        align-items: center;
        padding: calc(var(--nav-h) + 60px) 0 80px;
        position: relative;
        overflow: hidden;
      }
      .hero-landscape {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 55%;
        z-index: 0;
        pointer-events: none;
      }
      .hero-sky {
        position: absolute;
        inset: 0;
        z-index: 0;
        background:
          radial-gradient(
            ellipse 100% 60% at 50% 0%,
            rgba(245, 158, 11, 0.07) 0%,
            transparent 70%
          ),
          radial-gradient(
            ellipse 60% 40% at 80% 20%,
            rgba(220, 38, 38, 0.05) 0%,
            transparent 60%
          ),
          radial-gradient(
            ellipse 50% 50% at 20% 30%,
            rgba(180, 83, 9, 0.06) 0%,
            transparent 60%
          );
      }
      .hero-grid {
        position: absolute;
        inset: 0;
        z-index: 0;
        background-image:
          linear-gradient(rgba(245, 158, 11, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(245, 158, 11, 0.04) 1px, transparent 1px);
        background-size: 72px 72px;
        animation: gridDrift 40s linear infinite;
        mask-image: radial-gradient(
          ellipse 90% 70% at 50% 50%,
          black 20%,
          transparent 100%
        );
      }
      @keyframes gridDrift {
        to {
          background-position: 72px 72px;
        }
      }
      .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        pointer-events: none;
      }
      .orb-a {
        width: 600px;
        height: 600px;
        background: rgba(245, 158, 11, 0.09);
        top: -200px;
        right: -150px;
        animation: orbF 9s ease-in-out infinite;
      }
      .orb-b {
        width: 380px;
        height: 380px;
        background: rgba(220, 38, 38, 0.08);
        bottom: 60px;
        left: -100px;
        animation: orbF 11s ease-in-out infinite reverse;
      }
      .orb-c {
        width: 220px;
        height: 220px;
        background: rgba(251, 191, 36, 0.06);
        top: 55%;
        left: 42%;
        animation: orbF 7s ease-in-out infinite 2s;
      }
      @keyframes orbF {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(20px, -30px) scale(1.06);
        }
      }
      .animal-sil {
        position: absolute;
        z-index: 1;
        pointer-events: none;
        opacity: 0.07;
        fill: var(--amber);
        animation: animalDrift 14s ease-in-out infinite;
      }
      @keyframes animalDrift {
        0%,
        100% {
          transform: translate(0, 0) scale(1);
        }
        50% {
          transform: translate(12px, -18px) scale(1.03);
        }
      }
      .pt {
        position: absolute;
        width: 3px;
        height: 3px;
        background: var(--amber);
        border-radius: 50%;
        pointer-events: none;
        animation: ptRise 5s ease-in-out infinite;
      }
      @keyframes ptRise {
        0%,
        100% {
          transform: translateY(0) translateX(0);
          opacity: 0;
        }
        10% {
          opacity: 0.8;
        }
        90% {
          opacity: 0.8;
        }
        100% {
          transform: translateY(-140px) translateX(18px);
          opacity: 0;
        }
      }
      .hero-content {
        position: relative;
        z-index: 3;
        text-align: center;
        max-width: 980px;
        margin: 0 auto;
      }
      .hero-eyebrow {
        display: flex;
        justify-content: center;
        margin-bottom: 30px;
        animation: fadeUp 0.8s ease both;
      }
      .hero-h1 {
        font-family: "Playfair Display", serif;
        font-size: clamp(34px, 6vw, 78px);
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: -0.025em;
        margin-bottom: 28px;
        animation: fadeUp 0.8s ease 0.1s both;
      }
      .hero-sub {
        font-size: clamp(16px, 2.2vw, 20px);
        color: var(--muted);
        max-width: 600px;
        margin: 0 auto 44px;
        line-height: 1.75;
        animation: fadeUp 0.8s ease 0.2s both;
      }
      .hero-sub strong {
        color: var(--amber);
        font-weight: 600;
      }
      .hero-ctas {
        display: flex;
        gap: 14px;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 72px;
        animation: fadeUp 0.8s ease 0.3s both;
      }
      .hero-ctas .btn-fire {
        padding: 18px 42px;
        font-size: 16px;
      }
      .hero-ctas .btn-outline {
        padding: 17px 32px;
        font-size: 16px;
      }
      .hero-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 14px;
        animation: fadeUp 0.8s ease 0.4s both;
      }
      .stat-tile {
        padding: 26px 16px;
        border-radius: var(--rad-lg);
        background: var(--surf);
        border: 1px solid var(--border);
        backdrop-filter: blur(16px);
        text-align: center;
        cursor: default;
        transition: var(--t);
      }
      .stat-tile:hover {
        border-color: var(--border2);
        transform: translateY(-4px);
        box-shadow: 0 14px 40px rgba(0, 0, 0, 0.25);
      }
      .stat-num {
        font-family: "Playfair Display", serif;
        font-size: clamp(24px, 3.5vw, 40px);
        font-weight: 900;
        background: linear-gradient(135deg, var(--amber), #fbbf24);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
        margin-bottom: 6px;
        line-height: 1;
      }
      .stat-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 10px;
        color: var(--muted);
        letter-spacing: 0.07em;
        text-transform: uppercase;
      }
      .scroll-hint {
        position: absolute;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        z-index: 5;
      }
      .scroll-mouse {
        width: 22px;
        height: 36px;
        border: 2px solid var(--border2);
        border-radius: 12px;
        display: flex;
        justify-content: center;
        padding-top: 5px;
      }
      .scroll-dot {
        width: 3px;
        height: 7px;
        background: var(--amber);
        border-radius: 99px;
        animation: scrollB 1.9s ease-in-out infinite;
      }
      @keyframes scrollB {
        0%,
        100% {
          transform: translateY(0);
          opacity: 1;
        }
        80% {
          transform: translateY(10px);
          opacity: 0;
        }
      }
      .scroll-text {
        font-family: "JetBrains Mono", monospace;
        font-size: 9px;
        color: var(--dim);
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }
      #trust-strip {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        background: var(--bg2);
        padding: 18px 0;
        overflow: hidden;
        position: relative;
      }
      .trust-track {
        display: flex;
        gap: 56px;
        align-items: center;
        animation: marquee 30s linear infinite;
        white-space: nowrap;
      }
      .trust-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: var(--muted);
        flex-shrink: 0;
      }
      .trust-item i {
        color: var(--amber);
        font-size: 16px;
      }
      @keyframes marquee {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }
      section {
        padding: 110px 0;
        position: relative;
      }
      .container {
        max-width: 1320px;
        margin: 0 auto;
        padding: 0 28px;
      }
      .sec-tag {
        display: flex;
        justify-content: center;
        margin-bottom: 18px;
      }
      .sec-title {
        font-family: "Playfair Display", serif;
        font-size: clamp(34px, 5vw, 64px);
        font-weight: 900;
        line-height: 1.08;
        letter-spacing: -0.022em;
        text-align: center;
        margin-bottom: 18px;
      }
      .sec-sub {
        text-align: center;
        color: var(--muted);
        font-size: 18px;
        max-width: 540px;
        margin: 0 auto 68px;
        line-height: 1.7;
      }
      .js-go .reveal {
        opacity: 0;
        transform: translateY(36px);
        transition:
          opacity 0.75s ease,
          transform 0.75s ease;
      }
      .js-go .reveal.show {
        opacity: 1;
        transform: translateY(0);
      }
      #features {
        background: var(--bg2);
      }
      .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
      }
