        font-size: 15px;
        line-height: 1.6;
      }
      .step-visual {
        width: 100px;
        height: 100px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 107, 26, 0.08);
        border-radius: var(--radius-lg);
        font-size: 48px;
