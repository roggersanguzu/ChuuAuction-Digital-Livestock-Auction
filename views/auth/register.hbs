<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account | ChuuAuction</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="/vendor/bootstrap-icons/css/bootstrap-icons.css"
    />
    <link href="/css/app-theme.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Bricolage+Grotesque:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <script>
      tailwind.config = { darkMode: "class", theme: { extend: { fontFamily: {
      display: ["Bricolage Grotesque", "sans-serif"], body: ["Outfit",
      "sans-serif"], }, keyframes: { drift: { "0%, 100%": { transform:
      "translateY(0px)" }, "50%": { transform: "translateY(-10px)" }, }, },
      pulseSoft: { "0%, 100%": { opacity: "0.3", transform: "scale(1)" }, "50%":
      { opacity: "0.7", transform: "scale(1.08)" }, }, gridShift: { "0%": {
      transform: "translate(0, 0)" }, "100%": { transform: "translate(40px,
      40px)" }, }, pulseY: { "0%, 100%": { transform: "translateY(0)" }, "50%":
      { transform: "translateY(-6px)" }, }, sweep: { "0%": { top: "0%" },
      "100%": { top: "100%" }, }, sticker: { "0%, 100%": { transform:
      "translateY(0) rotate(-6deg)" }, "50%": { transform: "translateY(-8px)
      rotate(-2deg)" }, }, }, animation: { drift: "drift 6s ease-in-out
      infinite", pulseSoft: "pulseSoft 7s ease-in-out infinite", gridShift:
      "gridShift 12s linear infinite", pulseY: "pulseY 3s ease-in-out infinite",
      sweep: "sweep 2.2s linear infinite", sticker: "sticker 4s ease-in-out
      infinite", }, }, }, };
    </script>
  </head>
  <body
    class="min-h-screen bg-slate-950 text-gray-100 font-body overflow-x-hidden"
  >
    <main
      class="min-h-screen flex items-center justify-center px-4 py-10 relative"
    >
      <div class="fixed inset-0 overflow-hidden pointer-events-none">
        <div
          class="absolute inset-0 opacity-30 animate-gridShift"
          style="background-image: linear-gradient(rgba(56,189,248,0.10) 1px, transparent 1px), linear-gradient(90deg, rgba(56,189,248,0.10) 1px, transparent 1px); background-size: 40px 40px;"
        ></div>
        <div
          class="absolute top-12 right-8 w-48 h-48 rounded-full bg-cyan-500/10 blur-3xl animate-drift"
        ></div>
        <div
          class="absolute bottom-10 left-10 w-56 h-56 rounded-full bg-blue-500/10 blur-3xl animate-drift"
          style="animation-delay:1.5s;"
        ></div>
        <div
          class="absolute -top-24 -left-20 w-[28rem] h-[28rem] rounded-full bg-cyan-400/20 blur-3xl animate-pulseSoft"
        ></div>
        <div
          class="absolute top-1/3 right-1/4 w-48 h-48 rounded-full bg-sky-300/20 blur-2xl animate-drift"
          style="animation-delay:1.1s;"
        ></div>
      </div>
      <div
        class="w-full max-w-4xl grid lg:grid-cols-5 rounded-2xl overflow-hidden border border-slate-800 shadow-2xl relative z-10"
      >
        <section
          class="lg:col-span-2 p-8 hidden lg:flex flex-col justify-between border-r border-slate-800 bg-slate-900/80"
        >
          <div>
            <div class="flex items-center gap-3 mb-6">
              <img
                src="/img/logo.png"
                alt="ChuuAuction Logo"
                class="w-12 h-12 rounded-xl border border-cyan-400/30"
              />
              <h1 class="font-display text-2xl font-extrabold">ChuuAuction</h1>
            </div>
            <h2
              class="font-display text-3xl font-extrabold leading-tight"
            >Create account</h2>
            <p class="text-sm text-gray-400 mt-2">Start with verified details
              and safe trading habits.</p>
          </div>
          <div class="rounded-2xl border border-slate-700 bg-slate-800/60 p-4">
            <p
              class="text-xs uppercase tracking-widest text-cyan-300 mb-3"
            >Safety Sticker Board</p>
            <div
              class="relative h-44 rounded-xl border border-slate-700 bg-slate-900 overflow-hidden"
            >
              <div
                class="absolute inset-0 opacity-20"
                style="background-image: radial-gradient(circle, #67e8f9 1px, transparent 1px); background-size: 18px 18px;"
              ></div>
              <div
                class="absolute left-3 top-3 px-3 py-2 rounded-xl border border-cyan-300/40 bg-cyan-400/15 text-xs font-semibold text-cyan-200 -rotate-6 animate-sticker"
              >
                <i class="bi bi-shield-check mr-1"></i>
                Verify Docs
              </div>
              <div
                class="absolute right-3 top-12 px-3 py-2 rounded-xl border border-blue-300/40 bg-blue-400/15 text-xs font-semibold text-blue-200 rotate-6 animate-sticker"
                style="animation-delay:0.8s;"
              >
                <i class="bi bi-telephone-forward mr-1"></i>
                Confirm Contact
              </div>
              <div
                class="absolute left-8 bottom-5 px-3 py-2 rounded-xl border border-emerald-300/40 bg-emerald-400/15 text-xs font-semibold text-emerald-200 -rotate-3 animate-sticker"
                style="animation-delay:1.4s;"
              >
                <i class="bi bi-cash-coin mr-1"></i>
                Pay Securely
              </div>
              <div
                class="absolute right-8 bottom-3 px-3 py-2 rounded-xl border border-slate-300/30 bg-slate-400/10 text-xs font-semibold text-slate-200 rotate-3 animate-sticker"
                style="animation-delay:2s;"
              >
                <i class="bi bi-person-check mr-1"></i>
                Trusted Trade
              </div>
            </div>
          </div>
          <div class="space-y-2 text-sm text-gray-400">
            <p class="inline-flex items-center gap-2"><i
                class="bi bi-shield-check text-cyan-300"
              ></i>Secure onboarding</p>
            <p class="inline-flex items-center gap-2"><i
                class="bi bi-broadcast-pin text-cyan-300"
              ></i>Live auction access</p>
            <p class="inline-flex items-center gap-2"><i
                class="bi bi-people text-cyan-300"
              ></i>Verified community</p>
          </div>
        </section>
        <section class="lg:col-span-3 bg-slate-900/90 p-6 sm:p-8">
          <div class="text-center mb-6">
            <img
              src="/img/logo.png"
              alt="ChuuAuction Logo"
              class="w-14 h-14 mx-auto rounded-xl border border-cyan-400/30 mb-3 animate-drift"
            />
            <h2 class="font-display text-2xl font-extrabold">Create Account</h2>
          </div>
          {{#if error_msg}}
            <div
              class="mb-4 rounded-xl border border-red-500/40 bg-red-500/10 px-3 py-2 text-sm text-red-300"
            >{{error_msg}}</div>
          {{/if}}
          {{#if success_msg}}
            <div
              class="mb-4 rounded-xl border border-emerald-500/40 bg-emerald-500/10 px-3 py-2 text-sm text-emerald-300"
            >{{success_msg}}</div>
          {{/if}}
          <form
            id="create-account-form"
            action="/auth/register"
            method="POST"
            class="space-y-4"
          >
            <div class="grid sm:grid-cols-2 gap-3">
              <div>
                <label
                  class="text-xs font-semibold text-gray-300 uppercase tracking-wide"
                >Full Name</label>
                <input
                  type="text"
                  name="name"
                  required
                  placeholder="Roggers Anguzu"
                  class="mt-1 w-full rounded-xl bg-slate-800 border border-slate-700 focus:border-cyan-500 focus:outline-none px-3 py-2.5 text-sm transition-colors"
                />
              </div>
              <div>
                <label
                  class="text-xs font-semibold text-gray-300 uppercase tracking-wide"
                >Email Address</label>
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="roggers.anguzu@gmail.com"
                  class="mt-1 w-full rounded-xl bg-slate-800 border border-slate-700 focus:border-cyan-500 focus:outline-none px-3 py-2.5 text-sm transition-colors"
                />
              </div>
              <div>
                <label
                  class="text-xs font-semibold text-gray-300 uppercase tracking-wide"
                >Phone Number</label>
                <input
                  type="tel"
                  name="phone"
                  required
                  minlength="10"
                  placeholder="+256 700 000 000"
                  class="mt-1 w-full rounded-xl bg-slate-800 border border-slate-700 focus:border-cyan-500 focus:outline-none px-3 py-2.5 text-sm transition-colors"
                />
              </div>
              <div>
                <label
                  class="text-xs font-semibold text-gray-300 uppercase tracking-wide"
                >Role</label>
                <select
                  name="role"
                  required
                  class="mt-1 w-full rounded-xl bg-slate-800 border border-slate-700 focus:border-cyan-500 focus:outline-none px-3 py-2.5 text-sm transition-colors"
                >
                  <option value="">Select role</option>
                  <option value="Seller">Seller</option>
                  <option value="Buyer">Buyer</option>
                  <option value="Administrator">Administrator</option>
                </select>
              </div>
              <div>
                <label
                  class="text-xs font-semibold text-gray-300 uppercase tracking-wide"
                >Password</label>
                <div class="relative mt-1">
                  <input
                    type="password"
                    id="password"
                    name="password"
                    required
                    placeholder="Create strong password"
                    class="w-full rounded-xl bg-slate-800 border border-slate-700 focus:border-cyan-500 focus:outline-none px-3 py-2.5 pr-10 text-sm transition-colors"
                  />
                  <button
                    type="button"
                    id="toggle-password"
                    class="absolute right-2 top-1/2 -translate-y-1/2 h-8 w-8 rounded-md text-gray-400 hover:text-cyan-300 hover:bg-cyan-500/10 inline-flex items-center justify-center"
                    aria-label="Show password"
                  >
                    <i id="eye-icon" class="bi bi-eye"></i>
                  </button>
                </div>
                <div class="flex gap-1 mt-2">
                  <div
                    id="bar1"
                    class="h-1.5 flex-1 rounded-full bg-slate-700"
                  ></div>
                  <div
                    id="bar2"
                    class="h-1.5 flex-1 rounded-full bg-slate-700"
                  ></div>
                  <div
                    id="bar3"
                    class="h-1.5 flex-1 rounded-full bg-slate-700"
                  ></div>
                  <div
                    id="bar4"
                    class="h-1.5 flex-1 rounded-full bg-slate-700"
                  ></div>
                </div>
                <p
                  id="password-strength-text"
                  class="text-xs mt-1 text-gray-400"
                ></p>
              </div>
              <div>
                <label
                  class="text-xs font-semibold text-gray-300 uppercase tracking-wide"
                >Confirm Password</label>
                <input
                  type="password"
                  id="confirmPassword"
                  name="confirmPassword"
                  required
                  placeholder="Repeat password"
                  class="mt-1 w-full rounded-xl bg-slate-800 border border-slate-700 focus:border-cyan-500 focus:outline-none px-3 py-2.5 text-sm transition-colors"
                />
              </div>
            </div>
            <label class="flex items-start gap-2 text-sm text-gray-400">
              <input
                type="checkbox"
                name="terms"
                required
                class="mt-1 accent-cyan-500"
              />
              <span>I agree to the
                <a
                  href="/auth/terms"
                  class="text-cyan-300 hover:underline"
                >Terms & Conditions</a>
                and
                <a
                  href="/auth/privacy"
                  class="text-cyan-300 hover:underline"
                >Privacy Policy</a>.</span>
            </label>
            <button
              type="submit"
              class="w-full rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 py-2.5 text-sm font-bold hover:opacity-95 transition"
            >Create Account</button>
          </form>
          <p class="text-center text-sm text-gray-400 mt-4">Already have an
            account?
            <a
              href="/auth/login"
              class="text-cyan-300 font-semibold hover:underline"
            >Login</a></p>
        </section>
      </div>
    </main>
    <script src="/js/auth-ui.js"></script>
    <script src="/js/app-theme.js"></script>
    <script>
      (function () { var password = document.getElementById("password"); var
      text = document.getElementById("password-strength-text"); var bars = [
      document.getElementById("bar1"), document.getElementById("bar2"),
      document.getElementById("bar3"), document.getElementById("bar4"), ];
      function setBars(score) { var colors = ["#ef4444", "#f59e0b", "#22d3ee",
      "#22c55e"]; bars.forEach(function (bar, idx) { if (!bar) return;
      bar.style.backgroundColor = idx < score ? colors[idx] : "#334155"; }); if
      (!text) return; if (score === 0) text.textContent = ""; if (score === 1)
      text.textContent = "Very weak"; if (score === 2) text.textContent =
      "Weak"; if (score === 3) text.textContent = "Good"; if (score === 4)
      text.textContent = "Strong"; } function compute(value) { var score = 0; if
      (value.length >= 8) score += 1; if (/[A-Z]/.test(value) &&
      /[a-z]/.test(value)) score += 1; if (/[0-9]/.test(value)) score += 1; if
      (/[^A-Za-z0-9]/.test(value)) score += 1; return score; } if (password) {
      password.addEventListener("input", function () { var score =
      compute(password.value || ""); setBars(score); }); } })();
    </script>
  </body>
</html>
