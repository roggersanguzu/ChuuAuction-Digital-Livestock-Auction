        <!-- Theme toggle -->
        <button id="theme-toggle" class="theme-btn" title="Toggle theme">
          <i
            class="bi bi-moon-stars"
            style="color:#f97316;font-size:13px;"
            id="moon-icon"
          ></i>
          <i
            class="bi bi-sun-fill"
            style="color:#f97316;font-size:13px;display:none;"
            id="sun-icon"
          ></i>
        </button>

        <!-- Logo + name + badge ŌĆö all centered -->
        <div class="logo-block">
          <div class="logo-avatar" style="position:relative;">
            <img src="/img/logo.png" alt="ChuuAuction Logo" />
            <div class="online-dot-wrap">
              <div class="online-dot"></div>
            </div>
          </div>
          <div>
            <h1
              class="font-display"
              style="font-size:24px;font-weight:900;color:#f9fafb;line-height:1.2;text-align:center;"
            >
              <span class="text-gradient">Chuu</span>Auction
            </h1>
            <p
              style="font-size:11px;color:#6b7280;text-align:center;margin-top:2px;"
            >Digital Livestock Market</p>
          </div>
          <div class="welcome-badge">
            <i class="bi bi-arrow-return-left" style="font-size:9px;"></i>
            Welcome Back!
          </div>
        </div>

        <!-- Heading ŌĆö centered -->
        <div class="heading-block">
          <h2>Sign In to Dashboard</h2>
          <p>Access your trading account securely</p>
        </div>

        <!-- Flash messages -->
        {{#if error_msg}}
          <div class="flash-error">
            <i class="bi bi-exclamation-circle" style="flex-shrink:0;"></i>
            <span>{{error_msg}}</span>
          </div>
        {{/if}}
        {{#if success_msg}}
          <div class="flash-success">
            <i class="bi bi-check-circle" style="flex-shrink:0;"></i>
            <span>{{success_msg}}</span>
          </div>
        {{/if}}

        <!-- FORM -->
        <form
          id="login-form"
          action="/auth/login"
          method="POST"
          class="login-form"
        >

          <!-- Email -->
          <div>
            <label class="field-label">Email Address
              <span style="color:#ef4444;">*</span></label>
            <div class="field-wrap">
              <input
                type="email"
                name="email"
                placeholder="roggers.anguzu@gmail.com"
                required
                class="inp"
              />
              <i class="bi bi-envelope-at field-icon"></i>
            </div>
          </div>

          <!-- Password -->
          <div>
            <div
              style="display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;"
            >
              <label class="field-label" style="margin-bottom:0;">Password
                <span style="color:#ef4444;">*</span></label>
              <a
                href="#"
                aria-disabled="true"
                title="Password reset coming soon"
                onclick="return false;"
                style="font-size:10.5px;font-weight:600;color:#f97316;text-decoration:none;display:flex;align-items:center;gap:3px;"
              >
                <i class="bi bi-key" style="font-size:9px;"></i>
                Forgot password?
              </a>
            </div>
            <div class="field-wrap">
              <input
                type="password"
                name="password"
                id="password"
                placeholder="ŌĆóŌĆóŌĆóŌĆóŌĆóŌĆóŌĆóŌĆó"
                required
                class="inp"
              />
              <button type="button" id="toggle-password" class="eye-btn">
                <i class="bi bi-eye" id="eye-icon"></i>
              </button>
            </div>
          </div>

          <!-- Remember + Secure -->
          <div class="row-inline">
            <label class="checkbox-label">
              <input type="checkbox" name="remember" />
              <span>Remember me for 30 days</span>
            </label>
            <div class="secure-badge">
              <i
                class="bi bi-shield-lock-fill"
                style="color:#22c55e;font-size:11px;"
              ></i>
              <span>256-bit SSL</span>
            </div>
          </div>

          <!-- Submit -->
          <button type="submit" id="submit-btn" class="btn-submit">
            <span>
              <i class="bi bi-box-arrow-in-right" style="font-size:14px;"></i>
              Sign In to Dashboard
            </span>
          </button>

          <!-- Divider -->
          <div class="divider">or continue with</div>

          <!-- Social -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <a href="#" class="btn-social" aria-disabled="true" title="Google sign-in coming soon" onclick="return false;">
              <i class="bi bi-google" style="color:#f97316;font-size:13px;"></i>
              <span>Google</span>
            </a>
            <a href="#" class="btn-social" aria-disabled="true" title="Facebook sign-in coming soon" onclick="return false;">
              <i
                class="bi bi-facebook"
                style="color:#f97316;font-size:13px;"
              ></i>
              <span>Facebook</span>
            </a>
          </div>

          <!-- Sign up link -->
          <p style="text-align:center;font-size:11.5px;color:#6b7280;">
            Don't have an account?
            <a
              href="/auth/register"
              style="color:#f97316;font-weight:700;margin-left:3px;text-decoration:underline;"
            >Create Account ŌåÆ</a>
          </p>

        </form>
      </div>
      <!-- end right panel -->

    </div>
  </div>
  <!-- end card -->

  <!-- Trust bar -->
  <div class="trust-bar font-body">
    <div class="trust-item"><i
        class="bi bi-shield-fill-check"
        style="color:#22c55e;font-size:11px;"
      ></i><span>SSL Secure</span></div>
    <div class="trust-sep"></div>
    <div class="trust-item"><i
        class="bi bi-lock-fill"
        style="color:#60a5fa;font-size:11px;"
      ></i><span>Encrypted</span></div>
    <div class="trust-sep"></div>
    <div class="trust-item"><i
        class="bi bi-patch-check-fill"
        style="color:#f97316;font-size:11px;"
      ></i><span>Verified Platform</span></div>
    <div class="trust-sep"></div>
    <div class="trust-item"><i
        class="bi bi-lightning-charge-fill"
        style="color:#facc15;font-size:11px;"
      ></i><span>99.9% Uptime</span></div>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', function () { // ŌöĆŌöĆ Theme Toggle
  ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ const themeToggle =
  document.getElementById('theme-toggle'); const html =
  document.documentElement; const moonIcon =
  document.getElementById('moon-icon'); const sunIcon =
  document.getElementById('sun-icon'); function applyTheme(theme) { if (theme
  === 'dark') { html.classList.add('dark'); moonIcon.style.display = 'none';
  sunIcon.style.display = 'block'; } else { html.classList.remove('dark');
  moonIcon.style.display = 'block'; sunIcon.style.display = 'none'; } } //
  Default dark; respect saved preference const saved =
  localStorage.getItem('chuu-theme') || localStorage.getItem('theme') || 'dark'; applyTheme(saved);
  themeToggle?.addEventListener('click', function () { const next =
  html.classList.contains('dark') ? 'light' : 'dark';
  localStorage.setItem('theme', next); localStorage.setItem('chuu-theme', next); applyTheme(next); }); // ŌöĆŌöĆ Password
  Visibility Toggle ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ const
  togglePassword = document.getElementById('toggle-password'); const
  passwordInput = document.getElementById('password'); const eyeIcon =
  document.getElementById('eye-icon'); togglePassword?.addEventListener('click',
  function () { const type = passwordInput.getAttribute('type') === 'password' ?
  'text' : 'password'; passwordInput.setAttribute('type', type);
  eyeIcon.classList.toggle('bi-eye'); eyeIcon.classList.toggle('bi-eye-slash');
  }); // ŌöĆŌöĆ Form Submission + Validation ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
  const form = document.getElementById('login-form'); const submitBtn =
  document.getElementById('submit-btn'); form?.addEventListener('submit',
  function (e) { const email =
  form.querySelector('[name="email"]').value.trim(); const password =
  form.querySelector('[name="password"]').value.trim(); if (!email || !password)
  { alert('ŌÜĀ’ĖÅ Please fill in email and password'); e.preventDefault(); return; }
  const originalHTML = submitBtn.innerHTML; submitBtn.disabled = true;
  submitBtn.innerHTML = '<span><i class="bi bi-hourglass-split"></i> Signing
  In...</span>'; // Form submits for real ŌåÆ no e.preventDefault() here });
  setTimeout(function () { document.querySelectorAll('.flash-success, .flash-error').forEach(function (el) { el.style.transition = 'opacity .35s ease, transform .35s ease'; el.style.opacity = '0'; el.style.transform = 'translateY(-8px)'; setTimeout(function () { el.remove(); }, 380); }); }, 2800); console.log('ChuuAuction Login Page Loaded ¢ real authentication enabled');
  });
</script>


