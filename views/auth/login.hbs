<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | ChuuAuction</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/vendor/bootstrap-icons/css/bootstrap-icons.css" />
    <link href="/css/app-theme.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Bricolage+Grotesque:wght@600;700;800&display=swap" rel="stylesheet" />
    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            fontFamily: {
              display: ["Bricolage Grotesque", "sans-serif"],
              body: ["Outfit", "sans-serif"],
            },
            keyframes: {
              drift: {
                "0%, 100%": { transform: "translateY(0px)" },
                "50%": { transform: "translateY(-10px)" },
              },
              pulseSoft: {
                "0%, 100%": { opacity: "0.3", transform: "scale(1)" },
                "50%": { opacity: "0.7", transform: "scale(1.08)" },
              },
              gridShift: {
                "0%": { transform: "translate(0, 0)" },
                "100%": { transform: "translate(40px, 40px)" },
              },
            },
            animation: {
              drift: "drift 6s ease-in-out infinite",
              pulseSoft: "pulseSoft 7s ease-in-out infinite",
              gridShift: "gridShift 12s linear infinite",
            },
          },
        },
      };
    </script>
  </head>
  <body class="min-h-screen bg-slate-950 text-gray-100 font-body">
    <main class="min-h-screen flex items-center justify-center px-4 py-10">
      <div class="fixed inset-0 overflow-hidden pointer-events-none">
        <div class="absolute inset-0 opacity-30 animate-gridShift" style="background-image: linear-gradient(rgba(56,189,248,0.10) 1px, transparent 1px), linear-gradient(90deg, rgba(56,189,248,0.10) 1px, transparent 1px); background-size: 40px 40px;"></div>
        <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full bg-cyan-400/20 blur-3xl animate-pulseSoft"></div>
        <div class="absolute bottom-0 -right-24 w-[28rem] h-[28rem] rounded-full bg-blue-500/20 blur-3xl animate-drift"></div>
        <div class="absolute top-1/3 right-1/4 w-48 h-48 rounded-full bg-sky-300/20 blur-2xl animate-drift" style="animation-delay:1.3s;"></div>
      </div>
      <section class="w-full max-w-md rounded-2xl border border-slate-800 bg-slate-900/80 p-6 sm:p-8 shadow-2xl">
        <div class="flex items-center justify-center mb-4">
          <img src="/img/logo.png" alt="ChuuAuction Logo" class="w-14 h-14 rounded-xl border border-cyan-400/40 shadow-lg shadow-cyan-500/20 animate-drift" />
        </div>
        <h2 class="font-display text-2xl font-extrabold mb-6 text-center">Sign In</h2>
        {{#if error_msg}}
          <div class="mb-4 rounded-xl border border-red-500/40 bg-red-500/10 px-3 py-2 text-sm text-red-300">{{error_msg}}</div>
        {{/if}}
        {{#if success_msg}}
          <div class="mb-4 rounded-xl border border-emerald-500/40 bg-emerald-500/10 px-3 py-2 text-sm text-emerald-300">{{success_msg}}</div>
        {{/if}}
        <form id="login-form" action="/auth/login" method="POST" class="space-y-4">
          <div>
            <label class="text-xs font-semibold text-gray-300 uppercase tracking-wide">Email Address</label>
            <input type="email" name="email" required placeholder="roggers.anguzu@gmail.com" class="mt-1 w-full rounded-xl bg-slate-800 border border-slate-700 focus:border-cyan-500 focus:outline-none px-3 py-2.5 text-sm transition-colors" />
          </div>
          <div>
            <label class="text-xs font-semibold text-gray-300 uppercase tracking-wide">Password</label>
            <div class="relative mt-1">
              <input type="password" id="password" name="password" required placeholder="Enter your password" class="w-full rounded-xl bg-slate-800 border border-slate-700 focus:border-cyan-500 focus:outline-none px-3 py-2.5 pr-10 text-sm transition-colors" />
              <button type="button" id="toggle-password" class="absolute right-2 top-1/2 -translate-y-1/2 h-8 w-8 rounded-md text-gray-400 hover:text-cyan-300 hover:bg-cyan-500/10 inline-flex items-center justify-center" aria-label="Show password">
                <i id="eye-icon" class="bi bi-eye"></i>
              </button>
            </div>
          </div>
          <button type="submit" class="w-full rounded-xl bg-gradient-to-r from-cyan-500 to-blue-600 py-2.5 text-sm font-bold hover:opacity-95 transition">Login</button>
        </form>
        <p class="text-sm text-gray-400 text-center mt-5">No account yet? <a href="/auth/register" class="text-cyan-300 font-semibold hover:underline">Create one</a></p>
      </section>
    </main>
    <script src="/js/auth-ui.js"></script>
    <script src="/js/login-enhancements.js"></script>
    <script src="/js/app-theme.js"></script>
  </body>
</html>
